@model IEnumerable<BDSKhanhHoa.Models.Comment>
@{
    ViewData["Title"] = "Quản lý Bình Luận";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <!-- Thống kê nhanh -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 bg-primary text-white" style="border-radius: 12px;">
                <small>Tổng bình luận</small>
                <h3 class="fw-bold mb-0">@Model.Count()</h3>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 16px;">
        <div class="card-header bg-white border-0 pt-4 pb-0">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <h4 class="fw-bold mb-0 text-primary"><i class="bi bi-chat-dots me-2"></i>Quản lý Bình Luận</h4>
                </div>
                <div class="col-md-8">
                    <form method="get" class="d-flex gap-2 justify-content-end">
                        <input type="text" name="searchString" class="form-control rounded-pill w-50" placeholder="Tìm tên, nội dung..." value="@ViewBag.SearchString">
                        <select name="status" class="form-select rounded-pill w-auto">
                            <option value="">Tất cả</option>
                            <option value="visible" selected="@(ViewBag.Status == "visible")">Đang hiện</option>
                            <option value="pending" selected="@(ViewBag.Status == "pending")">Chờ duyệt (Bị ẩn)</option>
                        </select>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Lọc</button>
                    </form>
                </div>
            </div>

            <!-- THANH CÔNG CỤ DUYỆT NHANH (Sẽ ẩn/hiện khi check) -->
            <div id="bulkActions" class="mt-3 p-2 bg-light rounded-3 d-none animate__animated animate__fadeIn">
                <span class="ms-2 fw-bold text-dark"><span id="selectedCount">0</span> mục đã chọn:</span>
                <button class="btn btn-sm btn-success ms-3 rounded-pill px-3" onclick="bulkApprove()">
                    <i class="bi bi-check-all"></i> Duyệt hiển thị hàng loạt
                </button>
                <button class="btn btn-sm btn-danger ms-2 rounded-pill px-3" onclick="bulkDelete()">
                    <i class="bi bi-trash"></i> Xóa hàng loạt
                </button>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40px;">
                                <input type="checkbox" class="form-check-input" id="selectAll">
                            </th>
                            <th>Người dùng</th>
                            <th>Nội dung bình luận</th>
                            <th>Liên quan tin</th>
                            <th>Thời gian</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="row-@item.CommentID">
                                <td>
                                    <input type="checkbox" class="form-check-input row-checkbox" data-id="@item.CommentID">
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@(item.User?.Avatar ?? "/images/default-user.png")" class="rounded-circle me-2 border" width="35" height="35">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold small">@item.User?.FullName</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <p class="mb-0 text-truncate" style="max-width: 300px;" title="@item.Content">@item.Content</p>
                                </td>
                                <td><a href="/Property/Details/@item.PropertyID" target="_blank" class="badge bg-light text-primary text-decoration-none">#@item.PropertyID <i class="bi bi-link"></i></a></td>
                                <td class="small text-muted">@item.TimeAgo</td>
                                <td>
                                    <span class="badge @(item.IsHidden ? "bg-warning text-dark" : "bg-success") status-badge-@item.CommentID">
                                        @(item.IsHidden ? "Chờ duyệt" : "Đang hiện")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a href="/Admin/Comments/Details/@item.CommentID" class="btn btn-sm btn-light border-0 rounded-circle me-1"><i class="bi bi-eye"></i></a>
                                        <button class="btn btn-sm btn-light border-0 text-warning rounded-circle btn-toggle-admin me-1" data-id="@item.CommentID"><i class="bi bi-shield-check"></i></button>
                                        <button class="btn btn-sm btn-light border-0 text-danger rounded-circle btn-delete-admin" data-id="@item.CommentID"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            // Xử lý Checkbox chọn tất cả
            $('#selectAll').click(function () {
                $('.row-checkbox').prop('checked', this.checked);
                toggleBulkActions();
            });

            $('.row-checkbox').change(function () {
                toggleBulkActions();
            });

            function toggleBulkActions() {
                var count = $('.row-checkbox:checked').length;
                $('#selectedCount').text(count);
                if (count > 0) {
                    $('#bulkActions').removeClass('d-none');
                } else {
                    $('#bulkActions').addClass('d-none');
                }
            }

            // --- HÀNH ĐỘNG HÀNG LOẠT ---
            window.bulkApprove = function() {
                var ids = $('.row-checkbox:checked').map(function() { return $(this).data('id'); }).get();
                confirmBulk('/Admin/Comments/ApproveSelected', ids, 'Duyệt hiển thị các bình luận đã chọn?');
            }

            window.bulkDelete = function() {
                var ids = $('.row-checkbox:checked').map(function() { return $(this).data('id'); }).get();
                confirmBulk('/Admin/Comments/DeleteSelected', ids, 'Xóa vĩnh viễn các bình luận đã chọn?');
            }

            function confirmBulk(url, ids, message) {
                Swal.fire({
                    title: 'Xác nhận?', text: message, icon: 'question',
                    showCancelButton: true, confirmButtonText: 'Đồng ý'
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch(url, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(ids)
                        }).then(res => res.json()).then(data => {
                            if (data.success) {
                                Swal.fire('Thành công', data.message, 'success').then(() => location.reload());
                            }
                        });
                    }
                });
            }

            // Giữ lại các Ajax lẻ cũ của bạn (ToggleVisibility, Delete...)
            $('.btn-toggle-admin').click(function () {
                var id = $(this).data('id');
                $.post('/Admin/Comments/ToggleVisibility', { id: id }, function (res) {
                    if (res.success) {
                        location.reload(); // Cách đơn giản nhất để cập nhật badge và UI
                    }
                });
            });

            $('.btn-delete-admin').click(function () {
                var id = $(this).data('id');
                Swal.fire({
                    title: 'Xóa bình luận?', text: "Hành động này không thể hoàn tác!",
                    icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.post('/Admin/Comments/Delete', { id: id }, function (res) {
                            if (res.success) $('#row-' + id).fadeOut();
                        });
                    }
                });
            });
        });
    </script>
}