@model IEnumerable<BDSKhanhHoa.Models.Comment>
@{
    ViewData["Title"] = "Quản lý Bình Luận";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0" style="border-radius: 16px;">
        <div class="card-header bg-white border-0 pt-4 pb-0">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="fw-bold mb-0 text-primary"><i class="bi bi-chat-left-text me-2"></i>Quản lý Bình Luận</h4>

                <form method="get" class="d-flex gap-2">
                    <input type="text" name="searchString" class="form-control rounded-pill" placeholder="Tìm tên, nội dung..." value="@ViewBag.SearchString">
                    <select name="status" class="form-select rounded-pill">
                        <option value="">Tất cả trạng thái</option>
                        <option value="visible" selected="@(ViewBag.Status == "visible")">Đang hiện</option>
                        <option value="hidden" selected="@(ViewBag.Status == "hidden")">Bị ẩn</option>
                    </select>
                    <select name="dateSort" class="form-select rounded-pill">
                        <option value="desc" selected="@(ViewBag.DateSort == "desc")">Mới nhất</option>
                        <option value="asc" selected="@(ViewBag.DateSort == "asc")">Cũ nhất</option>
                    </select>
                    <button type="submit" class="btn btn-primary rounded-pill px-4"><i class="bi bi-funnel"></i> Lọc</button>
                </form>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Người dùng</th>
                            <th>Nội dung</th>
                            <th>Bài viết (BĐS)</th>
                            <th>Ngày đăng</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="row-@item.CommentID">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@(item.User?.Avatar ?? "/images/default-user.png")" class="rounded-circle me-2" width="40" height="40" style="object-fit:cover;">
                                        <strong>@item.User?.FullName</strong>
                                    </div>
                                </td>
                                <td>
                                    <span class="d-inline-block text-truncate" style="max-width: 250px;">
                                        @item.Content
                                    </span>
                                </td>
                                <td><a href="/Property/Details/@item.PropertyID" target="_blank" class="text-decoration-none">Xem tin <i class="bi bi-box-arrow-up-right"></i></a></td>
                                <td class="text-muted small">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge @(item.IsHidden ? "bg-danger" : "bg-success") status-badge-@item.CommentID">
                                        @(item.IsHidden ? "Đã Ẩn" : "Hiển thị")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a href="/Admin/Comments/Details/@item.CommentID" class="btn btn-sm btn-outline-info rounded-circle" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button class="btn btn-sm btn-outline-warning rounded-circle btn-toggle-admin" data-id="@item.CommentID" title="Ẩn/Hiện">
                                        <i class="bi bi-shield-lock"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger rounded-circle btn-delete-admin" data-id="@item.CommentID" title="Xóa vĩnh viễn">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $('.btn-toggle-admin').click(function () {
                var id = $(this).data('id');
                $.post('/Admin/Comments/ToggleVisibility', { id: id }, function (res) {
                    if (res.success) {
                        var badge = $('.status-badge-' + id);
                        if(res.isHidden) {
                            badge.removeClass('bg-success').addClass('bg-danger').text('Đã Ẩn');
                        } else {
                            badge.removeClass('bg-danger').addClass('bg-success').text('Hiển thị');
                        }
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Cập nhật thành công', showConfirmButton: false, timer: 1500 });
                    }
                });
            });

            $('.btn-delete-admin').click(function () {
                var id = $(this).data('id');
                Swal.fire({
                    title: 'Xóa vĩnh viễn?',
                    text: "Không thể khôi phục dữ liệu này!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Đồng ý xóa'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.post('/Admin/Comments/Delete', { id: id }, function (res) {
                            if (res.success) {
                                $('#row-' + id).fadeOut();
                            }
                        });
                    }
                });
            });
        });
    </script>
}