@model BDSKhanhHoa.Models.Area
@{
    ViewData["Title"] = "Xác nhận xóa Khu vực";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="card-body p-5 text-center">
                <div class="mb-4 text-danger">
                    <i class="bi bi-exclamation-triangle-fill" style="font-size: 4.5rem;"></i>
                </div>
                <h3 class="fw-bold text-dark">Dừng lại! Bạn có chắc chắn?</h3>
                <p class="text-muted px-lg-5">
                    Hành động này sẽ xóa vĩnh viễn khu vực <strong>@Model.AreaName</strong> và
                    <span class="text-danger fw-bold">TẤT CẢ các xã/phường</span> đang thuộc khu vực này.
                </p>

                <div class="bg-light rounded-4 p-3 my-4 text-start border">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Khu vực:</span>
                        <span class="fw-bold text-primary">@Model.AreaName</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small">Số lượng xã trực thuộc:</span>
                        <span class="badge bg-danger rounded-pill">@(Model.Wards?.Count ?? 0) đơn vị</span>
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="AreaID" />
                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                        <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 shadow-sm fw-bold">
                            Xác nhận xóa sạch
                        </button>
                        <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-5 border shadow-sm text-muted">
                            Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>