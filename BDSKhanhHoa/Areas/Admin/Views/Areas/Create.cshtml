@model BDSKhanhHoa.Models.Area
@{
    ViewData["Title"] = "Thêm Khu vực mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center py-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white py-3 border-0">
                <h5 class="fw-bold text-primary m-0"><i class="bi bi-plus-circle me-2"></i>@ViewData["Title"]</h5>
            </div>
            <div class="card-body p-4">
                <form asp-area="Admin" asp-controller="Areas" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">Tên khu vực </label>
                        @* asp-for phải khớp chính xác với tên thuộc tính trong class Area *@
                        <input asp-for="AreaName" class="form-control form-control-lg rounded-3" placeholder="Nhập tên khu vực..." />
                        <span asp-validation-for="AreaName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">Mô tả đặc điểm</label>
                        <textarea asp-for="Description" class="form-control rounded-3" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 pt-3 border-top">
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                            <i class="bi bi-check-lg me-1"></i> Xác nhận Tạo
                        </button>
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4 border">Hủy bỏ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* Quan trọng: Dòng này giúp báo lỗi ngay lập tức mà không cần load lại trang *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}