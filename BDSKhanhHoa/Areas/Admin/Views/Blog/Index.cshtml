@model IEnumerable<BDSKhanhHoa.Models.Blog>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Bài viết (Blog)";
}

<div class="row align-items-center mb-4 g-3">
    <div class="col-lg-5">
        <h3 class="fw-bold text-dark mb-1"><i class="bi bi-newspaper text-primary me-2"></i>Tin tức & Bài viết</h3>
        <p class="text-muted small mb-0">Hệ thống bài viết giúp SEO website và cung cấp kiến thức BĐS.</p>
    </div>

    <div class="col-lg-7 d-flex justify-content-lg-end gap-2">
        <form action="/Admin/Blog/Index" method="get" class="d-flex gap-2">
            <select name="category" class="form-select fw-bold bg-white shadow-sm border-0" onchange="this.form.submit()" style="min-width: 220px;">
                <option value="">-- Tất cả danh mục --</option>
                @foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat" selected="@(ViewBag.CurrentCategory == cat ? "selected" : null)">@cat</option>
                }
            </select>
        </form>

        <a href="/Admin/Blog/Create" class="btn btn-primary shadow-sm px-4 fw-bold rounded-3 text-nowrap">
            <i class="bi bi-pencil-square me-2"></i> Soạn bài mới
        </a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 bg-white">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3"><i class="bi bi-journal-text fs-3"></i></div>
                <div>
                    <p class="text-muted small fw-bold mb-0 text-uppercase">Số bài viết @(string.IsNullOrEmpty(ViewBag.CurrentCategory) ? "" : $"({ViewBag.CurrentCategory})")</p>
                    <h3 class="fw-bold mb-0 text-dark">@ViewBag.TotalPosts</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 bg-white">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 text-success p-3 rounded-3"><i class="bi bi-eye fs-3"></i></div>
                <div>
                    <p class="text-muted small fw-bold mb-0 text-uppercase">Tổng lượt xem</p>
                    <h3 class="fw-bold mb-0 text-dark">@ViewBag.TotalViews</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 bg-white">
            <thead class="table-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-secondary" style="width: 120px;">Hình ảnh</th>
                    <th class="py-3 text-uppercase small fw-bold text-secondary">Thông tin bài viết</th>
                    <th class="py-3 text-uppercase small fw-bold text-secondary">Tác giả</th>
                    <th class="text-center py-3 text-uppercase small fw-bold text-secondary">Lượt xem</th>
                    <th class="text-end pe-4 py-3 text-uppercase small fw-bold text-secondary">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <img src="@(string.IsNullOrEmpty(item.ImageURL) ? "/images/no-image.jpg" : item.ImageURL)"
                                     class="rounded-3 border shadow-sm object-fit-cover" style="width: 100px; height: 65px;"
                                     onerror="this.src='/images/no-image.jpg'">
                            </td>
                            <td class="py-3">
                                <div class="badge bg-light text-primary border mb-2">@item.Category</div>
                                <div class="fw-bold text-dark mb-1 text-truncate" style="max-width: 350px;" title="@item.Title">@item.Title</div>
                                <div class="text-muted small fw-medium"><i class="bi bi-clock me-1"></i> @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            </td>
                            <td class="py-3">
                                <span class="badge bg-light text-dark border fw-medium px-2 py-1">
                                    <i class="bi bi-person-fill text-secondary me-1"></i> @(item.User?.FullName ?? "Hệ thống")
                                </span>
                            </td>
                            <td class="py-3 text-center">
                                <span class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill"><i class="bi bi-eye"></i> @item.Views</span>
                            </td>
                            <td class="py-3 text-end pe-4">
                                <div class="btn-group shadow-sm rounded-3">
                                    <a href="/Admin/Blog/Edit/@item.BlogID" class="btn btn-sm btn-light border text-primary" title="Sửa bài">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-light border text-danger" onclick="confirmDelete(@item.BlogID)" title="Xóa bài">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </div>
                                <form id="deleteForm-@item.BlogID" action="/Admin/Blog/Delete/@item.BlogID" method="post" style="display:none;">
                                    @Html.AntiForgeryToken()
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="bi bi-journal-x display-4 text-muted opacity-25 d-block mb-3"></i>
                            <h6 class="text-muted fw-bold">Không tìm thấy bài viết nào thuộc danh mục này.</h6>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: 'Xóa bài viết này?',
                text: "Bài viết sẽ được đưa vào thùng rác!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Đồng ý xóa!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) { document.getElementById('deleteForm-' + id).submit(); }
            })
        }
        @if (TempData["Success"] != null)
        {
            <text>Swal.fire({ icon: 'success', title: 'Thành công!', text: '@Html.Raw(TempData["Success"])', timer: 3000, showConfirmButton: false });</text>
        }
        @if (TempData["Error"] != null)
        {
            <text>Swal.fire({ icon: 'error', title: 'Lỗi!', text: '@Html.Raw(TempData["Error"])' });</text>
        }
    </script>
}