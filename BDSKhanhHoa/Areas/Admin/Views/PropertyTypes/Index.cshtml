@model IEnumerable<BDSKhanhHoa.Models.PropertyType>
@{
    ViewData["Title"] = "Quản lý Danh mục Giao dịch";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm mb-4 border-0" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">
            <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center border-0">
                <h5 class="m-0 fw-bold"><i class="bi bi-cart-check-fill me-2"></i>MỤC MUA BÁN</h5>
                <a asp-action="Create" asp-route-parentId="1" class="btn btn-light btn-sm rounded-pill px-3 fw-bold text-primary shadow-sm">
                    <i class="bi bi-plus-lg"></i> Thêm loại bán
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 py-3">Tên loại hình con</th>
                                <th class="text-end pe-4">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in (List<BDSKhanhHoa.Models.PropertyType>)ViewBag.BuyGroup)
                            {
                                if (item.ParentID == 1) // Chỉ hiện các con
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-arrow-return-right text-muted me-3"></i>
                                                <span class="fw-semibold text-dark">@item.TypeName</span>
                                            </div>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="btn-group shadow-sm rounded-3">
                                                <a asp-action="Edit" asp-route-id="@item.TypeID" class="btn btn-outline-warning border-0 btn-sm"><i class="bi bi-pencil-square"></i></a>
                                                <a asp-action="Delete" asp-route-id="@item.TypeID" class="btn btn-outline-danger border-0 btn-sm"><i class="bi bi-trash"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">
            <div class="card-header bg-success text-white py-3 d-flex justify-content-between align-items-center border-0">
                <h5 class="m-0 fw-bold"><i class="bi bi-key-fill me-2"></i>MỤC CHO THUÊ</h5>
                <a asp-action="Create" asp-route-parentId="2" class="btn btn-light btn-sm rounded-pill px-3 fw-bold text-success shadow-sm">
                    <i class="bi bi-plus-lg"></i> Thêm loại thuê
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 py-3">Tên loại hình con</th>
                                <th class="text-end pe-4">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in (List<BDSKhanhHoa.Models.PropertyType>)ViewBag.RentGroup)
                            {
                                if (item.ParentID == 2)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-arrow-return-right text-muted me-3"></i>
                                                <span class="fw-semibold text-dark">@item.TypeName</span>
                                            </div>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="btn-group shadow-sm rounded-3">
                                                <a asp-action="Edit" asp-route-id="@item.TypeID" class="btn btn-outline-warning border-0 btn-sm"><i class="bi bi-pencil-square"></i></a>
                                                <a asp-action="Delete" asp-route-id="@item.TypeID" class="btn btn-outline-danger border-0 btn-sm"><i class="bi bi-trash"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>