@model BDSKhanhHoa.Models.PropertyType
@{
    ViewData["Title"] = "Cập nhật loại hình: " + Model.TypeName;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h4 class="fw-bold text-warning m-0"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa loại hình</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="TypeID" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase">Tên loại hình</label>
                        <input asp-for="TypeName" class="form-control form-control-lg rounded-3" />
                        <span asp-validation-for="TypeName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase">Thay đổi danh mục cha</label>
                        <select asp-for="ParentID" class="form-select form-select-lg rounded-3" asp-items="ViewBag.ParentID">
                            <option value="">-- Là danh mục gốc (Mua bán / Thuê) --</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold small text-uppercase">Mô tả</label>
                        <textarea asp-for="Description" class="form-control rounded-3" rows="4"></textarea>
                    </div>

                    <div class="pt-3 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-5 rounded-pill fw-bold">Cập nhật thay đổi</button>
                        <a asp-action="Index" class="btn btn-light px-4 rounded-pill border">Hủy bỏ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>