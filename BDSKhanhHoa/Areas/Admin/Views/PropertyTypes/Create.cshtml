@model BDSKhanhHoa.Models.PropertyType
@{
    ViewData["Title"] = "Thêm loại hình mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h4 class="fw-bold text-dark m-0"><i class="bi bi-plus-circle-fill text-primary me-2"></i>@ViewData["Title"]</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small uppercase">Tên loại hình (Ví dụ: Căn hộ, Đất nền...)</label>
                        <input asp-for="TypeName" class="form-control form-control-lg rounded-3 border-light-subtle bg-light" placeholder="..." autofocus />
                        <span asp-validation-for="TypeName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small uppercase">Danh mục giao dịch cha</label>
                        <select asp-for="ParentID" class="form-select form-select-lg rounded-3 border-light-subtle" asp-items="ViewBag.ParentID">
                        </select>
                        <div class="form-text small">Mục này sẽ xuất hiện dưới menu Mua hoặc Thuê trên Header.</div>
                    </div>

                

                    <div class="d-flex gap-2 pt-3 border-top mt-4">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm fw-bold">Lưu lại</button>
                        <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-4 border text-muted">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>