@model BDSKhanhHoa.Models.PropertyType
@{
    ViewData["Title"] = "Xác nhận xóa";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
                <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="card-body p-5 text-center">
                <div class="mb-4 text-danger">
                    <i class="bi bi-trash3-fill" style="font-size: 4rem;"></i>
                </div>
                <h3 class="fw-bold text-dark">Xác nhận xóa loại hình?</h3>
                <p class="text-muted">Hệ thống sẽ xóa vĩnh viễn <strong>@Model.TypeName</strong>. Thao tác này chỉ thực hiện được khi không có danh mục con hoặc tin đăng liên quan.</p>

                <div class="list-group list-group-flush text-start my-4 bg-light rounded-3 p-2">
                    <div class="list-group-item bg-transparent border-0 small">
                        <span class="text-muted">Tên loại:</span> <span class="fw-bold">@Model.TypeName</span>
                    </div>
                    <div class="list-group-item bg-transparent border-0 small">
                        <span class="text-muted">Mô tả:</span> <span>@Model.Description</span>
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="TypeID" />
                    <div class="d-flex gap-2 justify-content-center mt-4">
                        <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 shadow-sm">Đồng ý xóa</button>
                        <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-5 border shadow-sm">Hủy bỏ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>