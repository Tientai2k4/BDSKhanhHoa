@model IEnumerable<BDSKhanhHoa.Models.BusinessProfile>
@{
    ViewData["Title"] = "Quản lý Đối tác Chủ đầu tư";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-dark"><i class="bi bi-briefcase me-2"></i>DANH SÁCH PHÁP NHÂN DOANH NGHIỆP</h4>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Doanh nghiệp / MST</th>
                            <th>Đại diện pháp luật</th>
                            <th>Tài khoản hệ thống</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.BusinessName</div>
                                    <div class="small text-muted">MST: @item.TaxCode</div>
                                </td>
                                <td>
                                    <div class="fw-medium">@item.RepresentativeName</div>
                                    <div class="small text-muted">@item.RepresentativePhone</div>
                                </td>
                                <td>
                                    <span class="badge bg-info-subtle text-info border border-info-subtle px-2">
                                        @@@item.User?.Username
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(item.VerificationStatus == "Approved" ? "bg-success" : "bg-danger") rounded-pill">
                                        @item.VerificationStatus
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@item.BusinessProfileID" class="btn btn-sm btn-light border shadow-sm">
                                        <i class="bi bi-eye-fill"></i> Xem hồ sơ
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>