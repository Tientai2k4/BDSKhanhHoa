@model BDSKhanhHoa.Models.Project
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cập nhật Dự án: " + Model.ProjectName;
}

<div class="container-fluid px-4 mt-4 pb-5 animate__animated animate__fadeIn">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="ProjectID" />

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm rounded-4 border-0 mb-4">
                    <div class="card-header bg-warning text-dark p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>I. CẬP NHẬT THÔNG TIN CỐT LÕI</h5>
                            <a asp-action="Index" class="btn btn-sm btn-dark rounded-pill px-3 fw-bold">Quay lại Kho</a>
                        </div>
                    </div>
                    <div class="card-body p-4 p-lg-5">
                        <div class="mb-4">
                            <label class="form-label fw-bold">Tên thương mại dự án <span class="text-danger">*</span></label>
                            <input asp-for="ProjectName" class="form-control form-control-lg border-2 shadow-sm" required />
                        </div>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Phân khúc / Loại hình</label>
                                <input asp-for="ProjectType" class="form-control border-2 shadow-sm" placeholder="VD: Căn hộ cao cấp" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Chủ đầu tư chính <span class="text-danger">*</span></label>
                                <input asp-for="Investor" class="form-control border-2 shadow-sm" required />
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Tóm tắt Sapo (Mô tả ngắn)</label>
                            <textarea asp-for="Description" class="form-control border-2 shadow-sm" rows="3" required></textarea>
                        </div>
                        <div class="mb-0">
                            <label class="form-label fw-bold text-primary">Bài viết giới thiệu chi tiết (Chuẩn SEO)</label>
                            <textarea asp-for="ContentHtml" id="editor"></textarea>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm rounded-4 border-0">
                    <div class="card-header bg-primary text-white p-3"><h5 class="mb-0 fw-bold"><i class="bi bi-gear-wide-connected me-2"></i>II. THÔNG SỐ KỸ THUẬT & TIỆN ÍCH</h5></div>
                    <div class="card-body p-4 p-lg-5">
                        <div class="row g-4 mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Giá bán từ</label>
                                <input asp-for="PriceMin" type="number" step="0.01" class="form-control border-2 shadow-sm" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Đến tối đa</label>
                                <input asp-for="PriceMax" type="number" step="0.01" class="form-control border-2 shadow-sm" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Đơn vị giá</label>
                                <select asp-for="PriceUnit" class="form-select border-2 shadow-sm fw-bold">
                                    <option value="Tỷ">Tỷ đồng</option>
                                    <option value="Triệu/m2">Triệu / m²</option>
                                    <option value="USD">USD</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Quy mô khu đất</label>
                                <input asp-for="Scale" class="form-control border-2 shadow-sm" placeholder="VD: 5ha, 3 tòa tháp, 1500 căn" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Mật độ xây dựng (%)</label>
                                <input asp-for="ConstructionDensity" class="form-control border-2 shadow-sm" placeholder="VD: 35%" />
                            </div>
                        </div>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Diện tích SP Nhỏ nhất (m²)</label>
                                <input asp-for="AreaMin" type="number" step="0.1" class="form-control border-2 shadow-sm" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Diện tích SP Lớn nhất (m²)</label>
                                <input asp-for="AreaMax" type="number" step="0.1" class="form-control border-2 shadow-sm" />
                            </div>
                        </div>
                        <div class="mb-0">
                            <label class="form-label fw-bold text-warning">Hệ thống tiện ích nội khu</label>
                            <textarea asp-for="Utilities" class="form-control border-2 shadow-sm border-warning" rows="4" placeholder="Liệt kê các tiện ích nổi bật..."></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm rounded-4 border-0 mb-4 sticky-top" style="top: 90px; z-index: 100;">
                    <div class="card-body p-4">
                        <label class="form-label fw-bold text-primary mb-3"><i class="bi bi-person-check me-2"></i>Gán quyền Quản lý (CRM Leads)</label>
                        <select asp-for="OwnerUserID" class="form-select mb-4 shadow-sm border-2" asp-items="ViewBag.Owners"></select>

                        <div class="mb-4 bg-light p-3 rounded-4 border">
                            <label class="form-label fw-bold small text-muted">VỊ TRÍ DỰ ÁN</label>
                            <select asp-for="AreaID" class="form-select mb-2 shadow-sm" asp-items="ViewBag.Areas" id="areaDDL"></select>
                            <select asp-for="WardID" class="form-select mb-2 shadow-sm" asp-items="ViewBag.Wards" id="wardDDL"></select>
                            <input asp-for="AddressDetail" class="form-control shadow-sm" placeholder="Số nhà, đường..." />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">HÌNH ẢNH HIỆN TẠI</label>
                            <img src="@(string.IsNullOrEmpty(Model.MainImage) ? "/images/no-image.jpg" : Model.MainImage)" class="img-thumbnail w-100 mb-2 shadow-sm rounded-4" style="height: 180px; object-fit: cover;">
                            <input type="file" name="MainImageFile" class="form-control" accept="image/*" />
                            <small class="text-muted fst-italic">Chỉ upload nếu muốn đổi ảnh bìa mới.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-danger">HỒ SƠ PHÁP LÝ (BẢO MẬT)</label>
                            @if (!string.IsNullOrEmpty(Model.LegalDocs))
                            {
                                <a href="@Model.LegalDocs" target="_blank" class="d-block mb-2 text-danger fw-bold"><i class="bi bi-file-earmark-pdf-fill me-1"></i> Xem file hiện tại</a>
                            }
                            <input type="file" name="LegalDocsFile" class="form-control border-danger" accept=".pdf,.zip,.rar" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">TRẠNG THÁI DỰ ÁN</label>
                            <select asp-for="ProjectStatus" class="form-select form-select-lg fw-bold text-success border-2 border-success shadow-sm">
                                <option value="Sắp mở bán">Sắp mở bán (Booking)</option>
                                <option value="Đang mở bán">Đang mở bán</option>
                                <option value="Đang bàn giao">Đang bàn giao</option>
                                <option value="Đã bàn giao">Đã bàn giao hoàn thiện</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-warning btn-lg w-100 fw-black py-3 shadow text-dark">
                            <i class="bi bi-save2-fill me-2"></i>LƯU THAY ĐỔI DỰ ÁN
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        ClassicEditor.create(document.querySelector('#editor'));

        // AJAX Load Xã Phường
        $('#areaDDL').change(function() {
            var areaId = $(this).val();
            if(areaId) {
                $.getJSON('/Admin/AdminProject/GetWardsByArea?areaId=' + areaId, function(data) {
                    var items = '<option value="">-- Chọn Phường/Xã --</option>';
                    $.each(data, function(i, ward) { items += "<option value='" + ward.id + "'>" + ward.name + "</option>"; });
                    $('#wardDDL').html(items);
                });
            }
        });
    </script>
}