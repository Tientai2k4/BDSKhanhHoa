@model BDSKhanhHoa.Models.Project
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thiết lập Dự án mới";
}

<div class="container-fluid px-4 mt-4 pb-5 animate__animated animate__fadeIn">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm rounded-4 border-0 mb-4">
                    <div class="card-header bg-dark text-white p-3"><h5 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2 text-warning"></i>I. THÔNG TIN CỐT LÕI (BẮT BUỘC)</h5></div>
                    <div class="card-body p-4">
                        <div class="mb-4">
                            <label class="form-label fw-bold">Tên thương mại dự án <span class="text-danger">*</span></label>
                            <input asp-for="ProjectName" class="form-control form-control-lg border-primary border-opacity-25" placeholder="Ví dụ: Grand Mark Nha Trang..." required />
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Phân khúc / Loại hình</label>
                                <input asp-for="ProjectType" class="form-control" placeholder="Căn hộ cao cấp, Đất nền..." />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Chủ đầu tư chính <span class="text-danger">*</span></label>
                                <input asp-for="Investor" class="form-control" placeholder="Tên tập đoàn..." required />
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Tóm tắt ngắn (Hiện ở danh sách)</label>
                            <textarea asp-for="Description" class="form-control" rows="2" required placeholder="Mô tả sơ lược 1-2 câu..."></textarea>
                        </div>
                        <div class="mb-0">
                            <label class="form-label fw-bold text-primary">Nội dung giới thiệu chi tiết (Chuẩn SEO)</label>
                            <textarea asp-for="ContentHtml" id="editor"></textarea>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm rounded-4 border-0">
                    <div class="card-header bg-primary text-white p-3"><h5 class="mb-0 fw-bold"><i class="bi bi-gear-wide-connected me-2"></i>II. THÔNG SỐ & TIỆN ÍCH</h5></div>
                    <div class="card-body p-4">
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Giá bán từ (VNĐ)</label>
                                <input asp-for="PriceMin" type="number" step="0.01" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Đến tối đa</label>
                                <input asp-for="PriceMax" type="number" step="0.01" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Đơn vị</label>
                                <select asp-for="PriceUnit" class="form-select fw-bold">
                                    <option value="Tỷ">Tỷ đồng</option>
                                    <option value="Triệu/m2">Triệu/m2</option>
                                    <option value="USD">USD</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Diện tích tim tường (m²)</label>
                                <div class="input-group">
                                    <input asp-for="AreaMin" class="form-control" placeholder="Từ" />
                                    <span class="input-group-text">-</span>
                                    <input asp-for="AreaMax" class="form-control" placeholder="Đến" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Quy mô khu đất</label>
                                <input asp-for="Scale" class="form-control border-2 shadow-sm" placeholder="VD: 5ha, 3 tòa tháp, 1500 căn" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Mật độ xây dựng (%)</label>
                                <input asp-for="ConstructionDensity" class="form-control" placeholder="VD: 35%" />
                            </div>
                        </div>
                        <div class="mb-0">
                            <label class="form-label fw-bold">Hệ thống tiện ích nội khu</label>
                            <textarea asp-for="Utilities" class="form-control" rows="3" placeholder="Hồ bơi skyview, khu vui chơi, gym..."></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm rounded-4 border-0 mb-4 sticky-top" style="top: 90px; z-index: 100;">
                    <div class="card-body p-4">
                        <label class="form-label fw-bold text-primary mb-3"><i class="bi bi-person-check me-2"></i>Gán CĐT / Quản Lý Dự Án</label>
                        <select asp-for="OwnerUserID" class="form-select mb-4 shadow-sm border-2" asp-items="ViewBag.Owners" required>
                            <option value="">-- Chọn Doanh nghiệp đối tác --</option>
                        </select>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">VỊ TRÍ DỰ ÁN</label>
                            <select asp-for="AreaID" class="form-select mb-2" asp-items="ViewBag.Areas" id="areaDDL" required><option value="">-- Chọn Khu vực --</option></select>
                            <select asp-for="WardID" class="form-select mb-2" id="wardDDL" required><option value="">-- Chọn Phường/Xã --</option></select>
                            <input asp-for="AddressDetail" class="form-control" placeholder="Địa chỉ chính xác..." required />
                        </div>

                        <!-- KHU VỰC HÌNH ẢNH & PHÁP LÝ ĐƯỢC LÀM LẠI RÕ RÀNG -->
                        <div class="mb-4 bg-light p-3 rounded-4 border">
                            <label class="form-label fw-bold small text-muted d-block mb-3 border-bottom pb-2">HÌNH ẢNH & PHÁP LÝ</label>

                            <div class="mb-3">
                                <label class="form-label fw-bold text-dark"><i class="bi bi-image me-1 text-primary"></i>Ảnh bìa dự án <span class="text-danger">*</span></label>
                                <input type="file" name="MainImageFile" class="form-control shadow-sm" accept="image/*" required />
                                <small class="text-muted fst-italic">Định dạng: JPG, PNG, WEBP.</small>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold text-danger"><i class="bi bi-file-earmark-lock me-1"></i>Hồ sơ pháp lý <span class="text-danger">*</span></label>
                                <input type="file" name="LegalDocsFile" class="form-control border-danger shadow-sm" accept=".pdf,.zip,.rar" required />
                                <small class="text-muted fst-italic">Định dạng: PDF, ZIP, RAR. Tài liệu bảo mật.</small>
                            </div>

                            <div class="mb-0">
                                <label class="form-label fw-bold text-dark">Trạng thái dự án</label>
                                <select asp-for="ProjectStatus" class="form-select fw-bold text-success border-success shadow-sm">
                                    <option value="Sắp mở bán">Sắp mở bán (Booking)</option>
                                    <option value="Đang mở bán">Đang mở bán</option>
                                    <option value="Đã bàn giao">Đã bàn giao hoàn thiện</option>
                                </select>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-black py-3 shadow">
                            <i class="bi bi-cloud-arrow-up-fill me-2"></i>XUẤT BẢN DỰ ÁN
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        // Khởi tạo CKEditor và Cấu hình Upload Ảnh
        ClassicEditor
            .create(document.querySelector('#editor'), {
                ckfinder: {
                    // Trỏ đường dẫn về đúng Hàm (Action) vừa tạo trong Controller
                    uploadUrl: '/Admin/AdminProject/UploadImageCKEditor'
                }
            })
            .catch(error => {
                console.error(error);
            });

        // AJAX Load Xã Phường
        $('#areaDDL').change(function() {
            var areaId = $(this).val();
            if(areaId) {
                $.getJSON('/Admin/AdminProject/GetWardsByArea?areaId=' + areaId, function(data) {
                    var items = '<option value="">-- Chọn Phường/Xã --</option>';
                    $.each(data, function(i, ward) { items += "<option value='" + ward.id + "'>" + ward.name + "</option>"; });
                    $('#wardDDL').html(items);
                });
            } else {
                $('#wardDDL').html('<option value="">-- Chọn Phường/Xã --</option>');
            }
        });
    </script>
}