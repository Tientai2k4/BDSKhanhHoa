@model BDSKhanhHoa.Models.Project
@{
    ViewData["Title"] = "Chi tiết dự án: " + Model.ProjectName;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-light border fw-bold rounded-pill px-4 shadow-sm"><i class="bi bi-arrow-left me-2"></i>Trở về</a>
        <a asp-action="Edit" asp-route-id="@Model.ProjectID" class="btn btn-warning fw-bold rounded-pill px-4 shadow-sm"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa</a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-xl-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <img src="@(Model.MainImage ?? "/images/no-image.jpg")" class="w-100 shadow-sm" style="height:420px; object-fit:cover;">
                <div class="card-body p-4">
                    <h2 class="fw-black text-dark mb-2">@Model.ProjectName</h2>
                    <p class="text-primary fw-bold mb-4 fs-5"><i class="bi bi-geo-alt-fill text-danger me-1"></i>@Model.AddressDetail, @Model.Ward?.WardName, @Model.Area?.AreaName</p>

                    <h6 class="fw-bold text-uppercase border-bottom pb-2 mb-3">Giới thiệu tổng quan</h6>
                    <div class="text-secondary mb-4" style="line-height:1.8;">@Model.Description</div>

                    <h6 class="fw-bold text-uppercase border-bottom pb-2 mb-3">Bài viết chi tiết</h6>
                    <div class="ck-content">@Html.Raw(Model.ContentHtml)</div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-light py-3 fw-bold">THÔNG SỐ DỰ ÁN</div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <small class="text-muted d-block uppercase small fw-bold">Chủ đầu tư</small>
                        <span class="fs-5 fw-bold text-dark">@Model.Investor</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block uppercase small fw-bold">Khoảng giá</small>
                        <span class="fs-4 fw-black text-danger">@Model.PriceMin - @Model.PriceMax @Model.PriceUnit</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block uppercase small fw-bold">Diện tích căn hộ</small>
                        <span class="fs-5 fw-bold text-dark">@Model.AreaMin - @Model.AreaMax m²</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block uppercase small fw-bold">Trạng thái hiện tại</small>
                        <span class="badge bg-success px-3 py-2 rounded-pill">@Model.ProjectStatus</span>
                    </div>
                    <div class="mb-0">
                        <small class="text-muted d-block uppercase small fw-bold">Hồ sơ pháp lý</small>
                        <a href="@Model.LegalDocs" target="_blank" class="btn btn-outline-danger w-100 mt-2 fw-bold rounded-pill">
                            <i class="bi bi-file-earmark-pdf-fill me-2"></i>Tải xem File pháp lý
                        </a>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3"><i class="bi bi-person-badge-fill me-2"></i>TÀI KHOẢN QUẢN LÝ</h6>
                    <div class="d-flex align-items-center gap-3">
                        <img src="@(Model.Owner?.Avatar ?? "/images/avatars/default-user.png")" class="rounded-circle border border-2 border-white" width="50" height="50">
                        <div>
                            <div class="fw-bold">@Model.Owner?.FullName</div>
                            <small class="opacity-75">@@@Model.Owner?.Username</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>