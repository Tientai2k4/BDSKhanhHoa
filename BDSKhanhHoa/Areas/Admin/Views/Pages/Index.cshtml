@{
    ViewData["Title"] = "Quản lý Trang tĩnh";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    var pages = ViewBag.Pages as IEnumerable<(string Key, string Title, string Url, string Description)>;
}

<style>
    .page-card {
        background: #fff;
        border-radius: 22px;
        border: 1px solid rgba(148,163,184,.16);
        box-shadow: 0 12px 30px rgba(15, 23, 42, .06);
    }
</style>

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
        <h3 class="fw-black mb-1">Quản lý Trang tĩnh</h3>
        <div class="text-muted">Danh sách các trang public để admin theo dõi và chỉnh nội dung sau này.</div>
    </div>
</div>

<div class="row g-4">
    @if (pages != null)
    {
        foreach (var p in pages)
        {
            <div class="col-xl-4 col-md-6">
                <div class="page-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <h5 class="fw-bold mb-0">@p.Title</h5>
                        <span class="badge bg-light text-dark border">@p.Key</span>
                    </div>
                    <div class="text-muted mb-3">@p.Description</div>
                    <a href="@p.Url" target="_blank" class="btn btn-outline-primary rounded-pill fw-bold">
                        Mở trang
                    </a>
                </div>
            </div>
        }
    }
</div>