@model IEnumerable<BDSKhanhHoa.Models.StaticPage>

@{
    ViewData["Title"] = "Quản lý Trang tĩnh";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .page-card {
        background: #fff;
        border-radius: 22px;
        border: 1px solid rgba(148,163,184,.16);
        box-shadow: 0 12px 30px rgba(15, 23, 42, .06);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .page-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 16px 40px rgba(15, 23, 42, .12);
        }
</style>

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
        <h3 class="fw-black mb-1">Quản lý nội dung trang tĩnh</h3>
        <div class="text-muted">Cấu hình nội dung hiển thị cho các trang như Điều khoản, Chính sách, FAQ...</div>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill fw-bold shadow-sm px-4">
        <i class="bi bi-plus-circle-fill me-1"></i> Tạo trang mới
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    @if (Model != null && Model.Any())
    {
        foreach (var p in Model)
        {
            <div class="col-xl-4 col-md-6" id="page-card-@p.PageID">
                <div class="page-card p-4 h-100 d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <h5 class="fw-bold mb-0 text-primary">@p.Title</h5>
                        <span class="badge bg-light text-dark border">@p.PageKey</span>
                    </div>
                    <div class="text-muted mb-3 flex-grow-1">@(string.IsNullOrEmpty(p.Description) ? "Không có mô tả" : p.Description)</div>
                    <div class="text-secondary small mb-3">
                        <i class="bi bi-clock-history me-1"></i> Cập nhật: @p.UpdatedAt.ToString("dd/MM/yyyy HH:mm")
                    </div>

                    <div class="d-flex gap-2 mt-auto">
                        <a asp-action="Edit" asp-route-id="@p.PageID" class="btn btn-primary rounded-pill fw-bold flex-grow-1">
                            <i class="bi bi-pencil-square me-1"></i> Sửa
                        </a>
                        <a href="/Page/@p.PageKey" target="_blank" class="btn btn-outline-secondary rounded-pill px-3" title="Xem trang Public">
                            <i class="bi bi-eye-fill"></i>
                        </a>
                        <button class="btn btn-outline-danger rounded-pill px-3 btn-delete" data-id="@p.PageID" title="Xóa trang này">
                            <i class="bi bi-trash-fill"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted mt-5">
            <i class="bi bi-file-earmark-x fs-1 d-block mb-3 opacity-50"></i>
            Chưa có trang tĩnh nào trong hệ thống. Vui lòng bấm "Tạo trang mới".
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $('.btn-delete').click(function () {
                var id = $(this).data('id');
                Swal.fire({
                    title: 'Xác nhận xóa?',
                    text: "Bạn có chắc chắn muốn xóa trang tĩnh này không? Thao tác không thể hoàn tác!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đồng ý xóa',
                    cancelButtonText: 'Hủy bỏ'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.post('/Admin/Pages/Delete', { id: id }, function (res) {
                            if (res.success) {
                                $('#page-card-' + id).fadeOut(300, function() { $(this).remove(); });
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                            } else {
                                Swal.fire('Lỗi', res.message, 'error');
                            }
                        });
                    }
                });
            });
        });
    </script>
}