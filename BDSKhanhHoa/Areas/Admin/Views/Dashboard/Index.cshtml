@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Bảng điều khiển hệ thống";
}

<div class="row">
    <div class="col-md-4">
        <div class="card bg-primary text-white mb-4 shadow">
            <div class="card-body">
                <h5>Tổng tin đăng</h5>
                <h2>@ViewBag.TotalProperties</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-warning text-dark mb-4 shadow">
            <div class="card-body">
                <h5>Tin chờ duyệt</h5>
                <h2>@ViewBag.PendingProperties</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white mb-4 shadow">
            <div class="card-body">
                <h5>Tổng thành viên</h5>
                <h2>@ViewBag.TotalUsers</h2>
            </div>
        </div>
    </div>
</div>