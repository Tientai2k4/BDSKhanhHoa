@model BDSKhanhHoa.Models.AuditLog
@using System.Globalization

@{
    ViewData["Title"] = "Chi tiết sự kiện bảo mật";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .detail-wrap {
        background: #fff;
        border-radius: 24px;
        border: 1px solid rgba(148,163,184,.16);
        box-shadow: 0 12px 30px rgba(15, 23, 42, .06);
    }

    .meta-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 20px;
        height: 100%;
        transition: 0.2s;
    }

        .meta-card:hover {
            border-color: #cbd5e1;
            box-shadow: 0 4px 12px rgba(0,0,0,.03);
        }

    .meta-label {
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        font-weight: 800;
        color: #64748b;
        margin-bottom: 8px;
    }

    .meta-value {
        font-weight: 900;
        font-size: 1.1rem;
        color: #0f172a;
        word-break: break-word;
    }

    .terminal-box {
        background-color: #0f172a;
        color: #10b981;
        font-family: 'Courier New', Courier, monospace;
        padding: 20px;
        border-radius: 16px;
        border: 1px solid #334155;
        box-shadow: inset 0 2px 10px rgba(0,0,0,.2);
    }

        .terminal-box p {
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

    .terminal-label {
        color: #94a3b8;
        font-weight: bold;
        width: 150px;
        display: inline-block;
    }
</style>

<div class="detail-wrap p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4 border-bottom pb-4">
        <div>
            <h3 class="fw-black mb-1 text-dark"><i class="bi bi-search me-2 text-primary"></i>Chi tiết sự kiện #@Model.LogID</h3>
            <div class="text-muted"><i class="bi bi-clock-history me-1"></i> Ghi nhận lúc: @Model.CreatedAt.ToString("HH:mm:ss dd/MM/yyyy")</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill fw-bold px-4">
            <i class="bi bi-arrow-left me-2"></i> Trở về danh sách
        </a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-xl-6">
            <div class="meta-card d-flex align-items-center gap-3">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 54px; height: 54px; font-size: 1.5rem;">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div>
                    <div class="meta-label">Người khởi tạo</div>
                    <div class="meta-value">@(Model.User?.FullName ?? "System Auto")</div>
                    <div class="text-muted small">Account ID: @(Model.User != null ? Model.UserID.ToString() : "N/A")</div>
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="meta-card d-flex align-items-center gap-3">
                <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 54px; height: 54px; font-size: 1.5rem;">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <div>
                    <div class="meta-label">Phân loại hành động</div>
                    <div class="meta-value">@Model.Action</div>
                    <div class="text-muted small">Target Entity: @Model.Target</div>
                </div>
            </div>
        </div>
    </div>

    <h6 class="fw-bold mb-3 text-uppercase text-muted" style="letter-spacing: 1px;"><i class="bi bi-terminal me-2"></i>Dữ liệu hệ thống thô (Raw Data)</h6>
    <div class="terminal-box">
        <p><span class="terminal-label">[LOG_ID]</span> @Model.LogID</p>
        <p><span class="terminal-label">[TIMESTAMP]</span> @Model.CreatedAt.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")</p>
        <p><span class="terminal-label">[ACTION]</span> EXECUTE @Model.Action</p>
        <p><span class="terminal-label">[TARGET_TABLE]</span> dbo.@Model.Target</p>
        <p><span class="terminal-label">[EXECUTED_BY]</span> @(Model.User?.Username ?? "NT AUTHORITY\\SYSTEM")</p>
        <p><span class="terminal-label">[STATUS]</span> <span class="text-white bg-success px-2 rounded-1 small">SUCCESS</span></p>
    </div>
</div>