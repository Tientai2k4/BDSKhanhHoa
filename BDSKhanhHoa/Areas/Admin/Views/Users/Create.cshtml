@model BDSKhanhHoa.Models.User
@{
    ViewData["Title"] = "Thêm thành viên mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-person-plus me-2"></i>THÊM THÀNH VIÊN MỚI</h5>
                        <a asp-action="Index" class="btn btn-sm btn-light text-primary fw-bold rounded-pill px-3">Quay lại</a>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 bg-light">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-bold"></div>

                        <h6 class="fw-bold text-uppercase text-muted border-bottom pb-2 mb-4">Thông tin đăng nhập</h6>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="Username" class="form-label fw-bold small text-dark">Tên đăng nhập (Username) <span class="text-danger">*</span></label>
                                <input asp-for="Username" class="form-control rounded-3 py-2 border-0 shadow-sm" placeholder="VD: nguyenvan_a" required />
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Password" class="form-label fw-bold small text-dark">Mật khẩu <span class="text-danger">*</span></label>
                                <input asp-for="Password" type="password" class="form-control rounded-3 py-2 border-0 shadow-sm" placeholder="Ít nhất 6 ký tự" required />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                        </div>

                        <h6 class="fw-bold text-uppercase text-muted border-bottom pb-2 mb-4 mt-4">Thông tin cá nhân</h6>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-bold small text-dark">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" type="email" class="form-control rounded-3 py-2 border-0 shadow-sm" placeholder="VD: email@domain.com" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="FullName" class="form-label fw-bold small text-dark">Họ và tên</label>
                                <input asp-for="FullName" class="form-control rounded-3 py-2 border-0 shadow-sm" placeholder="VD: Nguyễn Văn A" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="RoleID" class="form-label fw-bold small text-primary">Phân quyền hệ thống</label>
                                <select asp-for="RoleID" class="form-select rounded-3 py-2 shadow-sm border-primary">
                                    <option value="3">Thành viên (Khách hàng/Môi giới)</option>
                                    <option value="2">Nhân viên (Kiểm duyệt viên)</option>
                                    <option value="1">Quản trị viên (Admin)</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-dark">Trạng thái khởi tạo</label>
                                <div class="form-check form-switch pt-2">
                                    <input class="form-check-input fs-5" type="checkbox" asp-for="IsActive" checked>
                                    <label class="form-check-label mt-1 ms-2" asp-for="IsActive">Cho phép đăng nhập ngay</label>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 pt-4 border-top text-end">
                            <a asp-action="Index" class="btn btn-secondary rounded-pill px-4 me-2">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 shadow fw-bold"><i class="bi bi-save me-2"></i> TẠO TÀI KHOẢN</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}