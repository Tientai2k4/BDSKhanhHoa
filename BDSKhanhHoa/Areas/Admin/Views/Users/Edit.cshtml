@model BDSKhanhHoa.Models.User
@{
    ViewData["Title"] = "Chỉnh sửa tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-primary text-white py-3 rounded-top-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-shield-lock me-2"></i>CẬP NHẬT QUYỀN HẠN & THÔNG TIN</h5>
                        <a asp-action="Index" class="btn btn-sm btn-light border-0 px-3 rounded-pill text-primary fw-bold">Trở lại</a>
                    </div>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="UserID" />

                        <div class="text-center mb-5">
                            <div class="position-relative d-inline-block">
                                <img src="@(string.IsNullOrEmpty(Model.Avatar) ? "/images/avatars/default.png" : Model.Avatar)"
                                     class="rounded-circle border border-4 border-light shadow" width="110" height="110" style="object-fit: cover;">
                            </div>
                            <h4 class="fw-bold mt-3 text-dark">@Model.FullName</h4>
                            <span class="text-muted small">Username: <strong>@Model.Username</strong></span>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Email hệ thống</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-envelope"></i></span>
                                    <input type="text" class="form-control bg-light border-0 text-muted" value="@Model.Email" readonly />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Họ và tên</label>
                                <input asp-for="FullName" class="form-control border-0 bg-light py-2" placeholder="Nhập tên..." required />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Số điện thoại</label>
                                <input asp-for="Phone" class="form-control border-0 bg-light py-2" placeholder="Nhập số điện thoại..." />
                            </div>

                            <div class="col-12"><hr class="my-2 opacity-10"></div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-primary text-uppercase">Vai trò hệ thống</label>
                                <select asp-for="RoleID" class="form-select border-primary shadow-sm py-2">
                                    <option value="3">Thành viên (Khách hàng/Môi giới)</option>
                                    <option value="2">Nhân viên (Điều hành viên)</option>
                                    <option value="1">Quản trị viên (Admin Toàn quyền)</option>
                                </select>
                            </div>

                     

                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Địa chỉ cư trú</label>
                                <textarea asp-for="Address" class="form-control border-0 bg-light" rows="2" placeholder="Địa chỉ chi tiết..."></textarea>
                            </div>

                            <div class="col-md-12">
                                <div class="p-3 border rounded-3 bg-light d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-0 fw-bold text-dark">Trạng thái hoạt động</h6>
                                        <small class="text-muted">Khóa tài khoản nếu có dấu hiệu vi phạm</small>
                                    </div>
                                    <div class="form-check form-switch fs-4">
                                        <input class="form-check-input" type="checkbox" role="switch" asp-for="IsActive">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 d-flex gap-3">
                            <button type="submit" class="btn btn-primary px-5 py-2 fw-bold rounded-pill shadow-sm">LƯU THAY ĐỔI</button>
                            <a asp-action="Index" class="btn btn-light px-4 py-2 rounded-pill">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}