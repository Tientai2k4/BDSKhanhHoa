@model BDSKhanhHoa.Models.User
@{
    ViewData["Title"] = "Cập nhật Hồ sơ Người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var bizProfile = ViewBag.BusinessProfile as BDSKhanhHoa.Models.BusinessProfile;
    bool hasBusiness = bizProfile != null;
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .input-group-text {
        background-color: #fff;
        border-right: none;
        color: #94a3b8;
    }

    .form-control:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
    }

    .input-with-icon {
        border-left: none;
    }

    .form-check-input:checked {
        background-color: #10b981;
        border-color: #10b981;
    }

    .card-custom {
        border: none;
        border-radius: 1.25rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .biz-card {
        background-color: #fffbeb;
        border: 1px solid #fbbf24;
        border-radius: 1rem;
    }

    .note-box {
        background-color: #fee2e2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-xl-10">

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserID" />
                @* Thêm các hidden input này để tránh lỗi Required của Model *@
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Username" />

                <div class="card card-custom mb-4">
                    <div class="card-header bg-white pt-4 px-4 border-0 d-flex justify-content-between align-items-center">
                        <h4 class="fw-bold mb-0">Chỉnh sửa tài khoản</h4>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Trở lại</a>
                    </div>

                    <div class="card-body p-4">
                        <!-- Header thông tin tĩnh -->
                        <div class="d-flex align-items-center gap-4 mb-4 pb-4 border-bottom">
                            <img src="@(Model.Avatar ?? "/images/avatars/default.png")" class="rounded-circle border border-4 border-white shadow-sm" width="80" height="90" style="object-fit: cover;">
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-1 text-primary">@@@Model.Username</h5>
                                <span class="badge bg-light text-dark border px-3 py-2 rounded-pill"><i class="bi bi-envelope me-1"></i> @Model.Email</span>
                            </div>
                            <div class="text-end">
                                <label class="form-label fw-bold small text-uppercase d-block mb-1">Trạng thái mở khóa</label>
                                <div class="form-check form-switch fs-2">
                                    <input class="form-check-input cursor-pointer" type="checkbox" role="switch" asp-for="IsActive">
                                </div>
                            </div>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Họ và tên người dùng <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                                    <input asp-for="FullName" class="form-control input-with-icon" required />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Chức danh / Vị trí</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-briefcase"></i></span>
                                    <input asp-for="Position" class="form-control input-with-icon" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Số điện thoại liên hệ</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                    <input asp-for="Phone" class="form-control input-with-icon num-only" maxlength="10" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Số Zalo CSKH</label>
                                <div class="input-group">
                                    <span class="input-group-text text-info"><i class="bi bi-chat-dots"></i></span>
                                    <input asp-for="Zalo" class="form-control input-with-icon num-only" maxlength="10" />
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-danger">Nhóm quyền hạn (Role)</label>
                                <select asp-for="RoleID" asp-items="ViewBag.RolesList" class="form-select border-danger-subtle fw-bold"></select>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small">Địa chỉ thường trú / Công tác</label>
                                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small text-danger">Ghi chú quản trị nội bộ</label>
                                <textarea asp-for="AdminNote" class="form-control note-box" rows="2" placeholder="Ghi chú phân công dự án..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- KYC DOANH NGHIỆP -->
                <div class="card card-custom mb-4 @(hasBusiness ? "biz-card" : "bg-light")">
                    <div class="card-body p-4">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input fs-4" type="checkbox" id="checkIsBusiness" name="IsBusiness" @(hasBusiness ? "checked" : "")>
                            <label class="form-check-label fw-bold ms-2 mt-1" for="checkIsBusiness">Kích hoạt Đặc quyền Doanh nghiệp / CĐT</label>
                        </div>
                        <div id="businessFields" style="@(hasBusiness ? "display: block;" : "display: none;")">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label small fw-bold">Tên Doanh nghiệp / Sàn Giao Dịch</label>
                                    <input type="text" name="BusinessName" class="form-control" value="@(hasBusiness? bizProfile.BusinessName: "")" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Mã số thuế</label>
                                    <input type="text" name="TaxCode" class="form-control font-monospace" value="@(hasBusiness? bizProfile.TaxCode: "")" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Email Doanh nghiệp (KYC)</label>
                                    <input type="email" name="BusinessEmail" class="form-control" value="@(hasBusiness? bizProfile.BusinessEmail: "")" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-end mb-5">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow fw-bold">Lưu tất cả thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#checkIsBusiness').change(function () {
                if ($(this).is(':checked')) {
                    $('#businessFields').slideDown();
                    $(this).closest('.card').addClass('biz-card').removeClass('bg-light');
                } else {
                    $('#businessFields').slideUp();
                    $(this).closest('.card').removeClass('biz-card').addClass('bg-light');
                }
            });

            $('.num-only').on('input', function() {
                this.value = this.value.replace(/[^0-9]/g, '');
            });

            // FIX LỖI GARBLED TEXT (SỬ DỤNG HTML RAW)
            @if (TempData["Success"] != null)
            {
                    <text>Swal.fire({ icon: 'success', title: 'Thành công', text: '@Html.Raw(TempData["Success"])', timer: 3000, toast: true, position: 'top-end', showConfirmButton: false });</text>
            }
            @if (TempData["Error"] != null)
            {
                    <text>Swal.fire({ icon: 'error', title: 'Lỗi dữ liệu', text: '@Html.Raw(TempData["Error"])' });</text>
            }
        });
    </script>
}