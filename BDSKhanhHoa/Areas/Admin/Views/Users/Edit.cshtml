@model BDSKhanhHoa.Models.User
@{
    ViewData["Title"] = "Cập nhật Hồ sơ";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="container py-4 animate__animated animate__fadeIn">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">

            <div class="card border-0 shadow-lg rounded-4 mb-4 overflow-hidden">
                <div class="card-header bg-warning py-3 border-bottom-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-pencil-square me-2"></i>CẬP NHẬT QUYỀN HẠN HỆ THỐNG</h5>
                        <a asp-action="Index" class="btn btn-sm btn-dark border-0 px-3 rounded-pill fw-bold shadow-sm">Trở lại</a>
                    </div>
                </div>
                <div class="card-body p-4 p-md-5 bg-light">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="UserID" />

                        <div class="text-center mb-5">
                            <img src="@(string.IsNullOrEmpty(Model.Avatar) ? "/images/avatars/default.png" : Model.Avatar)"
                                 class="rounded-circle border border-4 border-white shadow-sm mb-3" width="110" height="110" style="object-fit: cover;">
                            <h4 class="fw-bold text-dark mb-1">@(Model.FullName ?? Model.Username)</h4>
                            <span class="badge bg-secondary mb-2 fs-6 shadow-sm">@@@Model.Username</span>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Email hệ thống (Khóa cố định)</label>
                                <div class="input-group shadow-sm rounded-3">
                                    <span class="input-group-text bg-white border-0 text-muted"><i class="bi bi-envelope-lock"></i></span>
                                    <input type="text" class="form-control bg-white border-0 text-muted fw-bold" value="@Model.Email" readonly disabled />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-dark text-uppercase">Họ và tên</label>
                                <input asp-for="FullName" class="form-control border-0 shadow-sm py-2" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-dark text-uppercase">Số điện thoại</label>
                                <input asp-for="Phone" class="form-control border-0 shadow-sm py-2" />
                            </div>

                            <div class="col-12"><hr class="my-3 opacity-10"></div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-danger text-uppercase">Phân Quyền (Roles)</label>
                                <select asp-for="RoleID" asp-items="ViewBag.RolesList" class="form-select border-danger shadow-sm py-2 fw-bold text-danger"></select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-success text-uppercase">Khóa / Mở Khóa Tài Khoản</label>
                                <div class="p-2 border rounded-3 bg-white shadow-sm d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-dark small ms-2">Cho phép hoạt động</span>
                                    <div class="form-check form-switch fs-4 mb-0 me-2">
                                        <input class="form-check-input cursor-pointer" type="checkbox" role="switch" asp-for="IsActive">
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Địa chỉ / Khu vực</label>
                                <textarea asp-for="Address" class="form-control border-0 shadow-sm" rows="2"></textarea>
                            </div>
                        </div>

                        <div class="mt-5 pt-4 border-top d-flex justify-content-end gap-3">
                            <button type="submit" class="btn btn-warning text-dark px-5 py-2 fw-bold rounded-pill shadow-sm w-100">
                                <i class="bi bi-save-fill me-2"></i> LƯU THAY ĐỔI
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-danger shadow-sm rounded-4 mt-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="fw-bold text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>RE-SET MẬT KHẨU TÀI KHOẢN</h5>
                    <p class="text-muted small mb-0">Chỉ dùng khi người dùng nhờ Admin can thiệp. Hành động này sẽ thay thế mật khẩu cũ và ghi Log.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.UserID" />
                        <div class="row align-items-center g-3">
                            <div class="col-md-8">
                                <div class="input-group shadow-sm rounded-3 overflow-hidden">
                                    <span class="input-group-text bg-white border-0"><i class="bi bi-key-fill text-danger"></i></span>
                                    <input type="password" name="newPassword" class="form-control border-0 py-2 bg-white" placeholder="Mật khẩu mới (tối thiểu 6 ký tự)" required minlength="6" />
                                </div>
                            </div>
                            <div class="col-md-4 text-end">
                                <button type="submit" class="btn btn-danger w-100 py-2 fw-bold rounded-3 shadow-sm" onclick="return confirm('CẢNH BÁO BẢO MẬT: \nBạn có chắc chắn muốn đặt lại mật khẩu của @Model.Username không?');">Đổi Mật Khẩu</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        @if (TempData["Success"] != null)
        {
            <text>Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: '@TempData["Success"]', showConfirmButton: false, timer: 3000 });</text>
        }
        @if (TempData["Error"] != null)
        {
            <text>Swal.fire({ toast: true, position: 'top-end', icon: 'error', title: '@TempData["Error"]', showConfirmButton: false, timer: 4000 });</text>
        }
    </script>
}