@model IEnumerable<BDSKhanhHoa.Models.User>
@{
    ViewData["Title"] = "Thùng rác thành viên";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <a asp-action="Index" class="btn btn-light shadow-sm rounded-pill px-4 fw-bold text-dark border">
                <i class="bi bi-arrow-left me-2"></i> Quay lại danh sách
            </a>
            <h4 class="fw-bold text-danger mt-3 mb-0"><i class="bi bi-trash3-fill me-2"></i>THÙNG RÁC HỆ THỐNG</h4>
            <p class="text-muted small">Các tài khoản dưới đây đã bị khóa và đánh dấu xóa. Bạn có thể khôi phục hoặc xóa vĩnh viễn.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-danger text-white">
                        <tr>
                            <th class="ps-4 py-3">Tài khoản vi phạm / Xóa</th>
                            <th>Email hệ thống</th>
                            <th>Ngày tham gia</th>
                            <th class="text-center pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="row-@item.UserID" class="bg-danger-subtle bg-opacity-10">
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(item.Avatar) ? "/images/avatars/default.png" : item.Avatar)"
                                             class="rounded-circle border border-danger shadow-sm me-3" width="45" height="45" style="object-fit: cover; filter: grayscale(100%);">
                                        <div>
                                            <div class="fw-bold text-dark text-decoration-line-through">@(item.FullName ?? item.Username)</div>
                                            <div class="small text-danger fw-bold">@@@item.Username</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted small">@item.Email</td>
                                <td class="text-muted small">@item.CreatedAt?.ToString("dd/MM/yyyy")</td>
                                <td class="text-center pe-4">
                                    <div class="btn-group shadow-sm rounded-pill overflow-hidden border border-danger">
                                        <button onclick="restore(@item.UserID)" class="btn btn-sm btn-light text-success fw-bold px-3 border-end" title="Khôi phục trạng thái hoạt động">
                                            <i class="bi bi-arrow-counterclockwise me-1"></i> Khôi phục
                                        </button>
                                        <button onclick="deleteForever(@item.UserID)" class="btn btn-sm btn-danger fw-bold px-3" title="Xóa dữ liệu khỏi Database">
                                            <i class="bi bi-x-octagon-fill me-1"></i> Xóa vĩnh viễn
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <i class="bi bi-emoji-smile display-1 text-success opacity-50 mb-3 d-block"></i>
                                    <h5 class="text-muted">Thùng rác trống!</h5>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function restore(id) {
            $.post('/Admin/Users/Restore/' + id, function(res) {
                if(res.success) {
                    Swal.fire({
                        icon: 'success', title: 'Thành công', text: 'Tài khoản đã được khôi phục!', timer: 1500, showConfirmButton: false
                    }).then(() => { $('#row-' + id).fadeOut(); location.reload(); });
                }
            });
        }
        function deleteForever(id) {
            Swal.fire({
                title: 'Xóa vĩnh viễn?',
                text: "CẢNH BÁO: Dữ liệu này sẽ bị xóa hoàn toàn khỏi cơ sở dữ liệu. Không thể hoàn tác!",
                icon: 'error',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Xóa Vĩnh Viễn',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Admin/Users/DeleteForever/' + id, function(res) {
                        if(res.success) {
                            $('#row-' + id).fadeOut(400, function() { $(this).remove(); });
                            Swal.fire('Đã xóa', 'Dữ liệu đã biến mất vĩnh viễn.', 'success');
                        }
                    });
                }
            });
        }
    </script>
}