@model BDSKhanhHoa.Models.ContactMessage
@{
    ViewData["Title"] = "Chi tiết Liên hệ";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1 text-dark">
                <i class="bi bi-envelope-open me-2 text-primary"></i>Chi tiết thư #@Model.ContactID
            </h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a href="/Admin/Dashboard" class="text-decoration-none">Bảng điều khiển</a></li>
                    <li class="breadcrumb-item"><a href="/Admin/Contact" class="text-decoration-none">Hộp thư</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Chi tiết</li>
                </ol>
            </nav>
        </div>
        <a href="/Admin/Contact" class="btn btn-light border rounded-pill fw-bold shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 d-flex align-items-center" role="alert">
            <i class="bi bi-check-circle-fill fs-5 me-2"></i> @TempData["SuccessMsg"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- CỘT TRÁI: NỘI DUNG THƯ -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom p-4">
                    <h5 class="fw-bold text-dark mb-1">@Html.Raw(string.IsNullOrEmpty(Model.Subject) ? "<em class='text-muted'>Không có chủ đề</em>" : Model.Subject)</h5>
                    <div class="text-muted small"><i class="bi bi-clock me-1"></i> Gửi lúc: @Model.CreatedAt.ToString("dd/MM/yyyy - HH:mm:ss")</div>
                </div>
                <div class="card-body p-4 p-md-5">
                    <div class="bg-light p-4 rounded-4 border" style="min-height: 250px; font-size: 1.05rem; line-height: 1.6; color: #334155; white-space: pre-wrap;">@Model.Message</div>
                </div>
            </div>
        </div>

        <!-- CỘT PHẢI: THÔNG TIN NGƯỜI GỬI & XỬ LÝ -->
        <div class="col-lg-4">
            <!-- Box Người gửi -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom p-3">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-person-badge text-primary me-2"></i>Thông tin liên hệ</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <small class="text-muted fw-bold d-block text-uppercase mb-1">Họ tên khách hàng</small>
                        <div class="fs-6 fw-bold text-dark">@Model.FullName</div>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted fw-bold d-block text-uppercase mb-1">Số điện thoại</small>
                        @if (!string.IsNullOrEmpty(Model.Phone))
                        {
                            <a href="tel:@Model.Phone" class="fw-bold text-decoration-none fs-6">@Model.Phone</a>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Không cung cấp</span>
                        }
                    </div>
                    <div class="mb-3">
                        <small class="text-muted fw-bold d-block text-uppercase mb-1">Email phản hồi</small>
                        @if (!string.IsNullOrEmpty(Model.Email))
                        {
                            <a href="mailto:@Model.Email" class="fw-bold text-decoration-none fs-6 text-break">@Model.Email</a>
                            <a href="mailto:@Model.Email?subject=Phản hồi từ BDSKhanhHoa&body=Chào bạn @Model.FullName," class="btn btn-sm btn-outline-primary w-100 rounded-pill mt-2 fw-bold">
                                <i class="bi bi-reply-fill"></i> Trả lời qua Email
                            </a>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Không cung cấp</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Box Xử lý trạng thái -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom p-3">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-gear-fill text-warning me-2"></i>Trạng thái xử lý</h6>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <span class="fw-bold text-muted">Hiện tại:</span>
                        @if (Model.Status == "Chưa xử lý")
                        {
                            <span class="badge bg-danger rounded-pill px-3 py-2 fs-6">Chưa xử lý</span>
                        }
                        else if (Model.Status == "Đang xử lý")
                        {
                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2 fs-6">Đang xử lý</span>
                        }
                        else
                        {
                            <span class="badge bg-success rounded-pill px-3 py-2 fs-6">Đã xử lý xong</span>
                        }
                    </div>

                    <form action="/Admin/Contact/UpdateStatus" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.ContactID" />
                        <label class="form-label fw-bold small text-muted">Cập nhật sang trạng thái mới:</label>
                        <select name="status" class="form-select rounded-3 mb-3 fw-bold border-2">
                            <option value="Chưa xử lý" selected="@(Model.Status == "Chưa xử lý")">Chưa xử lý</option>
                            <option value="Đang xử lý" selected="@(Model.Status == "Đang xử lý")">Đang xử lý (Đang liên hệ)</option>
                            <option value="Đã xử lý" selected="@(Model.Status == "Đã xử lý")">Đã xử lý xong</option>
                        </select>
                        <button class="btn btn-primary w-100 rounded-pill fw-bold shadow-sm" type="submit">
                            <i class="bi bi-save2 me-1"></i> Lưu thay đổi
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>