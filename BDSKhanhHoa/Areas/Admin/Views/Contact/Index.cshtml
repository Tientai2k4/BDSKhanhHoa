@model IEnumerable<BDSKhanhHoa.Models.ContactMessage>
@{
    ViewData["Title"] = "Quản lý Liên Hệ";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    string keyword = ViewBag.Keyword as string ?? "";
    string status = ViewBag.Status as string ?? "";
}

<div class="container-fluid px-4 py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1 text-dark"><i class="bi bi-envelope-paper-fill text-primary me-2"></i>Hộp thư Khách hàng</h3>
            <div class="text-muted small">Quản lý các lời nhắn, góp ý từ khách vãng lai trên website.</div>
        </div>
    </div>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 d-flex align-items-center" role="alert">
            <i class="bi bi-check-circle-fill fs-5 me-2"></i> @TempData["SuccessMsg"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- BỘ LỌC TÌM KIẾM -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3 p-md-4">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-muted">Trạng thái</label>
                    <select name="status" class="form-select rounded-3 fw-medium">
                        <option value="">-- Tất cả trạng thái --</option>
                        <option value="Chưa xử lý" selected="@(status == "Chưa xử lý")">Chưa xử lý</option>
                        <option value="Đang xử lý" selected="@(status == "Đang xử lý")">Đang xử lý</option>
                        <option value="Đã xử lý" selected="@(status == "Đã xử lý")">Đã xử lý</option>
                    </select>
                </div>
                <div class="col-md-7">
                    <label class="form-label fw-bold small text-muted">Từ khóa tìm kiếm</label>
                    <input type="text" name="keyword" value="@keyword" class="form-control rounded-3" placeholder="Tên khách, SĐT, Email, tiêu đề..." />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary rounded-3 w-100 fw-bold"><i class="bi bi-search me-1"></i> Lọc dữ liệu</button>
                </div>
            </form>
        </div>
    </div>

    <!-- BẢNG DỮ LIỆU -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase text-secondary small fw-bold">Người gửi</th>
                            <th class="py-3 text-uppercase text-secondary small fw-bold">Nội dung tóm tắt</th>
                            <th class="py-3 text-uppercase text-secondary small fw-bold">Thời gian</th>
                            <th class="py-3 text-uppercase text-secondary small fw-bold text-center">Trạng thái</th>
                            <th class="pe-4 py-3 text-uppercase text-secondary small fw-bold text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark fs-6">@item.FullName</div>
                                        <div class="text-muted small"><i class="bi bi-telephone text-primary"></i> @(string.IsNullOrEmpty(item.Phone) ? "N/A" : item.Phone)</div>
                                    </td>
                                    <td style="max-width: 300px;">
                                        <div class="fw-bold text-dark text-truncate">@(string.IsNullOrEmpty(item.Subject) ? "Không có chủ đề" : item.Subject)</div>
                                        <div class="text-muted small text-truncate">@item.Message</div>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark">@item.CreatedAt.ToString("dd/MM/yyyy")</div>
                                        <div class="small text-muted">@item.CreatedAt.ToString("HH:mm")</div>
                                    </td>
                                    <td class="text-center">
                                        @if (item.Status == "Chưa xử lý")
                                        {
                                            <span class="badge bg-danger rounded-pill px-3 py-2">Chưa xử lý</span>
                                        }
                                        else if (item.Status == "Đang xử lý")
                                        {

                                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2">Đang xử lý</span>
                                        }
                                        else
                                        {

                                            <span class="badge bg-success rounded-pill px-3 py-2">Đã xử lý</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <a href="/Admin/Contact/Details/@item.ContactID" class="btn btn-sm btn-light border rounded-circle shadow-sm me-1" title="Xem chi tiết">
                                            <i class="bi bi-eye text-primary"></i>
                                        </a>
                                        <form action="/Admin/Contact/Delete" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.ContactID" />
                                            <button type="submit" class="btn btn-sm btn-light border rounded-circle shadow-sm" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa thư liên hệ này?');">
                                                <i class="bi bi-trash text-danger"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center py-5 text-muted">Không tìm thấy thư liên hệ nào phù hợp.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>