@model IEnumerable<BDSKhanhHoa.Models.Property>
@{
    ViewData["Title"] = "Quản lý & Kiểm duyệt Tin đăng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .admin-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        background: #fff;
    }

    .status-badge {
        font-weight: 600;
        padding: 0.4em 0.8em;
        border-radius: 8px;
    }

    .row-highlight-dup {
        background-color: #fff5f5 !important;
        border-left: 4px solid #ef4444;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s;
    }

        .action-btn:hover {
            transform: translateY(-2px);
        }

    .filter-tabs .btn {
        border-radius: 10px;
        font-weight: 600;
        padding: 0.5rem 1.2rem;
        margin-right: 0.5rem;
        border: 1px solid #e2e8f0;
        color: #64748b;
    }

        .filter-tabs .btn.active {
            background-color: #1e293b;
            color: #fff;
            border-color: #1e293b;
        }

        .filter-tabs .btn:hover:not(.active) {
            background-color: #f8fafc;
        }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="bi bi-shield-check text-primary me-2"></i>Hệ thống Kiểm duyệt 2026</h3>
            <p class="text-muted small mb-0">Quản lý tin đăng, duyệt tự động VIP và phát hiện trùng lặp.</p>
        </div>
        <div class="d-flex gap-2">
            <form action="/Admin/Properties/RunAutoApprove" method="post" class="d-inline">
                <button type="submit" class="btn btn-outline-primary fw-bold rounded-pill shadow-sm" title="Tự động duyệt các tin VIP Kim Cương hợp lệ">
                    <i class="bi bi-robot me-1"></i> Duyệt tự động VIP
                </button>
            </form>
            <a href="/Admin/Properties/ExportReport" class="btn btn-success fw-bold rounded-pill shadow-sm">
                <i class="bi bi-file-earmark-excel me-1"></i> Xuất Báo cáo
            </a>
        </div>
    </div>

    <div class="filter-tabs mb-4 overflow-auto white-space-nowrap pb-2">
        <a href="/Admin/Properties/Index" class="btn @(string.IsNullOrEmpty(ViewBag.CurrentStatus) ? "active shadow-sm" : "")">
            <i class="bi bi-grid-fill me-1"></i> Tất cả
        </a>
        <a href="/Admin/Properties/Index?status=Pending" class="btn @(ViewBag.CurrentStatus == "Pending" ? "active shadow-sm" : "")">
            <i class="bi bi-hourglass-split me-1"></i> Chờ duyệt
            @if (ViewBag.PendingCount > 0)
            {
                <span class="badge bg-danger ms-1 rounded-pill">@ViewBag.PendingCount</span>
            }
        </a>
        <a href="/Admin/Properties/Index?status=Approved" class="btn @(ViewBag.CurrentStatus == "Approved" ? "active shadow-sm" : "")">
            <i class="bi bi-check-circle-fill text-success me-1"></i> Đã duyệt
        </a>
        <a href="/Admin/Properties/Index?status=Rejected" class="btn @(ViewBag.CurrentStatus == "Rejected" ? "active shadow-sm" : "")">
            <i class="bi bi-x-circle-fill text-danger me-1"></i> Bị từ chối
        </a>
    </div>

    <div class="admin-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-secondary text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.5px;">Bất động sản</th>
                        <th class="py-3 text-secondary text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.5px;">Người đăng</th>
                        <th class="py-3 text-secondary text-uppercase text-center" style="font-size: 0.8rem; letter-spacing: 0.5px;">Gói / Trạng thái</th>
                        <th class="text-end pe-4 py-3 text-secondary text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.5px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <img src="/images/empty-state.svg" width="120" class="opacity-50 mb-3" alt="Empty" onerror="this.style.display='none';">
                                <h5 class="text-muted fw-bold">Không có dữ liệu</h5>
                                <p class="text-muted small">Chưa có tin đăng nào ở trạng thái này.</p>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        // Tô sáng dòng nếu là tin trùng lặp đang chờ duyệt
                        string rowClass = (item.Status == "Pending" && item.IsDuplicate) ? "row-highlight-dup" : "";

                        <tr class="@rowClass">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="position-relative">
                                        <img src="@(string.IsNullOrEmpty(item.MainImage) ? "/images/no-image.jpg" : item.MainImage)" class="rounded-3 object-fit-cover shadow-sm" width="100" height="75" onerror="this.src='/images/no-image.jpg'" />
                                        @if (item.IsAutoApproved)
                                        {
                                            <span class="position-absolute top-0 start-0 translate-middle p-1 bg-primary border border-light rounded-circle" title="Duyệt tự động">
                                                <i class="bi bi-robot text-white" style="font-size: 0.7rem;"></i>
                                            </span>
                                        }
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark mb-1" style="max-width: 300px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;" title="@item.Title">
                                            @item.Title
                                        </div>
                                        <div class="small text-muted mb-1"><i class="bi bi-geo-alt text-danger me-1"></i>@item.Ward?.Area?.AreaName</div>
                                        <div class="fw-bold text-danger" style="font-size: 0.95rem;">
                                            @(item.Price.HasValue ? (item.Price >= 1000000000 ? (item.Price / 1000000000)?.ToString("0.##") + " Tỷ" : (item.Price / 1000000)?.ToString("0.##") + " Tr") : "Thỏa thuận")
                                            <span class="text-muted fw-normal fs-6 ms-1">• @item.PropertyType?.TypeName</span>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                <div class="fw-bold text-dark mb-1">@item.User?.FullName</div>
                                <div class="small text-muted"><i class="bi bi-telephone me-1"></i>@item.User?.Phone</div>
                                <div class="small text-muted mt-1"><i class="bi bi-calendar-plus me-1"></i>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            </td>
                            <td class="py-3 text-center">
                                <div class="mb-2">
                                    @if (item.PostServicePackage?.PriorityLevel > 1)
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-star-fill me-1"></i>@item.PostServicePackage.PackageName</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-secondary border">Tin thường</span>
                                    }
                                </div>

                                @if (item.Status == "Approved")
                                {
                                    <span class="status-badge bg-success bg-opacity-10 text-success border border-success"><i class="bi bi-check2-all me-1"></i> Đã duyệt</span>
                                }
                                else if (item.Status == "Pending")
                                {
                                    if (item.IsDuplicate)
                                    {
                                        <span class="status-badge bg-danger bg-opacity-10 text-danger border border-danger mb-1 d-inline-block" title="@item.DuplicateReason"><i class="bi bi-exclamation-triangle-fill me-1"></i> Trùng lặp</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge bg-warning bg-opacity-10 text-warning border border-warning"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt</span>
                                    }
                                }
                                else if (item.Status == "Rejected")
                                {
                                    <span class="status-badge bg-secondary bg-opacity-10 text-secondary border border-secondary mb-1 d-inline-block"><i class="bi bi-slash-circle me-1"></i> Bị từ chối</span>
                                    <div class="small text-danger text-truncate mx-auto" style="max-width: 150px;" title="@item.RejectionReason">@item.RejectionReason</div>
                                }
                            </td>
                            <td class="text-end pe-4 py-3">
                                <div class="d-flex justify-content-end gap-2">

                                    <a href="/Property/Details/@item.PropertyID" target="_blank" class="action-btn bg-info bg-opacity-10 text-info border border-info" title="Xem chi tiết (Tab mới)">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    @if (item.Status == "Pending" || item.Status == "Rejected")
                                    {
                                        <form action="/Admin/Properties/UpdateStatus" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.PropertyID" />
                                            <button type="submit" name="newStatus" value="Approved" class="action-btn bg-success bg-opacity-10 text-success border border-success" title="Duyệt hiển thị">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }

                                    @if (item.Status == "Pending" || item.Status == "Approved")
                                    {
                                        <button type="button" class="action-btn bg-danger bg-opacity-10 text-danger border border-danger" onclick="openRejectModal(@item.PropertyID, '@Html.Raw(item.Title.Replace("'", "\\'"))')" title="Từ chối / Cấm">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    }

                                    <button type="button" class="action-btn bg-light text-secondary border" onclick="confirmDelete(@item.PropertyID)" title="Xóa bỏ">
                                        <i class="bi bi-trash3"></i>
                                    </button>

                                    <form id="deleteForm-@item.PropertyID" action="/Admin/Properties/Delete" method="post" class="d-none">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.PropertyID" />
                                    </form>

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-danger text-white border-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-shield-x me-2"></i>Từ Chối Tin Đăng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form action="/Admin/Properties/UpdateStatus" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" name="id" id="rejectPropertyId" />
                    <input type="hidden" name="newStatus" value="Rejected" />

                    <div class="alert alert-warning bg-opacity-10 border-warning border-opacity-25 small mb-3">
                        <i class="bi bi-info-circle-fill me-1 text-warning"></i>
                        Hệ thống sẽ <strong>tự động hoàn trả lượt đăng</strong> nếu đây là lần đầu tin bị từ chối. Nếu người dùng sửa lại tin đã bị từ chối trước đó, lượt đăng sẽ không được hoàn lại lần 2.
                    </div>

                    <p class="text-dark mb-2">Tin cần xử lý:</p>
                    <p id="rejectPropertyTitle" class="fw-bold text-primary px-3 py-2 bg-light rounded-3 border"></p>

                    <div class="mb-3 mt-4">
                        <label class="form-label fw-bold text-secondary">Lý do từ chối (Gửi cho người đăng) <span class="text-danger">*</span></label>
                        <textarea class="form-control" name="reason" rows="3" placeholder="Ví dụ: Hình ảnh không hợp lệ, thông tin liên hệ trong mô tả, sai chuyên mục..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0 bg-light">
                    <button type="button" class="btn btn-white border fw-bold rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger fw-bold rounded-pill px-4 shadow-sm">Xác nhận Từ chối</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function openRejectModal(id, title) {
            document.getElementById('rejectPropertyId').value = id;
            document.getElementById('rejectPropertyTitle').innerText = title;
            new bootstrap.Modal(document.getElementById('rejectModal')).show();
        }

        function confirmDelete(id) {
            Swal.fire({
                title: 'Xóa tin đăng?',
                text: "Dữ liệu sẽ được chuyển vào thùng rác.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Hủy bỏ',
                customClass: {
                    confirmButton: 'rounded-pill px-4',
                    cancelButton: 'rounded-pill px-4'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteForm-' + id).submit();
                }
            })
        }

        @if (TempData["Success"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'success', title: 'Thành công',
                    text: '@Html.Raw(TempData["Success"])', timer: 3000, showConfirmButton: false,
                    toast: true, position: 'top-end'
                });
                </text>
        }
        @if (TempData["Error"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'error', title: 'Thất bại',
                    text: '@Html.Raw(TempData["Error"])', timer: 4000, showConfirmButton: false,
                    toast: true, position: 'top-end'
                });
                </text>
        }
    </script>
}