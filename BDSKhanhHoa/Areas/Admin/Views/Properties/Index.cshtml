@model IEnumerable<BDSKhanhHoa.Models.Property>
@{
    ViewData["Title"] = "Quản lý & Duyệt Tin Đăng";
    // Tạm thời dùng Layout mặc định nếu bạn chưa có Layout riêng cho Admin
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4 bg-light min-vh-100">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark"><i class="bi bi-kanban text-primary me-2"></i> Hệ Thống Kiểm Duyệt Tin</h3>

        <div class="btn-group shadow-sm">
            <a href="/Admin/Properties/Index" class="btn @(string.IsNullOrEmpty(ViewBag.CurrentStatus) ? "btn-primary" : "btn-white border") fw-medium">Tất cả</a>
            <a href="/Admin/Properties/Index?status=Pending" class="btn @(ViewBag.CurrentStatus == "Pending" ? "btn-warning text-dark" : "btn-white border") fw-medium">Chờ duyệt</a>
            <a href="/Admin/Properties/Index?status=Approved" class="btn @(ViewBag.CurrentStatus == "Approved" ? "btn-success" : "btn-white border") fw-medium">Đã duyệt</a>
            <a href="/Admin/Properties/Index?status=Rejected" class="btn @(ViewBag.CurrentStatus == "Rejected" ? "btn-danger" : "btn-white border") fw-medium">Bị từ chối</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Tin đăng</th>
                        <th>Người đăng</th>
                        <th>Ngày đăng</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác duyệt</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                Không có tin đăng nào.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@(string.IsNullOrEmpty(item.MainImage) ? "/images/no-image.jpg" : item.MainImage)" class="rounded-3 object-fit-cover" width="60" height="60" />
                                    <div>
                                        <a href="/Property/Details/@item.PropertyID" target="_blank" class="fw-bold text-dark text-decoration-none d-block text-truncate" style="max-width: 250px;">@item.Title</a>
                                        <span class="text-danger fw-bold small">@(item.Price.HasValue ? (item.Price >= 1000000000 ? (item.Price / 1000000000)?.ToString("0.##") + " Tỷ" : (item.Price / 1000000)?.ToString("0.##") + " Tr") : "Thỏa thuận")</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="d-block fw-medium text-dark">@item.User?.FullName</span>
                                <span class="small text-muted">@item.User?.Phone</span>
                            </td>
                            <td>
                                <span class="d-block text-dark">@item.CreatedAt.ToString("dd/MM/yyyy")</span>
                                <span class="small text-muted">@item.CreatedAt.ToString("HH:mm")</span>
                            </td>
                            <td>
                                @if (item.Status == "Approved")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2">Đã duyệt</span>
                                }
                                else if (item.Status == "Pending")
                                {

                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-3 py-2">Chờ duyệt</span>
                                }
                                else if (item.Status == "Rejected")
                                {

                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3 py-2">Từ chối</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <form action="/Admin/Properties/UpdateStatus" method="post" class="d-inline-block">
                                    <input type="hidden" name="id" value="@item.PropertyID" />
                                    @if (item.Status == "Pending" || item.Status == "Rejected")
                                    {
                                        <button type="submit" name="newStatus" value="Approved" class="btn btn-sm btn-success fw-bold rounded-3 me-1" title="Duyệt tin">
                                            <i class="bi bi-check-lg"></i> Duyệt
                                        </button>
                                    }
                                    @if (item.Status == "Pending" || item.Status == "Approved")
                                    {
                                        <button type="submit" name="newStatus" value="Rejected" class="btn btn-sm btn-danger fw-bold rounded-3 me-1" title="Từ chối">
                                            <i class="bi bi-x-lg"></i> Cấm
                                        </button>
                                    }
                                </form>

                                <form action="/Admin/Properties/Delete" method="post" class="d-inline-block" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tin này không?');">
                                    <input type="hidden" name="id" value="@item.PropertyID" />
                                    <button type="submit" class="btn btn-sm btn-light border text-danger fw-bold rounded-3" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>