@model BDSKhanhHoa.Models.Banner
@{
    ViewData["Title"] = "Chỉnh sửa Banner";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-3">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-info py-3">
                    <h5 class="mb-0 text-white fw-bold"><i class="bi bi-pencil-square me-2"></i>CẬP NHẬT BANNER</h5>
                </div>
                <div class="card-body p-4 bg-light">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="BannerID" />
                        <input type="hidden" asp-for="ImageURL" />
                        <input type="hidden" asp-for="CreatedAt" />

                        <div class="row g-4">
                            <div class="col-lg-7">
                                <div class="bg-white p-4 rounded-4 shadow-sm h-100">
                                    <h6 class="fw-bold mb-3 border-bottom pb-2">HÌNH ẢNH BANNER</h6>

                                    <div class="mb-3 text-center">
                                        <label class="form-label text-muted small fw-bold text-start w-100">ẢNH HIỆN TẠI</label>
                                        <div id="previewContainer">
                                            <img id="imagePreview" src="@Model.ImageURL" class="w-100 rounded-4 shadow-sm border mb-3" style="max-height: 300px; object-fit: cover;">
                                        </div>

                                        <label class="form-label text-muted small fw-bold text-start w-100 mt-2">THAY ĐỔI ẢNH (BỎ TRỐNG NẾU GIỮ NGUYÊN)</label>
                                        <div class="drop-zone border-2 border-dashed rounded-4 p-4 text-center bg-light" id="dropZone" onclick="document.getElementById('imageInput').click()">
                                            <i class="bi bi-cloud-arrow-up fs-2 text-secondary"></i>
                                            <p class="mt-2 text-muted mb-0 small">Nhấn để tải lên ảnh mới thay thế</p>
                                            <input type="file" name="imageFile" id="imageInput" class="d-none" accept="image/*" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-5">
                                <div class="bg-white p-4 rounded-4 shadow-sm h-100 d-flex flex-column">
                                    <h6 class="fw-bold mb-3 border-bottom pb-2">THÔNG TIN PHỤ</h6>

                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">TIÊU ĐỀ CHÍNH</label>
                                        <input asp-for="Title" class="form-control rounded-3" />
                                    </div>


                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">LINK LIÊN KẾT</label>
                                        <input asp-for="LinkURL" class="form-control rounded-3" />
                                    </div>

                                    <div class="row mb-auto">
                                        <div class="col-6">
                                            <label class="form-label small fw-bold">THỨ TỰ</label>
                                            <input asp-for="DisplayOrder" class="form-control rounded-3" type="number" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label small fw-bold">TRẠNG THÁI</label>
                                            <div class="form-check form-switch pt-1 mt-1">
                                                <input class="form-check-input fs-5" type="checkbox" asp-for="IsActive">
                                                <label class="form-check-label ms-2 mt-1" for="IsActive">Hiển thị</label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                                        <a asp-action="Index" class="btn btn-light rounded-pill px-4 border">Hủy bỏ</a>
                                        <button type="submit" class="btn btn-info text-white rounded-pill px-4 shadow-sm"><i class="bi bi-save me-1"></i> CẬP NHẬT</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-dashed {
        border-style: dashed !important;
    }

    .drop-zone {
        cursor: pointer;
        transition: 0.3s;
    }

        .drop-zone:hover {
            background-color: #e9ecef !important;
            border-color: #0dcaf0 !important;
        }
</style>

@section Scripts {
    <script>
        document.getElementById('imageInput').onchange = function () {
            const [file] = this.files;
            if (file) {
                document.getElementById('imagePreview').src = URL.createObjectURL(file);
            }
        };
    </script>
}