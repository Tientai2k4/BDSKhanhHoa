@model BDSKhanhHoa.Models.Banner
@{
    ViewData["Title"] = "Chỉnh sửa Banner";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="fw-bold mb-0 text-info">CẬP NHẬT BANNER</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="BannerID" />
                        <input type="hidden" asp-for="ImageURL" />
                        <input type="hidden" asp-for="CreatedAt" />

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="Title" class="form-label fw-semibold">Tiêu đề chính</label>
                                <input asp-for="Title" class="form-control" />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="SubTitle" class="form-label fw-semibold">Mô tả phụ</label>
                                <textarea asp-for="SubTitle" class="form-control" rows="2"></textarea>
                            </div>

                            <div class="col-md-8">
                                <label asp-for="LinkURL" class="form-label fw-semibold">Đường dẫn</label>
                                <input asp-for="LinkURL" class="form-control" />
                            </div>

                            <div class="col-md-4">
                                <label asp-for="DisplayOrder" class="form-label fw-semibold">Thứ tự</label>
                                <input asp-for="DisplayOrder" type="number" class="form-control" />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-semibold d-block">Hình ảnh hiện tại</label>
                                <div class="mb-3">
                                    <img src="@Model.ImageURL" class="rounded border shadow-sm" style="max-height: 150px;" id="currentImage" />
                                </div>
                                <label class="form-label fw-semibold">Thay đổi ảnh (Bỏ trống nếu giữ nguyên)</label>
                                <input type="file" name="imageFile" id="imageInput" class="form-control" accept="image/*" />
                            </div>

                            <div class="col-md-12">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="IsActive">
                                    <label class="form-check-label fw-semibold" asp-for="IsActive">Kích hoạt hiển thị</label>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 pt-3 border-top d-flex gap-2">
                            <button type="submit" class="btn btn-info text-white px-4">
                                <i class="bi bi-save me-2"></i>Cập nhật
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4 border">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('imageInput').onchange = function (evt) {
            const [file] = this.files;
            if (file) {
                document.getElementById('currentImage').src = URL.createObjectURL(file);
            }
        };
    </script>
}