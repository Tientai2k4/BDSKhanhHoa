@model BDSKhanhHoa.Models.Banner
@{
    ViewData["Title"] = "Thêm Banner";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary py-3">
                    <h5 class="mb-0 text-white fw-bold"><i class="bi bi-cloud-arrow-up me-2"></i>THÊM BANNER SLIDER MỚI</h5>
                </div>
                <div class="card-body p-4 bg-light">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div class="row">
                            <div class="col-md-7">
                                <div class="bg-white p-4 rounded-4 shadow-sm h-100">
                                    <h6 class="fw-bold mb-3 border-bottom pb-2">HÌNH ẢNH BANNER</h6>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small fw-bold">CHỌN FILE ẢNH (BẮT BUỘC)</label>
                                        <div class="drop-zone border-2 border-dashed rounded-4 p-5 text-center bg-light" id="dropZone">
                                            <i class="bi bi-image display-4 text-secondary"></i>
                                            <p class="mt-2 text-muted">Nhấn vào đây để chọn ảnh hoặc kéo thả file</p>
                                            <input type="file" name="imageFile" id="imageInput" class="d-none" accept="image/*" required />
                                            <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('imageInput').click()">Chọn File</button>
                                        </div>
                                        <div id="previewContainer" class="mt-3 d-none">
                                            <img id="imagePreview" src="#" class="w-100 rounded-4 shadow-sm border" style="max-height: 350px; object-fit: cover;">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <div class="bg-white p-4 rounded-4 shadow-sm h-100">
                                    <h6 class="fw-bold mb-3 border-bottom pb-2">THÔNG TIN PHỤ (TÙY CHỌN)</h6>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">TIÊU ĐỀ CHÍNH</label>
                                        <input asp-for="Title" class="form-control rounded-3" placeholder="Ví dụ: Đất nền giá rẻ Diên Khánh" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">MÔ TẢ NGẮN</label>
                                        <textarea asp-for="SubTitle" class="form-control rounded-3" rows="2" placeholder="Nội dung mô tả ngắn trên banner..."></textarea>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">LINK LIÊN KẾT</label>
                                        <input asp-for="LinkURL" class="form-control rounded-3" placeholder="https://..." />
                                    </div>
                                    <div class="row">
                                        <div class="col-6">
                                            <label class="form-label small fw-bold">THỨ TỰ</label>
                                            <input asp-for="DisplayOrder" class="form-control rounded-3" type="number" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label small fw-bold">TRẠNG THÁI</label>
                                            <div class="form-check form-switch pt-1">
                                                <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                                                <label class="form-check-label" for="IsActive">Hiển thị</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mt-5 text-end pt-4 border-top">
                                        <a asp-action="Index" class="btn btn-light rounded-pill px-4 me-2 border">Hủy</a>
                                        <button type="submit" class="btn btn-primary rounded-pill px-5 shadow">LƯU BANNER</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .drop-zone {
        cursor: pointer;
        transition: 0.3s;
    }

        .drop-zone:hover {
            background-color: #e9ecef !important;
            border-color: #0d6efd !important;
        }
</style>

@section Scripts {
    <script>
        const imageInput = document.getElementById('imageInput');
        const imagePreview = document.getElementById('imagePreview');
        const previewContainer = document.getElementById('previewContainer');
        const dropZone = document.getElementById('dropZone');

        imageInput.onchange = function (evt) {
            const [file] = imageInput.files;
            if (file) {
                previewContainer.classList.remove('d-none');
                dropZone.classList.add('d-none');
                imagePreview.src = URL.createObjectURL(file);
            }
        };
    </script>
}