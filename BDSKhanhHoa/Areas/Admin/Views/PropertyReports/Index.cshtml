@model IEnumerable<BDSKhanhHoa.Models.PropertyReport>
@{
    ViewData["Title"] = "Quản lý Báo cáo vi phạm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h4 class="fw-bold mb-0 text-dark"><i class="bi bi-flag-fill me-2 text-danger"></i>QUẢN LÝ BÁO CÁO VI PHẠM</h4>
    </div>

    <div class="card border-0 shadow-sm mb-4 rounded-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-lg-6 col-md-12">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewBag.SearchString"
                               class="form-control border-start-0" placeholder="Tìm kiếm theo lý do hoặc tiêu đề tin...">
                    </div>
                </div>
                <div class="col-lg-4 col-md-8">
                    <select name="status" class="form-select">
                        <option value="All" selected="@(ViewBag.CurrentStatus == "All" ? "selected" : null)">-- Tất cả báo cáo --</option>
                        <option value="Pending" selected="@(ViewBag.CurrentStatus == "Pending" ? "selected" : null)">Chờ xử lý (Mới)</option>
                        <option value="Processed" selected="@(ViewBag.CurrentStatus == "Processed" ? "selected" : null)">Đã xử lý (Duyệt)</option>
                        <option value="Rejected" selected="@(ViewBag.CurrentStatus == "Rejected" ? "selected" : null)">Đã từ chối (Báo cáo sai)</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-4">
                    <button type="submit" class="btn btn-dark w-100 fw-bold"><i class="bi bi-funnel me-1"></i> Lọc</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden rounded-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase">
                    <tr>
                        <th class="ps-4 py-3 text-muted small">Người báo cáo</th>
                        <th class="text-muted small">Tin bị báo cáo</th>
                        <th class="text-muted small">Lý do chính</th>
                        <th class="text-muted small">Ngày gửi</th>
                        <th class="text-muted small">Trạng thái</th>
                        <th class="text-center pe-4 text-muted small">Xử lý</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="fw-bold">@(item.User?.FullName ?? "Ẩn danh")</div>
                                <div class="small text-muted">ID: #@item.ReportedBy</div>
                            </td>
                            <td style="max-width: 250px;">
                                @if (item.Property != null)
                                {
                                    <a href="/Property/Details/@item.PropertyID" target="_blank" class="text-decoration-none fw-bold text-primary text-truncate d-block" title="@item.Property.Title">
                                        @item.Property.Title
                                    </a>
                                    <span class="small text-muted"><i class="bi bi-hash"></i>@item.PropertyID</span>
                                }
                                else
                                {
                                    <span class="text-danger small">Tin đã bị xóa khỏi DB</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-danger-subtle text-danger">@item.Reason</span>
                            </td>
                            <td>
                                <div class="small">@item.CreatedAt.ToString("dd/MM/yyyy")</div>
                                <div class="small text-muted">@item.CreatedAt.ToString("HH:mm")</div>
                            </td>
                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i> Chờ xử lý</span>
                                }
                                else if (item.Status == "Processed")
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i> Đã xử lý</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i> Bác bỏ</span>
                                }
                            </td>
                            <td class="text-center pe-4">
                                <a asp-action="Details" asp-route-id="@item.ReportID" class="btn btn-sm btn-primary rounded-pill shadow-sm px-3">
                                    @(item.Status == "Pending" ? "Xử lý ngay" : "Xem lại")
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-check-circle display-4 d-block mb-3 text-success opacity-50"></i>
                                Tuyệt vời! Không có báo cáo vi phạm nào cần xử lý.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>