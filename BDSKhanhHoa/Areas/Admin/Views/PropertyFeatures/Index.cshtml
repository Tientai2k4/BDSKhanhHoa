@model IEnumerable<BDSKhanhHoa.Models.PropertyFeature>
@{
    ViewData["Title"] = "Quản lý Danh mục Tiện ích";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h3 class="fw-bold text-dark mb-1"><i class="bi bi-stars text-warning me-2"></i>Quản lý Tiện ích & Thông số</h3>
            <p class="text-muted small mb-0">Quản lý các thông số, tiện ích được gắn kèm vào Bất động sản.</p>
        </div>
        <div class="col-md-6">
            <form action="/Admin/PropertyFeatures/Index" method="get">
                <div class="input-group shadow-sm">
                    <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control bg-white border-0 py-2 fw-medium" placeholder="Tìm tên tiện ích hoặc giá trị...">
                    <button class="btn btn-primary px-4 fw-bold" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-4 fw-medium" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 text-secondary small text-uppercase fw-bold" style="width: 100px;">Mã BĐS</th>
                        <th class="py-3 text-secondary small text-uppercase fw-bold">Tin đăng đính kèm</th>
                        <th class="py-3 text-secondary small text-uppercase fw-bold text-center">Tên thuộc tính</th>
                        <th class="py-3 text-secondary small text-uppercase fw-bold">Giá trị</th>
                        <th class="text-end pe-4 py-3 text-secondary small text-uppercase fw-bold">Xóa</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-search display-4 text-muted opacity-25 d-block mb-3"></i>
                                <h6 class="text-muted fw-bold">Không tìm thấy tiện ích nào.</h6>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <span class="badge bg-light text-primary border p-2">#@item.PropertyID</span>
                            </td>
                            <td class="py-3">
                                <a href="/Property/Details/@item.PropertyID" target="_blank" class="fw-bold text-dark text-decoration-none text-truncate d-block" style="max-width: 300px;" title="@item.Property?.Title">
                                    @item.Property?.Title
                                </a>
                            </td>
                            <td class="py-3 text-center">
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold">@item.FeatureName</span>
                            </td>
                            <td class="py-3 fw-medium text-dark">
                                @item.FeatureValue
                            </td>
                            <td class="text-end pe-4 py-3">
                                <form action="/Admin/PropertyFeatures/Delete" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tiện ích này khỏi BĐS?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.FeatureID" />
                                    <button type="submit" class="btn btn-sm btn-light border text-danger rounded-3 shadow-sm" title="Xóa tiện ích">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>