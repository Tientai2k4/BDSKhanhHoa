@model IEnumerable<BDSKhanhHoa.Models.PostServicePackage>
@{
    ViewData["Title"] = "Quản lý Gói dịch vụ (VIP)";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .tier-card {
        transition: all 0.3s ease;
        border-left: 4px solid transparent;
    }

        .tier-card:hover {
            transform: translateX(5px);
            background-color: #f8fafc;
        }

    /* MÀU SẮC ĐẶC TRƯNG TỪNG HẠNG */
    /* Kim Cương */
    .tier-diamond {
        border-left-color: #00f2fe;
    }

    .icon-diamond {
        background: linear-gradient(135deg, #00c6ff, #0072ff);
        color: white;
        box-shadow: 0 4px 15px rgba(0, 198, 255, 0.4);
        animation: pulse-glow 2s infinite;
    }

    .text-diamond {
        background: linear-gradient(135deg, #00c6ff, #0072ff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 900;
    }

    /* Vàng */
    .tier-gold {
        border-left-color: #f6d365;
    }

    .icon-gold {
        background: linear-gradient(135deg, #f6d365, #fda085);
        color: #fff;
        box-shadow: 0 4px 15px rgba(253, 160, 133, 0.4);
    }

    .text-gold {
        color: #d35400;
        font-weight: 800;
    }

    /* Bạc */
    .tier-silver {
        border-left-color: #bdc3c7;
    }

    .icon-silver {
        background: linear-gradient(135deg, #e2e2e2, #bdc3c7);
        color: #2c3e50;
        box-shadow: 0 4px 10px rgba(189, 195, 199, 0.4);
    }

    .text-silver {
        color: #7f8c8d;
        font-weight: 800;
    }

    /* Đồng */
    .tier-bronze {
        border-left-color: #cd7f32;
    }

    .icon-bronze {
        background: linear-gradient(135deg, #e67e22, #d35400);
        color: #fff;
        box-shadow: 0 4px 10px rgba(211, 84, 0, 0.3);
    }

    .text-bronze {
        color: #e67e22;
        font-weight: 800;
    }

    /* Thường */
    .tier-normal {
        border-left-color: #e2e8f0;
    }

    .icon-normal {
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #e2e8f0;
    }

    .text-normal {
        color: #64748b;
        font-weight: 700;
    }

    @@keyframes pulse-glow {
        0%

    {
        box-shadow: 0 0 0 0 rgba(0, 198, 255, 0.4);
    }

    70% {
        box-shadow: 0 0 0 10px rgba(0, 198, 255, 0);
    }

    100% {
        box-shadow: 0 0 0 0 rgba(0, 198, 255, 0);
    }

    }

    .priority-badge {
        font-family: 'Consolas', monospace;
        font-size: 1.1rem;
    }
</style>

<div class="container-fluid py-4">
    <div class="row align-items-center mb-4 g-3">
        <div class="col-md-8">
            <h3 class="fw-black text-dark mb-1" style="font-weight: 900;"><i class="bi bi-tags text-primary me-2"></i>Quản Lý Gói Đăng Tin</h3>
            <p class="text-muted small mb-0">Hệ thống phân cấp tin VIP tự động đính kèm Logo và hiệu ứng nổi bật ngoài giao diện.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a href="/Admin/PostServicePackages/Create" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4 py-2">
                <i class="bi bi-plus-circle me-1"></i> Tạo Gói Dịch Vụ Mới
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 text-secondary small text-uppercase fw-bold">Thông tin gói (Hạng)</th>
                        <th class="py-3 text-secondary small text-uppercase fw-bold text-center">Thời hạn</th>
                        <th class="py-3 text-secondary small text-uppercase fw-bold text-end">Giá cước</th>
                        <th class="py-3 text-secondary small text-uppercase fw-bold text-center">Điểm hiển thị (Top)</th>
                        <th class="text-end pe-4 py-3 text-secondary small text-uppercase fw-bold">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-box-seam display-1 d-block mb-3 opacity-25"></i>
                                <h6 class="fw-bold">Chưa có cấu hình gói dịch vụ nào.</h6>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        // Phân loại giao diện
                        string tierClass = "tier-normal";
                        string iconClass = "icon-normal";
                        string textClass = "text-normal";
                        string iconObj = "bi-tag-fill";

                        switch (item.PackageType)
                        {
                            case "Kim Cương":
                                tierClass = "tier-diamond"; iconClass = "icon-diamond"; textClass = "text-diamond"; iconObj = "bi-gem";
                                break;
                            case "Vàng":
                                tierClass = "tier-gold"; iconClass = "icon-gold"; textClass = "text-gold"; iconObj = "bi-star-fill";
                                break;
                            case "Bạc":
                                tierClass = "tier-silver"; iconClass = "icon-silver"; textClass = "text-silver"; iconObj = "bi-shield-fill";
                                break;
                            case "Đồng":
                                tierClass = "tier-bronze"; iconClass = "icon-bronze"; textClass = "text-bronze"; iconObj = "bi-award-fill";
                                break;
                        }

                        <tr class="tier-card @tierClass">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle @iconClass" style="width: 48px; height: 48px;">
                                        <i class="bi @iconObj fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark fs-6 mb-1">@item.PackageName</div>
                                        <div class="small @textClass text-uppercase"><i class="bi bi-stars me-1"></i>Hạng: @item.PackageType</div>
                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <div class="small text-muted text-truncate mt-1" style="max-width: 250px;" title="@item.Description">@item.Description</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="py-3 text-center">
                                <span class="badge bg-light text-dark border px-3 py-2 fw-bold"><i class="bi bi-calendar-event text-primary me-1"></i> @item.DurationDays Ngày</span>
                            </td>
                            <td class="py-3 text-end">
                                <span class="fw-black fs-5 @textClass">@(item.Price == 0 ? "MIỄN PHÍ" : item.Price.ToString("N0") + " ₫")</span>
                            </td>
                            <td class="py-3 text-center">
                                <div class="d-inline-flex align-items-center justify-content-center bg-dark text-white priority-badge rounded-3 shadow-sm" style="width: 40px; height: 40px;" title="Ưu tiên hiển thị: @item.PriorityLevel">
                                    @item.PriorityLevel
                                </div>
                            </td>
                            <td class="text-end pe-4 py-3">
                                <div class="d-inline-flex gap-2">
                                    <a href="/Admin/PostServicePackages/Edit/@item.PackageID" class="btn btn-sm btn-light border text-primary rounded-3 shadow-sm" title="Chỉnh sửa">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <form id="deleteForm-@item.PackageID" action="/Admin/PostServicePackages/Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.PackageID" />
                                        <button type="button" class="btn btn-sm btn-light border text-danger rounded-3 shadow-sm" onclick="confirmDelete(@item.PackageID)" title="Xóa">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: 'Xóa Gói Dịch Vụ?',
                text: "Lưu ý: Không thể xóa nếu đang có tin đăng sử dụng gói này!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: '<i class="bi bi-trash3"></i> Đồng ý xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) { document.getElementById('deleteForm-' + id).submit(); }
            })
        }
        @if (TempData["Success"] != null)
        {
                <text>Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: '@Html.Raw(TempData["Success"])', showConfirmButton: false, timer: 3000 });</text>
        }
        @if (TempData["Error"] != null)
        {
                <text>Swal.fire({ icon: 'error', title: 'Lỗi Xóa Dữ Liệu!', text: '@Html.Raw(TempData["Error"])' });</text>
        }
    </script>
}