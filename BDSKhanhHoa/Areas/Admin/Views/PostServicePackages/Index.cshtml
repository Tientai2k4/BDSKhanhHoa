@model IEnumerable<BDSKhanhHoa.Models.PostServicePackage>
@{
    ViewData["Title"] = "Quản lý Gói dịch vụ (VIP)";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row align-items-center mb-4 g-3">
        <div class="col-md-8">
            <h3 class="fw-bold text-dark mb-1"><i class="bi bi-gem text-warning me-2"></i>Cấu hình Gói Đăng Tin</h3>
            <p class="text-muted small mb-0">Quản lý giá cả, quyền lợi và mức độ ưu tiên của các gói tin trên hệ thống.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a href="/Admin/PostServicePackages/Create" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4">
                <i class="bi bi-plus-circle me-1"></i> Thêm Gói Mới
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 text-secondary small text-uppercase fw-bold">Tên Gói</th>
                        <th class="py-3 text-secondary small text-uppercase fw-bold">Giá cước</th>
                        <th class="py-3 text-secondary small text-uppercase fw-bold text-center">Thời gian</th>
                        <th class="py-3 text-secondary small text-uppercase fw-bold text-center">Ưu tiên (Top)</th>
                        <th class="text-end pe-4 py-3 text-secondary small text-uppercase fw-bold">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-box-seam display-1 d-block mb-3 opacity-25"></i>
                                <h6 class="fw-bold">Chưa có cấu hình gói dịch vụ nào.</h6>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="fw-bold text-dark fs-6 mb-1">
                                    @item.PackageName
                                    @if (item.IsHighlighted)
                                    {
                                        <span class="badge bg-danger ms-2 rounded-pill small"><i class="bi bi-fire"></i> Nổi bật</span>
                                    }
                                </div>
                                <div class="small text-muted text-truncate" style="max-width: 300px;">@item.Description</div>
                            </td>
                            <td class="py-3">
                                <span class="fw-bold text-primary fs-6">@(item.Price == 0 ? "Miễn phí" : item.Price.ToString("N0") + " VNĐ")</span>
                            </td>
                            <td class="py-3 text-center">
                                <span class="badge bg-light text-dark border px-3 py-2 fw-medium">@item.DurationDays Ngày</span>
                            </td>
                            <td class="py-3 text-center">
                                <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-10 text-warning fw-bold rounded-circle" style="width: 35px; height: 35px;">
                                    @item.PriorityLevel
                                </div>
                            </td>
                            <td class="text-end pe-4 py-3">
                                <div class="d-inline-flex gap-2">
                                    <a href="/Admin/PostServicePackages/Edit/@item.PackageID" class="btn btn-sm btn-light border text-primary rounded-3 shadow-sm" title="Chỉnh sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form id="deleteForm-@item.PackageID" action="/Admin/PostServicePackages/Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.PackageID" />
                                        <button type="button" class="btn btn-sm btn-light border text-danger rounded-3 shadow-sm" onclick="confirmDelete(@item.PackageID)" title="Xóa">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: 'Xóa Gói Dịch Vụ?',
                text: "Không thể xóa nếu đang có tin đăng sử dụng gói này!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Đồng ý xóa'
            }).then((result) => {
                if (result.isConfirmed) { document.getElementById('deleteForm-' + id).submit(); }
            })
        }
        @if (TempData["Success"] != null)
        {
            <text>Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: '@Html.Raw(TempData["Success"])', showConfirmButton: false, timer: 3000 });</text>
        }
        @if (TempData["Error"] != null)
        {
            <text>Swal.fire({ icon: 'error', title: 'Lỗi!', text: '@Html.Raw(TempData["Error"])' });</text>
        }
    </script>
}