@model BDSKhanhHoa.Models.PostServicePackage
@{
    ViewData["Title"] = "Thêm mới Gói dịch vụ";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark mb-0"><i class="bi bi-plus-circle text-primary me-2"></i>Thêm Gói Đăng Tin Mới</h3>
        <a href="/Admin/PostServicePackages/Index" class="btn btn-light border shadow-sm fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Trở về
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-4 p-md-5">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-4">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Tên Gói Dịch Vụ <span class="text-danger">*</span></label>
                            <input asp-for="PackageName" class="form-control form-control-lg bg-light" placeholder="Vd: VIP Kim Cương, Tin Thường..." required />
                            <span asp-validation-for="PackageName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Mức độ ưu tiên <span class="text-danger">*</span></label>
                            <input asp-for="PriorityLevel" type="number" class="form-control form-control-lg bg-light" placeholder="1, 2, 3..." required />
                            <small class="text-muted">Số càng cao, tin càng trên Top.</small>
                            <span asp-validation-for="PriorityLevel" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Giá tiền (VNĐ) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Price" type="number" class="form-control bg-light" required />
                                <span class="input-group-text bg-white">VNĐ</span>
                            </div>
                            <small class="text-muted">Nhập 0 nếu là gói miễn phí.</small>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Thời gian hiển thị <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="DurationDays" type="number" class="form-control bg-light" required />
                                <span class="input-group-text bg-white">Ngày</span>
                            </div>
                        </div>

                        <div class="col-12 d-flex align-items-center mt-md-4">
                            <div class="form-check form-switch fs-5">
                                <input class="form-check-input" type="checkbox" asp-for="IsHighlighted" id="IsHighlighted">
                                <label class="form-check-label fw-bold ms-2 text-danger" for="IsHighlighted"><i class="bi bi-fire"></i> Gắn nhãn Nổi bật (Đổi màu đỏ cho tin đăng)</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold">Mô tả đặc quyền của gói</label>
                            <textarea asp-for="Description" class="form-control bg-light" rows="4" placeholder="Ví dụ: Hiển thị to hơn, có viền đỏ nổi bật, đứng trên tin VIP Bạc..."></textarea>
                        </div>
                    </div>

                    <hr class="my-5">
                    <div class="text-end">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold rounded-pill px-5 shadow-sm">
                            <i class="bi bi-floppy-fill me-2"></i> LƯU GÓI DỊCH VỤ
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-4 d-none d-lg-block">
            <div class="alert alert-info border-0 shadow-sm rounded-4 p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-lightbulb me-2"></i>Mẹo cấu hình</h5>
                <ul class="mb-0 lh-lg text-dark small">
                    <li><strong>Mức độ ưu tiên:</strong> Hệ thống sẽ sắp xếp tin theo PriorityLevel. Gói có Priority = 100 sẽ luôn nằm trên gói có Priority = 10.</li>
                    <li><strong>Tin nổi bật:</strong> Bật tùy chọn này sẽ gắn thẻ "HOT" màu đỏ và bôi viền đỏ cho tin đăng ngoài giao diện khách hàng.</li>
                </ul>
            </div>
        </div>
    </div>
</div>