                            <div style="flex:1; min-width:0;">
                                <div class="news-meta" style="margin-bottom:6px;">
                                    <span style="color:var(--coral); font-weight:700; font-size:0.7rem;">@n.Category</span>
                                    · @n.CreatedAt.ToString("dd/MM/yyyy") · <i class="bi bi-eye"></i> @n.Views
                                </div>
                                <div class="news-headline sm">@n.Title</div>
                            </div>
