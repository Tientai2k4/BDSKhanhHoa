            // Lấy danh sách Khu Vực sắp xếp từ cao tới thấp theo số lượng tin
            var topAreas = areasList
                .Select(a => new { Area = a, Count = areaCounts.ContainsKey(a.AreaID) ? areaCounts[a.AreaID] : 0 })
                .OrderByDescending(x => x.Count)
