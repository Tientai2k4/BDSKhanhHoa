@model IEnumerable<BDSKhanhHoa.Models.Property>
@using BDSKhanhHoa.Models
@{
    ViewData["Title"] = "Trang Chủ - Bất Động Sản Khánh Hòa";
    var banners = ViewBag.Banners as List<Banner>;
}

<style>
    /* --- HERO SLIDER (BANNER) --- */
    .hero-section {
        position: relative;
        margin-top: -15px;
    }

    .carousel-item {
        height: 550px;
        min-height: 400px;
        background-color: #000;
    }

    .banner-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.7; /* Làm tối ảnh để nổi bật chữ và form */
    }

    .carousel-caption-custom {
        position: absolute;
        top: 40%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100%;
        z-index: 10;
        text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }

    /* --- SEARCH BOX OVERLAY --- */
    .search-overlay {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        max-width: 1100px;
        padding: 0 15px;
        z-index: 20;
    }

    .search-tabs {
        display: flex;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .search-tab-btn {
        background: rgba(255, 255, 255, 0.9);
        color: #333;
        border: none;
        padding: 12px 25px;
        font-weight: 700;
        border-radius: 10px 10px 0 0;
        margin-right: 5px;
        transition: 0.3s;
        text-transform: uppercase;
        font-size: 0.9rem;
    }

        .search-tab-btn.active {
            background: #fff;
            color: #0056b3;
        }

    .search-box-body {
        background: #fff;
        padding: 20px;
        border-radius: 0 15px 15px 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .search-input-group {
        background: #f1f3f5;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 8px 12px;
        display: flex;
        align-items: center;
        height: 52px;
    }

        .search-input-group i {
            color: #6c757d;
            margin-right: 10px;
        }

        .search-input-group select,
        .search-input-group input {
            border: none;
            background: transparent;
            width: 100%;
            outline: none;
            font-size: 0.95rem;
        }

    .btn-search-main {
        background: #e81c2e;
        color: white;
        border: none;
        border-radius: 8px;
        width: 100%;
        height: 52px;
        font-weight: 700;
        transition: 0.3s;
    }

        .btn-search-main:hover {
            background: #c71525;
            box-shadow: 0 4px 12px rgba(232, 28, 46, 0.3);
        }

    /* --- PROPERTY CARD --- */
    .property-card {
        border: none;
        border-radius: 12px;
        overflow: hidden;
        transition: 0.3s;
        background: #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
    }

        .property-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.12);
        }

    .img-wrapper {
        position: relative;
        height: 210px;
    }

        .img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .badge-vip {
        position: absolute;
        top: 10px;
        left: 10px;
        background: linear-gradient(45deg, #ff0000, #ff8c00);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 800;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }

    .price-text {
        color: #e81c2e;
        font-weight: 700;
        font-size: 1.15rem;
    }

    /* --- RESPONSIVE --- */
    @@media (max-width: 992px) {
        .carousel-item {
            height: 650px;
        }

        .search-overlay {
            bottom: 20px;
        }

        .carousel-caption-custom h1 {
            font-size: 1.8rem;
        }
    }

    @@media (max-width: 768px) {
        .carousel-item {
            height: 750px;
        }

        .search-tab-btn {
            padding: 10px 15px;
            font-size: 0.8rem;
        }

        .search-box-body {
            border-radius: 12px;
        }
    }
</style>

<section class="hero-section">
    <div id="bannerCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
        <div class="carousel-inner">
            @if (banners != null && banners.Any())
            {
                for (int i = 0; i < banners.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@banners[i].ImageURL" class="banner-img" alt="@banners[i].Title">
                        <div class="carousel-caption-custom text-center text-white">
                            <h1 class="display-4 fw-bold">@banners[i].Title</h1>
                            <p class="fs-5 d-none d-md-block">@banners[i].SubTitle</p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="carousel-item active">
                    <img src="/images/banner-khanhhoa.jpg" class="banner-img" alt="BDS Khánh Hòa">
                    <div class="carousel-caption-custom text-center text-white">
                        <h1 class="display-4 fw-bold">BẤT ĐỘNG SẢN KHÁNH HÒA</h1>
                        <p class="fs-5">Tìm là thấy - Đăng là bán</p>
                    </div>
                </div>
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    <div class="search-overlay">
        <ul class="search-tabs">
            <li>
                <button type="button" class="search-tab-btn active" id="tab-buy" onclick="setSearchMode('buy')">Bán</button>
            </li>
            <li>
                <button type="button" class="search-tab-btn" id="tab-rent" onclick="setSearchMode('rent')">Cho thuê</button>
            </li>
        </ul>
        <div class="search-box-body">
            <form action="/Property/Search" method="get" id="searchForm">
                <input type="hidden" name="transactionType" id="transactionType" value="buy" />

                <div class="row g-2 mb-2">
                    <div class="col-lg-7 col-md-12">
                        <div class="search-input-group">
                            <i class="bi bi-search"></i>
                            <input type="text" name="keyword" placeholder="Nhập tên dự án, đường, khu vực...">
                        </div>
                    </div>
                    <div class="col-lg-5 col-md-12">
                        <div class="search-input-group">
                            <i class="bi bi-house"></i>
                            <select name="typeId" id="propertyTypeSelect">
                                <option value="">Tất cả loại nhà đất</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="row g-2">
                    <div class="col-lg-2 col-md-6">
                        <div class="search-input-group">
                            <i class="bi bi-geo-alt"></i>
                            <select name="areaId" id="areaSelect" onchange="fetchWards(this.value)">
                                <option value="">Khu vực</option>
                                @if (ViewBag.Areas != null)
                                {
                                    foreach (var a in ViewBag.Areas)
                                    {
                                        <option value="@a.AreaID">@a.AreaName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-6">
                        <div class="search-input-group">
                            <i class="bi bi-map"></i>
                            <select name="wardId" id="wardSelect">
                                <option value="">Phường/Xã</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="search-input-group">
                            <i class="bi bi-cash"></i>
                            <select name="priceRange">
                                <option value="">Mức giá</option>
                                <option value="0-500">Dưới 500 triệu</option>
                                <option value="500-1000">500 triệu - 1 tỷ</option>
                                <option value="1000-3000">1 - 3 tỷ</option>
                                <option value="3000-5000">3 - 5 tỷ</option>
                                <option value="5000-10000">5 - 10 tỷ</option>
                                <option value="10000-999999">Trên 10 tỷ</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="search-input-group">
                            <i class="bi bi-fullscreen-exit"></i>
                            <select name="sizeRange">
                                <option value="">Diện tích</option>
                                <option value="0-30">Dưới 30 m²</option>
                                <option value="30-50">30 - 50 m²</option>
                                <option value="50-100">50 - 100 m²</option>
                                <option value="100-200">100 - 200 m²</option>
                                <option value="200-500">200 - 500 m²</option>
                                <option value="500-999999">Trên 500 m²</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-12">
                        <button type="submit" class="btn btn-search-main w-100">
                            <i class="bi bi-search me-1"></i> TÌM KIẾM
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

<section class="container my-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-uppercase" style="color: #003366; border-left: 5px solid #e81c2e; padding-left: 15px;">
                Tin đăng mới nhất
            </h2>
        </div>
        <a href="/Property" class="text-primary fw-bold text-decoration-none">
            Xem tất cả <i class="bi bi-arrow-right"></i>
        </a>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <a href="/Property/Details/@item.PropertyID" class="text-decoration-none text-dark">
                        <div class="property-card h-100">
                            <div class="img-wrapper">
                                <img src="@(string.IsNullOrEmpty(item.MainImage) ? "/images/no-image.jpg" : item.MainImage)" alt="@item.Title">
                                <span class="badge-vip"><i class="bi bi-star-fill text-warning me-1"></i> VIP</span>
                            </div>
                            <div class="card-body p-3">
                                <h6 class="fw-bold text-truncate mb-2" title="@item.Title">@item.Title</h6>
                                <div class="price-text mb-2">
                                    @(item.Price.HasValue? item.Price.Value.ToString("N0") + " VNĐ" : "Thỏa thuận")
                                </div>
                                <div class="d-flex justify-content-between text-muted border-top pt-2 mt-2" style="font-size: 0.85rem;">
                                    <span><i class="bi bi-rulers me-1"></i> @item.AreaSize m²</span>
                                    <span class="text-truncate" style="max-width: 120px;">
                                        <i class="bi bi-geo-alt me-1"></i> @(item.Ward?.Area?.AreaName ?? "Khánh Hòa")
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 text-muted">
                <i class="bi bi-house-x display-4"></i>
                <p class="mt-3">Hiện chưa có tin đăng nào được hiển thị.</p>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        // Lấy danh sách Types từ ViewBag (được Controller truyền qua)
        const allPropertyTypes = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.Types));

        // Hàm chuyển đổi chế độ Bán/Thuê
        function setSearchMode(mode) {
            document.getElementById('transactionType').value = mode;

            // Toggle class active cho các nút tab
            if (mode === 'buy') {
                document.getElementById('tab-buy').classList.add('active');
                document.getElementById('tab-rent').classList.remove('active');
            } else {
                document.getElementById('tab-rent').classList.add('active');
                document.getElementById('tab-buy').classList.add('active'); // Sửa lỗi logic tab
                document.getElementById('tab-buy').classList.remove('active');
                document.getElementById('tab-rent').classList.add('active');
            }

            // Lọc lại dropdown Loại nhà đất
            filterPropertyTypes(mode);
        }

        // Hàm lọc loại nhà đất dựa trên Tab
        function filterPropertyTypes(mode) {
            const select = document.getElementById('propertyTypeSelect');
            select.innerHTML = '<option value="">Tất cả loại nhà đất</option>';

            const filtered = allPropertyTypes.filter(t => {
                const name = t.TypeName.toLowerCase();
                if (mode === 'buy') {
                    // Ưu tiên hiện các loại có chữ "Bán" hoặc không có chữ "Thuê"
                    return name.includes('bán') || (!name.includes('thuê') && !name.includes('trọ'));
                } else {
                    // Ưu tiên hiện các loại có chữ "Thuê" hoặc "Trọ"
                    return name.includes('thuê') || name.includes('trọ');
                }
            });

            filtered.forEach(t => {
                let opt = new Option(t.TypeName, t.TypeID);
                select.add(opt);
            });
        }

        // AJAX: Load Phường/Xã từ SQL Server
        async function fetchWards(areaId) {
            const wardSelect = document.getElementById('wardSelect');
            wardSelect.innerHTML = '<option value="">Đang tải...</option>';

            if (!areaId) {
                wardSelect.innerHTML = '<option value="">Phường/Xã</option>';
                return;
            }

            try {
                // Gọi API GetWardsByArea trong HomeController
                const response = await fetch(`/Home/GetWardsByArea?areaId=${areaId}`);
                if (!response.ok) throw new Error('Network response was not ok');
                const data = await response.json();

                wardSelect.innerHTML = '<option value="">Phường/Xã</option>';
                data.forEach(ward => {
                    let opt = new Option(ward.wardName, ward.wardId);
                    wardSelect.add(opt);
                });
            } catch (error) {
                console.error("Lỗi khi tải Phường Xã:", error);
                wardSelect.innerHTML = '<option value="">Lỗi dữ liệu</option>';
            }
        }

        // Khi load trang lần đầu
        document.addEventListener("DOMContentLoaded", function() {
            setSearchMode('buy');
        });
    </script>
}v