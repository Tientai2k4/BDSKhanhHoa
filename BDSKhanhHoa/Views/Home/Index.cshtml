<section class="hero">
    <div id="heroCarousel" class="carousel slide carousel-fade hero-carousel" data-bs-ride="carousel" data-bs-interval="6000">
        <div class="carousel-inner" style="height:100%;">
            @if (banners != null && banners.Any())
            {
                for (int i = 0; i < banners.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")" style="height:100%;">
                        <img src="@banners[i].ImageURL" class="hero-img" alt="@banners[i].Title">

                        <div class="hero-content">
                            @if (!string.IsNullOrEmpty(banners[i].SubTitle))
                            {
                                <div class="hero-eyebrow">@banners[i].SubTitle</div>
                            }

                            @if (!string.IsNullOrEmpty(banners[i].Title))
                            {
                                <h1 class="hero-title">@banners[i].Title</h1>
                            }

                            @if (!string.IsNullOrEmpty(banners[i].LinkURL))
                            {
                                <a href="@banners[i].LinkURL" class="btn-hero-link">Tìm hiểu thêm</a>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="carousel-item active" style="height:100%;">
                    <img src="/images/banner-khanhhoa.jpg" class="hero-img" alt="BDS Khánh Hòa"
                         onerror="this.src='https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=2070&auto=format&fit=crop'">
                    <div class="hero-content">
                        <div class="hero-eyebrow">Nền tảng bất động sản số 1 Khánh Hòa</div>
                        <h1 class="hero-title">
                            Tìm Ngôi Nhà<br>
                            <span>Mơ Ước Của Bạn</span>
                        </h1>
                    </div>
                </div>
                <div class="carousel-item" style="height:100%;">
                    <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?q=80&w=2070&auto=format&fit=crop" class="hero-img" alt="BDS Khánh Hòa">
                    <div class="hero-content">
                        <div class="hero-eyebrow">Cơ hội đầu tư sinh lời</div>
                        <h1 class="hero-title">
                            Bất Động Sản<br>
                            <span>Ven Biển</span>
                        </h1>
                    </div>
                </div>
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev" style="z-index:15;">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next" style="z-index:15;">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    <div class="search-float">
        <div class="search-glass">
            <div class="stabs">
                <button type="button" class="stab active" id="stab-buy" onclick="setMode('buy')">
                    <i class="bi bi-tag me-1"></i> Mua bán
                </button>
                <button type="button" class="stab" id="stab-rent" onclick="setMode('rent')">
                    <i class="bi bi-key me-1"></i> Cho thuê
                </button>
            </div>
            <form action="/Property/Search" method="get" id="searchForm">
                <input type="hidden" name="transactionType" id="transactionType" value="buy">
                <div class="row g-2">
                    <div class="col-lg-4 col-md-12">
                        <div class="sfield">
                            <i class="bi bi-search"></i>
                            <input type="text" name="keyword" placeholder="Tên dự án, đường, khu vực...">
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-6 col-6">
                        <div class="sfield">
                            <i class="bi bi-buildings"></i>
                            <select name="typeId" id="typeSelect">
                                <option value="">Loại nhà đất</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-6 col-6">
                        <div class="sfield">
                            <i class="bi bi-geo-alt"></i>
                            <select name="areaId" id="areaSelect" onchange="loadWards(this.value)">
                                <option value="">Khu vực</option>
