                        <div class="news-meta"><i class="bi bi-calendar3"></i> @firstNews.CreatedAt.ToString("dd/MM/yyyy") &nbsp;·&nbsp; <i class="bi bi-eye"></i> @firstNews.Views lượt xem</div>
                        <div class="news-headline">@firstNews.Title</div>
                        <div class="news-excerpt">@firstNews.Summary</div>
                    </div>
