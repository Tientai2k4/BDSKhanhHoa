                    }
                </div>
            }
        </div>
    </div>
</section>
<section class="section-wrap" style="padding-bottom:72px; background:#fff;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-flex-end mb-0">
            <div>
                <div class="section-label"><span>Được chọn lọc cho bạn</span></div>
                <h2 class="section-title">Bất Động Sản Dành Cho Bạn</h2>
            </div>
            <a href="/Property/Search" class="view-all d-none d-md-flex">Xem tất cả <i class="bi bi-arrow-right"></i></a>
        </div>

        <div class="d-flex align-items-center justify-content-between mb-4 mt-4 flex-wrap gap-3">
            <div class="prop-tabs">
                <button type="button" class="prop-tab active" onclick="filterProps('all',this)">Tất cả</button>
                <button type="button" class="prop-tab" onclick="filterProps('buy',this)">Mua bán</button>
                <button type="button" class="prop-tab" onclick="filterProps('rent',this)">Cho thuê</button>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <select class="sfield" style="width:auto; padding:0 14px; height:40px; font-size:0.83rem;" onchange="filterByType(this.value)" id="propTypeFilter">
                    <option value="">Tất cả loại</option>
                </select>
                <select class="sfield" id="sortSelect" style="width:auto; padding:0 14px; height:40px; font-size:0.83rem;" onchange="sortProperties(this.value)">
                    <option value="newest">Sắp xếp: Mới nhất</option>
                    <option value="price_asc">Giá thấp → cao</option>
                    <option value="price_desc">Giá cao → thấp</option>
                </select>
            </div>
        </div>

        <div class="row g-3 g-md-4" id="propGrid">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    string tierClass = "";
                    string tierLabel = "";
                    string tierIcon = "";

                    // Lấy PackageID gốc để ánh xạ Giao diện, bỏ qua chuỗi PackageType dễ gây lỗi
                    int priority = item.PackageID;

                    if (priority >= 4) { tierClass = "tier-diamond"; tierLabel = "Kim Cương"; tierIcon = "bi-gem"; }
                    else if (priority == 3) { tierClass = "tier-gold"; tierLabel = "Vàng"; tierIcon = "bi-star-fill"; }
                    else if (priority == 2) { tierClass = "tier-silver"; tierLabel = "Bạc"; tierIcon = "bi-shield-fill"; }
                    else if (priority == 1) { tierClass = "tier-bronze"; tierLabel = "Đồng"; tierIcon = "bi-award-fill"; }
                    else { tierClass = "tier-normal"; tierLabel = "Tin Thường"; tierIcon = "bi-tag-fill"; priority = 0; }

                    string priceStr = item.Price.HasValue
                    ? (item.Price >= 1000000000m
                    ? (item.Price.Value / 1000000000m).ToString("0.##") + " Tỷ"
                    : (item.Price.Value / 1000000m).ToString("0.##") + " Triệu")
                    : "Thỏa thuận";

                    string typeName = item.PropertyType?.TypeName?.ToLower() ?? "";
                    bool isRent = typeName.Contains("thuê") || typeName.Contains("trọ");
                    string propMode = isRent ? "rent" : "buy";
                    string transTagClass = isRent ? "tag-rent" : "tag-buy";
                    string transTagText = isRent ? "Cho Thuê" : "Bán";

                    decimal rawPrice = item.Price ?? 0;
                    long ticks = item.CreatedAt.Ticks;

                    <div class="col-xl-3 col-lg-4 col-md-6 col-12 prop-item"
                         data-mode="@propMode"
                         data-typeid="@item.TypeID"
                         data-priority="@priority"
                         data-price="@rawPrice"
                         data-date="@ticks">
                        <a href="/Property/Details/@item.PropertyID" class="text-decoration-none d-block h-100">
                            <div class="prop-card @tierClass">
                                <div class="prop-img-wrap">
                                    <img src="@(string.IsNullOrEmpty(item.MainImage) ? "/images/no-image.jpg" : item.MainImage)"
                                         alt="@item.Title" loading="lazy"
                                         onerror="this.src='/images/no-image.jpg'">
                                    <span class="prop-tier"><i class="bi @tierIcon me-1"></i>@tierLabel</span>

                                    <span class="prop-trans-tag @transTagClass">@transTagText</span>

                                    <button class="prop-fav" type="button" onclick="event.preventDefault();toggleFav(this)" title="Lưu tin">
                                        <i class="bi bi-heart"></i>
                                    </button>
                                </div>
                                <div class="prop-body">
                                    <div class="prop-price">@priceStr</div>
                                    <div class="prop-title" title="@item.Title">@item.Title</div>
                                    <div class="prop-meta">
                                        <div class="prop-meta-item">
                                            <i class="bi bi-vector-pen"></i>
                                            <span>@item.AreaSize m²</span>
                                        </div>
                                        <div class="prop-meta-item" style="max-width:55%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                            <i class="bi bi-geo-alt"></i>
                                            <span>@(item.Ward?.Area?.AreaName ?? "Khánh Hòa")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
        </div>

        <div class="text-center mt-4">
            <a href="/Property/Search" class="btn" style="background:var(--navy);color:#fff;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;padding:14px 40px;border-radius:100px;font-size:0.9rem;letter-spacing:0.06em;box-shadow:0 4px 18px rgba(11,22,40,0.22);transition:var(--trans);" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
                <i class="bi bi-grid me-2"></i>Xem tất cả bất động sản
            </a>
        </div>
    </div>
</section>

