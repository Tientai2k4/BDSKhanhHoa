@model IEnumerable<BDSKhanhHoa.Models.Property>
@using BDSKhanhHoa.Models
@{
    ViewData["Title"] = "Trang Chủ - Bất Động Sản Khánh Hòa";
    var banners = ViewBag.Banners as List<Banner>;
}

<style>
    /* ============================================================
           BDS KHÁNH HÒA — HOMEPAGE 2026
           Design: Luxury Real Estate · Coastal Premium · Deep Navy + Gold
           ============================================================ */

    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');

    :root {
        --navy: #0b1628;
        --navy-mid: #152340;
        --navy-light: #1e3458;
        --gold: #c9a84c;
        --gold-light: #e8c97a;
        --gold-pale: #fdf6e3;
        --coral: #e8533a;
        --coral-light: #ff6b4a;
        --sky: #3b82f6;
        --sky-light: #60a5fa;
        --surface: #ffffff;
        --bg: #f7f8fc;
        --bg2: #eef1f8;
        --border: #e2e7f0;
        --text: #0f1c35;
        --text-mid: #3d5175;
        --text-soft: #7a8fa8;
        --text-ghost: #b0bfd4;
        --r-sm: 8px;
        --r-md: 14px;
        --r-lg: 20px;
        --r-xl: 28px;
        --r-2xl: 36px;
        --shadow-card: 0 2px 16px rgba(11,22,40,0.08);
        --shadow-hover: 0 12px 40px rgba(11,22,40,0.16);
        --trans: all 0.26s cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    /* ─── HERO ─────────────────────────────────────────────── */
    .hero {
        position: relative;
        height: 640px;
        overflow: hidden;
        background: var(--navy);
    }

    @@media(max-width:767px) {
        .hero {
            height: 700px;
        }
    }

    .hero-carousel {
        height: 100%;
    }

        .hero-carousel .carousel-item {
            height: 640px;
        }

    @@media(max-width:767px) {
        .hero-carousel .carousel-item {
            height: 700px;
        }
    }

    .hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-content {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -55%);
        text-align: center;
        width: 100%;
        max-width: 860px;
        padding: 0 24px;
        z-index: 10;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(201,168,76,0.18);
        border: 1px solid rgba(201,168,76,0.45);
        color: var(--gold-light);
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 6px 18px;
        border-radius: 100px;
        margin-bottom: 22px;
    }

        .hero-eyebrow::before {
            content: '';
            width: 6px;
            height: 6px;
            background: var(--gold);
            border-radius: 50%;
            animation: pulse-gold 2s ease-in-out infinite;
        }

    @@keyframes pulse-gold {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(201,168,76,0.5);
        }

        50% {
            box-shadow: 0 0 0 6px rgba(201,168,76,0);
        }
    }

    .hero-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.4rem, 5.5vw, 4.2rem);
        font-weight: 900;
        color: #fff;
        line-height: 1.1;
        letter-spacing: -0.02em;
        text-shadow: 0 4px 32px rgba(0,0,0,0.4);
        margin-bottom: 18px;
    }

        .hero-title span {
            color: var(--gold-light);
        }

    .hero-sub {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: clamp(1rem, 2vw, 1.2rem);
        color: rgba(255,255,255,0.78);
        font-weight: 400;
        line-height: 1.6;
        margin-bottom: 0;
    }

    .btn-hero-link {
        display: inline-block;
        background: linear-gradient(135deg, var(--coral), #c9371f);
        color: #fff;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 700;
        padding: 14px 36px;
        border-radius: 100px;
        font-size: 0.95rem;
        letter-spacing: 0.06em;
        text-decoration: none;
        text-transform: uppercase;
        margin-top: 12px;
        transition: var(--trans);
        box-shadow: 0 4px 18px rgba(232,83,58,0.35);
    }

        .btn-hero-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(232,83,58,0.45);
            color: #fff;
        }

    /* ─── SEARCH BOX ─────────────────────────────────────────── */
    .search-float {
        position: absolute;
        bottom: -1px;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        max-width: 1160px;
        padding: 0 24px;
        z-index: 20;
    }

    .search-glass {
        background: rgba(255,255,255,0.97);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.9);
        border-radius: var(--r-xl) var(--r-xl) 0 0;
        padding: 24px 28px 18px;
        box-shadow: 0 -8px 40px rgba(11,22,40,0.18);
    }

    .stabs {
        display: flex;
        gap: 6px;
        margin-bottom: 18px;
    }

    .stab {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 700;
        padding: 9px 24px;
        border-radius: 100px;
        border: 2px solid transparent;
        cursor: pointer;
        transition: var(--trans);
        letter-spacing: 0.04em;
        background: var(--bg2);
        color: var(--text-mid);
    }

        .stab.active {
            background: var(--navy);
            color: #fff;
            border-color: var(--navy);
            box-shadow: 0 4px 16px rgba(11,22,40,0.25);
        }

        .stab:not(.active):hover {
            background: var(--border);
            color: var(--text);
        }

    .sfield {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--bg);
        border: 1.5px solid var(--border);
        border-radius: var(--r-md);
        padding: 0 14px;
        height: 48px;
        transition: var(--trans);
    }

        .sfield:focus-within {
            border-color: var(--navy);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(11,22,40,0.07);
        }

        .sfield i {
            color: var(--text-soft);
            font-size: 0.95rem;
            flex-shrink: 0;
        }

        .sfield select, .sfield input {
            border: none;
            background: transparent;
            width: 100%;
            outline: none;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 0.88rem;
            color: var(--text);
        }

            .sfield select option {
                color: var(--text);
            }

    .btn-search {
        background: linear-gradient(135deg, var(--coral), #c9371f);
        color: #fff;
        border: none;
        border-radius: var(--r-md);
        height: 48px;
        width: 100%;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        transition: var(--trans);
        box-shadow: 0 4px 18px rgba(232,83,58,0.35);
    }

        .btn-search:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(232,83,58,0.45);
            color: #fff;
        }

    /* ─── GENERAL SECTION ─────────────────────────────────── */
    .section-wrap {
        padding: 72px 0 0;
    }

        .section-wrap.bg-alt {
            background: var(--bg);
        }

        .section-wrap.bg-navy {
            background: var(--navy);
        }

    .section-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--coral);
        margin-bottom: 10px;
    }

        .section-label::before {
            content: '';
            width: 24px;
            height: 2px;
            background: var(--coral);
            border-radius: 2px;
        }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.6rem, 3.5vw, 2.4rem);
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin-bottom: 6px;
    }

        .section-title.on-dark {
            color: #fff;
        }

    .section-sub {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.92rem;
        color: var(--text-soft);
        font-weight: 400;
    }

        .section-sub.on-dark {
            color: rgba(255,255,255,0.55);
        }

    .view-all {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 600;
        font-size: 0.88rem;
        color: var(--sky);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--trans);
        white-space: nowrap;
    }

        .view-all:hover {
            color: var(--sky-light);
            gap: 10px;
        }

        .view-all.on-dark {
            color: var(--gold-light);
        }

            .view-all.on-dark:hover {
                color: var(--gold);
            }

    /* ─── NEWS TICKER ──────────────────────────────────────── */
    .news-ticker-bar {
        background: var(--navy);
        padding: 14px 0;
        overflow: hidden;
        position: relative;
    }

    .ticker-label {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--gold);
        white-space: nowrap;
        padding: 4px 16px;
        background: rgba(201,168,76,0.15);
        border: 1px solid rgba(201,168,76,0.3);
        border-radius: 4px;
        margin-right: 20px;
        flex-shrink: 0;
    }

    .ticker-track {
        display: flex;
        align-items: center;
        animation: ticker-scroll 40s linear infinite;
        white-space: nowrap;
        gap: 0;
    }

    .ticker-item {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.85rem;
        color: rgba(255,255,255,0.75);
        padding: 0 32px;
        white-space: nowrap;
        border-right: 1px solid rgba(255,255,255,0.12);
        transition: var(--trans);
        cursor: pointer;
    }

        .ticker-item:hover {
            color: var(--gold-light);
        }

        .ticker-item span {
            color: var(--gold-light);
            font-weight: 600;
            margin-right: 4px;
        }

    @@keyframes ticker-scroll {
        0% {
            transform: translateX(0);
        }

        100% {
            transform: translateX(-50%);
        }
    }

    /* ─── NEWS SECTION ─────────────────────────────────────── */
    .news-grid {
        display: grid;
        gap: 24px;
    }

        .news-grid.large {
            grid-template-columns: 1.4fr 1fr;
        }

    @@media(max-width:991px) {
        .news-grid.large {
            grid-template-columns: 1fr;
        }
    }

    .news-card-main {
        position: relative;
        border-radius: var(--r-lg);
        overflow: hidden;
        background: var(--surface);
        box-shadow: var(--shadow-card);
        transition: var(--trans);
        text-decoration: none;
        display: block;
    }

        .news-card-main:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-hover);
        }

        .news-card-main .news-img-wrap {
            position: relative;
            height: 280px;
            overflow: hidden;
        }

    @@media(max-width:767px) {
        .news-card-main .news-img-wrap {
            height: 220px;
        }
    }

    .news-card-main .news-img-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .news-card-main:hover .news-img-wrap img {
        transform: scale(1.04);
    }

    .news-cat-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        background: var(--coral);
        color: #fff;
        padding: 5px 12px;
        border-radius: 100px;
        z-index: 5;
    }

    .news-body {
        padding: 20px 22px 22px;
    }

    .news-meta {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.78rem;
        color: var(--text-soft);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .news-meta i {
            font-size: 0.8rem;
        }

    .news-headline {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1.4;
        margin-bottom: 10px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

        .news-headline.sm {
            font-size: 1rem;
            -webkit-line-clamp: 3;
        }

    .news-excerpt {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.87rem;
        color: var(--text-mid);
        line-height: 1.65;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .news-list {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .news-item-sm {
        display: flex;
        gap: 14px;
        padding: 16px 0;
        border-bottom: 1px solid var(--border);
        text-decoration: none;
        transition: var(--trans);
        align-items: flex-start;
    }

        .news-item-sm:last-child {
            border-bottom: none;
        }

        .news-item-sm:hover .news-headline.sm {
            color: var(--sky);
        }

    .news-thumb {
        width: 88px;
        height: 72px;
        border-radius: var(--r-sm);
        object-fit: cover;
        flex-shrink: 0;
    }

    /* ─── PROPERTY CARDS ───────────────────────────────────── */
    .prop-tabs {
        display: flex;
        gap: 4px;
        background: var(--bg2);
        border-radius: 100px;
        padding: 4px;
        width: fit-content;
        margin-bottom: 32px;
    }

    .prop-tab {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 9px 28px;
        border-radius: 100px;
        border: none;
        cursor: pointer;
        transition: var(--trans);
        background: transparent;
        color: var(--text-soft);
    }

        .prop-tab.active {
            background: var(--surface);
            color: var(--text);
            box-shadow: 0 2px 10px rgba(11,22,40,0.1);
        }

    .prop-card {
        background: var(--surface);
        border-radius: var(--r-lg);
        border: 1.5px solid var(--border);
        overflow: hidden;
        transition: var(--trans);
        height: 100%;
        display: flex;
        flex-direction: column;
        position: relative;
    }

        .prop-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-hover);
        }

    .prop-img-wrap {
        position: relative;
        height: 210px;
        overflow: hidden;
    }

        .prop-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

    .prop-card:hover .prop-img-wrap img {
        transform: scale(1.05);
    }

    .prop-status-badge {
        position: absolute;
        bottom: 14px;
        left: 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 5px 13px;
        border-radius: 100px;
        z-index: 5;
    }

    .status-opening {
        background: #16a34a;
        color: #fff;
    }

    .status-coming {
        background: var(--gold);
        color: var(--navy);
    }

    .status-done {
        background: var(--text-soft);
        color: #fff;
    }

    .prop-tier {
        position: absolute;
        top: 12px;
        left: 12px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 5px 11px;
        border-radius: 100px;
        z-index: 5;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .tier-diamond .prop-tier {
        background: linear-gradient(135deg,#00c6ff,#0072ff);
        color: #fff;
        box-shadow: 0 3px 12px rgba(0,114,255,0.4);
    }

    .tier-gold .prop-tier {
        background: linear-gradient(135deg,#f6d365,#fda085);
        color: #7a4000;
        box-shadow: 0 3px 12px rgba(253,160,133,0.4);
    }

    .tier-silver .prop-tier {
        background: linear-gradient(135deg,#e8ebed,#b8c2cc);
        color: #2c3e50;
        box-shadow: 0 3px 12px rgba(184,194,204,0.4);
    }

    .tier-normal .prop-tier {
        background: rgba(255,255,255,0.92);
        color: var(--text-soft);
        border: 1px solid var(--border);
    }

    .prop-fav {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 32px;
        height: 32px;
        background: rgba(255,255,255,0.92);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        z-index: 5;
        transition: var(--trans);
    }

        .prop-fav:hover {
            background: #fff;
            transform: scale(1.12);
        }

        .prop-fav i {
            font-size: 0.82rem;
            color: var(--text-soft);
        }

        .prop-fav:hover i {
            color: #e81c2e;
        }

    .prop-trans-tag {
        position: absolute;
        bottom: 12px;
        right: 12px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 4px;
        z-index: 5;
    }

    .tag-buy {
        background: rgba(232,83,58,0.9);
        color: #fff;
    }

    .tag-rent {
        background: rgba(59,130,246,0.9);
        color: #fff;
    }

    .prop-body {
        padding: 16px 18px 18px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .prop-price {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 800;
        font-size: 1.1rem;
        color: var(--coral);
        letter-spacing: -0.02em;
        margin-bottom: 8px;
    }

    .tier-diamond .prop-price {
        color: #0065e8;
    }

    .tier-gold .prop-price {
        color: #c25a0a;
    }

    .prop-title {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text);
        line-height: 1.5;
        flex: 1;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 14px;
    }

    .prop-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 12px;
        border-top: 1px solid var(--bg2);
        gap: 6px;
    }

    .prop-meta-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.8rem;
        color: var(--text-soft);
        font-weight: 500;
    }

        .prop-meta-item i {
            font-size: 0.85rem;
            color: var(--text-ghost);
        }

    /* ─── PROJECT CARDS ──────────────────────────────────── */
    .project-card {
        border-radius: var(--r-lg);
        overflow: hidden;
        background: var(--surface);
        box-shadow: var(--shadow-card);
        transition: var(--trans);
        text-decoration: none;
        display: block;
    }

        .project-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-hover);
        }

    .project-img-wrap {
        position: relative;
        height: 230px;
        overflow: hidden;
    }

        .project-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

    .project-card:hover .project-img-wrap img {
        transform: scale(1.05);
    }

    .project-body {
        padding: 18px 20px 20px;
    }

    .project-investor {
        font-family: 'Plus Jakarta Sans',sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-soft);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 6px;
    }

    .project-name {
        font-family: 'Playfair Display',serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 10px;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .project-loc {
        font-family: 'Plus Jakarta Sans',sans-serif;
        font-size: 0.82rem;
        color: var(--text-soft);
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .project-loc i {
            color: var(--coral);
        }

    /* ─── LOCATION SECTION ─────────────────────────────── */
    .loc-card {
        position: relative;
        border-radius: var(--r-lg);
        overflow: hidden;
        cursor: pointer;
        transition: var(--trans);
        text-decoration: none;
        display: block;
    }

        .loc-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-hover);
        }

    .loc-img {
        width: 100%;
        object-fit: cover;
        display: block;
    }

        .loc-img.tall {
            height: 320px;
        }

