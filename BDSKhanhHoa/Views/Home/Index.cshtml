@model IEnumerable<BDSKhanhHoa.Models.Property>
@using BDSKhanhHoa.Models
@{
    ViewData["Title"] = "Trang Chủ - Bất Động Sản Khánh Hòa";
    var banners = ViewBag.Banners as List<Banner>;
}

<style>
    /* ================= HERO BANNER ================= */
    .hero-section {
        position: relative;
        background: #000;
    }

    .carousel-item {
        height: 580px;
    }

    @@media (max-width: 991px) {
        .carousel-item {
            height: 520px;
        }
    }

    @@media (max-width: 767px) {
        .carousel-item {
            height: 680px;
        }
    }

    .banner-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.55;
        filter: brightness(0.85);
    }

    /* Gradient overlay at bottom for readability */
    .hero-section::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 60%;
        background: linear-gradient(to top, rgba(8,15,40,0.75) 0%, transparent 100%);
        z-index: 5;
        pointer-events: none;
    }

    .carousel-caption-custom {
        position: absolute;
        top: 38%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100%;
        max-width: 800px;
        padding: 0 24px;
        z-index: 10;
        text-align: center;
    }

        .carousel-caption-custom h1 {
            font-family: 'Sora', sans-serif;
            font-size: clamp(1.8rem, 4vw, 3.2rem);
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.02em;
            line-height: 1.15;
            text-shadow: 0 2px 20px rgba(0,0,0,0.4);
            margin-bottom: 14px;
        }

        .carousel-caption-custom p {
            font-size: clamp(1rem, 2vw, 1.2rem);
            color: rgba(255,255,255,0.88);
            font-weight: 400;
            text-shadow: 0 1px 8px rgba(0,0,0,0.4);
            margin: 0;
        }

    /* Carousel controls */
    .carousel-control-prev,
    .carousel-control-next {
        width: 48px;
        opacity: 0.7;
        z-index: 15;
    }

        .carousel-control-prev:hover,
        .carousel-control-next:hover {
            opacity: 1;
        }

    /* ================= SEARCH BOX ================= */
    .search-overlay {
        position: absolute;
        bottom: 36px;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        max-width: 1100px;
        padding: 0 20px;
        z-index: 20;
    }

    .search-tabs {
        display: flex;
        list-style: none;
        padding: 0;
        margin: 0 0 0 4px;
    }

    .search-tab-btn {
        font-family: 'Sora', sans-serif;
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
        color: rgba(255,255,255,0.9);
        border: 1px solid rgba(255,255,255,0.3);
        border-bottom: none;
        padding: 10px 28px;
        font-weight: 700;
        font-size: 0.85rem;
        border-radius: 12px 12px 0 0;
        margin-right: 6px;
        transition: all 0.2s ease;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        cursor: pointer;
    }

        .search-tab-btn.active {
            background: #fff;
            color: var(--primary);
            border-color: rgba(255,255,255,0.9);
        }

        .search-tab-btn:not(.active):hover {
            background: rgba(255,255,255,0.35);
        }

    .search-box-body {
        background: #fff;
        padding: 20px 22px;
        border-radius: 0 16px 16px 16px;
        box-shadow: 0 20px 60px rgba(8,15,40,0.25);
    }

    .search-field {
        background: #f4f6fb;
        border: 1.5px solid #e4e8f0;
        border-radius: 10px;
        padding: 0 14px;
        display: flex;
        align-items: center;
        height: 50px;
        transition: border-color 0.2s;
    }

        .search-field:focus-within {
            border-color: var(--primary);
            background: #fff;
        }

        .search-field i {
            color: var(--text-light);
            margin-right: 10px;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .search-field select,
        .search-field input {
            border: none;
            background: transparent;
            width: 100%;
            outline: none;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.92rem;
            color: var(--text-main);
        }

            .search-field select option {
                color: var(--text-main);
            }

    .btn-search-main {
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: 10px;
        height: 50px;
        width: 100%;
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 0.88rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        transition: all 0.2s ease;
        box-shadow: 0 4px 16px rgba(240,90,40,0.3);
    }

        .btn-search-main:hover {
            background: #d44d1e;
            box-shadow: 0 6px 22px rgba(240,90,40,0.4);
            transform: translateY(-1px);
            color: #fff;
        }

    /* ================= SECTION HEADER ================= */
    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 32px;
    }

    .section-title {
        font-family: 'Sora', sans-serif;
        font-size: 1.6rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
        letter-spacing: -0.02em;
        position: relative;
        padding-left: 18px;
    }

        .section-title::before {
            content: '';
            position: absolute;
            left: 0;
            top: 8%;
            height: 84%;
            width: 5px;
            background: var(--accent);
            border-radius: 4px;
        }

    .section-subtitle {
        font-size: 0.88rem;
        color: var(--text-muted);
        margin: 4px 0 0 18px;
        font-weight: 400;
    }

    .view-all-link {
        color: var(--primary);
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: gap 0.2s;
        white-space: nowrap;
    }

        .view-all-link:hover {
            color: var(--primary-dark);
            gap: 10px;
        }

    /* ================= PROPERTY CARD ================= */
    .property-card {
        background: #fff;
        border-radius: 16px;
        border: 1.5px solid #eaecf5;
        overflow: hidden;
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .property-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 40px rgba(26,86,219,0.12);
            border-color: #c6d4f5;
        }

    .card-img-wrapper {
        position: relative;
        height: 200px;
        overflow: hidden;
        flex-shrink: 0;
    }

        .card-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

    .property-card:hover .card-img-wrapper img {
        transform: scale(1.04);
    }

    /* Status badge */
    .card-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: linear-gradient(135deg, #e81c2e, #ff6b35);
        color: #fff;
        font-family: 'Sora', sans-serif;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 4px 12px;
        border-radius: 20px;
        box-shadow: 0 2px 8px rgba(232,28,46,0.35);
    }

    /* Favorite button */
    .card-fav-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 32px;
        height: 32px;
        background: rgba(255,255,255,0.92);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
    }

        .card-fav-btn:hover {
            background: #fff;
            transform: scale(1.1);
        }

        .card-fav-btn i {
            font-size: 0.85rem;
            color: #94a3b8;
        }

    /* Card body */
    .card-content {
        padding: 16px 18px 18px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .card-price {
        color: var(--accent);
        font-family: 'Sora', sans-serif;
        font-weight: 800;
        font-size: 1.15rem;
        margin-bottom: 8px;
        letter-spacing: -0.02em;
    }

    .card-title {
        font-weight: 600;
        font-size: 0.92rem;
        color: var(--text-main);
        line-height: 1.45;
        margin-bottom: 14px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    .card-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 12px;
        border-top: 1px solid #f1f4fb;
    }

    .card-meta-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.82rem;
        color: var(--text-muted);
        font-weight: 500;
    }

        .card-meta-item i {
            font-size: 0.88rem;
            color: var(--text-light);
        }

    /* ================= EMPTY STATE ================= */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-muted);
    }

    .empty-state-icon {
        width: 72px;
        height: 72px;
        background: #f1f4fb;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 1.8rem;
        color: var(--text-light);
    }

    .empty-state h5 {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1rem;
        color: var(--text-main);
        margin-bottom: 6px;
    }

    .empty-state p {
        font-size: 0.88rem;
        margin: 0;
    }

    /* ================= RESPONSIVE ================= */
    @@media (max-width: 991px) {
        .search-overlay {
            bottom: 20px;
        }

        .section-title {
            font-size: 1.35rem;
        }
    }

    @@media (max-width: 767px) {
        .search-box-body {
            border-radius: 14px;
        }

        .search-tab-btn {
            padding: 9px 18px;
            font-size: 0.78rem;
        }

        .section-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 10px;
        }

        .card-img-wrapper {
            height: 190px;
        }
    }

    @@media (max-width: 575px) {
        .search-overlay {
            padding: 0 12px;
        }
    }
</style>

<!-- ==================== HERO BANNER ==================== -->
<section class="hero-section">
    <div id="bannerCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="5000">
        <div class="carousel-inner">
            @if (banners != null && banners.Any())
            {
                for (int i = 0; i < banners.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@banners[i].ImageURL" class="banner-img" alt="@banners[i].Title">
                        <div class="carousel-caption-custom">
                            <h1>@banners[i].Title</h1>
                            <p class="d-none d-md-block">@banners[i].SubTitle</p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="carousel-item active">
                    <img src="/images/banner-khanhhoa.jpg" class="banner-img" alt="BDS Khánh Hòa">
                    <div class="carousel-caption-custom">
                        <h1>Bất Động Sản Khánh Hòa</h1>
                        <p>Tìm là thấy — Đăng là bán</p>
                    </div>
                </div>
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    <!-- ==================== SEARCH BOX ==================== -->
    <div class="search-overlay">
        <ul class="search-tabs">
            <li>
                <button type="button" class="search-tab-btn active" id="tab-buy" onclick="setSearchMode('buy')">
                    <i class="bi bi-tag me-1"></i> Mua bán
                </button>
            </li>
            <li>
                <button type="button" class="search-tab-btn" id="tab-rent" onclick="setSearchMode('rent')">
                    <i class="bi bi-key me-1"></i> Cho thuê
                </button>
            </li>
        </ul>

        <div class="search-box-body">
            <form action="/Property/Search" method="get" id="searchForm">
                <input type="hidden" name="transactionType" id="transactionType" value="buy" />

                <div class="row g-2 mb-2">
                    <div class="col-lg-7 col-md-12">
                        <div class="search-field">
                            <i class="bi bi-search"></i>
                            <input type="text" name="keyword" placeholder="Nhập tên dự án, đường, khu vực...">
                        </div>
                    </div>
                    <div class="col-lg-5 col-md-12">
                        <div class="search-field">
                            <i class="bi bi-buildings"></i>
                            <select name="typeId" id="propertyTypeSelect">
                                <option value="">Tất cả loại nhà đất</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="row g-2">
                    <div class="col-lg-2 col-md-6 col-6">
                        <div class="search-field">
                            <i class="bi bi-geo-alt"></i>
                            <select name="areaId" id="areaSelect" onchange="fetchWards(this.value)">
                                <option value="">Khu vực</option>
                                @if (ViewBag.Areas != null)
                                {
                                    foreach (var a in ViewBag.Areas)
                                    {
                                        <option value="@a.AreaID">@a.AreaName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-6 col-6">
                        <div class="search-field">
                            <i class="bi bi-map"></i>
                            <select name="wardId" id="wardSelect">
                                <option value="">Phường/Xã</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="search-field">
                            <i class="bi bi-cash-coin"></i>
                            <select name="priceRange">
                                <option value="">Mức giá</option>
                                <option value="0-500">Dưới 500 triệu</option>
                                <option value="500-1000">500 triệu – 1 tỷ</option>
                                <option value="1000-3000">1 – 3 tỷ</option>
                                <option value="3000-5000">3 – 5 tỷ</option>
                                <option value="5000-10000">5 – 10 tỷ</option>
                                <option value="10000-999999">Trên 10 tỷ</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="search-field">
                            <i class="bi bi-aspect-ratio"></i>
                            <select name="sizeRange">
                                <option value="">Diện tích</option>
                                <option value="0-30">Dưới 30 m²</option>
                                <option value="30-50">30 – 50 m²</option>
                                <option value="50-100">50 – 100 m²</option>
                                <option value="100-200">100 – 200 m²</option>
                                <option value="200-500">200 – 500 m²</option>
                                <option value="500-999999">Trên 500 m²</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-12">
                        <button type="submit" class="btn-search-main">
                            <i class="bi bi-search me-2"></i>Tìm kiếm
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

<!-- ==================== LISTING SECTION ==================== -->
<section class="container my-5" style="padding-top: 8px;">
    <div class="section-header">
        <div>
            <h2 class="section-title">Tin đăng mới nhất</h2>
            <p class="section-subtitle">Cập nhật liên tục từ chủ nhà và môi giới uy tín</p>
        </div>
        <a href="/Property" class="view-all-link">
            Xem tất cả <i class="bi bi-arrow-right"></i>
        </a>
    </div>

    <div class="row g-3 g-md-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6 col-12">
                    <a href="/Property/Details/@item.PropertyID" class="text-decoration-none d-block h-100">
                        <div class="property-card">
                            <div class="card-img-wrapper">
                                <img src="@(string.IsNullOrEmpty(item.MainImage) ? "/images/no-image.jpg" : item.MainImage)"
                                     alt="@item.Title"
                                     loading="lazy">
                                <span class="card-badge"><i class="bi bi-star-fill me-1" style="font-size:.65rem;"></i>VIP</span>
                                <button class="card-fav-btn" type="button" title="Lưu tin">
                                    <i class="bi bi-heart"></i>
                                </button>
                            </div>
                            <div class="card-content">
                                <div class="card-price">
                                    @(item.Price.HasValue? item.Price.Value.ToString("N0") + " VNĐ" : "Thỏa thuận")
                                </div>
                                <div class="card-title" title="@item.Title">@item.Title</div>
                                <div class="card-meta">
                                    <div class="card-meta-item">
                                        <i class="bi bi-vector-pen"></i>
                                        <span>@item.AreaSize m²</span>
                                    </div>
                                    <div class="card-meta-item" style="max-width: 55%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <i class="bi bi-geo-alt"></i>
                                        <span>@(item.Ward?.Area?.AreaName ?? "Khánh Hòa")</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-house-slash"></i></div>
                    <h5>Chưa có tin đăng</h5>
                    <p>Hiện chưa có bất động sản nào được hiển thị. Vui lòng quay lại sau.</p>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        const allPropertyTypes = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.Types));

        function setSearchMode(mode) {
            document.getElementById('transactionType').value = mode;
            document.getElementById('tab-buy').classList.toggle('active', mode === 'buy');
            document.getElementById('tab-rent').classList.toggle('active', mode === 'rent');
            filterPropertyTypes(mode);
        }

        function filterPropertyTypes(mode) {
            const select = document.getElementById('propertyTypeSelect');
            select.innerHTML = '<option value="">Tất cả loại nhà đất</option>';

            const filtered = allPropertyTypes.filter(t => {
                const name = t.TypeName.toLowerCase();
                if (mode === 'buy') {
                    return name.includes('bán') || (!name.includes('thuê') && !name.includes('trọ'));
                } else {
                    return name.includes('thuê') || name.includes('trọ');
                }
            });

            filtered.forEach(t => select.add(new Option(t.TypeName, t.TypeID)));
        }

        async function fetchWards(areaId) {
            const wardSelect = document.getElementById('wardSelect');
            wardSelect.innerHTML = '<option value="">Đang tải...</option>';

            if (!areaId) {
                wardSelect.innerHTML = '<option value="">Phường/Xã</option>';
                return;
            }

            try {
                const response = await fetch(`/Home/GetWardsByArea?areaId=${areaId}`);
                if (!response.ok) throw new Error('Network error');
                const data = await response.json();
                wardSelect.innerHTML = '<option value="">Phường/Xã</option>';
                data.forEach(ward => wardSelect.add(new Option(ward.wardName, ward.wardId)));
            } catch (err) {
                console.error('Lỗi tải phường xã:', err);
                wardSelect.innerHTML = '<option value="">Lỗi dữ liệu</option>';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            setSearchMode('buy');
        });
    </script>
}
