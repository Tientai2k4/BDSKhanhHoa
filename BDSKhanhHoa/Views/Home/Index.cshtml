                    </div>
                    <div class="col-lg-2 col-md-6 col-6">
                        <div class="sfield">
                            <i class="bi bi-cash-coin"></i>
                            <select name="priceRange">
                                <option value="">Mức giá</option>
                                <option value="0-500">Dưới 500 triệu</option>
                                <option value="500-1000">500tr – 1 tỷ</option>
                                <option value="1000-3000">1 – 3 tỷ</option>
                                <option value="3000-5000">3 – 5 tỷ</option>
                                <option value="5000-10000">5 – 10 tỷ</option>
                                <option value="10000-999999">Trên 10 tỷ</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-6 col-6">
                        <button type="submit" class="btn-search">
                            <i class="bi bi-search me-2"></i>Tìm kiếm
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>
<div class="news-ticker-bar">
