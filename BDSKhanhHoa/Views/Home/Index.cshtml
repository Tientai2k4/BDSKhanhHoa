        <div class="news-grid large">
            @if (ViewBag.LatestNews != null && ((List<BDSKhanhHoa.Models.Blog>)ViewBag.LatestNews).Any())
            {
                var latestNews = ViewBag.LatestNews as List<BDSKhanhHoa.Models.Blog>;
                var firstNews = latestNews.First();
                var remainingNews = latestNews.Skip(1).ToList();

                <a href="/Blog/Details/@firstNews.BlogID" class="news-card-main">
                    <div class="news-img-wrap">
                        <img src="@(string.IsNullOrEmpty(firstNews.ImageURL) ? "/images/no-image.jpg" : firstNews.ImageURL)" alt="@firstNews.Title">
