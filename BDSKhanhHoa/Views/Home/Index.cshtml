@section Scripts {
    <script>
        // ─── Search Mode ───────────────────────────────────────
        const allTypes = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.Types));

        function setMode(mode) {
            document.getElementById('transactionType').value = mode;
            document.getElementById('stab-buy').classList.toggle('active', mode === 'buy');
            document.getElementById('stab-rent').classList.toggle('active', mode === 'rent');
            const sel = document.getElementById('typeSelect');
            sel.innerHTML = '<option value="">Loại nhà đất</option>';
            allTypes.filter(t => {
                const n = t.TypeName.toLowerCase();
                return mode === 'buy' ? (!n.includes('thuê') && !n.includes('trọ')) : (n.includes('thuê') || n.includes('trọ'));
            }).forEach(t => sel.add(new Option(t.TypeName, t.TypeID)));

            // Sync the filter dropdown too
            const pf = document.getElementById('propTypeFilter');
            if(pf) {
                pf.innerHTML = '<option value="">Tất cả loại</option>';
                allTypes.forEach(t => pf.add(new Option(t.TypeName, t.TypeID)));
            }
        }

        async function loadWards(areaId) {
            const ws = document.getElementById('wardSelect');
            if(!ws) return;
            if (!areaId) { ws.innerHTML = '<option value="">Phường/Xã</option>'; return; }
            try {
                const r = await fetch(`/Home/GetWardsByArea?areaId=${areaId}`);
                const d = await r.json();
                ws.innerHTML = '<option value="">Phường/Xã</option>';
                d.forEach(w => ws.add(new Option(w.wardName, w.wardId)));
            } catch(e) { console.error(e); }
        }

             function filterProps(mode, btn) {
            // 1. Kích hoạt màu nút
            document.querySelectorAll('.prop-tab').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            // 2. Reset Select loại nhà đất
            document.getElementById('propTypeFilter').value = "";

            // 3. Lọc Ẩn/Hiện dữ liệu theo thuộc tính data-mode
            document.querySelectorAll('.prop-item').forEach(item => {
                if (mode === 'all') {
                    item.style.display = 'block';
                } else {
                    item.style.display = item.getAttribute('data-mode') === mode ? 'block' : 'none';
                }
            });

            // 4. Kích hoạt lại hàm sort để giữ đúng thứ tự VIP sau khi lọc
            const currentSort = document.getElementById('sortSelect').value;
            sortProperties(currentSort);
        }
                // Bổ sung logic lọc cho dropdown Loại BĐS
        function filterByType(typeId) {
               const activeTabMode = document.querySelector('.prop-tab.active').getAttribute('onclick').match(/'([^']+)'/)[1];

               document.querySelectorAll('.prop-item').forEach(item => {
                   const itemMode = item.getAttribute('data-mode');
                   const itemType = item.getAttribute('data-typeid');

                   const matchMode = (activeTabMode === 'all') || (itemMode === activeTabMode);
                   const matchType = (typeId === "") || (itemType === typeId);

                   item.style.display = (matchMode && matchType) ? 'block' : 'none';
               });

               // Kích hoạt lại hàm sort để giữ đúng thứ tự VIP sau khi lọc
               const currentSort = document.getElementById('sortSelect').value;
               sortProperties(currentSort);
           }

        function toggleFav(btn) {
            const i = btn.querySelector('i');
            i.classList.toggle('bi-heart');
            i.classList.toggle('bi-heart-fill');
            if(i.classList.contains('bi-heart-fill')) i.style.color='#e81c2e';
            else i.style.color='';
        }

        // ─── Counter animation ───────────────────────────────
        function animateCounters() {
            document.querySelectorAll('.stat-num[data-target]').forEach(el => {
                const target = parseInt(el.dataset.target);
                let current = 0;
                const step = Math.ceil(target / 60);
                const timer = setInterval(() => {
                    current = Math.min(current + step, target);
                    el.textContent = current.toLocaleString('vi-VN') + (target > 1000 ? '+' : '+');
                    if (current >= target) clearInterval(timer);
                }, 24);
            });
        }

        const statsBar = document.querySelector('.stats-bar');
        if(statsBar) {
            const obs = new IntersectionObserver(entries => {
                if(entries[0].isIntersecting) { animateCounters(); obs.disconnect(); }
            }, {threshold:0.3});
            obs.observe(statsBar);
        }

        // ─── Calculators ─────────────────────────────────────
        function calcChiPhi() {
            const dt = parseFloat(document.getElementById('dtXayDung').value) || 0;
            const tang = parseFloat(document.getElementById('soTang').value) || 1;
            const tc = parseFloat(document.getElementById('tieuchuan').value);
            if(!dt) { alert('Vui lòng nhập diện tích'); return; }
            const total = dt * tang * tc;
            const min = (total * 0.9).toFixed(0);
            const max = (total * 1.15).toFixed(0);
            document.getElementById('chiPhiVal').textContent =
                formatMoney(parseInt(min)) + ' – ' + formatMoney(parseInt(max));
            document.getElementById('chiPhiResult').style.display = 'block';
        }

        function calcLaiSuat() {
            const P = (parseFloat(document.getElementById('soTienVay').value) || 0) * 1e6;
            const r = (parseFloat(document.getElementById('laiSuat').value) || 0) / 100 / 12;
            const n = (parseFloat(document.getElementById('thoiHan').value) || 0) * 12;
            if(!P || !r || !n) { alert('Vui lòng nhập đủ thông tin'); return; }
            const monthly = P * r * Math.pow(1+r,n) / (Math.pow(1+r,n)-1);
            const total = monthly * n;
            document.getElementById('laiSuatVal').textContent = formatMoney(Math.round(monthly)) + '/tháng';
            document.getElementById('laiSuatNote').textContent =
                `Tổng tiền trả: ${formatMoney(Math.round(total))} | Lãi phát sinh: ${formatMoney(Math.round(total - P))}`;
            document.getElementById('laiSuatResult').style.display = 'block';
        }

        function calcTuoi() {
            const year = parseInt(document.getElementById('birthYear').value);
            const gender = document.getElementById('gender').value;
            if(!year || year < 1900 || year > 2020) { alert('Năm sinh không hợp lệ'); return; }
            // Simplified cung số calculation
            let sum = year.toString().split('').reduce((a,b)=>a+parseInt(b),0);
            while(sum > 9) sum = sum.toString().split('').reduce((a,b)=>a+parseInt(b),0);
            const goodYears = [2025, 2026, 2027, 2028].filter((y,i) => (y - year) % 3 !== 0);
            const notes = {1:'Mệnh Thủy — Hướng Bắc, màu đen/xanh', 2:'Mệnh Thổ — Hướng Đông Bắc', 3:'Mệnh Mộc — Hướng Đông', 4:'Mệnh Mộc — Hướng Đông Nam', 5:'Mệnh Thổ — Hướng Trung tâm', 6:'Mệnh Kim — Hướng Tây', 7:'Mệnh Kim — Hướng Tây Bắc', 8:'Mệnh Thổ — Hướng Đông Bắc', 9:'Mệnh Hỏa — Hướng Nam'};
            document.getElementById('tuoiVal').textContent = goodYears.slice(0,2).join(', ') || '2027, 2028';
            document.getElementById('tuoiNote').textContent = notes[sum] || 'Cần xem chi tiết thêm với chuyên gia phong thủy';
            document.getElementById('tuoiResult').style.display = 'block';
        }

        function calcPhongThuy() {
            const year = parseInt(document.getElementById('ptBirthYear').value);
            const gender = document.getElementById('ptGender').value;
            if(!year || year < 1900) { alert('Năm sinh không hợp lệ'); return; }
            const menh = ['Thủy','Thổ','Mộc','Mộc','Thổ','Kim','Kim','Thổ','Hỏa'];
            const huong = {male: ['Đông Nam','Nam','Đông','Đông Nam','Tây','Đông Bắc','Tây','Đông Bắc','Nam'], female: ['Đông','Đông Nam','Nam','Đông','Đông Nam','Tây Bắc','Tây Bắc','Tây','Đông']};
            let sum = year.toString().split('').reduce((a,b)=>a+parseInt(b),0);
            while(sum > 9) sum = sum.toString().split('').reduce((a,b)=>a+parseInt(b),0);
            const idx = (sum - 1 + 9) % 9;
            document.getElementById('ptMenh').textContent = `Mệnh ${menh[idx]} — Hướng tốt: ${(huong[gender]||huong.male)[idx]}`;
            document.getElementById('ptAdvice').textContent =
                `Màu sắc may mắn: ${['Đen/Xanh đậm','Vàng/Nâu','Xanh lá','Xanh lá','Vàng đất','Trắng/Xám','Trắng','Vàng','Đỏ/Hồng'][idx]}. Vật liệu phù hợp: ${['Kính/Gương','Gạch Ceramic','Gỗ tự nhiên','Gỗ','Đá tự nhiên','Kim loại','Sắt/Thép','Đá ong','Gạch đỏ'][idx]}. Nên tránh: ${['Đất/Gốm','Cây xanh nhiều','Kim loại','Kim loại sáng','Nước/Kính','Lửa/Đỏ','Lửa','Nước','Nước'][idx]}.`;
            document.getElementById('ptResult').style.display = 'block';
        }

        function formatMoney(n) {
            if(n >= 1e9) return (n/1e9).toFixed(2).replace(/\.?0+$/,'') + ' tỷ';
            if(n >= 1e6) return (n/1e6).toFixed(0) + ' triệu';
            return n.toLocaleString('vi-VN') + ' đ';
        }

        document.addEventListener('DOMContentLoaded', () => {
            setMode('buy');
        });

        // ── HÀM CHỐT CHẶN: ÉP BUỘC VIP LÊN ĐẦU TRONG MỌI HOÀN CẢNH
         function sortProperties(sortType) {
             const grid = document.getElementById('propGrid');
             const items = Array.from(grid.querySelectorAll('.prop-item'));

             items.sort((a, b) => {
                 const priorityA = parseInt(a.getAttribute('data-priority')) || 0;
                 const priorityB = parseInt(b.getAttribute('data-priority')) || 0;

                 // LỚP BẢO VỆ 1: Dù user chọn Giá thấp hay Giá cao, miễn Khác Gói VIP là ép gói VIP cao hơn LÊN ĐẦU
                 if (priorityA !== priorityB) {
                     return priorityB - priorityA;
                 }

                 // LỚP BẢO VỆ 2: Chỉ khi cùng 1 gói VIP (Cùng Kim Cương, hoặc Cùng Thường) thì mới áp dụng tiêu chí của bộ lọc
                 if (sortType === 'newest') {
                     return parseInt(b.getAttribute('data-date')) - parseInt(a.getAttribute('data-date'));
                 } else if (sortType === 'price_asc') {
                     return parseFloat(a.getAttribute('data-price')) - parseFloat(b.getAttribute('data-price'));
                 } else if (sortType === 'price_desc') {
                     return parseFloat(b.getAttribute('data-price')) - parseFloat(a.getAttribute('data-price'));
                 }
                 return 0;
             });

             // Gắn lại các Item vào DOM sau khi đã xếp chuẩn thứ tự
             items.forEach(item => grid.appendChild(item));
         }
    </script>
}