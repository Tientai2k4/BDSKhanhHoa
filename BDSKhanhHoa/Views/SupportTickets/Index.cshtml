@model IEnumerable<BDSKhanhHoa.Models.Project>
@using BDSKhanhHoa.Models
@{
    ViewData["Title"] = "Trung tâm hỗ trợ CĐT";
    Layout = "~/Views/Shared/_BusinessLayout.cshtml";

    string businessName = ViewBag.BusinessName as string ?? "Doanh nghiệp đối tác";
    int projectCount = ViewBag.ProjectCount ?? 0;
    var supportHistory = ViewBag.SupportHistory as IEnumerable<ContactMessage>;

    string TranslateStatus(string? st)
    {
        return st switch
        {
            "Pending" => "Chờ duyệt",
            "Processing" => "Đang xử lý",
            "Done" => "Đã hoàn tất",
            "Đã xử lý" => "Đã hoàn tất",
            _ => st ?? "Chờ xử lý"
        };
    }

    string GetStatusBadge(string? st)
    {
        return st switch
        {
            "Pending" => "bg-danger text-white",
            "Processing" => "bg-warning text-dark",
            "Done" or "Đã xử lý" => "bg-success text-white",
            _ => "bg-secondary text-white"
        };
    }
}

<style>
    body {
        background-color: #f8fafc;
    }

    .support-hero {
        background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        border-radius: 24px;
        padding: 40px;
        color: white;
        margin-bottom: 30px;
        box-shadow: 0 10px 30px rgba(59, 130, 246, 0.3);
        position: relative;
        overflow: hidden;
    }

        .support-hero::after {
            content: '';
            position: absolute;
            top: -50px;
            right: -50px;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            pointer-events: none;
        }

    .glass-card {
        background: #ffffff;
        border-radius: 20px;
        border: 1px solid rgba(226, 232, 240, 0.8);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.04);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .glass-card:hover {
            box-shadow: 0 15px 35px rgba(15, 23, 42, 0.08);
        }

    .form-control-custom, .form-select-custom {
        border-radius: 14px;
        border: 1.5px solid #cbd5e1;
        padding: 14px 20px;
        font-weight: 500;
        background-color: #f8fafc;
        transition: all 0.2s;
    }

        .form-control-custom:focus, .form-select-custom:focus {
            background-color: #ffffff;
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        }

    .input-icon-wrap {
        position: relative;
    }

        .input-icon-wrap i {
            position: absolute;
            top: 50%;
            left: 20px;
            transform: translateY(-50%);
            color: #64748b;
            font-size: 1.2rem;
        }

        .input-icon-wrap .form-control-custom, .input-icon-wrap .form-select-custom {
            padding-left: 55px;
        }

    .upload-zone {
        border: 2px dashed #94a3b8;
        border-radius: 16px;
        padding: 30px 20px;
        text-align: center;
        background: #f8fafc;
        transition: all 0.3s;
        cursor: pointer;
        position: relative;
    }

        .upload-zone:hover, .upload-zone:focus-within {
            border-color: #3b82f6;
            background: #eff6ff;
        }

        .upload-zone input[type="file"] {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }

    .timeline {
        position: relative;
        padding-left: 30px;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: 11px;
            top: 5px;
            height: calc(100% - 10px);
            width: 2px;
            background: #e2e8f0;
        }

    .timeline-item {
        position: relative;
        margin-bottom: 24px;
    }

        .timeline-item:last-child {
            margin-bottom: 0;
        }

    .timeline-icon {
        position: absolute;
        left: -30px;
        top: 0;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: #3b82f6;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        border: 4px solid #fff;
        box-shadow: 0 0 0 1px #e2e8f0;
    }

    .table-custom thead th {
        background: #f8fafc;
        color: #475569;
        font-size: 0.8rem;
        text-transform: uppercase;
        font-weight: 800;
        border-bottom: 2px solid #e2e8f0;
        padding: 15px;
    }

    .table-custom tbody td {
        padding: 15px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
    }

    @@media (max-width: 768px) {
        .support-hero

    {
        padding: 25px;
        border-radius: 16px;
    }

    .glass-card {
        padding: 20px !important;
    }

    }
</style>

<div class="container-fluid px-2 px-md-4 mb-5 animate__animated animate__fadeIn">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 bg-success text-white mb-4 d-flex align-items-center" role="alert">
            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
            <div><strong>Thành công!</strong> @TempData["Success"]</div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0 bg-danger text-white mb-4 d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
            <div><strong>Lỗi:</strong> @TempData["Error"]</div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- HERO BANNER -->
    <div class="support-hero">
        <div class="row align-items-center position-relative" style="z-index: 1;">
            <div class="col-lg-8">
                <span class="badge bg-white text-primary rounded-pill px-3 py-2 fw-bold mb-3 shadow-sm">Trung tâm hỗ trợ Đối tác</span>
                <h1 class="fw-black mb-2" style="font-size: clamp(1.8rem, 4vw, 2.5rem);">Xin chào, @businessName!</h1>
                <p class="mb-0 fs-5 text-white-50">Cổng tiếp nhận yêu cầu thay đổi thông tin dự án, cập nhật giá bán, hình ảnh và hồ sơ pháp lý.</p>
            </div>
            <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
                <div class="d-inline-flex align-items-center bg-white bg-opacity-10 rounded-4 p-3 border border-white border-opacity-25">
                    <div class="bg-white text-primary rounded-circle d-flex align-items-center justify-content-center me-3 shadow" style="width: 50px; height: 50px;">
                        <i class="bi bi-buildings-fill fs-4"></i>
                    </div>
                    <div class="text-start">
                        <div class="text-white-50 small text-uppercase fw-bold">Dự án đang quản lý</div>
                        <div class="fs-3 fw-black lh-1 text-white">@projectCount <span class="fs-6 fw-normal text-white-50">dự án</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="row g-4 mb-4">

        <!-- CỘT TRÁI: FORM ĐIỀN YÊU CẦU -->
        <div class="col-xl-8 col-lg-7">
            <div class="glass-card p-4 p-md-5 h-100">
                <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3 me-3">
                        <i class="bi bi-pencil-square fs-3"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-1 text-dark">Tạo Phiếu Yêu Cầu Mới</h4>
                        <div class="text-muted small">Điền chi tiết thông tin bên dưới để Admin xử lý nhanh nhất.</div>
                    </div>
                </div>

                <form asp-action="Submit" asp-controller="SupportTickets" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="fullName" value="@ViewBag.BusinessName" />
                    <input type="hidden" name="phone" value="@ViewBag.UserPhone" />
                    <input type="hidden" name="email" value="@ViewBag.UserEmail" />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark">Dự án cần hỗ trợ <span class="text-danger">*</span></label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-building"></i>
                                <select name="projectId" class="form-select-custom w-100" required>
                                    <option value="">-- Chọn dự án của bạn --</option>
                                    @if (Model != null && Model.Any())
                                    {
                                        foreach (var p in Model)
                                        {
                                            <option value="@p.ProjectID">@p.ProjectName</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark">Chủ đề <span class="text-danger">*</span></label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-card-text"></i>
                                <input type="text" name="subject" class="form-control-custom w-100" placeholder="VD: Xin cập nhật bảng giá đợt 2" required />
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold text-dark">Nội dung chi tiết <span class="text-danger">*</span></label>
                            <div class="position-relative">
                                <textarea name="message" class="form-control-custom w-100" rows="5" placeholder="Mô tả thật rõ ràng phần bạn muốn thay đổi.&#10;Ví dụ:&#10;- Đổi giá bán Min thành 2.5 tỷ&#10;- Xóa ảnh số 3 và thay bằng ảnh trong file đính kèm..." required style="padding-top: 15px;"></textarea>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold text-dark">Đính kèm Tài liệu / Hình ảnh <span class="text-muted fw-normal">(Tùy chọn)</span></label>
                            <div class="upload-zone">
                                <input type="file" name="attachment" accept=".jpg,.jpeg,.png,.webp,.pdf,.zip,.rar" id="fileInput" onchange="showFileName()" />
                                <i class="bi bi-cloud-arrow-up-fill text-primary mb-2 d-block" style="font-size: 3rem;"></i>
                                <h6 class="fw-bold text-dark mb-1">Kéo thả file vào đây hoặc <span class="text-primary text-decoration-underline">Click để Chọn file</span></h6>
                                <p class="text-muted small mb-0" id="fileNameText">Hỗ trợ: JPG, PNG, PDF, ZIP, RAR (Tối đa 20MB)</p>
                            </div>
                        </div>

                        <div class="col-12 mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold text-uppercase shadow-sm d-flex justify-content-center align-items-center" style="font-size: 1.1rem; letter-spacing: 0.5px;">
                                <i class="bi bi-send-fill me-2 fs-5"></i> Gửi Yêu Cầu Cho Admin
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- CỘT PHẢI: QUY TRÌNH & FAQ -->
        <div class="col-xl-4 col-lg-5">
            <div class="glass-card p-4 mb-4">
                <h5 class="fw-bold text-dark mb-4"><i class="bi bi-clock-history text-primary me-2"></i>Quy trình xử lý</h5>
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-icon bg-primary"><i class="bi bi-1-circle"></i></div>
                        <h6 class="fw-bold mb-1">Gửi yêu cầu</h6>
                        <p class="text-muted small mb-0">CĐT điền form và đính kèm tài liệu hợp lệ.</p>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-icon bg-warning text-dark"><i class="bi bi-2-circle"></i></div>
                        <h6 class="fw-bold mb-1">Kiểm duyệt</h6>
                        <p class="text-muted small mb-0">Admin tiếp nhận, kiểm tra tính pháp lý và độ chính xác.</p>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-icon bg-success"><i class="bi bi-3-circle"></i></div>
                        <h6 class="fw-bold mb-1">Hoàn tất cập nhật</h6>
                        <p class="text-muted small mb-0">Hệ thống áp dụng thay đổi và gửi thông báo xác nhận cho CĐT.</p>
                    </div>
                </div>
            </div>

            <div class="glass-card p-4">
                <h5 class="fw-bold text-dark mb-4"><i class="bi bi-question-circle text-danger me-2"></i>Câu hỏi thường gặp</h5>
                <div class="accordion accordion-flush" id="faqAccordion">
                    <div class="accordion-item bg-transparent border-bottom mb-2">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent fw-bold text-dark px-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                Gửi nhiều file ảnh cùng lúc bằng cách nào?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body px-0 pt-0 text-muted small">
                                Hệ thống hỗ trợ 1 file đính kèm. Vui lòng <b>nén tất cả vào 1 file .ZIP hoặc .RAR</b> rồi tải lên.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-transparent border-bottom mb-0">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent fw-bold text-dark px-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                Thời gian xử lý mất bao lâu?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body px-0 pt-0 text-muted small">
                                Các yêu cầu thay đổi giá, mô tả, hình ảnh sẽ được phê duyệt trong vòng <b>2 - 4 giờ làm việc</b>.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- KHU VỰC LỊCH SỬ YÊU CẦU CỦA CĐT -->
    <div class="glass-card p-4 p-md-5">
        <div class="d-flex align-items-center mb-4 border-bottom pb-3">
            <div class="bg-success bg-opacity-10 text-success rounded-3 p-3 me-3">
                <i class="bi bi-clock-history fs-3"></i>
            </div>
            <div>
                <h4 class="fw-bold mb-1 text-dark">Lịch sử Yêu cầu hỗ trợ</h4>
                <div class="text-muted small">Theo dõi toàn bộ các lần bạn đã yêu cầu chỉnh sửa dự án và tiến độ hiện tại.</div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-custom align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 5%;">#</th>
                        <th style="width: 25%;">Dự án</th>
                        <th style="width: 30%;">Nội dung chỉnh sửa</th>
                        <th style="width: 15%;">Ngày gửi</th>
                        <th style="width: 15%;">Tài liệu đính kèm</th>
                        <th style="width: 10%;" class="text-center">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (supportHistory != null && supportHistory.Any())
                    {
                        int index = 1;
                        foreach (var item in supportHistory)
                        {
                            <tr>
                                <td class="fw-bold text-muted">@index</td>
                                <td>
                                    <div class="fw-bold text-primary">@(item.Project != null ? item.Project.ProjectName : "N/A")</div>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark mb-1">@item.Subject</div>
                                    <div class="text-muted small text-truncate" style="max-width: 300px;" title="@item.Message">@item.Message</div>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    <div class="small text-muted">@item.CreatedAt.ToString("HH:mm")</div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.AttachmentPath))
                                    {
                                        <a href="@item.AttachmentPath" target="_blank" class="btn btn-sm btn-outline-info rounded-pill fw-bold">
                                            <i class="bi bi-paperclip"></i> Xem file
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic">Không có</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge rounded-pill @GetStatusBadge(item.Status) px-3 py-2 w-100">
                                        @TranslateStatus(item.Status)
                                    </span>
                                </td>
                            </tr>
                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <img src="/images/no-data.svg" alt="No data" style="width: 120px; opacity: 0.5; margin-bottom: 15px;" onerror="this.style.display='none'">
                                <h6 class="text-muted fw-bold">Chưa có lịch sử yêu cầu nào.</h6>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<script>
    function showFileName() {
        var fileInput = document.getElementById('fileInput');
        var fileNameText = document.getElementById('fileNameText');
        if (fileInput.files.length > 0) {
            var fileName = fileInput.files[0].name;
            fileNameText.innerHTML = '<span class="text-primary fw-bold"><i class="bi bi-file-earmark-check-fill me-1"></i> Đã chọn: ' + fileName + '</span>';
        } else {
            fileNameText.innerHTML = 'Hỗ trợ: JPG, PNG, PDF, ZIP, RAR (Tối đa 20MB)';
        }
    }
</script>