@model IEnumerable<BDSKhanhHoa.Models.Notification>
@{
    ViewData["Title"] = "Trung tâm Thông báo";
    Layout = "~/Views/Shared/_UserLayout.cshtml";

    string currentFilter = ViewBag.CurrentFilter as string ?? "all";
    int unreadCount = ViewBag.UnreadCount ?? 0;
    int appointmentCount = ViewBag.AppointmentCount ?? 0;
    int actionCount = ViewBag.ActionCount ?? 0;
    int consultationCount = ViewBag.ConsultationCount ?? 0;
    int totalCount = ViewBag.TotalCount ?? 0;
}

<style>
    :root {
        --surface-color: #ffffff;
        --bg-color: #f8fafc;
        --border-color: #e2e8f0;
        --transition-std: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .noti-shell {
        min-height: 85vh;
    }

    .noti-filter-bar {
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        padding: 12px;
        display: flex;
        gap: 8px;
        margin-bottom: 24px;
        box-shadow: 0 4px 20px rgba(15,23,42,0.04);
        flex-wrap: nowrap;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

        .noti-filter-bar::-webkit-scrollbar {
            display: none;
        }

    .filter-btn {
        padding: 10px 18px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 0.95rem;
        color: #475569;
        text-decoration: none;
        transition: var(--transition-std);
        border: 1px solid transparent;
        display: flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
    }

        .filter-btn:hover {
            background: #f1f5f9;
            color: #0f172a;
        }

        .filter-btn.active {
            background: #0f172a;
            color: #ffffff;
            border-color: #0f172a;
            box-shadow: 0 4px 15px rgba(15,23,42,0.2);
        }

            .filter-btn.active .badge {
                background: #ffffff !important;
                color: #0f172a !important;
            }

    .noti-card {
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        padding: 24px;
        margin-bottom: 16px;
        display: flex;
        gap: 20px;
        transition: var(--transition-std);
        position: relative;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
    }

        .noti-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 35px rgba(15,23,42,0.08);
            border-color: #cbd5e1;
        }

        .noti-card.unread::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 6px;
            background: #3b82f6;
            border-radius: 6px 0 0 6px;
        }

    .noti-icon-wrap {
        width: 60px;
        height: 60px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        flex-shrink: 0;
    }

    .icon-info {
        background: #dbeafe;
        color: #2563eb;
    }

    .icon-action {
        background: #fef3c7;
        color: #d97706;
    }

    .icon-danger {
        background: #fee2e2;
        color: #dc2626;
    }

    .icon-success {
        background: #d1fae5;
        color: #059669;
    }

    .icon-consult {
        background: #e0e7ff;
        color: #0891b2;
    }

    .noti-content {
        flex-grow: 1;
        min-width: 0;
    }

    .noti-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .noti-text {
        font-size: 0.95rem;
        color: #475569;
        line-height: 1.6;
        margin-bottom: 14px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .noti-meta {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .action-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background: #f1f5f9;
        color: #334155;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 800;
        border: 1px solid #e2e8f0;
        transition: 0.2s;
    }

    .noti-card:hover .action-badge {
        background: #0f172a;
        color: #fff;
        border-color: #0f172a;
    }

    .btn-delete-noti {
        position: absolute;
        right: 24px;
        top: 24px;
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: #f1f5f9;
        color: #94a3b8;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition-std);
        opacity: 0;
        z-index: 2;
        font-size: 1.1rem;
    }

    .noti-card:hover .btn-delete-noti {
        opacity: 1;
    }

    .btn-delete-noti:hover {
        background: #fee2e2;
        color: #dc2626;
        transform: scale(1.1);
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background: #fff;
        border-radius: 24px;
        border: 1px dashed #cbd5e1;
    }

        .empty-state i {
            font-size: 5rem;
            color: #e2e8f0;
            margin-bottom: 20px;
            display: block;
        }

    @@media (max-width: 576px) {
        .noti-card {
            padding: 16px;
            gap: 12px;
        }

        .noti-icon-wrap {
            width: 45px;
            height: 45px;
            font-size: 1.2rem;
        }

        .noti-title {
            font-size: 1rem;
            flex-direction: column;
        }

        .btn-delete-noti {
            opacity: 1;
            top: 16px;
            right: 16px;
            width: 32px;
            height: 32px;
            font-size: 0.9rem;
        }
    }
</style>

<div class="noti-shell animate__animated animate__fadeIn">
    <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
        <div>
            <h3 class="fw-black text-dark mb-1"><i class="bi bi-bell-fill text-primary me-2"></i>Hộp Thư Hệ Thống</h3>
            <p class="text-muted mb-0 fs-6">Nhận thông tin Lịch hẹn, Yêu cầu tư vấn và Cảnh báo hệ thống.</p>
        </div>
        @if (unreadCount > 0)
        {
            <form id="markAllForm" class="m-0">
                @Html.AntiForgeryToken()
                <button type="button" class="btn btn-dark rounded-pill fw-bold px-4 py-2 shadow-sm" id="btnMarkAllRead">
                    <i class="bi bi-check2-all me-1"></i> Đánh dấu tất cả đã đọc
                </button>
            </form>
        }
    </div>

    <!-- BỘ LỌC CHI TIẾT -->
    <div class="noti-filter-bar">
        <a href="/Notification/Index?filter=all" class="filter-btn @(currentFilter == "all" ? "active" : "")">
            <i class="bi bi-collection"></i> Tất cả hòm thư
        </a>
        <a href="/Notification/Index?filter=unread" class="filter-btn @(currentFilter == "unread" ? "active" : "")">
            <i class="bi bi-envelope-exclamation"></i> Chưa đọc
            @if (unreadCount > 0)
            {
                <span class="badge bg-danger rounded-pill">@unreadCount</span>
            }
        </a>
        <a href="/Notification/Index?filter=appointment" class="filter-btn @(currentFilter == "appointment" ? "active" : "")">
            <i class="bi bi-calendar-check text-success"></i> Lịch hẹn báo
            @if (appointmentCount > 0)
            {
                <span class="badge bg-success rounded-pill">@appointmentCount</span>
            }
        </a>
        <a href="/Notification/Index?filter=consultation" class="filter-btn @(currentFilter == "consultation" ? "active" : "")">
            <i class="bi bi-headset text-info"></i> Khách tương tác
            @if (consultationCount > 0)
            {
                <span class="badge bg-info text-dark rounded-pill">@consultationCount</span>
            }
        </a>
        <a href="/Notification/Index?filter=action" class="filter-btn @(currentFilter == "action" ? "active" : "")">
            <i class="bi bi-cursor-fill text-warning"></i> Chờ xử lý
            @if (actionCount > 0)
            {
                <span class="badge bg-warning text-dark rounded-pill">@actionCount</span>
            }
        </a>
        <a href="/Notification/Index?filter=system" class="filter-btn @(currentFilter == "system" ? "active" : "")">
            <i class="bi bi-shield-exclamation text-danger"></i> Cảnh báo hệ thống
        </a>
    </div>

    <!-- DANH SÁCH THÔNG BÁO -->
    <div class="noti-list">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                var titleLower = (item.Title ?? "").ToLower();
                bool hasAction = !string.IsNullOrWhiteSpace(item.ActionUrl);

                // CẬP NHẬT LOGIC NHẬN DIỆN MỚI NHẤT
                bool isDanger = titleLower.Contains("gỡ bỏ") || titleLower.Contains("khóa") || titleLower.Contains("từ chối") || titleLower.Contains("vi phạm") || titleLower.Contains("thất bại");
                bool isAppointment = titleLower.Contains("lịch hẹn");
                bool isConsultation = titleLower.Contains("tư vấn") || titleLower.Contains("liên hệ") || titleLower.Contains("bình luận");
                bool isSuccess = titleLower.Contains("thành công") || titleLower.Contains("duyệt");

                string cardClass = item.IsRead ? "" : "unread";

                // Nhận diện Icon thông minh
                string iconClass = "icon-info bi-info-circle-fill";
                if (isDanger) iconClass = "icon-danger bi-shield-fill-x";
                else if (isSuccess) iconClass = "icon-success bi-check-circle-fill";
                else if (isAppointment) iconClass = "icon-success bi-calendar2-check-fill";
                else if (isConsultation) iconClass = "icon-consult bi-headset";
                else if (hasAction) iconClass = "icon-action bi-exclamation-triangle-fill";

                string safeContent = "Không có thông tin chi tiết.";
                if (!string.IsNullOrWhiteSpace(item.Content))
                {
                    safeContent = System.Text.RegularExpressions.Regex.Replace(item.Content, "<.*?>", string.Empty);
                }

                <div class="position-relative" id="noti-row-@item.NotificationID">
                    <a href="/Notification/Details/@item.NotificationID" class="noti-card @cardClass">
                        <div class="noti-icon-wrap @iconClass.Split(' ')[0]">
                            <i class="bi @iconClass.Split(' ')[1]"></i>
                        </div>
                        <div class="noti-content">
                            <div class="noti-title">
                                <span>@(item.Title ?? "Thông báo mới từ hệ thống")</span>
                                <span class="noti-meta"><i class="bi bi-clock-history"></i> @item.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</span>
                            </div>
                            <div class="noti-text">
                                @safeContent
                            </div>

                            @if (hasAction)
                            {
                                <div class="action-badge">
                                    @if (isAppointment)
                                    {
                                        <i class="bi bi-calendar-event text-success"></i>
                                    }
                                    else if (isDanger)
                                    {

                                        <i class="bi bi-exclamation-octagon text-danger"></i>
                                    }
                                    else
                                    {

                                        <i class="bi bi-box-arrow-up-right text-primary"></i>
                                    }
                                    @(string.IsNullOrWhiteSpace(item.ActionText) ? "Nhấn vào để truy cập" : item.ActionText)
                                </div>
                            }
                        </div>
                    </a>

                    <!-- Nút Xóa đè bằng CSS -->
                    <form class="d-inline" id="form-del-@item.NotificationID">
                        @Html.AntiForgeryToken()
                        <button type="button" class="btn-delete-noti shadow-sm" onclick="deleteNoti(event, @item.NotificationID)" title="Xóa thông báo">
                            <i class="bi bi-trash3-fill"></i>
                        </button>
                    </form>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox-fill"></i>
                <h3 class="fw-black text-dark mb-2">Hộp thư gọn gàng</h3>
                <p class="text-muted fs-5">Bạn không có thông báo nào trong danh mục <strong>"@currentFilter"</strong>.</p>
            </div>
        }
    </div>

    <!-- PHÂN TRANG -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-center mt-5">
            <nav>
                <ul class="pagination pagination-lg">
                    <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="/Notification/Index?filter=@currentFilter&page=@(ViewBag.CurrentPage - 1)"><i class="bi bi-chevron-left"></i></a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link shadow-sm" href="/Notification/Index?filter=@currentFilter&page=@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="/Notification/Index?filter=@currentFilter&page=@(ViewBag.CurrentPage + 1)"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Xử lý AJAX: Đánh dấu tất cả đã đọc
        $('#btnMarkAllRead').click(function () {
            const form = $('#markAllForm');
            const token = $('input[name="__RequestVerificationToken"]', form).val();

            const btn = $(this);
            const originalText = btn.html();
            btn.html('<span class="spinner-border spinner-border-sm me-2"></span> Đang xử lý...');
            btn.prop('disabled', true);

            $.ajax({
                url: '/Notification/MarkAllAsRead',
                type: 'POST',
                data: { __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        Swal.fire('Lỗi', res.message, 'error');
                        btn.html(originalText);
                        btn.prop('disabled', false);
                    }
                },
                error: function() {
                    Swal.fire('Lỗi', 'Lỗi kết nối mạng, vui lòng thử lại.', 'error');
                    btn.html(originalText);
                    btn.prop('disabled', false);
                }
            });
        });

        // Xử lý AJAX: Xóa một thông báo bằng hiệu ứng trượt
        function deleteNoti(e, id) {
            e.preventDefault();
            e.stopPropagation();

            Swal.fire({
                title: 'Gỡ thông báo này?',
                text: "Dữ liệu sẽ bị xóa vĩnh viễn khỏi hộp thư.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: '<i class="bi bi-trash"></i> Xóa',
                cancelButtonText: 'Đóng'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]', '#form-del-' + id).val();
                    $.ajax({
                        url: '/Notification/Delete',
                        type: 'POST',
                        data: { id: id, __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                $('#noti-row-' + id).css({
                                    'transform': 'translateX(100%)',
                                    'opacity': '0',
                                    'transition': 'all 0.4s ease'
                                });
                                setTimeout(function() {
                                    $('#noti-row-' + id).slideUp(300, function() { $(this).remove(); });
                                }, 400);
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã xóa tin nhắn', showConfirmButton: false, timer: 2000 });
                            } else {
                                Swal.fire('Lỗi', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }
    </script>
}