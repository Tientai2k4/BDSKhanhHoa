@model BDSKhanhHoa.ViewModels.ForgotPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Quên mật khẩu | Bất Động Sản Khánh Hòa</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <style>
        body {
            background: url('https://images.unsplash.com/photo-1560518883-ce09059eeffa?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .overlay {
            background: rgba(0, 0, 0, 0.6);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            border: none;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
        }

        .btn-primary-gradient {
            background: linear-gradient(45deg, #0061f2, #6900d1);
            border: none;
            padding: 12px;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-primary-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,97,242,0.4);
            }
    </style>
</head>
<body>
    <div class="overlay">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-5">
                    <div class="card login-card p-4 p-md-5 animate__animated animate__fadeInDown">
                        <div class="text-center mb-4">
                            <h3 class="fw-bold text-primary">Quên Mật Khẩu</h3>
                            <p class="text-muted small">Nhập Email bạn đã đăng ký, chúng tôi sẽ gửi mã xác nhận để bạn đặt lại mật khẩu.</p>
                        </div>

                        <form asp-action="ForgotPassword" method="post">
                            <div class="mb-4">
                                <label class="form-label small fw-bold">Email của bạn</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-envelope text-primary"></i></span>
                                    <input asp-for="Email" class="form-control border-start-0" placeholder="VD: nguyenvanA@gmail.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                            </div>

                            <button type="submit" class="btn btn-primary-gradient w-100 text-white shadow mb-3">GỬI MÃ XÁC NHẬN</button>

                            <div class="text-center mt-3">
                                <a href="/Account/Login" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left"></i> Quay lại đăng nhập</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>