@model BDSKhanhHoa.ViewModels.ForgotPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Quên mật khẩu | BDS Khánh Hòa</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light d-flex align-items-center" style="height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="card border-0 shadow-lg p-4" style="border-radius: 15px;">
                    <div class="text-center mb-4">
                        <h4 class="fw-bold">Khôi phục mật khẩu</h4>
                        <p class="text-muted small">Nhập email đã đăng ký, chúng tôi sẽ gửi mật khẩu mới cho bạn.</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
                    }

                    <form asp-action="ForgotPassword" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email của bạn</label>
                            <input asp-for="Email" class="form-control" placeholder="Nhập email của bạn ở đây " style="padding: 12px; border-radius: 10px;" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 10px; background: #0061f2;">GỬI MẬT KHẨU MỚI</button>
                    </form>

                    <div class="text-center mt-4">
                        <a href="/Account/Login" class="text-decoration-none small fw-bold">Quay lại đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>