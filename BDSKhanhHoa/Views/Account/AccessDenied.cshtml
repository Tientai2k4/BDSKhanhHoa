@{
    Layout = null;
    ViewData["Title"] = "Từ chối truy cập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Bất Động Sản Khánh Hòa</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .error-card {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
            max-width: 550px;
            width: 100%;
            padding: 50px 40px;
            text-align: center;
            border-top: 5px solid #dc3545;
        }

        .error-icon {
            font-size: 80px;
            color: #dc3545;
            margin-bottom: 20px;
            line-height: 1;
        }

        .btn-back {
            background: linear-gradient(135deg, #0d6efd, #0dcaf0);
            color: #fff;
            border: none;
            padding: 12px 30px;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            margin-top: 20px;
        }

            .btn-back:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(13, 110, 253, 0.3);
                color: #fff;
            }
    </style>
</head>
<body>
    <div class="container px-3">
        <div class="error-card mx-auto">
            <div class="error-icon">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h2 class="fw-bold text-dark mb-3">TỪ CHỐI TRUY CẬP</h2>
            <h5 class="text-danger mb-4">Lỗi 403 - Forbidden</h5>

            <p class="text-muted mb-4 fs-6" style="line-height: 1.6;">
                Xin lỗi, tài khoản của bạn không có đủ thẩm quyền để truy cập vào khu vực này.
                Vui lòng liên hệ với Quản trị viên cấp cao (Admin) nếu bạn cho rằng đây là một sự nhầm lẫn.
            </p>

            @if (!string.IsNullOrEmpty(ViewBag.ReturnUrl))
            {
                <div class="bg-light p-3 rounded-3 mb-4 border text-start">
                    <span class="small fw-bold text-muted text-uppercase d-block mb-1">Đường dẫn bị chặn:</span>
                    <code class="text-danger text-break">@ViewBag.ReturnUrl</code>
                </div>
            }

            <div class="d-flex justify-content-center gap-3">
                <a href="javascript:history.back()" class="btn btn-light rounded-pill px-4 py-2 border fw-bold text-secondary shadow-sm">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                </a>
                <a href="/" class="btn btn-back mt-0 shadow-sm">
                    <i class="bi bi-house-door-fill me-2"></i>Về Trang Chủ
                </a>
            </div>
        </div>
    </div>
</body>
</html>