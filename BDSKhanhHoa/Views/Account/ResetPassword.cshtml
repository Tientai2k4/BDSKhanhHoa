@model dynamic
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đặt lại mật khẩu | BĐS Khánh Hòa</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light d-flex align-items-center" style="height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="card border-0 shadow-lg p-4" style="border-radius: 15px;">
                    <div class="text-center mb-4">
                        <h4 class="fw-bold">Thiết lập mật khẩu mới</h4>
                        <p class="text-muted small">Nhập mã xác nhận từ Email và mật khẩu mới của bạn.</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
                    }

                    <form asp-action="ResetPassword" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Mã xác nhận (Token)</label>
                            <input name="token" class="form-control" placeholder="Nhập mã 8 ký tự" required style="border-radius: 10px;" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Mật khẩu mới</label>
                            <input name="newPassword" type="password" class="form-control" placeholder="••••••••" required style="border-radius: 10px;" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 10px; background: #0061f2;">CẬP NHẬT MẬT KHẨU</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>