@model BDSKhanhHoa.Models.User
@{
    ViewData["Title"] = "Trang cá nhân";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-5">
                        <div class="position-relative d-inline-block">
                            <img id="avatarPreview" src="@(Model.Avatar ?? "/images/avatars/default-user.png")"
                                 class="rounded-circle border border-4 border-white shadow"
                                 style="width: 130px; height: 130px; object-fit: cover;">

                            <form asp-action="UpdateAvatar" method="post" enctype="multipart/form-data" id="formAvatar">
                                <label for="fileAvatar" class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                                       style="width: 35px; height: 35px; cursor: pointer; border: 2px solid white;">
                                    <i class="bi bi-camera-fill"></i>
                                </label>
                                <input type="file" id="fileAvatar" name="AvatarFile" hidden accept="image/*" onchange="document.getElementById('formAvatar').submit();">
                            </form>
                        </div>
                        <h4 class="fw-bold mt-3 mb-1">@Model.FullName</h4>
                        <p class="text-muted small">Thành viên từ: @Model.CreatedAt?.ToString("dd/MM/yyyy")</p>
                    </div>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success border-0 small shadow-sm mb-4">@TempData["Success"]</div>
                    }

                    <form asp-action="UpdateProfile" method="post">
                        <input type="hidden" asp-for="UserID" />
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Họ và tên</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-person text-primary"></i></span>
                                    <input asp-for="FullName" class="form-control bg-light border-0" placeholder="Nhập họ tên...">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Số điện thoại</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-phone text-primary"></i></span>
                                    <input asp-for="Phone" class="form-control bg-light border-0" placeholder="Nhập số điện thoại...">
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small">Email (Không thể thay đổi)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-envelope text-muted"></i></span>
                                    <input asp-for="Email" class="form-control bg-light border-0 text-muted" readonly>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small">Địa chỉ</label>
                                <input asp-for="Address" class="form-control bg-light border-0" placeholder="Ví dụ: Nha Trang, Khánh Hòa">
                            </div>
                            <div class="col-12 text-center mt-5">
                                <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                                    LƯU THÔNG TIN
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>