@model BDSKhanhHoa.Models.User
@{
    ViewData["Title"] = "Quản lý hồ sơ hệ thống";

    bool isAdminOrStaff = User.IsInRole("Admin") || User.IsInRole("Staff");
    var businessProfile = ViewBag.BusinessProfile as BDSKhanhHoa.Models.BusinessProfile;
    bool isEnterprise = businessProfile != null && businessProfile.VerificationStatus == "Approved";

    if (isAdminOrStaff)
    {
        Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    }
    else if (isEnterprise)
    {
        Layout = "~/Views/Shared/_BusinessLayout.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_UserLayout.cshtml";
    }

    // Tính toán độ hoàn thiện hồ sơ
    int completionRate = 10;
    if (!string.IsNullOrEmpty(Model.Email)) completionRate += 10;
    if (!string.IsNullOrEmpty(Model.FullName)) completionRate += 15;
    if (!string.IsNullOrEmpty(Model.Phone)) completionRate += 15;
    if (Model.Avatar != null && !Model.Avatar.Contains("default")) completionRate += 10;
    if (!string.IsNullOrEmpty(Model.Address)) completionRate += 10;
    if (!string.IsNullOrEmpty(Model.Zalo)) completionRate += 10;
    if (isEnterprise && !string.IsNullOrEmpty(Model.Position)) completionRate += 20;
    if (!isEnterprise && !string.IsNullOrEmpty(Model.Facebook)) completionRate += 10;
    if (!isEnterprise && !string.IsNullOrEmpty(Model.Bio)) completionRate += 10;
}

<style>
    :root {
        --admin-gradient: linear-gradient(135deg, #1e293b 0%, #334155 100%);
        --member-gradient: linear-gradient(135deg, #0061f2 0%, #00cfd5 100%);
        --enterprise-gradient: linear-gradient(135deg, #0f172a 0%, #d97706 100%);
        --input-bg: #f8fafc;
        --border-color: #e2e8f0;
    }

    /* Card Styling */
    .profile-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        overflow: hidden;
        margin-bottom: 20px;
    }

    .profile-header-bg {
        height: 100px;
        background: @(isAdminOrStaff ? "var(--admin-gradient)" : (isEnterprise ? "var(--enterprise-gradient)" : "var(--member-gradient)"));
    }

    /* Avatar */
    .avatar-section {
        margin-top: -50px;
        position: relative;
    }

    .avatar-wrapper {
        width: 100px;
        height: 100px;
        margin: 0 auto;
        position: relative;
        border: 4px solid #fff;
        border-radius: 50%;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    .avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
    }

    .avatar-edit-btn {
        position: absolute;
        bottom: 0;
        right: 0;
        background: #fff;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: 1px solid #e2e8f0;
        color: #64748b;
        transition: all 0.2s;
    }

        .avatar-edit-btn:hover {
            background: #f8fafc;
            color: #0061f2;
        }

    /* Inputs */
    .form-label {
        font-weight: 600;
        font-size: 0.8rem;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        margin-bottom: 6px;
    }

    .input-group-custom {
        background: var(--input-bg);
        border: 1px solid var(--border-color);
        border-radius: 10px;
        padding: 2px 12px;
        display: flex;
        align-items: center;
        transition: all 0.2s ease;
    }

        .input-group-custom:focus-within {
            background: #fff;
            border-color: #0061f2;
            box-shadow: 0 0 0 3px rgba(0, 97, 242, 0.1);
        }

        .input-group-custom i {
            color: #94a3b8;
            margin-right: 10px;
            font-size: 1rem;
        }

        .input-group-custom input,
        .input-group-custom textarea {
            border: none;
            background: transparent;
            width: 100%;
            outline: none;
            padding: 10px 0;
            font-size: 0.95rem;
            font-weight: 500;
            color: #1e293b;
        }

    /* Stat Cards */
    .stat-card {
        background: #f8fafc;
        border-radius: 12px;
        padding: 12px;
        text-align: center;
        border: 1px solid #f1f5f9;
    }

        .stat-card h3 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .stat-card span {
            font-size: 0.65rem;
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
        }

    /* Mobile Responsive */
    @@media (max-width: 768px) {
        .profile-card {
            border-radius: 0;
            border-left: none;
            border-right: none;
        }

        .container-fluid {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        .btn-submit-mobile {
            width: 100%;
            padding: 12px !important;
        }
    }

    .biz-info-box {
        background: #f8fafc;
        border-radius: 10px;
        padding: 12px 15px;
        border-left: 4px solid #f59e0b;
    }

    .biz-info-label {
        display: block;
        font-size: 0.7rem;
        color: #64748b;
        text-transform: uppercase;
        font-weight: 700;
    }
</style>

<div class="container-fluid px-md-4 mt-3 animate__animated animate__fadeIn">
    <div class="row g-3">
        <!-- CỘT TRÁI: AVATAR & STATS -->
        <div class="col-lg-4 col-xl-3">
            <div class="profile-card pb-4">
                <div class="profile-header-bg"></div>
                <div class="avatar-section text-center">
                    <div class="avatar-wrapper">
                        <img src="@(Model.Avatar ?? "/images/avatars/default-user.png")" class="avatar-img" id="avatarPreview">
                        <form asp-action="UpdateAvatar" method="post" enctype="multipart/form-data" id="formAvatar">
                            <label for="fileAvatar" class="avatar-edit-btn shadow-sm" title="Đổi ảnh">
                                <i class="bi bi-camera-fill" style="font-size: 0.8rem;"></i>
                            </label>
                            <input type="file" id="fileAvatar" name="AvatarFile" hidden accept="image/*" onchange="document.getElementById('formAvatar').submit();">
                        </form>
                    </div>

                    <div class="mt-3 px-3">
                        <h5 class="fw-bold mb-0 text-truncate">@Model.FullName</h5>
                        <p class="text-muted small mb-2 text-truncate">@Model.Email</p>

                        @if (isAdminOrStaff)
                        {
                            <span class="badge bg-dark rounded-pill px-3 py-2"><i class="bi bi-shield-fill me-1"></i> Admin</span>
                        }
                        else if (isEnterprise)
                        {
                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i class="bi bi-patch-check-fill me-1"></i> Đối tác CĐT</span>
                        }
                        else
                        {
                            <span class="badge bg-primary rounded-pill px-3 py-2"><i class="bi bi-person-fill me-1"></i> Thành viên</span>
                        }
                    </div>
                </div>

                <div class="px-4 mt-4">
                    <div class="d-flex justify-content-between small fw-bold mb-1">
                        <span class="text-secondary" style="font-size: 0.7rem;">HỒ SƠ HOÀN THIỆN</span>
                        <span class="text-primary" style="font-size: 0.7rem;">@(completionRate > 100 ? 100 : completionRate)%</span>
                    </div>
                    <div class="progress" style="height: 6px; border-radius: 10px; background: #f1f5f9;">
                        <div class="progress-bar @(completionRate >= 80 ? "bg-success" : "bg-primary")"
                             style="width: @completionRate%"></div>
                    </div>

                    <div class="row g-2 mt-3 text-center">
                        @if (isAdminOrStaff)
                        {
                            <div class="col-6">
                                <div class="stat-card">
                                    <h3>@ViewBag.PendingAds</h3>
                                    <span>Chờ duyệt</span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-card">
                                    <h3>@ViewBag.NewReports</h3>
                                    <span>Báo cáo</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="col-6">
                                <div class="stat-card">
                                    <h3>@ViewBag.TotalProps</h3>
                                    <span>Tin đăng</span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-card">
                                    <h3>@ViewBag.TotalProjects</h3>
                                    <span>Dự án</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- CỘT PHẢI: FORM CHỈNH SỬA -->
        <div class="col-lg-8 col-xl-9">
            <div class="profile-card p-3 p-md-4">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3">
                        <i class="bi bi-person-vcard text-primary fs-4"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Thông tin cá nhân</h5>
                </div>

                <form asp-action="UpdateProfile" method="post">
                    <input type="hidden" asp-for="UserID" />

                    <div class="row g-3">
                        @if (isEnterprise)
                        {
                            <div class="col-12">
                                <div class="alert alert-primary border-0 rounded-4 d-flex align-items-center py-2 px-3 mb-2">
                                    <i class="bi bi-info-circle-fill me-2"></i>
                                    <span class="small fw-medium">Ghi chú: @(Model.AdminNote ?? "Tài khoản quản lý dự án hệ thống.")</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Người phụ trách</label>
                                <div class="input-group-custom">
                                    <i class="bi bi-person-check"></i>
                                    <input asp-for="FullName" required placeholder="Nhập họ tên...">
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Chức danh</label>
                                <div class="input-group-custom bg-light opacity-75">
                                    <i class="bi bi-briefcase"></i>
                                    <input asp-for="Position" readonly>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="col-md-6">
                                <label class="form-label">Họ và tên</label>
                                <div class="input-group-custom">
                                    <i class="bi bi-person"></i>
                                    <input asp-for="FullName" required placeholder="Nhập họ tên...">
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Điện thoại (Tối đa 10 số)</label>
                                <div class="input-group-custom">
                                    <i class="bi bi-telephone"></i>
                                    <input asp-for="Phone" required id="phoneInput" maxlength="10" placeholder="0xxxxxxxxx">
                                </div>
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Giới thiệu ngắn (Bio)</label>
                                <div class="input-group-custom">
                                    <textarea asp-for="Bio" rows="2" placeholder="Chia sẻ kinh nghiệm hoặc châm ngôn sống của bạn..."></textarea>
                                </div>
                            </div>
                        }

                        <div class="col-md-6">
                            <label class="form-label">Số Zalo CSKH</label>
                            <div class="input-group-custom">
                                <i class="bi bi-chat-dots text-info"></i>
                                <input asp-for="Zalo" id="zaloInput" maxlength="10" placeholder="Số điện thoại Zalo...">
                            </div>
                            <span asp-validation-for="Zalo" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Email liên hệ</label>
                            <div class="input-group-custom bg-light opacity-75">
                                <i class="bi bi-envelope"></i>
                                <input asp-for="Email" readonly>
                            </div>
                        </div>

                        @if (!isEnterprise)
                        {
                            <div class="col-12">
                                <label class="form-label">Link Facebook</label>
                                <div class="input-group-custom">
                                    <i class="bi bi-facebook text-primary"></i>
                                    <input asp-for="Facebook" placeholder="https://facebook.com/username">
                                </div>
                            </div>
                        }

                        <div class="col-12">
                            <label class="form-label">Địa chỉ</label>
                            <div class="input-group-custom">
                                <i class="bi bi-geo-alt"></i>
                                <input asp-for="Address" placeholder="VD: Nha Trang, Khánh Hòa...">
                            </div>
                        </div>

                        <div class="col-12 text-end mt-4">
                            <button type="submit" class="btn btn-primary px-5 py-2 fw-bold rounded-pill shadow-sm btn-submit-mobile">
                                <i class="bi bi-check2-circle me-1"></i> LƯU THAY ĐỔI
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            @if (isEnterprise && businessProfile != null)
            {
                <div class="profile-card p-3 p-md-4 mt-3">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-3">
                            <i class="bi bi-building-check text-warning fs-4"></i>
                        </div>
                        <h5 class="fw-bold mb-0">Hồ sơ Pháp nhân (KYC)</h5>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <div class="biz-info-box">
                                <span class="biz-info-label">Tên Doanh nghiệp</span>
                                <div class="fw-bold text-uppercase">@businessProfile.BusinessName</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="biz-info-box" style="border-left-color: #64748b;">
                                <span class="biz-info-label">Mã số thuế</span>
                                <div class="font-monospace">@businessProfile.TaxCode</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="biz-info-box" style="border-left-color: #64748b;">
                                <span class="biz-info-label">Email Công ty</span>
                                <div>@(businessProfile.BusinessEmail ?? "N/A")</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const setupPhoneValidation = (id) => {
            const input = document.getElementById(id);
            if (input) {
                input.addEventListener('input', function (e) {
                    // Lọc mọi thứ không phải số ra khỏi input
                    let value = this.value.replace(/[^0-9]/g, '');

                    // Tuyệt đối giới hạn ở 10 số
                    if (value.length > 10) {
                        value = value.substring(0, 10);
                    }
                    this.value = value;
                });
            }
        };

        setupPhoneValidation('phoneInput');
        setupPhoneValidation('zaloInput');
    </script>
}