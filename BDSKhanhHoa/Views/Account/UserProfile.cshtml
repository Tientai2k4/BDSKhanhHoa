@model BDSKhanhHoa.Models.User
@{
    ViewData["Title"] = "Hồ sơ: " + Model.FullName;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var properties = ViewBag.ActiveProperties as List<BDSKhanhHoa.Models.Property>;
    int trustScore = ViewBag.TrustScore ?? 0;
    string joinDate = Model.CreatedAt?.ToString("MM/yyyy") ?? "Gần đây";

    // Chuẩn hóa số điện thoại cho link Zalo
    string zaloLink = !string.IsNullOrEmpty(Model.Zalo) ? $"https://zalo.me/{Model.Zalo.Replace(" ", "")}" : "#";
}

<style>
    .seller-header-card {
        background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        overflow: hidden;
        margin-bottom: 40px;
    }

    .seller-cover {
        height: 140px;
        background: linear-gradient(90deg, var(--primary) 0%, var(--primary-2) 100%);
        position: relative;
    }

    .seller-avatar-wrap {
        position: absolute;
        bottom: -50px;
        left: 40px;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 5px solid #fff;
        background: #fff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

        .seller-avatar-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }

    .trust-badge {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 32px;
        height: 32px;
        background: #10b981;
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 3px solid #fff;
        font-size: 1rem;
    }

    .seller-info-section {
        padding: 60px 40px 30px;
    }

    .seller-name {
        font-size: 1.6rem;
        font-family: 'Sora', sans-serif;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .trust-score-bar {
        height: 8px;
        border-radius: 8px;
        background: #e2e8f0;
        width: 150px;
        overflow: hidden;
        margin-top: 8px;
    }

    .trust-score-fill {
        height: 100%;
        background: linear-gradient(90deg, #10b981, #34d399);
    }

    .contact-btn {
        padding: 12px 24px;
        border-radius: 14px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
        text-decoration: none;
    }

    .btn-call {
        background: #10b981;
        color: #fff;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
    }

        .btn-call:hover {
            background: #059669;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
        }

    .btn-zalo {
        background: #0068ff;
        color: #fff;
        box-shadow: 0 4px 15px rgba(0, 104, 255, 0.3);
    }

        .btn-zalo:hover {
            background: #0054cc;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 104, 255, 0.4);
        }

    .btn-fb {
        background: #f1f5f9;
        color: #1877f2;
        border: 1px solid #e2e8f0;
    }

        .btn-fb:hover {
            background: #e2e8f0;
            transform: translateY(-2px);
        }

    /* Kế thừa lại CSS của Property Card từ trang Search (Rút gọn) */
    .property-card {
        background: #fff;
        border-radius: 16px;
        border: 1.5px solid #eaecf5;
        overflow: hidden;
        transition: 0.25s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        position: relative;
    }

        .property-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 40px rgba(26,86,219,0.12);
            border-color: #c6d4f5;
        }

    .card-img-wrapper {
        position: relative;
        height: 200px;
        overflow: hidden;
    }

        .card-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .card-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        font-size: 0.68rem;
        font-weight: 800;
        text-transform: uppercase;
        padding: 5px 12px;
        border-radius: 20px;
        z-index: 10;
    }

    .card-content {
        padding: 16px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .card-price {
        color: var(--primary-2);
        font-weight: 800;
        font-size: 1.15rem;
        margin-bottom: 8px;
    }

    .card-title {
        font-weight: 600;
        font-size: 0.92rem;
        color: #0f172a;
        margin-bottom: 14px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    @@media (max-width: 768px) {
        .seller-avatar-wrap {
            left: 50%;
            transform: translateX(-50%);
        }

        .seller-info-section {
            text-align: center;
            padding: 60px 20px 20px;
        }

        .seller-name {
            justify-content: center;
        }

        .trust-score-bar {
            margin: 8px auto;
        }

        .action-buttons {
            justify-content: center;
            flex-wrap: wrap;
        }
    }
</style>

<div class="container py-5">
    <div class="seller-header-card">
        <div class="seller-cover">
            <div class="seller-avatar-wrap">
                <img src="@(Model.Avatar ?? "/images/avatars/default-user.png")" alt="@Model.FullName" onerror="this.src='/images/avatars/default-user.png'">
                @if (trustScore >= 80)
                {
                    <div class="trust-badge" title="Tài khoản uy tín cao"><i class="bi bi-shield-check"></i></div>
                }
            </div>
        </div>
        <div class="seller-info-section">
            <div class="row align-items-center g-4">
                <div class="col-lg-6">
                    <h1 class="seller-name">
                        @Model.FullName
                        @if (Model.IsEmailVerified == true)
                        {
                            <i class="bi bi-patch-check-fill text-primary fs-5" title="Đã xác thực danh tính"></i>
                        }
                    </h1>
                    <p class="text-muted mb-2"><i class="bi bi-calendar3 me-2"></i>Thành viên từ: @joinDate</p>

                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="small fw-bold text-dark">Chỉ số uy tín: @trustScore%</span>
                        @if (trustScore == 100)
                        {
                            <span class="badge bg-success small">Tuyệt đối</span>
                        }
                    </div>
                    <div class="trust-score-bar">
                        <div class="trust-score-fill" style="width: @trustScore%"></div>
                    </div>
                </div>

                <div class="col-lg-6 text-lg-end">
                    <div class="action-buttons d-flex gap-2 justify-content-lg-end">
                        <a href="tel:@Model.Phone" class="contact-btn btn-call">
                            <i class="bi bi-telephone-outbound-fill"></i> Gọi @Model.Phone
                        </a>

                        @if (!string.IsNullOrEmpty(Model.Zalo))
                        {
                            <a href="@zaloLink" target="_blank" class="contact-btn btn-zalo">
                                Chat Zalo
                            </a>
                        }

                        @if (!string.IsNullOrEmpty(Model.Facebook))
                        {
                            <a href="@Model.Facebook" target="_blank" class="contact-btn btn-fb" title="Xem Facebook">
                                <i class="bi bi-facebook"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h3 class="fw-bold mb-1 font-sora">Đang rao bán / cho thuê</h3>
            <p class="text-muted mb-0">Hiển thị <strong class="text-primary">@ViewBag.TotalActive</strong> bất động sản từ @Model.FullName</p>
        </div>
    </div>

    <div class="row g-4">
        @if (properties != null && properties.Any())
        {
            foreach (var item in properties)
            {
                // Xử lý huy hiệu gói (Badge)
                string badgeHtml = "<span class='card-badge bg-light text-secondary border'><i class='bi bi-tag-fill me-1'></i> Tin Thường</span>";
                if (item.PackageID == 4) badgeHtml = "<span class='card-badge text-white' style='background: linear-gradient(135deg, #00c6ff, #0072ff);'><i class='bi bi-gem me-1'></i> Kim Cương</span>";
                else if (item.PackageID == 3) badgeHtml = "<span class='card-badge text-dark' style='background: linear-gradient(135deg, #f6d365, #fda085);'><i class='bi bi-star-fill me-1'></i> Vàng</span>";
                else if (item.PackageID == 2) badgeHtml = "<span class='card-badge text-dark' style='background: linear-gradient(135deg, #e2e2e2, #bdc3c7);'><i class='bi bi-shield-fill me-1'></i> Bạc</span>";

                <div class="col-xl-3 col-lg-4 col-md-6 col-12">
                    <a href="/Property/Details/@item.PropertyID" class="text-decoration-none d-block h-100">
                        <div class="property-card">
                            <div class="card-img-wrapper">
                                <img src="@(string.IsNullOrEmpty(item.MainImage) ? "/images/no-image.jpg" : item.MainImage)" alt="@item.Title" loading="lazy">
                                @Html.Raw(badgeHtml)
                            </div>
                            <div class="card-content">
                                <div class="card-price">
                                    @(item.Price.HasValue ? (item.Price >= 1000000000m ? (item.Price.Value / 1000000000m).ToString("0.##") + " Tỷ" : (item.Price.Value / 1000000m).ToString("0.##") + " Triệu") : "Thỏa thuận")
                                </div>
                                <div class="card-title" title="@item.Title">@item.Title</div>
                                <div class="d-flex justify-content-between align-items-center pt-2 mt-auto border-top text-muted small fw-bold">
                                    <span><i class="bi bi-rulers me-1"></i>@item.AreaSize m²</span>
                                    <span class="text-truncate" style="max-width: 55%;"><i class="bi bi-geo-alt me-1"></i>@(item.Ward?.Area?.AreaName ?? "Khánh Hòa")</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 4rem; opacity: 0.3;"></i>
                <h5 class="mt-3 fw-bold text-dark">Chưa có tin đăng nào</h5>
                <p class="text-muted">Người dùng này hiện không có bất động sản nào đang được giao dịch.</p>
            </div>
        }
    </div>
</div>