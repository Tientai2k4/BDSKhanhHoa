@model BDSKhanhHoa.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 mt-4 animate__animated animate__fadeIn">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 70px; height: 70px;">
                        <i class="bi bi-shield-lock-fill fs-2"></i>
                    </div>
                    <h4 class="fw-bold text-dark">Thay Đổi Mật Khẩu</h4>
                    <p class="text-muted small">Mật khẩu mới nên có ít nhất 6 ký tự, bao gồm chữ và số.</p>
                </div>

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Mật khẩu hiện tại -->
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary small">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock"></i></span>
                            <input type="password" name="OldPassword" class="form-control py-2 bg-light border-start-0" required placeholder="Nhập mật khẩu cũ..." id="oldPass">
                            <button class="btn btn-outline-secondary border-start-0 bg-light" type="button" onclick="togglePassword('oldPass', 'iconOld')">
                                <i class="bi bi-eye-slash" id="iconOld"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Mật khẩu mới -->
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary small">Mật khẩu mới <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-key"></i></span>
                            <input type="password" name="NewPassword" class="form-control py-2 bg-light border-start-0" required placeholder="Nhập mật khẩu mới..." id="newPass">
                            <button class="btn btn-outline-secondary border-start-0 bg-light" type="button" onclick="togglePassword('newPass', 'iconNew')">
                                <i class="bi bi-eye-slash" id="iconNew"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <!-- Xác nhận mật khẩu mới -->
                    <div class="mb-4">
                        <label class="form-label fw-bold text-secondary small">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-check-circle"></i></span>
                            <input type="password" name="ConfirmPassword" class="form-control py-2 bg-light border-start-0" required placeholder="Nhập lại mật khẩu mới..." id="confirmPass">
                            <button class="btn btn-outline-secondary border-start-0 bg-light" type="button" onclick="togglePassword('confirmPass', 'iconConfirm')">
                                <i class="bi bi-eye-slash" id="iconConfirm"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold rounded-pill shadow-sm py-2">
                            <i class="bi bi-arrow-repeat me-2"></i> CẬP NHẬT MẬT KHẨU
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(inputId, iconId) {
            const passwordInput = document.getElementById(inputId);
            const icon = document.getElementById(iconId);

            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            } else {
                passwordInput.type = "password";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            }
        }
    </script>
}