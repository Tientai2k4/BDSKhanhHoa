@model BDSKhanhHoa.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập | Bất Động Sản Khánh Hòa</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <style>
        body {
            background: url('https://images.unsplash.com/photo-1560518883-ce09059eeffa?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .overlay {
            background: rgba(0, 0, 0, 0.6);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            border: none;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
        }

        .btn-primary-gradient {
            background: linear-gradient(45deg, #0061f2, #6900d1);
            border: none;
            padding: 12px;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-primary-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,97,242,0.4);
            }

        .form-control {
            border-radius: 10px;
            padding: 12px;
            background: #f8f9fa;
        }
    </style>
</head>
<body>
    <div class="overlay">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-5">
                    <div class="card login-card p-4 p-md-5 animate__animated animate__fadeInUp">
                        <div class="text-center mb-4">
                            <h2 class="fw-bold text-primary">Bất Động Sản Khánh Hòa</h2>
                            <p class="text-muted">Đăng nhập để tiếp tục khám phá</p>
                        </div>

                        <form asp-action="Login" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold">Email hoặc Tên đăng nhập</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-person text-primary"></i></span>
                                    <input asp-for="AccountName" class="form-control border-start-0" placeholder="Nhập tên đăng nhập " />
                                </div>
                                <span asp-validation-for="AccountName" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold">Mật khẩu</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-lock text-primary"></i></span>
                                    <input asp-for="Password" type="password" id="loginPass" class="form-control border-start-0 border-end-0" placeholder="••••••••" />
                                    <button type="button" class="input-group-text bg-white border-start-0" onclick="toggleLoginPass()">
                                        <i class="bi bi-eye-slash" id="toggleIcon"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <script>
                                function toggleLoginPass() {
                                    const passInput = document.getElementById('loginPass');
                                    const icon = document.getElementById('toggleIcon');
                                    if (passInput.type === "password") {
                                        passInput.type = "text";
                                        icon.classList.replace('bi-eye-slash', 'bi-eye');
                                    } else {
                                        passInput.type = "password";
                                        icon.classList.replace('bi-eye', 'bi-eye-slash');
                                    }
                                }
                            </script>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input asp-for="RememberMe" class="form-check-input" />
                                    <label class="form-check-label small">Duy trì đăng nhập</label>
                                </div>
                                <a href="/Account/ForgotPassword" class="small text-decoration-none">Quên mật khẩu?</a>
                            </div>

                            <button type="submit" class="btn btn-primary-gradient w-100 text-white shadow mb-3">ĐĂNG NHẬP NGAY</button>

                            <div class="text-center mb-3 text-muted small">Hoặc đăng nhập bằng</div>

                            <a href="/Account/LoginGoogle"
                               class="btn btn-outline-dark w-100 d-flex align-items-center justify-content-center py-2 mb-4"
                               style="border-radius: 10px;">

                                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
                                     alt="Google"
                                     width="20"
                                     height="20"
                                     class="me-2"
                                     style="display:inline-block;">

                                <span class="fw-semibold">Đăng nhập với Google</span>
                            </a>

                            <div class="text-center">
                                <span class="text-muted small">Chưa có tài khoản?</span>
                                <a href="/Account/Register" class="fw-bold text-primary text-decoration-none ms-1">Đăng ký ngay</a>
                            </div>
                        </form>
                    </div>
                    <div class="text-center mt-4 text-white-50 small">
                        &copy; 2026 - ĐATN Nguyễn Tiến Tài - Đại Học Nha Trang
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Sử dụng Html.Raw để hiển thị tiếng Việt chính xác trong JavaScript

        @if (TempData["Success"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: '@Html.Raw(TempData["Success"])',
                    confirmButtonColor: '#0061f2',
                    timer: 5000
                });
                </text>
        }

        @if (TempData["Error"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi...',
                    text: '@Html.Raw(TempData["Error"])',
                    confirmButtonColor: '#d33'
                });
                </text>
        }
    </script>
</body>
</html>