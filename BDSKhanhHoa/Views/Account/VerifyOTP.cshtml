@{
    ViewData["Title"] = "Xác thực Email";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xác thực OTP - BDS Khánh Hòa</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8fafc;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .otp-card {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
            max-width: 480px;
            width: 100%;
            text-align: center;
        }

        .otp-inputs {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin: 30px 0;
        }

            .otp-inputs input {
                width: 50px;
                height: 60px;
                font-size: 24px;
                text-align: center;
                font-weight: bold;
                border-radius: 12px;
                border: 2px solid #e2e8f0;
                background: #f8fafc;
                transition: 0.3s;
            }

                .otp-inputs input:focus {
                    border-color: #2563eb;
                    background: white;
                    outline: none;
                    box-shadow: 0 0 0 4px #eff6ff;
                }

        .btn-verify {
            background: #2563eb;
            border: none;
            padding: 14px;
            font-weight: 700;
            border-radius: 12px;
            width: 100%;
            color: white;
            transition: 0.3s;
        }

            .btn-verify:hover {
                background: #1d4ed8;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>
    <div class="otp-card animate__animated animate__fadeInUp">
        <h3 class="fw-bold mb-2 text-dark">Xác Thực Tài Khoản</h3>
        <p class="text-muted small mb-4">Vui lòng nhập mã OTP 6 số đã được gửi đến email <br /><strong class="text-primary">@TempData["EmailToVerify"]</strong></p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 small fw-bold">@ViewBag.Error</div>
        }
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning py-2 small fw-bold">@TempData["Warning"]</div>
        }

        <form asp-action="VerifyOTP" method="post" id="otpForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="otp" id="fullOtp" />
            <div class="otp-inputs" id="otpContainer">
                <input type="text" maxlength="1" pattern="[0-9]" autofocus>
                <input type="text" maxlength="1" pattern="[0-9]">
                <input type="text" maxlength="1" pattern="[0-9]">
                <input type="text" maxlength="1" pattern="[0-9]">
                <input type="text" maxlength="1" pattern="[0-9]">
                <input type="text" maxlength="1" pattern="[0-9]">
            </div>
            <button type="submit" class="btn-verify">Xác Thực Ngay</button>
        </form>
    </div>

    <script>
        // Xử lý tự động nhảy sang ô tiếp theo khi nhập OTP
        const inputs = document.querySelectorAll('.otp-inputs input');
        const hiddenInput = document.getElementById('fullOtp');

        inputs.forEach((input, index) => {
            input.addEventListener('keyup', (e) => {
                if (e.target.value.length === 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
                updateHiddenInput();
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && e.target.value === '' && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });

        function updateHiddenInput() {
            hiddenInput.value = Array.from(inputs).map(i => i.value).join('');
        }
    </script>
</body>
</html>