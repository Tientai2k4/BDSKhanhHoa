@model IEnumerable<BDSKhanhHoa.Models.ProjectLead>
@using System.Globalization

@{
    ViewData["Title"] = "Phễu Khách Hàng (CRM)";
    Layout = "~/Views/Shared/_BusinessLayout.cshtml";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string currentStatus = ViewBag.CurrentStatus as string;
    int? currentProjectId = ViewBag.CurrentProjectId as int?;
    string keyword = ViewBag.CurrentKeyword as string ?? string.Empty;
}

<!-- CDN SweetAlert2 để hiển thị thông báo -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
        --crm-primary: #4f46e5;
        --crm-slate-50: #f8fafc;
        --crm-slate-200: #e2e8f0;
        --radius-xl: 16px;
    }

    .glass-panel {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: var(--radius-xl);
        border: 1px solid var(--crm-slate-200);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .table-crm thead th {
        background: var(--crm-slate-50);
        color: #64748b;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 800;
        padding: 16px 20px;
        border-bottom: 2px solid var(--crm-slate-200);
    }

    .table-crm tbody td {
        padding: 16px 20px;
        vertical-align: middle;
        border-bottom: 1px solid var(--crm-slate-50);
    }

    .badge-crm {
        padding: 8px 16px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.75rem;
    }

    .status-new {
        background: #fee2e2;
        color: #b91c1c;
        border: 1px solid #fca5a5;
    }

    .status-contact {
        background: #fef3c7;
        color: #b45309;
        border: 1px solid #fcd34d;
    }

    .status-resolved {
        background: #dcfce7;
        color: #047857;
        border: 1px solid #86efac;
    }

    .status-invalid {
        background: #f3f4f6;
        color: #374151;
        border: 1px solid #d1d5db;
    }

    .note-box {
        background: #fffbeb;
        border-left: 3px solid #f59e0b;
        padding: 8px 12px;
        border-radius: 8px;
        font-size: 0.8rem;
        color: #92400e;
        margin-top: 8px;
    }
</style>

<div class="container-fluid py-4 animate__animated animate__fadeIn">

    @if (TempData["Success"] != null)
    {
        <script>Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: '@TempData["Success"]', showConfirmButton: false, timer: 3000 });</script>
    }
    @if (TempData["Error"] != null)
    {
        <script>Swal.fire({ toast: true, position: 'top-end', icon: 'error', title: '@TempData["Error"]', showConfirmButton: false, timer: 4000 });</script>
    }

    <!-- Header & Thống kê -->
    <div class="glass-panel p-4 mb-4 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <h4 class="fw-bolder text-dark mb-1"><i class="bi bi-funnel-fill text-primary me-2"></i>QUẢN TRỊ KHÁCH HÀNG TIỀM NĂNG</h4>
            <p class="text-muted mb-0 small">Phân hệ CRM dành riêng cho Chủ đầu tư và Quản lý dự án.</p>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <span class="badge bg-light text-dark border fs-6 px-3 py-2 rounded-pill shadow-sm">Tổng: @ViewBag.TotalLeads Lead</span>
            <span class="badge bg-danger fs-6 px-3 py-2 rounded-pill shadow-sm animate__animated animate__pulse animate__infinite">Mới: @ViewBag.NewLeads chờ gọi</span>
            <span class="badge bg-secondary fs-6 px-3 py-2 rounded-pill shadow-sm">Hủy/Rác: @(ViewBag.InvalidLeads ?? 0)</span>

            <a href="@Url.Action("ExportLeadsToCsv", new { projectId = ViewBag.CurrentProjectId })" class="btn btn-success fw-bold rounded-pill px-4 shadow-sm ms-2">
                <i class="bi bi-file-earmark-excel-fill me-1"></i> Xuất File
            </a>
        </div>
    </div>

    <!-- Bộ lọc tìm kiếm -->
    <div class="glass-panel p-4 mb-4">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-xl-4 col-md-6">
                <label class="form-label small fw-bold text-muted text-uppercase">Dự án quản lý</label>
                <select name="projectId" class="form-select border-secondary shadow-sm fw-bold" asp-items="ViewBag.ProjectList">
                    <option value="">-- Toàn bộ dự án --</option>
                </select>
            </div>
            <div class="col-xl-3 col-md-6">
                <label class="form-label small fw-bold text-muted text-uppercase">Giai đoạn Sale</label>
                <select name="status" class="form-select border-secondary shadow-sm fw-bold">
                    <option value="">Tất cả trạng thái</option>
                    <option value="New" selected="@(currentStatus == "New")">🆕 Khách mới</option>
                    <option value="Contacted" selected="@(currentStatus == "Contacted")">⏳ Đang chăm sóc</option>
                    <option value="Resolved" selected="@(currentStatus == "Resolved")">✅ Chốt thành công</option>
                    <option value="Invalid" selected="@(currentStatus == "Invalid")">❌ Hủy / Sai số (Lead Rác)</option>
                </select>
            </div>
            <div class="col-xl-3 col-md-8">
                <label class="form-label small fw-bold text-muted text-uppercase">Từ khóa</label>
                <input type="text" name="keyword" value="@keyword" class="form-control border-secondary shadow-sm" placeholder="Tên, SĐT, Email khách hàng..." />
            </div>
            <div class="col-xl-2 col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm"><i class="bi bi-search"></i> Lọc</button>
            </div>
        </form>
    </div>

    <!-- Bảng dữ liệu -->
    <div class="glass-panel overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover table-crm mb-0">
                <thead>
                    <tr>
                        <th>Khách hàng / Liên hệ</th>
                        <th>Dự án quan tâm</th>
                        <th width="30%">Nhu cầu & Ghi chú (Note)</th>
                        <th>Thời gian</th>
                        <th>Pipeline Trạng thái</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var lead in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark fs-6 mb-1">@lead.Name</div>
                                    <div class="d-flex gap-2 mt-2">
                                        <a href="tel:@lead.Phone" class="badge bg-success-subtle text-success text-decoration-none border border-success-subtle py-2"><i class="bi bi-telephone-fill me-1"></i>@lead.Phone</a>
                                        @if (!string.IsNullOrEmpty(lead.Email))
                                        {
                                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle py-2"><i class="bi bi-envelope-fill"></i> Email</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-bold text-primary">@lead.Project?.ProjectName</span>
                                    <div class="small text-muted mt-1"><i class="bi bi-geo-alt-fill me-1"></i>@(lead.Project?.Ward?.WardName ?? "Đang cập nhật")</div>
                                </td>
                                <td>
                                    <div class="small bg-light p-2 rounded-3 border mb-1 text-dark">
                                        <strong>Khách nhắn:</strong> @(string.IsNullOrEmpty(lead.Message) ? "Chỉ để lại SĐT yêu cầu gọi lại" : lead.Message)
                                    </div>
                                    @if (!string.IsNullOrEmpty(lead.Note))
                                    {
                                        <div class="note-box" title="@lead.Note">
                                            <i class="bi bi-journal-text me-1"></i>
                                            @(lead.Note.Length > 60 ? lead.Note.Substring(0, 60) + "..." : lead.Note)
                                        </div>
                                    }
                                </td>
                                <td>
                                    <span class="d-block fw-bold text-dark">@lead.CreatedAt.ToString("dd/MM/yyyy")</span>
                                    <small class="text-muted">@lead.CreatedAt.ToString("HH:mm")</small>
                                </td>
                                <td>
                                    @switch (lead.LeadStatus)
                                    {
                                        case "New":
                                            <span class="badge-crm status-new"><i class="bi bi-exclamation-circle-fill me-1"></i>Khách Mới</span>
                                            break;
                                        case "Contacted":
                                            <span class="badge-crm status-contact"><i class="bi bi-headset me-1"></i>Đang chăm sóc</span>
                                            break;
                                        case "Resolved":
                                            <span class="badge-crm status-resolved"><i class="bi bi-star-fill me-1"></i>Đã chốt HĐ</span>
                                            break;
                                        case "Invalid":
                                            <span class="badge-crm status-invalid"><i class="bi bi-x-circle-fill me-1"></i>Hủy/Sai Số</span>
                                            break;
                                        default:
                                            <span class="badge-crm bg-secondary text-white">Chưa rõ</span>
                                            break;
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm rounded-pill bg-white border">
                                        <a asp-action="EditLead" asp-route-id="@lead.LeadID" class="btn btn-sm btn-light fw-bold px-3 border-end" title="Chi tiết & Đặt lịch hẹn">
                                            <i class="bi bi-calendar-plus-fill text-primary"></i>
                                        </a>
                                        <a asp-action="LeadHistory" asp-route-id="@lead.LeadID" class="btn btn-sm btn-light fw-bold px-3" title="Hồ sơ & Lịch sử 360">
                                            <i class="bi bi-person-vcard-fill text-success"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <img src="~/images/empty-state.svg" alt="No data" style="width: 150px; opacity: 0.4;" class="mb-3" />
                                <h5 class="fw-bold text-muted">Không tìm thấy dữ liệu khách hàng.</h5>
                                <p class="text-muted small">Hãy thử nới lỏng bộ lọc hoặc chọn một dự án khác.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Phân trang -->
        @if (totalPages > 1)
        {
            <div class="p-4 border-top bg-light">
                <nav>
                    <ul class="pagination pagination-rounded justify-content-center mb-0 gap-2">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                            <a class="page-link border-0 shadow-sm rounded-circle" href="@Url.Action("Index", new { page = currentPage - 1, projectId = currentProjectId, status = currentStatus, keyword = keyword })">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(currentPage == i ? "active" : "")">
                                <a class="page-link border-0 shadow-sm rounded-circle @(currentPage == i ? "bg-primary text-white" : "text-dark")" href="@Url.Action("Index", new { page = i, projectId = currentProjectId, status = currentStatus, keyword = keyword })">@i</a>
                            </li>
                        }
                        <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                            <a class="page-link border-0 shadow-sm rounded-circle" href="@Url.Action("Index", new { page = currentPage + 1, projectId = currentProjectId, status = currentStatus, keyword = keyword })">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>