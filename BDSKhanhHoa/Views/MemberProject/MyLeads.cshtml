@model IEnumerable<BDSKhanhHoa.Models.ProjectLead>
@{
    ViewData["Title"] = "CRM Quản lý Khách Hàng";
    Layout = "~/Views/Shared/_BusinessLayout.cshtml";
}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container-fluid px-0 animate__animated animate__fadeIn">

    @if (TempData["Success"] != null)
    {
        <script>Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: '@TempData["Success"]', showConfirmButton: false, timer: 3000 });</script>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-4 rounded-4 shadow-sm border">
        <div>
            <h4 class="fw-bolder text-dark mb-1"><i class="bi bi-funnel-fill text-success me-2"></i>CRM: PHỄU KHÁCH HÀNG DỰ ÁN</h4>
            <p class="text-muted mb-0 small">Toàn bộ khách hàng quan tâm đến các dự án của công ty sẽ được đổ về đây.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-light text-dark border fs-6 px-3 py-2 rounded-pill shadow-sm me-2">Tổng: @ViewBag.TotalLeads khách</span>
            <span class="badge bg-danger fs-6 px-3 py-2 rounded-pill shadow-sm animate__animated animate__pulse animate__infinite">Mới: @ViewBag.NewLeads chờ gọi</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase small fw-bold text-muted">
                    <tr>
                        <th class="ps-4 py-3">Khách hàng / Liên hệ</th>
                        <th>Dự án quan tâm</th>
                        <th width="25%">Nhu cầu / Ghi chú CRM</th>
                        <th>Thời gian</th>
                        <th>Pipeline Trạng thái</th>
                        <th class="text-end pe-4">Cập nhật</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lead in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="fw-bold text-dark fs-6 mb-1">@lead.Name</div>
                                <div class="d-flex gap-2">
                                    <a href="tel:@lead.Phone" class="badge bg-success-subtle text-success text-decoration-none border border-success-subtle"><i class="bi bi-telephone-fill me-1"></i>@lead.Phone</a>
                                    @if (!string.IsNullOrEmpty(lead.Email))
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle"><i class="bi bi-envelope"></i> Email</span>
                                    }
                                </div>
                            </td>
                            <td><span class="fw-bold text-primary">@lead.Project?.ProjectName</span></td>
                            <td>
                                <div class="small bg-light p-2 rounded-3 border mb-1"><strong>Khách nhắn:</strong> @(string.IsNullOrEmpty(lead.Message) ? "Không có lời nhắn" : lead.Message)</div>
                                @if (!string.IsNullOrEmpty(lead.Note))
                                {
                                    <div class="small text-warning fw-bold"><i class="bi bi-journal-check me-1"></i>Note: @lead.Note</div>
                                }
                            </td>
                            <td>
                                <span class="d-block fw-bold text-dark">@lead.CreatedAt.ToString("dd/MM/yyyy")</span>
                                <small class="text-muted">@lead.CreatedAt.ToString("HH:mm")</small>
                            </td>
                            <td>
                                @if (lead.LeadStatus == "New")
                                {
                                    <span class="badge bg-danger px-3 py-2 rounded-pill shadow-sm">Khách Mới</span>
                                }
                                else if (lead.LeadStatus == "Contacted")
                                {

                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill shadow-sm">Đang thương lượng</span>
                                }
                                else
                                {

                                    <span class="badge bg-success px-3 py-2 rounded-pill shadow-sm"><i class="bi bi-star-fill me-1"></i>Đã chốt HĐ</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button type="button" class="btn btn-sm btn-dark rounded-pill px-3 fw-bold shadow-sm" onclick="openUpdateModal(@lead.LeadID, '@lead.Name', '@lead.LeadStatus', '@lead.Note')">
                                    <i class="bi bi-pencil-square me-1"></i> Tiến độ
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted"><i class="bi bi-funnel display-4 d-block mb-3 opacity-25"></i>Phễu khách hàng hiện đang trống.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="crmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-dark text-white rounded-top-4">
                <h5 class="modal-title fw-bold"><i class="bi bi-headset me-2"></i>Cập nhật phễu bán hàng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateLeadStatus" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" name="id" id="crmLeadId" />
                    <div class="alert alert-info border-0 rounded-3 mb-4">
                        Khách hàng: <strong id="crmLeadName" class="fs-5 text-primary"></strong>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark text-uppercase small">Chuyển đổi trạng thái</label>
                        <select name="status" id="crmStatus" class="form-select form-select-lg shadow-sm border border-secondary fw-bold">
                            <option value="New">🚨 Khách mới (Chưa liên hệ)</option>
                            <option value="Contacted">⏳ Đã liên hệ / Đang chăm sóc</option>
                            <option value="Resolved">✅ Chốt DEAL thành công</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark text-uppercase small">Ghi chú nội bộ CRM (Bảo mật)</label>
                        <textarea name="note" id="crmNote" class="form-control border shadow-sm" rows="3" placeholder="Ví dụ: Khách thiện chí, tuần sau hẹn đi xem nhà mẫu..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-bottom-4">
                    <button type="button" class="btn btn-secondary fw-bold rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm"><i class="bi bi-save me-1"></i> Lưu tiến độ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openUpdateModal(id, name, status, note) {
        document.getElementById('crmLeadId').value = id;
        document.getElementById('crmLeadName').innerText = name;
        document.getElementById('crmStatus').value = status;
        document.getElementById('crmNote').value = note;
        new bootstrap.Modal(document.getElementById('crmModal')).show();
    }
</script>