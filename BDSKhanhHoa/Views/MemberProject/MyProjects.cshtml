@model IEnumerable<BDSKhanhHoa.Models.Project>
@{
    ViewData["Title"] = "Quản lý danh mục Dự án";
    Layout = "~/Views/Shared/_BusinessLayout.cshtml";
    var leadCounts = ViewBag.LeadCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<style>
    .project-card {
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        background: #ffffff;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .project-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            border-color: #4f46e5;
        }

    .project-img-wrapper {
        position: relative;
        height: 220px;
        overflow: hidden;
    }

    .project-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .project-card:hover .project-img {
        transform: scale(1.05);
    }

    .status-badge {
        position: absolute;
        top: 16px;
        right: 16px;
        padding: 6px 14px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 0.75rem;
        backdrop-filter: blur(8px);
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-selling {
        background: rgba(16, 185, 129, 0.9);
        color: white;
    }

    .status-pending {
        background: rgba(245, 158, 11, 0.9);
        color: white;
    }

    .status-handed {
        background: rgba(79, 70, 229, 0.9);
        color: white;
    }

    .project-stats {
        display: flex;
        justify-content: space-between;
        background: #f8fafc;
        border-radius: 12px;
        padding: 12px 16px;
        margin-top: 16px;
    }

    .stat-item {
        text-align: center;
    }

    .stat-val {
        font-weight: 800;
        color: #0f172a;
        font-size: 1.1rem;
    }

    .stat-lbl {
        font-size: 0.7rem;
        color: #64748b;
        text-transform: uppercase;
        font-weight: 600;
    }

    .action-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
        margin-top: auto;
        padding-top: 20px;
    }

    .btn-grid-action {
        padding: 10px 5px;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: 600;
        text-align: center;
        transition: all 0.2s;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        text-decoration: none;
    }

    .btn-crm {
        background: #eef2ff;
        color: #4f46e5;
        border: 1px solid #e0e7ff;
    }

        .btn-crm:hover {
            background: #4f46e5;
            color: white;
        }

    .btn-timeline {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #dcfce7;
    }

        .btn-timeline:hover {
            background: #16a34a;
            color: white;
        }

    .btn-vault {
        background: #fffbeb;
        color: #d97706;
        border: 1px solid #fef3c7;
    }

        .btn-vault:hover {
            background: #d97706;
            color: white;
        }
</style>

<div class="container-fluid pb-5 pt-3">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-2">Danh mục Dự án</h2>
            <p class="text-muted mb-0">Quản lý, điều phối thông tin và khách hàng tiềm năng cho các dự án bạn đang phụ trách tại Khánh Hòa.</p>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                int leadsCount = leadCounts.ContainsKey(item.ProjectID) ? leadCounts[item.ProjectID] : 0;
                string badgeClass = item.ProjectStatus == "Đang mở bán" ? "status-selling" :
                (item.ProjectStatus == "Đã bàn giao" ? "status-handed" : "status-pending");

                <div class="col-xl-4 col-md-6">
                    <div class="project-card">
                        <div class="project-img-wrapper">
                            <img src="@(string.IsNullOrEmpty(item.MainImage) ? "/images/default-project.jpg" : item.MainImage)" class="project-img" alt="@item.ProjectName" />
                            <div class="status-badge @badgeClass">@item.ProjectStatus</div>
                        </div>

                        <div class="p-4 d-flex flex-column flex-grow-1">
                            <div class="mb-1 text-primary small fw-bold"><i class="bi bi-geo-alt-fill me-1"></i>@(item.Ward?.WardName ?? ""), @(item.Area?.AreaName ?? "")</div>
                            <h5 class="fw-bold text-dark mb-2" style="line-height: 1.4;">@item.ProjectName</h5>
                            <p class="text-muted small mb-0"><i class="bi bi-building me-1"></i>CĐT: @item.Investor</p>

                            <div class="project-stats">
                                <div class="stat-item">
                                    <div class="stat-val text-primary">@leadsCount</div>
                                    <div class="stat-lbl">Khách quan tâm</div>
                                </div>
                                <div class="stat-item border-start border-end px-3">
                                    <div class="stat-val text-success">@item.Scale</div>
                                    <div class="stat-lbl">Quy mô</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-val text-warning">@item.CreatedAt.ToString("MM/yyyy")</div>
                                    <div class="stat-lbl">Phê duyệt</div>
                                </div>
                            </div>

                            <div class="action-grid">
                                <a href="@Url.Action("Index", "MemberProject", new { projectId = item.ProjectID })" class="btn-grid-action btn-crm">
                                    <i class="bi bi-funnel-fill fs-5"></i>
                                    <span>Phễu Khách</span>
                                </a>
                                <a href="@Url.Action("ManageTimeline", "ProjectTimeline", new { id = item.ProjectID })" class="btn-grid-action btn-timeline">
                                    <i class="bi bi-calendar-range-fill fs-5"></i>
                                    <span>Tiến độ</span>
                                </a>
                                <a href="@Url.Action("ManageVault", "ProjectVault", new { id = item.ProjectID })" class="btn-grid-action btn-vault">
                                    <i class="bi bi-safe2-fill fs-5"></i>
                                    <span>Hồ sơ</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white rounded-4 border shadow-sm">
            <img src="~/images/no-projects.svg" alt="No projects" style="width: 200px; opacity: 0.7; margin-bottom: 20px;" />
            <h4 class="text-dark fw-bold">Chưa có dự án nào được gán</h4>
            <p class="text-muted w-50 mx-auto">Tài khoản doanh nghiệp của bạn hiện chưa được Quản trị viên phân quyền quản lý dự án nào trên hệ thống. Vui lòng liên hệ Admin để cập nhật hồ sơ.</p>
        </div>
    }
</div>