@model BDSKhanhHoa.Models.ProjectLead
@using System.Globalization

@{
    ViewData["Title"] = "Xử lý lead khách hàng";
    Layout = "~/Views/Shared/_BusinessLayout.cshtml";

    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("Index", "MemberProject");
    var projectName = Model.Project?.ProjectName ?? "(Chưa gắn dự án)";
    var projectId = Model.ProjectID;
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .panel-card {
        background: #fff;
        border-radius: 24px;
        border: 1px solid rgba(148,163,184,.14);
        box-shadow: 0 12px 30px rgba(15, 23, 42, .08);
    }

    .soft-label {
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        font-weight: 800;
        color: #475569;
        margin-bottom: 8px;
    }

    .soft-input {
        border-radius: 16px;
        min-height: 52px;
        border: 1px solid #dbe3ef;
        box-shadow: none !important;
        font-weight: 600;
    }

    .btn-main {
        min-height: 52px;
        border-radius: 16px;
        font-weight: 800;
        border: none;
    }

    .stat-box {
        border-radius: 20px;
        padding: 18px;
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: #fff;
    }

        .stat-box .value {
            font-size: 2rem;
            font-weight: 900;
            line-height: 1;
        }
</style>

<div class="container-fluid px-0">
    @if (TempData["Success"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Success"]?.ToString() ?? "")),
                    showConfirmButton: false,
                    timer: 3000
                });
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'error',
                    title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Error"]?.ToString() ?? "")),
                    showConfirmButton: false,
                    timer: 3800
                });
            });
        </script>
    }

    <div class="panel-card p-4 mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
            <div>
                <div class="text-uppercase fw-bold text-secondary small">CRM / Lead chi tiết</div>
                <h4 class="fw-black mb-2">@Model.Name</h4>
                <div class="text-muted">Dự án: <span class="fw-bold text-dark">@projectName</span></div>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <span class="badge rounded-pill bg-primary px-3 py-2">Trạng thái: @Model.LeadStatus</span>
                <span class="badge rounded-pill bg-light text-dark border px-3 py-2">Tạo lúc: @Model.CreatedAt.ToString("HH:mm dd/MM/yyyy", CultureInfo.GetCultureInfo("vi-VN"))</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-4">
            <div class="panel-card p-4 h-100">
                <h5 class="fw-bold mb-3">Thông tin khách hàng</h5>

                <div class="mb-3">
                    <div class="soft-label">Họ tên</div>
                    <div class="p-3 rounded-4 border bg-light fw-semibold">@Model.Name</div>
                </div>

                <div class="mb-3">
                    <div class="soft-label">Số điện thoại</div>
                    <div class="p-3 rounded-4 border bg-light fw-semibold">@Model.Phone</div>
                </div>

                <div class="mb-3">
                    <div class="soft-label">Email</div>
                    <div class="p-3 rounded-4 border bg-light fw-semibold">@(!string.IsNullOrWhiteSpace(Model.Email) ? Model.Email : "Chưa có")</div>
                </div>

                <div class="mb-3">
                    <div class="soft-label">Tin nhắn ban đầu</div>
                    <div class="p-3 rounded-4 border bg-light">@(!string.IsNullOrWhiteSpace(Model.Message) ? Model.Message : "Không có lời nhắn")</div>
                </div>

                <div class="mb-3">
                    <div class="soft-label">Ghi chú CRM hiện tại</div>
                    <div class="p-3 rounded-4 border" style="background:#fff7ed;border-color:#fed7aa;">
                        @(!string.IsNullOrWhiteSpace(Model.Note) ? Model.Note : "Chưa có ghi chú")
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="panel-card p-4 mb-4">
                <h5 class="fw-bold mb-3">Cập nhật trạng thái lead</h5>

                <form asp-action="UpdateLeadStatus" asp-controller="MemberProject" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.LeadID" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <div class="col-md-4">
                        <label class="form-label soft-label">Trạng thái</label>
                        <select name="status" class="form-select soft-input" required>
                            <option value="New" selected="@(Model.LeadStatus == "New")">New - Khách mới</option>
                            <option value="Contacted" selected="@(Model.LeadStatus == "Contacted")">Contacted - Đang chăm sóc</option>
                            <option value="Resolved" selected="@(Model.LeadStatus == "Resolved")">Resolved - Đã chốt</option>
                        </select>
                    </div>

                    <div class="col-md-8">
                        <label class="form-label soft-label">Ghi chú CRM</label>
                        <textarea name="note" class="form-control soft-input" rows="3" placeholder="Ghi lại kết quả gọi điện, nhu cầu, mức độ quan tâm...">@Model.Note</textarea>
                    </div>

                    <div class="col-12 d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-primary btn-main px-4">
                            <i class="bi bi-save2 me-1"></i> Lưu trạng thái
                        </button>
                        <a href="@returnUrl" class="btn btn-outline-secondary btn-main px-4">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại
                        </a>
                    </div>
                </form>
            </div>

            <div class="panel-card p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <div>
                        <h5 class="fw-bold mb-1">Tạo lịch hẹn điều phối</h5>
                        <div class="text-muted">Dùng khi khách đồng ý đi xem thực tế. Nhập trực tiếp nhân sự phụ trách và số điện thoại.</div>
                    </div>
                    <div class="badge rounded-pill bg-warning text-dark px-3 py-2">ProjectID: @projectId</div>
                </div>

                <form asp-action="Create" asp-controller="Appointments" method="post" class="row g-3" id="appointmentForm">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="projectId" value="@projectId" />
                    <input type="hidden" name="leadId" value="@Model.LeadID" />
                    <input type="hidden" name="customerName" value="@Model.Name" />
                    <input type="hidden" name="customerPhone" value="@Model.Phone" />
                    <input type="hidden" name="customerEmail" value="@Model.Email" />

                    <div class="col-md-4">
                        <label class="form-label soft-label">Ngày hẹn</label>
                        <input type="date" name="appointmentDate" class="form-control soft-input" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label soft-label">Giờ hẹn</label>
                        <input type="time" name="appointmentTime" class="form-control soft-input" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label soft-label">Địa điểm gặp</label>
                        <input type="text" name="meetingLocation" class="form-control soft-input" value="@projectName" placeholder="Ví dụ: Sảnh dự án / Nhà mẫu" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label soft-label">Nhân viên phụ trách</label>
                        <input type="text" name="staffName" class="form-control soft-input" placeholder="Ví dụ: Nguyễn Văn A" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label soft-label">Số điện thoại nhân viên</label>
                        <input type="text" name="staffPhone" class="form-control soft-input" placeholder="Ví dụ: 0901..." required />
                    </div>

                    <div class="col-12">
                        <label class="form-label soft-label">Ghi chú điều phối</label>
                        <textarea name="note" class="form-control soft-input" rows="4" placeholder="Thông tin đón khách, yêu cầu riêng, lưu ý đi xem..."></textarea>
                    </div>

                    <div class="col-12 d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-success btn-main px-4">
                            <i class="bi bi-calendar-plus me-1"></i> Tạo lịch hẹn
                        </button>
                        <a href="/Appointments/Index" class="btn btn-outline-dark btn-main px-4">
                            <i class="bi bi-calendar2-week me-1"></i> Xem lịch hẹn
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>