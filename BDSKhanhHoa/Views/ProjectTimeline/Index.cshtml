@model IEnumerable<BDSKhanhHoa.Models.Project>
@using System.Text.Json
@{
    ViewData["Title"] = "Nhật ký giai đoạn dự án";
    Layout = "~/Views/Shared/_BusinessLayout.cshtml";

    int totalProjects = ViewBag.TotalProjects ?? 0;
    int activeProjects = ViewBag.ActiveProjects ?? 0;
    int completedProjects = ViewBag.CompletedProjects ?? 0;
    int pendingProjects = ViewBag.PendingProjects ?? 0;
    string businessName = ViewBag.BusinessName as string ?? "Doanh nghiệp đối tác";
}

<!-- Cấu trúc DTO để đọc JSON ngay trên View -->
@functions {
    public class MilestonePreview
    {
        public DateTime Date { get; set; }
        public string Title { get; set; }
    }
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    :root {
        --timeline-primary: #4f46e5;
        --timeline-success: #10b981;
        --timeline-warning: #f59e0b;
        --timeline-slate: #64748b;
    }

    .timeline-topbar {
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 12px 30px rgba(15, 23, 42, .08);
        border: 1px solid rgba(148,163,184,.15);
        padding: 30px;
        margin-bottom: 25px;
    }

    .timeline-title {
        font-size: 1.75rem;
        font-weight: 900;
        letter-spacing: -0.02em;
        background: linear-gradient(to right, #0f172a, var(--timeline-primary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .timeline-chip {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 10px 18px;
        border-radius: 14px;
        background: #ffffff;
        border: 1.5px solid #f1f5f9;
        font-weight: 700;
        color: #334155;
        transition: all 0.3s ease;
    }

        .timeline-chip:hover {
            border-color: var(--timeline-primary);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.1);
        }

    .project-block {
        border-radius: 28px;
        overflow: hidden;
        background: #fff;
        border: 1px solid #e2e8f0;
        box-shadow: 0 15px 35px rgba(15, 23, 42, .05);
        margin-bottom: 30px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .project-block:hover {
            border-color: var(--timeline-primary);
            box-shadow: 0 20px 40px rgba(79, 70, 229, 0.08);
        }

    .project-head {
        padding: 24px 30px;
        border-bottom: 1px solid #f1f5f9;
        background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
    }

    .project-cover {
        width: 100%;
        height: 100%;
        min-height: 250px;
        object-fit: cover;
        border-radius: 20px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }

    .phase-box {
        border-radius: 20px;
        border: 1.5px solid #f1f5f9;
        background: #fcfcfd;
        padding: 22px;
        height: 100%;
        position: relative;
        transition: all 0.3s ease;
    }

        .phase-box:hover {
            background: #fff;
            border-color: var(--timeline-primary);
        }

    .btn-manage {
        background: var(--timeline-primary);
        color: #fff;
        border-radius: 12px;
        padding: 12px 24px;
        font-weight: 700;
        border: none;
        transition: all 0.3s;
    }

        .btn-manage:hover {
            background: #3730a3;
            transform: scale(1.05);
            color: white;
        }

    .latest-update-box {
        background: linear-gradient(to right, #eff6ff, #ffffff);
        border-left: 4px solid var(--timeline-primary);
        border-radius: 0 16px 16px 0;
        padding: 16px 20px;
    }
</style>

<div class="container-fluid py-4 animate__animated animate__fadeIn">

    <!-- TOPBAR THỐNG KÊ -->
    <div class="timeline-topbar d-flex flex-column flex-lg-row justify-content-between align-items-center gap-4">
        <div>
            <div class="timeline-title">Nhật ký & Tiến độ Thi công</div>
            <p class="text-muted fw-medium mb-0">Hệ thống quản trị vòng đời dự án chuyên nghiệp dành cho Chủ đầu tư.</p>
            <div class="mt-2 text-primary fw-bold"><i class="bi bi-patch-check-fill"></i> @businessName</div>
        </div>
        <div class="d-flex gap-3 flex-wrap justify-content-center">
            <div class="timeline-chip">
                <span class="text-primary fs-4"><i class="bi bi-collection-fill"></i></span>
                <div><div class="small text-muted">Tổng số</div><div class="lh-1">@totalProjects Dự án</div></div>
            </div>
            <div class="timeline-chip">
                <span class="text-success fs-4"><i class="bi bi-megaphone-fill"></i></span>
                <div><div class="small text-muted">Thị trường</div><div class="lh-1">@activeProjects Đang bán</div></div>
            </div>
            <div class="timeline-chip">
                <span class="text-warning fs-4"><i class="bi bi-shield-lock-fill"></i></span>
                <div><div class="small text-muted">Kiểm duyệt</div><div class="lh-1">@pendingProjects Chờ duyệt</div></div>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            var cover = string.IsNullOrWhiteSpace(item.MainImage) ? "/images/no-image.jpg" : item.MainImage;

            // XỬ LÝ LOGIC: Đọc dữ liệu JSON để lấy tổng mốc & mốc mới nhất
            int milestoneCount = 0;
            string latestTitle = "Khởi tạo & Công bố Dự án";
            DateTime latestDate = item.CreatedAt;

            if (!string.IsNullOrEmpty(item.TimelineJson))
            {
                try
                {
                    var list = JsonSerializer.Deserialize<List<MilestonePreview>>(item.TimelineJson);
                    if (list != null && list.Any())
                    {
                        milestoneCount = list.Count;
                        // Sắp xếp ngày lấy dòng mới nhất
                        var latest = list.OrderByDescending(m => m.Date).First();
                        latestTitle = latest.Title;
                        latestDate = latest.Date;
                    }
                }
                catch { /* Bỏ qua nếu lỗi Parse */ }
            }

            <div class="project-block animate__animated animate__fadeInUp">
                <!-- Header Dự án -->
                <div class="project-head d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-4">
                            <i class="bi bi-building-fill-check text-primary fs-3"></i>
                        </div>
                        <div>
                            <h4 class="mb-1 fw-900 text-dark">@item.ProjectName</h4>
                            <div class="text-muted fw-semibold">
                                <i class="bi bi-geo-alt-fill text-danger"></i> @item.Ward?.WardName, @item.Area?.AreaName
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-3">
                        <div class="text-end d-none d-md-block">
                            <div class="small text-muted fw-bold">TRẠNG THÁI</div>
                            <span class="badge @(item.ProjectStatus == "Đang mở bán" ? "bg-success" : "bg-secondary") rounded-pill px-3 py-2">
                                @item.ProjectStatus
                            </span>
                        </div>
                        <div class="text-end d-none d-md-block">
                            <div class="small text-muted fw-bold">HỒ SƠ</div>
                            <span class="badge @(item.ApprovalStatus == "Approved" ? "bg-primary" : "bg-warning text-dark") rounded-pill px-3 py-2">
                                @item.ApprovalStatus
                            </span>
                        </div>
                    </div>
                </div>

                <div class="project-body p-4">
                    <div class="row g-4 align-items-stretch">

                        <!-- Ảnh bìa -->
                        <div class="col-xl-4 col-lg-5">
                            <div class="position-relative h-100">
                                <img src="@cover" alt="@item.ProjectName" class="project-cover" />
                                <div class="position-absolute bottom-0 start-0 w-100 p-3">
                                    <div class="bg-white bg-opacity-90 backdrop-blur rounded-4 p-3 border shadow-sm">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="fw-bold text-dark"><i class="bi bi-list-stars text-primary"></i> Tổng mốc tiến độ:</span>
                                            <span class="badge bg-dark rounded-circle" style="width:28px; height:28px; display:flex; align-items:center; justify-content:center;">@milestoneCount</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Nội dung Tiến độ thực tế -->
                        <div class="col-xl-8 col-lg-7 d-flex flex-column">

                            <!-- Hiển thị mốc mới nhất lấy từ JSON thay vì 3 ô cứng -->
                            <div class="latest-update-box shadow-sm mb-4">
                                <div class="text-primary small fw-bold text-uppercase mb-2"><i class="bi bi-broadcast me-1"></i> Báo cáo tiến độ mới nhất</div>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="badge bg-primary rounded-pill px-3 py-2"><i class="bi bi-clock-history me-1"></i> @latestDate.ToString("dd/MM/yyyy")</span>
                                    <h5 class="fw-bold text-dark mb-0">@latestTitle</h5>
                                </div>
                            </div>

                            <div class="phase-box flex-grow-1 d-flex flex-column justify-content-between shadow-sm">
                                <div>
                                    <h6 class="fw-bold text-dark"><i class="bi bi-info-circle-fill text-muted me-2"></i>Mô tả tổng quan dự án</h6>
                                    <p class="text-muted mb-0" style="display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.6;">
                                        @item.Description
                                    </p>
                                </div>

                                <div class="d-flex flex-wrap gap-2 mt-4 pt-4 border-top">
                                    <a href="@Url.Action("ManageTimeline", "ProjectTimeline", new { id = item.ProjectID })" class="btn btn-manage shadow-sm">
                                        <i class="bi bi-pencil-square me-2"></i>Quản lý Nhật ký
                                    </a>
                                    <a href="/Project/Details/@item.ProjectID" target="_blank" class="btn btn-light border fw-bold text-dark rounded-3 px-4">
                                        <i class="bi bi-globe me-1"></i> Xem Public
                                    </a>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <!-- Empty State -->
        <div class="timeline-topbar p-5 text-center">
            <div class="py-5">
                <i class="bi bi-folder-x display-1 text-muted opacity-25"></i>
                <h3 class="fw-900 text-dark mt-4">Chưa có dự án phụ trách</h3>
                <p class="text-muted px-5">Khi các dự án của bạn được Admin gán quyền quản lý, nhật ký thi công và lộ trình giai đoạn sẽ hiển thị chi tiết tại đây để bạn điều phối.</p>
                <a href="/" class="btn btn-primary rounded-pill px-5 py-3 fw-bold mt-3 shadow">Quay lại Trang chủ</a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $('.project-block').hover(
            function() { $(this).find('.project-cover').css('transform', 'scale(1.02)'); },
            function() { $(this).find('.project-cover').css('transform', 'scale(1)'); }
        );
    </script>
}