@model IEnumerable<BDSKhanhHoa.Models.Favorite>
@{
    ViewData["Title"] = "Bất động sản đã lưu";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    .fav-card {
        border: 1px solid #edf2f7;
        border-radius: 16px;
        overflow: hidden;
        transition: 0.3s;
        background: #fff;
        height: 100%;
        display: flex;
        flex-direction: column;
        position: relative;
    }

        .fav-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
            border-color: #cbd5e1;
        }

    .img-wrapper {
        position: relative;
        height: 200px;
    }

        .img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .btn-remove-fav {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(255,255,255,0.9);
        color: #ef4444;
        border: none;
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: 0.2s;
        z-index: 10;
    }

        .btn-remove-fav:hover {
            background: #ef4444;
            color: white;
            transform: scale(1.1);
        }

    .badge-status {
        position: absolute;
        top: 12px;
        left: 12px;
        font-weight: 800;
        font-size: 0.75rem;
        padding: 4px 12px;
        border-radius: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }
</style>

<div class="card-custom p-4 p-md-5">
    <div class="border-bottom pb-3 mb-4">
        <h4 class="fw-bold text-dark mb-1"><i class="bi bi-heart-fill text-danger me-2"></i>Danh sách yêu thích</h4>
        <p class="text-muted small mb-0">Bạn đã lưu <strong class="text-primary fs-6">@Model.Count()</strong> bất động sản.</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                var p = item.Property;
                if (p != null)
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="fav-card">
                            <form asp-action="Remove" method="post" onsubmit="return confirm('Bạn muốn bỏ lưu tin này?');">
                                <input type="hidden" name="id" value="@item.FavoriteID" />
                                <button type="submit" class="btn-remove-fav" title="Bỏ lưu"><i class="bi bi-trash3-fill"></i></button>
                            </form>

                            <a href="/Property/Details/@p.PropertyID" class="text-decoration-none text-dark d-flex flex-column h-100">
                                <div class="img-wrapper">
                                    <img src="@(string.IsNullOrEmpty(p.MainImage) ? "/images/no-image.jpg" : p.MainImage)" onerror="this.src='/images/no-image.jpg'">
                                    @if (p.Status == "Approved")
                                    {
                                        <span class="badge bg-success badge-status">Đang giao dịch</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-secondary badge-status">Đã ẩn/Hết hạn</span>
                                    }
                                </div>
                                <div class="card-body p-3 d-flex flex-column flex-grow-1">
                                    <h6 class="fw-bold mb-2 lh-base text-dark" style="height: 42px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">@p.Title</h6>
                                    <div class="text-danger fw-bold fs-5 mb-2">
                                        @(p.Price.HasValue ? (p.Price >= 1000000000 ? (p.Price / 1000000000)?.ToString("0.##") + " Tỷ" : (p.Price / 1000000)?.ToString("0.##") + " Tr") : "Thỏa thuận")
                                    </div>
                                    <div class="d-flex justify-content-between text-muted mt-auto pt-3 border-top small fw-medium">
                                        <span><i class="bi bi-rulers text-secondary me-1"></i> @p.AreaSize m²</span>
                                        <span class="text-truncate" style="max-width: 140px;"><i class="bi bi-geo-alt text-secondary me-1"></i> @p.Ward?.Area?.AreaName</span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            }
        }
        else
        {
            <div class="col-12 text-center py-5 bg-light rounded-4 border border-dashed">
                <i class="bi bi-balloon-heart text-muted display-1 opacity-50 mb-3 d-block"></i>
                <h5 class="fw-bold text-dark">Danh sách yêu thích trống</h5>
                <p class="text-secondary mb-4">Bạn chưa lưu bất kỳ bất động sản nào. Hãy khám phá và lưu lại những căn nhà ưng ý nhé.</p>
                <a href="/Property/Search" class="btn btn-primary fw-bold px-4 rounded-pill">Khám phá ngay</a>
            </div>
        }
    </div>
</div>