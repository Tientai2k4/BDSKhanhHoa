<div class="list-group list-group-flush mb-4">
    @foreach (var cat in ViewBag.Categories)
    {
        <div class="fw-bold mt-2 text-uppercase text-muted" style="font-size: 0.85rem;">@cat.TypeName</div>

        // Thay đổi ở đây: Lấy từ danh sách đã truyền qua ViewBag thay vì _context
        var subTypes = ((List<BDSKhanhHoa.Models.PropertyType>)ViewBag.AllSubTypes)
        .Where(t => t.ParentID == cat.TypeID);

        foreach (var sub in subTypes)
        {
            <a href="?typeId=@sub.TypeID" class="list-group-item list-group-item-action border-0 ps-3">
                <i class="fas fa-chevron-right small me-2 text-secondary"></i>@sub.TypeName
            </a>
        }
    }
</div>