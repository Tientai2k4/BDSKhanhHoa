            .footer-newsletter p {
                color: #dbeafe;
                font-size: .92rem;
                margin-bottom: 14px;
                line-height: 1.7;
            }

            .footer-newsletter .form-control {
                background: rgba(15,23,42,.55);
                color: #fff;
                border: 1px solid rgba(148,163,184,.22);
                border-radius: 14px;
                box-shadow: none !important;
            }

                .footer-newsletter .form-control::placeholder {
                    color: #94a3b8;
                }

            .footer-newsletter .btn {
                border-radius: 14px;
                font-weight: 700;
                padding-left: 16px;
                padding-right: 16px;
            }

        .footer-trustbar {
            position: relative;
            padding: 18px 0;
            border-bottom: 1px solid rgba(148,163,184,.12);
            background: rgba(255,255,255,.02);
        }

        .footer-trust-item {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #e2e8f0;
            font-size: .9rem;
            line-height: 1.5;
        }

            .footer-trust-item i {
                width: 34px;
                height: 34px;
                border-radius: 10px;
                background: rgba(255,255,255,.06);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                color: #7dd3fc;
                flex-shrink: 0;
            }

        .footer-bottom {
            position: relative;
            padding: 18px 0;
            background: rgba(0,0,0,.18);
        }

        .footer-bottom-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
        }

        .footer-bottom p {
            margin: 0;
            font-size: .88rem;
            color: #94a3b8;
        }

        .footer-legal {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            align-items: center;
        }

            .footer-legal a {
                color: #cbd5e1;
                text-decoration: none;
                font-size: .88rem;
            }

                .footer-legal a:hover {
                    color: #fff;
                }

        /* ═══════════════════════════════════
                   AI CHAT
                ═══════════════════════════════════ */
        .ai-chatbot-btn {
            position: fixed;
            right: 24px;
            bottom: 24px;
            width: 58px;
            height: 58px;
            border-radius: 50%;
            border: 3px solid rgba(255,255,255,.35);
            background: linear-gradient(135deg, var(--primary), #3b82f6);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 14px 34px rgba(37,99,235,.28);
            cursor: pointer;
            z-index: 2000;
            transition: var(--transition);
        }

            .ai-chatbot-btn:hover {
                transform: scale(1.06);
            }

        .chat-widget {
            position: fixed;
            right: 24px;
            bottom: 94px;
            width: 380px;
            height: 580px;
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(15,23,42,.18);
            overflow: hidden;
            display: none;
            flex-direction: column;
            z-index: 2001;
            border: 1px solid rgba(229,234,242,.95);
        }

        .chat-header {
            padding: 16px 18px;
            background: linear-gradient(135deg, var(--primary), #3b82f6);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            .chat-header h6 {
                margin: 0;
                font-size: .96rem;
                font-weight: 800;
            }

            .chat-header small {
                opacity: .85;
            }

        .chat-body {
            flex: 1;
            padding: 16px;
            overflow-y: auto;
            background: #f8fafc;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .chat-message {
            max-width: 86%;
        }

            .chat-message.user {
                align-self: flex-end;
            }

            .chat-message.bot {
                align-self: flex-start;
            }

        .bubble {
            padding: 10px 14px;
            border-radius: 16px;
            line-height: 1.5;
            font-size: .92rem;
        }

        .user .bubble {
            background: var(--primary);
            color: #fff;
            border-radius: 16px 16px 4px 16px;
        }

        .bot .bubble {
            background: #fff;
            color: var(--text);
            border: 1px solid var(--border);
            border-radius: 16px 16px 16px 4px;
        }

        .typing-dots {
            display: flex;
            gap: 5px;
            padding: 6px 2px;
        }

            .typing-dots span {
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: #94a3b8;
                animation: bounce 1.3s infinite ease-in-out;
            }

                .typing-dots span:nth-child(2) {
                    animation-delay: .18s;
                }

                .typing-dots span:nth-child(3) {
                    animation-delay: .36s;
                }

        @@keyframes bounce {
            0%, 80%, 100% {
                transform: scale(0);
            }

            40% {
                transform: scale(1);
            }
        }

        .chat-footer {
            padding: 12px;
            background: #fff;
            border-top: 1px solid var(--border);
        }

            .chat-footer .form-control {
                border-radius: 14px 0 0 14px;
                border: 1px solid var(--border);
                box-shadow: none !important;
            }

            .chat-footer .btn {
                border-radius: 0 14px 14px 0;
            }

        /* ═══════════════════════════════════
                   RESPONSIVE
                ═══════════════════════════════════ */
        @@media (max-width: 1399.98px) {
            .navbar > .container {
                min-height: 72px;
            }

            .user-pill {
                max-width: 200px;
            }

                .user-pill .name {
                    max-width: 100px;
                }
        }

        @@media (max-width: 1199.98px) {
            .navbar > .container {
                min-height: 68px;
            }

            .desktop-shell {
                display: none !important;
            }

            .mobile-header-actions {
                display: flex !important;
            }

            .navbar-brand img {
                height: 42px;
            }

            .brand-subtitle {
                display: none;
            }
        }

        @@media (max-width: 991.98px) {
            .footer-top {
                padding: 44px 0 28px;
            }

            .footer-badges {
                grid-template-columns: 1fr;
            }

            .footer-bottom-inner {
                justify-content: center;
                text-align: center;
            }

            .footer-legal {
                justify-content: center;
            }

            .chat-widget {
                width: calc(100vw - 24px);
                right: 12px;
                left: 12px;
                height: 72vh;
            }

            .ai-chatbot-btn {
                right: 14px;
                bottom: 14px;
            }
        }

        @@media (max-width: 575.98px) {
            .navbar > .container {
                min-height: 64px;
                gap: 10px;
            }

            .navbar-brand {
                max-width: calc(100% - 160px);
            }

                .navbar-brand img {
                    height: 38px;
                }

            .brand-text {
                display: none;
            }

            .mobile-header-actions {
                gap: 8px;
            }

                .mobile-header-actions .icon-btn,
                .mobile-header-actions .btn-post-ad-sm,
                .mobile-header-actions .menu-btn {
                    width: 40px;
                    height: 40px;
                }

            .footer-brand {
                align-items: flex-start;
            }

                .footer-brand img {
                    width: 48px;
                    height: 48px;
                }

            .footer-newsletter {
                padding: 16px;
            }

            .ai-chatbot-btn {
                width: 54px;
                height: 54px;
            }

            .mob-action-row.two-col {
                grid-template-columns: 1fr;
            }

            .mob-shortcut-grid {
                grid-template-columns: 1fr 1fr;
            }
        }
    </style>
</head>
<body>

    <!-- ═══════════════ HEADER ═══════════════ -->
    <header class="header-main">
        <nav class="navbar navbar-expand-xl navbar-light">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index" aria-label="Trang chủ BĐS Khánh Hòa">
                    <img src="/images/logo.png" alt="BDS Khánh Hòa Logo">
                    <div class="brand-text">
                        <p class="brand-title">BĐS Khánh Hòa</p>
                        <p class="brand-subtitle">Mua bán · Cho thuê · Dự án</p>
                    </div>
                </a>

                <!-- Mobile header right buttons -->
                <div class="mobile-header-actions d-xl-none ms-auto">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a href="/Notification/Index" class="icon-btn position-relative" title="Thông báo">
                            <i class="bi bi-bell-fill"></i>
                            @if (unreadCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white" style="font-size:.63rem;">
                                    @(unreadCount > 9 ? "9+" : unreadCount.ToString())
                                </span>
                            }
                        </a>
                        @if (canPostSingleAd)
                        {
                            <a href="/Property/Create" class="btn-post-ad btn-post-ad-sm" title="Đăng tin">
                                <i class="bi bi-plus-lg"></i>
                            </a>
                        }
                        else
                        {
                            <a href="/Account/Profile" class="icon-btn" title="Tài khoản">
                                <i class="bi bi-person-circle"></i>
                            </a>
                        }
                    }
                    else
                    {
                        <a href="/Account/Login" class="icon-btn" title="Đăng nhập">
                            <i class="bi bi-person-lock"></i>
                        </a>
                    }
                    <button class="navbar-toggler menu-btn" type="button"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#mobileMenu"
                            aria-controls="mobileMenu"
                            aria-label="Mở menu">
                        <i class="bi bi-list"></i>
                    </button>
                </div>

                <!-- Desktop nav -->
                <div class="desktop-shell w-100 d-none d-xl-flex">
                    <ul class="navbar-nav mx-auto mb-0 flex-row">
                        <li class="nav-item">
                            <a class="nav-link nav-main-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1"></i><span class="nav-text">Trang chủ</span>
                            </a>
                        </li>
                        @await Component.InvokeAsync("NavbarMenu")
                        <li class="nav-item">
                            <a class="nav-link nav-main-link" href="/Project">
                                <i class="bi bi-buildings me-1"></i><span class="nav-text">Dự án</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-main-link" href="/Blog">
                                <i class="bi bi-newspaper me-1"></i><span class="nav-text">Tin thị trường</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-main-link" asp-controller="Contact" asp-action="Index">
                                <i class="bi bi-chat-dots me-1"></i><span class="nav-text">Liên hệ</span>
                            </a>
                        </li>
                    </ul>

                    <div class="header-actions">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (canPostSingleAd)
                            {
                                <a href="/Property/Create" class="btn-post-ad">
                                    <i class="bi bi-plus-circle"></i>
                                    <span>Đăng tin</span>
                                </a>
                            }
                            <!-- Notification dropdown -->
                            <div class="dropdown">
                                <a href="#" class="icon-btn position-relative" data-bs-toggle="dropdown" aria-expanded="false" title="Thông báo">
                                    <i class="bi bi-bell-fill"></i>
                                    @if (unreadCount > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white" style="font-size:.63rem;">
                                            @(unreadCount > 9 ? "9+" : unreadCount.ToString())
                                        </span>
                                    }
                                </a>
                                <div class="dropdown-menu dropdown-menu-end p-0" style="width:320px;overflow:hidden;">
                                    <div class="px-3 py-2 fw-bold text-white" style="background:linear-gradient(135deg,var(--primary),#3b82f6);">
                                        Thông báo của bạn
                                    </div>
                                    <div class="notification-list">
                                        @if (topNotifications.Any())
                                        {
                                            foreach (var noti in topNotifications)
                                            {
                                                <a href="/Notification/Details/@noti.NotificationID"
                                                   class="dropdown-item border-bottom @(noti.IsRead ? "" : "bg-light")">
                                                    <div class="fw-bold text-dark text-truncate">@noti.Title</div>
                                                    <div class="text-muted small notification-preview">@noti.Content</div>
                                                </a>
                                            }
                                        }
                                        else
                                        {
                                            <div class="p-4 text-center text-muted small">Không có thông báo mới</div>
                                        }
                                    </div>
                                </div>
                            </div>
                            <!-- User dropdown -->
                            <div class="dropdown">
                                <button class="btn p-0 border-0 bg-transparent" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="user-pill">
                                        <img src="@avatarUrl" alt="Avatar">
                                        <span class="name">@userName</span>
                                        <i class="bi bi-chevron-down text-secondary ms-1"></i>
                                    </span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @if (isAdminOrStaff)
                                    {
                                        <li><h6 class="dropdown-header text-danger">Hệ thống quản trị</h6></li>
                                        <li>
                                            <a class="dropdown-item" href="/Admin/Dashboard">
                                                <i class="bi bi-speedometer2 me-2 text-danger"></i>Bảng điều khiển Admin
                                            </a>
                                        </li>
                                    }
                                    else if (isBusinessVerified)
                                    {
                                        <li><h6 class="dropdown-header text-primary fw-bold text-uppercase small" style="letter-spacing:1px;">Dành Cho Đối Tác</h6></li>
                                        <li>
                                            <a class="dropdown-item py-2 fw-semibold text-primary bg-light rounded-2 mx-2 mb-1" style="width: auto;" href="/MemberProject/Index">
                                                <i class="bi bi-rocket-takeoff-fill me-2 text-accent"></i>Vào Cổng Quản Lý Dự Án
                                            </a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li><h6 class="dropdown-header text-muted">Tài khoản cá nhân</h6></li>
                                        <li><a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person-circle me-2 text-primary"></i>Hồ sơ của tôi</a></li>
                                        <li><a class="dropdown-item" href="/Property/MyAds"><i class="bi bi-card-checklist me-2 text-primary"></i>Quản lý tin đăng</a></li>
                                        <li><a class="dropdown-item" href="/Favorite/Index"><i class="bi bi-heart-fill me-2 text-danger"></i>Tin đã yêu thích</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger fw-bold">
                                                <i class="bi bi-box-arrow-right me-2"></i>Thoát tài khoản
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn-post-ad">
                                <i class="bi bi-person-lock"></i><span>Đăng nhập</span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- ═══════════════ MOBILE OFFCANVAS MENU ═══════════════ -->
    <div class="offcanvas offcanvas-end offcanvas-mobile" tabindex="-1" id="mobileMenu" aria-labelledby="mobileMenuLabel">

        <!-- Header offcanvas -->
        <div class="offcanvas-header">
            <div class="d-flex align-items-center gap-3">
                <img src="/images/logo.png" alt="BDS Khánh Hòa" style="width:36px;height:36px;object-fit:contain;border-radius:8px;">
                <div>
                    <div style="font-family:'Sora',sans-serif;font-weight:800;font-size:1rem;line-height:1.2;">BĐS Khánh Hòa</div>
                    <small style="opacity:.8;font-size:.78rem;">Menu điều hướng</small>
                </div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Đóng"></button>
        </div>

        <!-- Body offcanvas -->
        <div class="offcanvas-body">

            <!-- ── BLOCK 1: TÀI KHOẢN ── -->
            <div class="mob-account-block">
                @if (User.Identity.IsAuthenticated)
                {
                    <!-- Thông tin user -->
                    <div class="mob-user-row">
                        <img src="@avatarUrl" alt="Avatar">
                        <div style="min-width:0;flex:1;">
                            <div class="mob-user-name">@userName</div>
                            @if (isAdminOrStaff)
                            {
                                <span class="mob-user-badge mob-badge-admin">
                                    <i class="bi bi-shield-fill-check"></i> Admin / Staff
                                </span>
                            }
                            else if (isBusinessVerified)
                            {
                                <span class="mob-user-badge mob-badge-business">
                                    <i class="bi bi-building-check"></i> Doanh nghiệp
                                </span>
                            }
                            else
                            {
                                <span class="mob-user-badge mob-badge-personal">
                                    <i class="bi bi-person-fill"></i> Cá nhân
                                </span>
                            }
                        </div>
                    </div>

                    <!-- Nút hành động -->
                    <div class="mob-action-row @(canPostSingleAd ? "two-col" : "one-col")">
                        @if (canPostSingleAd)
                        {
                            <a href="/Property/Create" class="mob-action-btn mob-btn-primary" data-bs-dismiss="offcanvas">
                                <i class="bi bi-plus-circle-fill"></i> Đăng tin
                            </a>
                        }
                        <a href="/Notification/Index" class="mob-action-btn mob-btn-outline position-relative" data-bs-dismiss="offcanvas">
                            <i class="bi bi-bell-fill"></i>
                            Thông báo
                            @if (unreadCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white" style="font-size:.6rem;transform:translate(-60%,-30%)!important;">
                                    @(unreadCount > 9 ? "9+" : unreadCount.ToString())
                                </span>
                            }
                        </a>
                    </div>
                }
                else
                {
                    <!-- Khách -->
                    <div class="mob-user-row">
                        <img src="/images/avatars/default-user.png" alt="Avatar">
                        <div style="min-width:0;">
                            <div class="mob-user-name">Khách truy cập</div>
                            <div style="font-size:.8rem;color:var(--muted);margin-top:3px;">Đăng nhập để sử dụng đầy đủ tính năng</div>
                        </div>
                    </div>
                    <div class="mob-action-row two-col">
                        <a href="/Account/Login" class="mob-action-btn mob-btn-primary" data-bs-dismiss="offcanvas">
                            <i class="bi bi-person-lock"></i> Đăng nhập
                        </a>
                        <a href="/Account/Register" class="mob-action-btn mob-btn-outline" data-bs-dismiss="offcanvas">
                            <i class="bi bi-person-plus"></i> Đăng ký
                        </a>
                    </div>
                }
            </div>

            <!-- ── BLOCK 2: ĐIỀU HƯỚNG CHÍNH ── -->
            <div class="mob-section">
                <div class="mob-section-title">Điều hướng chính</div>
                <ul class="mob-nav-list">
                    <li>
                        <a class="mob-nav-item" asp-controller="Home" asp-action="Index" data-bs-dismiss="offcanvas">
                            <span class="mob-nav-icon icon-home"><i class="bi bi-house-fill"></i></span>
                            Trang chủ
                        </a>
                    </li>
                    <li>
                        <a class="mob-nav-item" href="/BatDongSan/NhaDatBan" data-bs-dismiss="offcanvas">
                            <span class="mob-nav-icon icon-sell"><i class="bi bi-building-fill"></i></span>
                            Nhà đất bán
                        </a>
                    </li>
                    <li>
                        <a class="mob-nav-item" href="/BatDongSan/NhaDatChoThue" data-bs-dismiss="offcanvas">
                            <span class="mob-nav-icon icon-rent"><i class="bi bi-key-fill"></i></span>
                            Nhà đất cho thuê
                        </a>
                    </li>
                    <li>
                        <a class="mob-nav-item" href="/Project" data-bs-dismiss="offcanvas">
                            <span class="mob-nav-icon icon-project"><i class="bi bi-buildings-fill"></i></span>
                            Dự án
                        </a>
                    </li>
                    <li>
                        <a class="mob-nav-item" href="/Blog" data-bs-dismiss="offcanvas">
                            <span class="mob-nav-icon icon-news"><i class="bi bi-newspaper"></i></span>
                            Tin thị trường
                        </a>
                    </li>
                    <li>
                        <a class="mob-nav-item" asp-controller="Contact" asp-action="Index" data-bs-dismiss="offcanvas">
                            <span class="mob-nav-icon icon-contact"><i class="bi bi-chat-dots-fill"></i></span>
                            Liên hệ
                        </a>
                    </li>
                </ul>
            </div>

            <!-- ── BLOCK 3: TÀI KHOẢN & QUẢN LÝ ── -->
            @if (User.Identity.IsAuthenticated)
            {
                <div class="mob-section">
                    <div class="mob-section-title">Tài khoản &amp; Quản lý</div>
                    <ul class="mob-nav-list">
                        @if (isAdminOrStaff)
                        {
                            <li>
                                <a class="mob-nav-item" href="/Admin/Dashboard" data-bs-dismiss="offcanvas">
                                    <span class="mob-nav-icon icon-admin"><i class="bi bi-speedometer2"></i></span>
                                    Bảng điều khiển Admin
                                </a>
                            </li>
                        }
                        else if (isBusinessVerified)
                        {
                            <li>
                                <a class="mob-nav-item fw-bold text-primary" style="background-color: rgba(13, 110, 253, 0.05); border-left: 3px solid #0d6efd;" href="/MemberProject/Index" data-bs-dismiss="offcanvas">
                                    <span class="mob-nav-icon"><i class="bi bi-rocket-takeoff-fill text-primary"></i></span>
                                    Vào Cổng Quản Lý Dự Án
                                </a>
                            </li>
                        }
                        else
                        {
                            <li>
                                <a class="mob-nav-item" href="/Account/Profile" data-bs-dismiss="offcanvas">
                                    <span class="mob-nav-icon icon-profile"><i class="bi bi-person-circle"></i></span>
                                    Hồ sơ của tôi
                                </a>
                            </li>
                            <li>
                                <a class="mob-nav-item" href="/Property/MyAds" data-bs-dismiss="offcanvas">
                                    <span class="mob-nav-icon icon-myads"><i class="bi bi-card-checklist"></i></span>
                                    Quản lý tin đăng
                                </a>
                            </li>
                            <li>
                                <a class="mob-nav-item" href="/Favorite/Index" data-bs-dismiss="offcanvas">
                                    <span class="mob-nav-icon icon-fav"><i class="bi bi-heart-fill"></i></span>
                                    Tin đã yêu thích
                                </a>
                            </li>
                        }

                        <!-- Thoát tài khoản -->
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="mob-nav-item danger" data-bs-dismiss="offcanvas">
                                    <span class="mob-nav-icon icon-logout"><i class="bi bi-box-arrow-right"></i></span>
                                    Thoát tài khoản
