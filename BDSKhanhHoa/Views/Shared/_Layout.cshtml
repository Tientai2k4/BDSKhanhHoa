        }

            .mobile-header-actions .icon-btn {
                width: 42px;
                height: 42px;
            }

            .mobile-header-actions .btn-post-ad-sm {
                width: 42px;
                height: 42px;
                padding: 0;
            }

            .mobile-header-actions .menu-btn {
                width: 42px;
                height: 42px;
                background: #fff;
                border: 1px solid var(--border);
                box-shadow: var(--shadow-sm);
            }

                .mobile-header-actions .menu-btn i {
                    font-size: 1.55rem;
                    line-height: 1;
                    color: var(--primary);
                }

        /* ═══════════════════════════════════
                   MOBILE OFFCANVAS — ĐÃ VIẾT LẠI
                ═══════════════════════════════════ */
        .offcanvas-mobile {
            width: min(92vw, 400px);
            border-left: 1px solid rgba(229,234,242,.92);
