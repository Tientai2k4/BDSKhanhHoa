            border: 1px solid var(--border);
            border-radius: 999px;
            background: #fff;
            box-shadow: var(--shadow-sm);
            white-space: nowrap;
        }

            .user-pill img {
                width: 32px;
                height: 32px;
                border-radius: 50%;
