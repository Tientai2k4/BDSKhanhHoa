            font-weight: 700;
            font-size: .94rem;
            padding: 10px 12px !important;
            border-radius: 12px;
            transition: var(--transition);
            white-space: nowrap;
            line-height: 1;
        }

            .nav-link:hover, .nav-link.active, .nav-main-link:hover {
                color: var(--primary) !important;
                background: rgba(37,99,235,.08);
            }

        .nav-icon {
            font-size: 1rem;
            flex-shrink: 0;
        }

        .nav-text {
            white-space: nowrap;
        }

        .header-actions {
