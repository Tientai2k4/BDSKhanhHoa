    <script>
        $(function () {
            const $btn    = $('#chatbotToggle');
            const $widget = $('#chatWidget');
            const $input  = $('#chatInput');
            const $body   = $('#chatBody');

            $btn.on('click', function () {
                if ($widget.is(':visible')) { $widget.fadeOut(200); }
                else { $widget.fadeIn(200).css('display','flex'); $input.trigger('focus'); }
            });
            $('#chatClose').on('click', function () { $widget.fadeOut(200); });

            function appendMessage(text, sender) {
                const html = `<div class="chat-message ${sender} animate__animated animate__fadeInUp animate__faster"><div class="bubble">${text}</div></div>`;
                $body.append(html);
                $body.scrollTop($body[0].scrollHeight);
            }

            async function handleChat() {
                const message = $input.val().trim();
                if (!message) return;
                appendMessage(message, 'user');
                $input.val('');

                const loadingId = 'loading-' + Date.now();
                $body.append(`<div class="chat-message bot" id="${loadingId}"><div class="bubble typing-dots"><span></span><span></span><span></span></div></div>`);
                $body.scrollTop($body[0].scrollHeight);

                try {
                    const response = await fetch('/api/chat/send', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message })
                    });
                    if (!response.ok) throw new Error('API Error');
                    const data = await response.json();
                    $('#' + loadingId).remove();
                    appendMessage(data.message, 'bot');
                    if (data.suggestedProperties && data.suggestedProperties.length > 0) {
                        data.suggestedProperties.forEach(p => {
                            $body.append(`
                                <div class="chat-message bot animate__animated animate__fadeIn mt-2">
                                    <div class="bubble p-3" style="background:#fff;border-left:3px solid var(--primary);">
                                        <div class="fw-bold text-dark mb-1" style="font-size:.88rem;">${p.title}</div>
                                        <div style="color:var(--sea);font-weight:700;font-size:.9rem;margin-bottom:8px;">${p.price}</div>
                                        <a href="${p.link}" target="_blank" class="btn btn-sm btn-outline-primary w-100" style="font-size:.82rem;">Xem chi tiết</a>
                                    </div>
                                </div>
                            `);
                        });
                    }
                } catch (e) {
                    $('#' + loadingId).remove();
                    appendMessage('Lỗi kết nối. Vui lòng thử lại sau.', 'bot');
                }
                $body.scrollTop($body[0].scrollHeight);
            }

            $('#chatSendBtn').on('click', handleChat);
            $input.on('keypress', function (e) { if (e.which === 13) handleChat(); });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
