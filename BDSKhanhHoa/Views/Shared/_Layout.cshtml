<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BDSKhanhHoa: Kênh Thông Tin Bất Động Sản Số 1 Khánh Hòa</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --primary-color: #0056b3;
            --secondary-color: #ff6b00;
            --dark-blue: #0f172a;
            --light-gray: #f8fafc;
            --text-color: #334155;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-color);
            background-color: #ffffff;
            line-height: 1.6;
        }

        /* --- HEADER & NAVIGATION --- */
        .header-main {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            box-shadow: 0 2px 15px rgba(0,0,0,0.05);
            transition: var(--transition);
        }

        .navbar-brand {
            font-weight: 900;
            font-size: 1.7rem;
            color: var(--primary-color) !important;
            letter-spacing: -1px;
        }

        .nav-link {
            font-weight: 600;
            color: #475569 !important;
            padding: 10px 15px !important;
            font-size: 0.95rem;
            position: relative;
        }

            .nav-link::after {
                content: '';
                position: absolute;
                bottom: 5px;
                left: 15px;
                right: 15px;
                height: 2px;
                background: var(--primary-color);
                transform: scaleX(0);
                transition: var(--transition);
            }

            .nav-link:hover::after, .nav-link.active::after {
                transform: scaleX(1);
            }

            .nav-link:hover {
                color: var(--primary-color) !important;
            }

        /* --- ACTION BUTTONS --- */
        .btn-post-ad {
            background: linear-gradient(45deg, var(--secondary-color), #ff8e3c);
            color: white !important;
            font-weight: 700;
            padding: 10px 25px !important;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(255, 107, 0, 0.3);
            border: none;
            transition: var(--transition);
        }

            .btn-post-ad:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(255, 107, 0, 0.4);
            }

        /* --- NOTIFICATION BELL --- */
        .noti-wrapper {
            position: relative;
            cursor: pointer;
            padding: 10px;
            color: #64748b;
        }

        .noti-badge {
            position: absolute;
            top: 5px;
            right: 5px;
            background: #ef4444;
            color: white;
            font-size: 10px;
            font-weight: 800;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
        }

        /* --- CHATBOT AI FLOAT BUTTON --- */
        .ai-chatbot-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            background: var(--primary-color);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 25px rgba(0, 86, 179, 0.3);
            cursor: pointer;
            z-index: 1000;
            transition: var(--transition);
        }

            .ai-chatbot-btn:hover {
                transform: scale(1.1) rotate(5deg);
            }

        /* --- FOOTER --- */
        footer {
            background-color: var(--dark-blue);
            color: #94a3b8;
            padding-top: 70px;
        }

            footer h5 {
                color: white;
                font-weight: 700;
                margin-bottom: 25px;
                text-transform: uppercase;
                font-size: 0.9rem;
                letter-spacing: 1px;
            }

        .footer-link {
            color: #94a3b8;
            text-decoration: none;
            display: block;
            margin-bottom: 12px;
            transition: var(--transition);
        }

            .footer-link:hover {
                color: white;
                padding-left: 5px;
            }

        .social-btn {
            width: 35px;
            height: 35px;
            background: rgba(255,255,255,0.05);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            color: white;
            margin-right: 10px;
            transition: var(--transition);
        }

            .social-btn:hover {
                background: var(--primary-color);
                color: white;
            }
    </style>
</head>
<body>
    <header class="header-main sticky-top">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-houses-fill me-2"></i> BDSKhanhHoa
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link active" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/BatDongSan/NhaDatBan">Nhà đất bán</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/BatDongSan/NhaDatChoThue">Nhà đất cho thuê</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Blog" asp-action="Index">Tin tức</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contact" asp-action="Index">Liên hệ</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        <div class="dropdown me-2">
                            <div class="noti-wrapper" data-bs-toggle="dropdown">
                                <i class="bi bi-bell-fill fs-5"></i>
                                <span class="noti-badge">3</span>
                            </div>
                            <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-0 mt-3" style="width: 320px; border-radius: 15px;">
                                <div class="p-3 bg-primary text-white rounded-top d-flex justify-content-between align-items-center">
                                    <span class="fw-bold">Thông báo hệ thống</span>
                                    <small class="opacity-75">Mới nhất</small>
                                </div>
                                <div class="list-group list-group-flush" style="max-height: 350px; overflow-y: auto;">
                                    <a href="#" class="list-group-item list-group-item-action p-3">
                                        <div class="d-flex w-100 justify-content-between small">
                                            <strong class="text-primary">Tin đăng đã duyệt</strong>
                                            <span class="text-muted">10p trước</span>
                                        </div>
                                        <p class="mb-1 small">Tin "Căn hộ Mường Thanh" của bạn đã được Admin duyệt thành công.</p>
                                    </a>
                                </div>
                                <div class="p-2 text-center border-top">
                                    <a href="#" class="small text-decoration-none fw-bold">Xem tất cả thông báo</a>
                                </div>
                            </div>
                        </div>

                        <partial name="_LoginPartial" />

                        @if (!User.IsInRole("Admin"))
                        {
                            <a href="/Property/Create" class="btn btn-post-ad ms-lg-3">
                                <i class="bi bi-plus-circle me-1"></i> ĐĂNG TIN
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <div class="ai-chatbot-btn shadow-lg" id="chatbotToggle" title="Chat với AI tư vấn">
        <i class="bi bi-robot fs-3"></i>
    </div>

    <footer class="mt-5 border-top">
        <div class="container pb-5">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h3 class="text-white fw-900 mb-4">BDSKhanhHoa</h3>
                    <p class="small opacity-75 lh-lg mb-4">
                        Nền tảng kết nối bất động sản hàng đầu tại tỉnh Khánh Hòa.
                        Chúng tôi hỗ trợ người dùng tìm kiếm, đăng tin và tư vấn chuyên sâu
                        với sự hỗ trợ của công nghệ trí tuệ nhân tạo (Chatbot AI).
                    </p>
                    <div class="d-flex">
                        <a href="#" class="social-btn"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-btn"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="social-btn"><i class="bi bi-linkedin"></i></a>
                        <a href="#" class="social-btn"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h5>Danh mục mua bán</h5>
                    <nav class="d-flex flex-column">
                        <a href="#" class="footer-link small">Bán căn hộ Nha Trang</a>
                        <a href="#" class="footer-link small">Bán đất nền Diên Khánh</a>
                        <a href="#" class="footer-link small">Bán nhà riêng Cam Ranh</a>
                        <a href="#" class="footer-link small">Bán biệt thự nghỉ dưỡng</a>
                    </nav>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h5>Hỗ trợ khách hàng</h5>
                    <nav class="d-flex flex-column">
                        <a href="#" class="footer-link small">Điều khoản sử dụng</a>
                        <a href="#" class="footer-link small">Chính sách bảo mật</a>
                        <a href="#" class="footer-link small">Quy trình đăng tin</a>
                        <a href="#" class="footer-link small">Bảng giá gói VIP</a>
                    </nav>
                </div>
                <div class="col-lg-4">
                    <h5>Liên hệ với chúng tôi</h5>
                    <div class="small opacity-75">
                        <p class="mb-2 d-flex"><i class="bi bi-geo-alt-fill text-primary me-3"></i> Số 02 Nguyễn Đình Chiểu, Vĩnh Thọ, Nha Trang, Khánh Hòa.</p>
                        <p class="mb-2 d-flex"><i class="bi bi-telephone-fill text-primary me-3"></i> 1900 79 79 (Hotline 24/7)</p>
                        <p class="mb-2 d-flex"><i class="bi bi-envelope-fill text-primary me-3"></i> support@bdskhanhhoa.com.vn</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="py-3 bg-black bg-opacity-25 text-center border-top border-white border-opacity-10">
            <p class="mb-0 small fw-bold text-secondary">© 2026 BDSKhanhHoa - Đồ án tốt nghiệp CNTT: Phát triển bởi Nguyễn Tiến Tài.</p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>