            }

        .mob-action-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 11px 14px;
            border-radius: 12px;
            font-family: 'Sora', sans-serif;
            font-size: .88rem;
            font-weight: 700;
            border: none;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            position: relative;
            white-space: nowrap;
        }

        .mob-btn-primary {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: #fff !important;
            box-shadow: 0 4px 14px rgba(37,99,235,.25);
        }

            .mob-btn-primary:hover {
                transform: translateY(-1px);
                color: #fff !important;
            }

        .mob-btn-outline {
            background: #fff;
            color: var(--primary) !important;
            border: 1.5px solid #bfdbfe;
        }

            .mob-btn-outline:hover {
                background: #eff6ff;
                color: var(--primary) !important;
            }

        /* ── Block section (nav group) ── */
        .mob-section {
            background: #fff;
            margin-top: 10px;
            border-top: 1px solid #e8eef6;
            border-bottom: 1px solid #e8eef6;
        }

        .mob-section-title {
            font-family: 'Sora', sans-serif;
            font-size: .7rem;
            font-weight: 800;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: #94a3b8;
            padding: 14px 20px 6px;
        }

        /* Nav items */
        .mob-nav-list {
            list-style: none;
            margin: 0;
            padding: 0 10px 10px;
        }

            .mob-nav-list li {
                margin: 0;
            }

        .mob-nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 12px;
            font-family: 'Sora', sans-serif;
            font-size: .93rem;
            font-weight: 600;
            color: var(--text) !important;
            text-decoration: none;
            transition: var(--transition);
            cursor: pointer;
            border: none;
            background: transparent;
            width: 100%;
            text-align: left;
        }

            .mob-nav-item:hover {
                background: #eff6ff;
                color: var(--primary) !important;
            }

                .mob-nav-item:hover .mob-nav-icon {
                    color: var(--primary);
                }

            .mob-nav-item.danger {
                color: #dc2626 !important;
            }

                .mob-nav-item.danger:hover {
                    background: #fef2f2;
                    color: #dc2626 !important;
                }

        .mob-nav-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .95rem;
            flex-shrink: 0;
