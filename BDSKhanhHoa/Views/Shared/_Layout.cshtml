                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

        .navbar-toggler {
            border: none;
            padding: 0;
            box-shadow: none !important;
            flex-shrink: 0;
            background: transparent;
            width: 42px;
            height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            position: relative;
            z-index: 1050;
        }

            .navbar-toggler:focus {
