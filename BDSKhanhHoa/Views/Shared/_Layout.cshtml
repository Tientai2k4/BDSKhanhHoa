                display: flex;
                align-items: center;
                gap: 14px;
            }

        .navbar-brand {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 0;
            margin-right: 0;
            flex-shrink: 0;
            white-space: nowrap;
            min-width: 0;
        }

            .navbar-brand img {
