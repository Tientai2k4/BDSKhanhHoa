        .bubble {
            padding: 10px 14px;
            border-radius: 16px;
            line-height: 1.5;
            font-size: .92rem;
        }

        .user .bubble {
            background: var(--primary);
            color: #fff;
            border-radius: 16px 16px 4px 16px;
        }

        .bot .bubble {
            background: #fff;
            color: var(--text);
            border: 1px solid var(--border);
            border-radius: 16px 16px 16px 4px;
        }

        .typing-dots {
            display: flex;
            gap: 5px;
            padding: 6px 2px;
