<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BDSKhanhHoa: Hệ Thống Bất Động Sản AI Số 1 Khánh Hòa</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --primary: #1a56db;
            --primary-dark: #1242a8;
            --primary-light: #ebf2ff;
            --accent: #f05a28;
            --accent-light: #fff3ee;
            --surface: #ffffff;
            --bg: #f4f6fb;
            --border: #e4e8f0;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --text-light: #94a3b8;
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 18px;
            --radius-xl: 24px;
            --shadow-xs: 0 1px 3px rgba(15,23,42,0.06);
            --shadow-sm: 0 2px 10px rgba(15,23,42,0.08);
            --shadow-md: 0 6px 24px rgba(15,23,42,0.10);
            --shadow-lg: 0 16px 48px rgba(15,23,42,0.12);
            --transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            color: var(--text-main);
            background: var(--bg);
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        h1, h2, h3, h4, h5, h6, .navbar-brand {
            font-family: 'Sora', sans-serif;
        }

        /* ===== NAVBAR ===== */
        .header-main {
            background: rgba(255,255,255,0.97);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            box-shadow: var(--shadow-xs);
            position: sticky;
            top: 0;
            z-index: 1030;
        }

        .navbar {
            padding: 0;
        }

            .navbar > .container {
                min-height: 68px;
            }

        .navbar-brand {
            display: flex;
            align-items: center;
            padding: 0;
        }

            .navbar-brand img {
                height: 52px;
                object-fit: contain;
            }

        .nav-link {
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
            font-size: 0.93rem;
            color: var(--text-muted) !important;
            padding: 8px 14px !important;
            border-radius: var(--radius-sm);
            transition: var(--transition);
            letter-spacing: 0.01em;
        }

            .nav-link:hover,
            .nav-link.active {
                color: var(--primary) !important;
                background: var(--primary-light);
            }

        .btn-post-ad {
            background: var(--accent);
            color: #fff !important;
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 0.85rem;
            padding: 10px 22px !important;
            border-radius: var(--radius-md);
            border: none;
            letter-spacing: 0.04em;
            transition: var(--transition);
            box-shadow: 0 4px 14px rgba(240,90,40,0.25);
            text-transform: uppercase;
        }

            .btn-post-ad:hover {
                background: #d44d1e;
                box-shadow: 0 6px 20px rgba(240,90,40,0.35);
                transform: translateY(-1px);
                color: #fff !important;
            }

        .navbar-toggler {
            border: none;
            padding: 6px;
        }

            .navbar-toggler:focus {
                box-shadow: none;
            }

        /* ===== AI CHATBOT ===== */
        .ai-chatbot-btn {
            position: fixed;
            bottom: 28px;
            right: 28px;
            width: 58px;
            height: 58px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 28px rgba(26,86,219,0.35);
            cursor: pointer;
            z-index: 2000;
            transition: var(--transition);
            border: 3px solid rgba(255,255,255,0.3);
        }

            .ai-chatbot-btn:hover {
                transform: scale(1.08);
                box-shadow: 0 12px 36px rgba(26,86,219,0.45);
            }

            .ai-chatbot-btn i {
                font-size: 1.4rem;
            }

        .chat-widget {
            position: fixed;
            bottom: 100px;
            right: 28px;
            width: 380px;
            height: 580px;
            background: var(--surface);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-lg);
            z-index: 2001;
            overflow: hidden;
            display: none;
            flex-direction: column;
            border: 1px solid var(--border);
        }

        .chat-header {
            background: var(--primary);
            color: white;
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .chat-header h6 {
                font-family: 'Sora', sans-serif;
                font-size: 0.95rem;
                margin: 0;
                font-weight: 700;
            }

            .chat-header small {
                font-size: 0.78rem;
                opacity: 0.8;
            }

        .chat-body {
            flex: 1;
            padding: 16px;
            overflow-y: auto;
            background: var(--bg);
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .chat-message {
            max-width: 86%;
        }

            .chat-message.user {
                align-self: flex-end;
            }

            .chat-message.bot {
                align-self: flex-start;
            }

        .bubble {
            padding: 10px 15px;
            font-size: 0.9rem;
            line-height: 1.55;
            border-radius: var(--radius-md);
        }

        .user .bubble {
            background: var(--primary);
            color: white;
            border-radius: var(--radius-md) var(--radius-md) 4px var(--radius-md);
        }

        .bot .bubble {
            background: var(--surface);
            color: var(--text-main);
            border: 1px solid var(--border);
            border-radius: var(--radius-md) var(--radius-md) var(--radius-md) 4px;
        }

        .typing-dots {
            display: flex;
            gap: 4px;
            padding: 8px 4px;
        }

            .typing-dots span {
                width: 6px;
                height: 6px;
                background: var(--text-light);
                border-radius: 50%;
                animation: bounce 1.3s infinite ease-in-out;
            }

                .typing-dots span:nth-child(2) {
                    animation-delay: 0.18s;
                }

                .typing-dots span:nth-child(3) {
                    animation-delay: 0.36s;
                }

        @@keyframes bounce {
            0%, 80%, 100%

        {
            transform: scale(0);
        }

        40% {
            transform: scale(1);
        }

        }

        .chat-footer {
            padding: 12px 14px;
            background: var(--surface);
            border-top: 1px solid var(--border);
        }

            .chat-footer .input-group .form-control {
                border-radius: var(--radius-md) 0 0 var(--radius-md);
                border: 1px solid var(--border);
                font-size: 0.9rem;
                padding: 10px 14px;
            }

            .chat-footer .btn {
                border-radius: 0 var(--radius-md) var(--radius-md) 0;
                background: var(--primary);
                border-color: var(--primary);
            }

        /* ===== FOOTER ===== */
        footer {
            background: #0d1529;
            color: #7a8fb5;
            padding-top: 70px;
            margin-top: 72px;
        }

        .footer-logo-text {
            font-family: 'Sora', sans-serif;
            font-size: 1.25rem;
            font-weight: 800;
            color: #fff;
            margin-bottom: 12px;
        }

        .footer-title {
            font-family: 'Sora', sans-serif;
            color: #fff;
            font-weight: 700;
            font-size: 0.95rem;
            margin-bottom: 20px;
            letter-spacing: 0.02em;
            text-transform: uppercase;
        }

        .footer-link {
            color: #7a8fb5;
            text-decoration: none;
            display: block;
            margin-bottom: 10px;
            font-size: 0.9rem;
            transition: var(--transition);
        }

            .footer-link:hover {
                color: #fff;
                transform: translateX(4px);
            }

        .footer-social {
            width: 36px;
            height: 36px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.1);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--radius-sm);
            color: #fff;
            text-decoration: none;
            transition: var(--transition);
            font-size: 0.95rem;
        }

            .footer-social:hover {
                background: var(--primary);
                border-color: var(--primary);
                color: #fff;
            }

        .footer-contact-item {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 12px;
            font-size: 0.88rem;
            line-height: 1.5;
        }

            .footer-contact-item i {
                color: var(--primary);
                margin-top: 2px;
                flex-shrink: 0;
                font-size: 0.95rem;
            }

        .copyright-bar {
            background: rgba(0,0,0,0.25);
            padding: 22px 0;
            margin-top: 56px;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

            .copyright-bar p {
                margin: 0;
                font-size: 0.82rem;
                color: #5a6e8e;
            }

            .copyright-bar span {
                color: #5a9bff;
                font-family: 'Sora', sans-serif;
                font-weight: 600;
            }

        /* ===== UTILITIES ===== */
        .text-primary-custom {
            color: var(--primary) !important;
        }

        .text-accent {
            color: var(--accent) !important;
        }
    </style>
</head>
<body>

    <header class="header-main">
        <nav class="navbar navbar-expand-xl">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="/images/logo.png" alt="BDS Khánh Hòa Logo">
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                    <i class="bi bi-list fs-2 text-primary"></i>
                </button>

                <div class="collapse navbar-collapse" id="navContent">
                    <ul class="navbar-nav mx-auto gap-1 mb-2 mb-xl-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i>Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/BatDongSan/NhaDatBan"><i class="bi bi-building me-1"></i>Nhà đất bán</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/BatDongSan/NhaDatChoThue"><i class="bi bi-key me-1"></i>Cho thuê</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Project"><i class="bi bi-buildings me-1"></i>Dự án</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Blog"><i class="bi bi-newspaper me-1"></i>Tin thị trường</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contact" asp-action="Index"><i class="bi bi-chat-dots me-1"></i>Liên hệ</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        <partial name="_LoginPartial" />

                        @if (User.Identity.IsAuthenticated && User.IsInRole("Member"))
                        {
                            <a href="/Property/Create" class="btn btn-post-ad d-none d-sm-inline-flex align-items-center gap-2">
                                <i class="bi bi-plus-circle"></i> Đăng tin
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <!-- Chatbot Toggle Button -->
    <div class="ai-chatbot-btn" id="chatbotToggle" title="Trợ lý AI">
        <i class="bi bi-robot"></i>
    </div>

    <!-- Chat Widget -->
    <div id="chatWidget" class="chat-widget">
        <div class="chat-header">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-stars fs-5"></i>
                <div>
                    <h6>Gemini Assistant</h6>
                    <small>Tư vấn BĐS 24/7</small>
                </div>
            </div>
            <i class="bi bi-x-lg fs-5" id="chatClose" style="cursor:pointer;opacity:0.8;"></i>
        </div>

        <div id="chatBody" class="chat-body">
            <div class="chat-message bot">
                <div class="bubble animate__animated animate__fadeIn">
                    Chào bạn! Mình là trợ lý AI của BDS Khánh Hòa. Bạn đang tìm kiếm bất động sản khu vực nào? 🏠
                </div>
            </div>
        </div>

        <div class="chat-footer">
            <div class="input-group">
                <input id="chatInput" type="text" class="form-control" placeholder="Nhập câu hỏi..." autocomplete="off">
                <button id="chatSendBtn" class="btn btn-primary px-3">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer>
        <div class="container pb-5">
            <div class="row g-5">
                <div class="col-lg-4">
                    <div class="footer-logo-text">BĐS Khánh Hòa</div>
                    <p style="font-size:0.88rem; line-height:1.75; margin-bottom:20px;">
                        Cổng thông tin bất động sản hàng đầu tỉnh Khánh Hòa. Tích hợp AI để giúp bạn tìm được tổ ấm lý tưởng nhanh chóng và dễ dàng.
                    </p>
                    <div class="d-flex gap-2">
                        <a href="#" class="footer-social"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="footer-social"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="footer-social"><i class="bi bi-tiktok"></i></a>
                        <a href="#" class="footer-social"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>

                <div class="col-lg-2 col-6">
                    <div class="footer-title">Khám phá</div>
                    <a href="#" class="footer-link">Nhà đất bán</a>
                    <a href="#" class="footer-link">Đất nền</a>
                    <a href="#" class="footer-link">Căn hộ</a>
                    <a href="#" class="footer-link">Cho thuê</a>
                    <a href="#" class="footer-link">Tin mới nhất</a>
                </div>

                <div class="col-lg-2 col-6">
                    <div class="footer-title">Hỗ trợ</div>
                    <a href="#" class="footer-link">Điều khoản sử dụng</a>
                    <a href="#" class="footer-link">Quy định đăng tin</a>
                    <a href="#" class="footer-link">Chính sách bảo mật</a>
                    <a href="#" class="footer-link">Báo giá VIP</a>
                </div>

                <div class="col-lg-4">
                    <div class="footer-title">Liên hệ</div>
                    <div class="footer-contact-item">
                        <i class="bi bi-geo-alt-fill"></i>
                        <span>02 Nguyễn Đình Chiểu, Vĩnh Thọ, Nha Trang, Khánh Hòa</span>
                    </div>
                    <div class="footer-contact-item">
                        <i class="bi bi-telephone-fill"></i>
                        <span>Hotline: <a href="tel:1900889900" style="color:#5a9bff;text-decoration:none;">1900 88 99</a></span>
                    </div>
                    <div class="footer-contact-item">
                        <i class="bi bi-envelope-fill"></i>
                        <span><a href="mailto:support@bdskhanhhoa.vn" style="color:#5a9bff;text-decoration:none;">support@bdskhanhhoa.vn</a></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="copyright-bar text-center">
            <div class="container">
                <p>
                    © 2026 Đồ án tốt nghiệp CNTT – Đại học Nha Trang<br>
                    <span>Phát triển bởi: Nguyễn Tiến Tài</span>
                </p>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            const $btn = $('#chatbotToggle');
            const $widget = $('#chatWidget');
            const $input = $('#chatInput');
            const $body = $('#chatBody');

            $btn.on('click', function () {
                if ($widget.is(':visible')) {
                    $widget.fadeOut(250);
                } else {
                    $widget.fadeIn(250).css('display', 'flex');
                    $input.focus();
                }
            });

            $('#chatClose').on('click', function () { $widget.fadeOut(250); });

            function appendMessage(text, sender) {
                const html = `<div class="chat-message ${sender} animate__animated animate__fadeInUp animate__faster"><div class="bubble">${text}</div></div>`;
                $body.append(html);
                $body.animate({ scrollTop: $body[0].scrollHeight }, 300);
            }

            async function handleChat() {
                const message = $input.val().trim();
                if (!message) return;
                appendMessage(message, 'user');
                $input.val('');

                const loadingId = 'loading-' + Date.now();
                $body.append(`<div class="chat-message bot" id="${loadingId}"><div class="bubble typing-dots"><span></span><span></span><span></span></div></div>`);
                $body.scrollTop($body[0].scrollHeight);

                try {
                    const response = await fetch('/api/chat/send', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message })
                    });
                    if (!response.ok) throw new Error('API Error');
                    const data = await response.json();
                    $(`#${loadingId}`).remove();
                    appendMessage(data.message, 'bot');

                    if (data.suggestedProperties && data.suggestedProperties.length > 0) {
                        data.suggestedProperties.forEach(p => {
                            $body.append(`<div class="chat-message bot animate__animated animate__fadeIn mt-2"><div class="bubble p-3" style="border-left:3px solid var(--primary);background:#fff;"><div class="fw-bold text-dark mb-1" style="font-size:.88rem;">${p.title}</div><div style="color:var(--accent);font-weight:700;font-size:.9rem;margin-bottom:8px;">${p.price}</div><a href="${p.link}" target="_blank" class="btn btn-sm btn-outline-primary w-100" style="font-size:.82rem;">Xem chi tiết</a></div></div>`);
                        });
                    }
                } catch (e) {
                    $(`#${loadingId}`).remove();
                    appendMessage('Lỗi kết nối. Vui lòng thử lại sau.', 'bot');
                }
                $body.animate({ scrollTop: $body[0].scrollHeight }, 300);
            }

            $('#chatSendBtn').on('click', handleChat);
            $input.on('keypress', function (e) { if (e.which === 13) handleChat(); });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
