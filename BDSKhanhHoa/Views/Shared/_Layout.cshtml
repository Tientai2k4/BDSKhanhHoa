            }

        .dropdown-menu {
            border: 1px solid rgba(230,237,245,.96);
            border-radius: 16px;
            box-shadow: var(--shadow-md);
            padding: 10px;
        }

        .dropdown-item {
            border-radius: 12px;
            font-weight: 600;
            padding-top: 10px;
            padding-bottom: 10px;
        }

            .dropdown-item:active {
                background: rgba(37,99,235,.1);
