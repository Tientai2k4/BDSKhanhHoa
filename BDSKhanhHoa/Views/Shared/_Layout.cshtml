@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using BDSKhanhHoa.Models
@inject BDSKhanhHoa.Data.ApplicationDbContext _context

@{
    int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out int currentUserId);

    var businessProfile = currentUserId > 0
        ? _context.BusinessProfiles.AsNoTracking().FirstOrDefault(b => b.UserID == currentUserId)
        : null;

    bool isBusinessVerified = businessProfile != null && businessProfile.VerificationStatus == "Approved";
    bool isAdminOrStaff = User.IsInRole("Admin") || User.IsInRole("Staff");
    bool canPostSingleAd = User.Identity.IsAuthenticated && !isBusinessVerified && !isAdminOrStaff;

    int unreadCount = 0;
    var topNotifications = new List<Notification>();

    if (User.Identity.IsAuthenticated && currentUserId > 0)
    {
        unreadCount = _context.Notifications.Count(n => n.UserID == currentUserId && !n.IsRead);

        topNotifications = _context.Notifications
            .AsNoTracking()
            .Where(n => n.UserID == currentUserId)
            .OrderByDescending(n => n.CreatedAt)
            .Take(5)
            .ToList();
    }

    var avatarUrl = User.FindFirst("Avatar")?.Value ?? "/images/avatars/default-user.png";
    var userName = !string.IsNullOrWhiteSpace(User.Identity?.Name) ? User.Identity.Name : "Tài khoản";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BDSKhanhHoa</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --bg: #f5f8fc;
            --surface: rgba(255,255,255,.96);
            --surface-2: #ffffff;
            --text: #0f172a;
            --muted: #64748b;
            --border: #e5ecf4;
            --primary: #2563eb;
            --primary-2: #1d4ed8;
            --sea: #0ea5e9;
            --sea-2: #0284c7;
            --success: #16a34a;
            --danger: #ef4444;
            --shadow-sm: 0 8px 22px rgba(15, 23, 42, .06);
            --shadow-md: 0 16px 38px rgba(15, 23, 42, .10);
            --shadow-lg: 0 22px 60px rgba(15, 23, 42, .16);
            --radius: 18px;
            --radius-lg: 22px;
            --radius-xl: 28px;
            --transition: all .22s ease;
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            background: var(--bg);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
        }

        body {
            min-height: 100vh;
        }

        h1, h2, h3, h4, h5, h6, .navbar-brand, .btn, .nav-link {
            font-family: 'Sora', sans-serif;
        }

        a {
            text-decoration: none;
        }

        main {
            min-height: 60vh;
        }

        /* ═══════════════════════════════════
                   HEADER
                ═══════════════════════════════════ */
        .header-main {
            position: sticky;
            top: 0;
            z-index: 1030;
            background: rgba(255,255,255,.92);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-bottom: 1px solid rgba(230,237,245,.95);
            box-shadow: 0 1px 0 rgba(15,23,42,.04);
        }

        .navbar {
            padding: 0;
        }

