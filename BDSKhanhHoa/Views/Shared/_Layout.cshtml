        }

        /* ── Shortcut block (cuối) ── */
        .mob-shortcuts {
            background: #fff;
            margin-top: 10px;
            margin-bottom: 10px;
            border-top: 1px solid #e8eef6;
            border-bottom: 1px solid #e8eef6;
            padding: 6px 10px 14px;
        }

        .mob-shortcuts-title {
            font-family: 'Sora', sans-serif;
            font-size: .7rem;
            font-weight: 800;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: #94a3b8;
            padding: 14px 10px 10px;
        }

        .mob-shortcut-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .mob-shortcut-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 11px 12px;
            border-radius: 12px;
            background: #f8fafc;
            border: 1.5px solid #e2e8f0;
            font-family: 'Sora', sans-serif;
            font-size: .82rem;
            font-weight: 700;
            color: var(--text) !important;
            text-decoration: none;
            transition: var(--transition);
        }

            .mob-shortcut-btn:hover {
                background: #eff6ff;
                border-color: #bfdbfe;
                color: var(--primary) !important;
            }

            .mob-shortcut-btn i {
                font-size: .9rem;
                flex-shrink: 0;
            }

        /* ═══════════════════════════════════
                   FOOTER
                ═══════════════════════════════════ */
        .footer-modern {
            background: radial-gradient(circle at top left,rgba(14,165,233,.16),transparent 28%), radial-gradient(circle at top right,rgba(37,99,235,.14),transparent 24%), linear-gradient(180deg,#0b1220 0%,#0f172a 100%);
            color: #cbd5e1;
            margin-top: 72px;
            position: relative;
            overflow: hidden;
        }

            .footer-modern::before {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg,rgba(255,255,255,.03),transparent 40%);
                pointer-events: none;
            }

        .footer-top {
            position: relative;
            padding: 56px 0 34px;
            border-bottom: 1px solid rgba(148,163,184,.14);
        }

        .footer-brand {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 18px;
        }

            .footer-brand img {
                width: 56px;
                height: 56px;
                object-fit: contain;
                flex-shrink: 0;
            }

        .footer-brand-title {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.2;
        }

        .footer-brand-subtitle {
            margin: 3px 0 0;
            color: #94a3b8;
            font-size: .88rem;
            line-height: 1.5;
        }

        .footer-desc {
            color: #cbd5e1;
            font-size: .94rem;
            line-height: 1.9;
            margin-bottom: 18px;
        }

        .footer-section-title {
            color: #fff;
            font-weight: 800;
            font-size: .95rem;
            margin-bottom: 18px;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .footer-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #cbd5e1;
            text-decoration: none;
            font-size: .92rem;
            padding: 7px 0;
            transition: all .2s ease;
        }

            .footer-link:hover {
                color: #fff;
                transform: translateX(4px);
            }

            .footer-link i {
                color: #60a5fa;
                flex-shrink: 0;
            }

        .footer-contact {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .footer-contact-item {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

            .footer-contact-item .icon {
                width: 38px;
                height: 38px;
                border-radius: 12px;
                background: rgba(255,255,255,.06);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                color: #7dd3fc;
                flex-shrink: 0;
            }

            .footer-contact-item .info {
                min-width: 0;
            }

            .footer-contact-item .label {
                display: block;
                font-size: .74rem;
                color: #94a3b8;
                text-transform: uppercase;
                letter-spacing: .08em;
                margin-bottom: 4px;
            }

            .footer-contact-item .value {
                color: #fff;
                text-decoration: none;
                font-weight: 600;
                line-height: 1.5;
            }

                .footer-contact-item .value:hover {
                    color: #7dd3fc;
                }

        .footer-socials {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 16px;
        }

        .footer-social {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,.06);
            color: #fff;
            text-decoration: none;
            transition: all .2s ease;
        }

            .footer-social:hover {
                background: linear-gradient(135deg,#0ea5e9,#2563eb);
                transform: translateY(-2px);
                color: #fff;
            }

        .footer-badges {
            display: grid;
            grid-template-columns: repeat(2,minmax(0,1fr));
            gap: 10px;
            margin-top: 18px;
        }

        .footer-badge {
            padding: 12px 14px;
            border-radius: 16px;
            background: rgba(255,255,255,.05);
            border: 1px solid rgba(148,163,184,.12);
            color: #e2e8f0;
            font-size: .86rem;
            line-height: 1.5;
        }

            .footer-badge strong {
                display: block;
                color: #fff;
                font-size: .92rem;
                margin-bottom: 2px;
            }

        .footer-newsletter {
            border-radius: 20px;
