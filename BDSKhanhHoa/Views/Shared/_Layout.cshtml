                box-shadow: 0 16px 30px rgba(14,165,233,.30);
                color: #fff !important;
            }

        .btn-post-ad-sm {
            width: 42px;
            height: 42px;
            padding: 0;
            border-radius: 50%;
        }

        .icon-btn {
            width: 42px;
            height: 42px;
            border: 1px solid var(--border);
            border-radius: 50%;
            background: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #334155;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
            flex-shrink: 0;
