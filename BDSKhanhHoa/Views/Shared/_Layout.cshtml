            border: 1px solid #bfdbfe;
        }

        .mob-badge-admin {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

        /* Nút hành động */
        .mob-action-row {
            display: grid;
            gap: 10px;
        }

            .mob-action-row.two-col {
                grid-template-columns: 1fr 1fr;
            }

            .mob-action-row.one-col {
