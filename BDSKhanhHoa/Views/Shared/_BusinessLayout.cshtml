@using BDSKhanhHoa.Data
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _context

@{
    int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out int currentUserId);
    var userAvatar = User.FindFirst("Avatar")?.Value ?? "/images/avatars/default-business.png";

    var businessProfile = _context.BusinessProfiles.AsNoTracking().FirstOrDefault(b => b.UserID == currentUserId);
    var businessName = businessProfile?.BusinessName ?? "Doanh nghiệp đối tác";

    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";

    int newLeadsCount = _context.ProjectLeads.Count(l => l.HandledByUserID == currentUserId && l.LeadStatus == "New");
    int activeProjects = _context.Projects.Count(p => p.OwnerUserID == currentUserId && !p.IsDeleted);
    int activeAppointments = _context.Appointments.Count(a => a.BuyerID == currentUserId || a.SellerID == currentUserId);
    int upcomingAppointments = _context.Appointments.Count(a =>
        (a.BuyerID == currentUserId || a.SellerID == currentUserId) &&
        (a.Status == "Pending" || a.Status == "Confirmed"));

    bool IsActive(string controller, string? action = null)
    {
        if (!string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)) return false;
        return action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
    }

    string navClass(string controller, string? action = null) => IsActive(controller, action) ? "menu-item active" : "menu-item";
}

<!DOCTYPE html>
<html lang="vi" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>@ViewData["Title"] - Enterprise Portal | BDS KHÁNH HÒA</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --bg: #f4f7fb;
            --surface: rgba(255, 255, 255, 0.88);
            --text: #0f172a;
            --muted: #64748b;
            --navy: #0b1220;
            --accent: #f59e0b;
            --sidebar-width: 290px;
            --header-height: 78px;
            --transition: 260ms cubic-bezier(.2,.8,.2,1);
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            color: var(--text);
            background: radial-gradient(circle at top left, rgba(245, 158, 11, 0.08), transparent 25%), radial-gradient(circle at top right, rgba(14, 165, 233, 0.08), transparent 20%), linear-gradient(180deg, #f8fbff 0%, var(--bg) 100%);
            background-attachment: fixed;
            overflow-x: hidden;
        }

        h1, h2, h3, h4, h5, h6, .brand-text {
            font-family: 'Plus Jakarta Sans', sans-serif;
            letter-spacing: -0.02em;
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(100, 116, 139, 0.4);
            border-radius: 10px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: var(--accent);
            }

        .mobile-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(4px);
            z-index: 1035;
            opacity: 0;
            visibility: hidden;
            transition: var(--transition);
        }

            .mobile-overlay.active {
                opacity: 1;
                visibility: visible;
            }

        .sidebar-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: linear-gradient(180deg, var(--navy) 0%, #0f172a 100%);
            color: #fff;
            z-index: 1040;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 25px rgba(15, 23, 42, 0.15);
            transition: var(--transition);
        }

        .sidebar-brand {
            height: var(--header-height);
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .brand-chip {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 14px;
            text-decoration: none;
            color: #fff;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
        }

            .brand-chip i {
                font-size: 1.4rem;
                color: var(--accent);
            }

        .sidebar-content {
            flex: 1;
            overflow-y: auto;
            padding: 20px 14px;
        }

        .biz-profile-card {
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 20px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
        }

            .biz-profile-card .avatar {
                width: 50px;
                height: 50px;
                border-radius: 12px;
                object-fit: cover;
                border: 2px solid var(--accent);
                box-shadow: 0 4px 15px rgba(245, 158, 11, 0.2);
            }

        .menu-category {
            display: block;
            margin: 20px 10px 8px;
            color: rgba(148, 163, 184, 0.8);
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            margin-bottom: 4px;
            color: rgba(226, 232, 240, 0.85);
            text-decoration: none;
            border-radius: 14px;
            font-weight: 600;
            font-size: 0.92rem;
            transition: var(--transition);
            border: 1px solid transparent;
        }

            .menu-item i.menu-icon {
                font-size: 1.15rem;
                width: 24px;
                text-align: center;
            }

            .menu-item:hover {
                background: rgba(255,255,255,0.08);
                color: #fff;
                transform: translateX(3px);
            }

            .menu-item.active {
                background: linear-gradient(135deg, rgba(245, 158, 11, 0.9), rgba(251, 191, 36, 0.9));
                color: #0f172a;
                box-shadow: 0 8px 20px rgba(245, 158, 11, 0.25);
                border-color: rgba(255,255,255,0.2);
            }

        .menu-badge {
            margin-left: auto;
            padding: 2px 8px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 800;
            color: #fff;
            background: linear-gradient(135deg, #ef4444, #f97316);
        }

            .menu-badge.soft {
                background: rgba(255,255,255,0.15);
                color: #fff;
            }

        .sidebar-footer {
            padding: 14px;
            border-top: 1px solid rgba(255,255,255,0.06);
        }

            .sidebar-footer .mini-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 12px;
                border-radius: 12px;
                color: rgba(226, 232, 240, 0.8);
                text-decoration: none;
                transition: var(--transition);
                font-weight: 600;
                font-size: 0.9rem;
            }

                .sidebar-footer .mini-link:hover {
                    background: rgba(255,255,255,0.08);
                    color: #fff;
                }

                .sidebar-footer .mini-link.text-danger:hover {
                    background: rgba(239, 68, 68, 0.15);
                    color: #fca5a5 !important;
                }

        .main-panel {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .top-header {
            position: sticky;
            top: 0;
            z-index: 1030;
            height: var(--header-height);
            padding: 0 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(15, 23, 42, 0.05);
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.02);
        }

        .icon-btn {
            position: relative;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            border: 1px solid rgba(15, 23, 42, 0.08);
            background: #fff;
            color: var(--text);
            text-decoration: none;
            transition: var(--transition);
        }

            .icon-btn:hover {
                background: #f8fafc;
                color: var(--accent);
                border-color: var(--accent);
            }

            .icon-btn .badge-dot {
                position: absolute;
                top: -4px;
                right: -4px;
                min-width: 18px;
                height: 18px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 50%;
                font-size: 0.65rem;
                font-weight: 800;
                color: #fff;
                background: #ef4444;
                border: 2px solid #fff;
            }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 6px 14px 6px 6px;
            border-radius: 50px;
            background: #fff;
            border: 1px solid rgba(15, 23, 42, 0.08);
        }

            .user-chip img {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                object-fit: cover;
            }

            .user-chip .name {
                font-weight: 700;
                color: var(--text);
                font-size: 0.9rem;
            }

            .user-chip .role {
                color: var(--muted);
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

        .content-body {
            padding: 28px;
            flex: 1;
        }

        @@media (max-width: 991.98px) {
            .sidebar-wrapper {
                transform: translateX(-100%);
            }

                .sidebar-wrapper.show {
                    transform: translateX(0);
                }

            .main-panel {
                margin-left: 0;
            }

            .top-header {
                padding: 0 16px;
            }

            .content-body {
                padding: 16px;
            }
        }

        @@media (max-width: 575.98px) {
            .user-chip .role {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="mobile-overlay" id="mobileOverlay"></div>

    <aside class="sidebar-wrapper" id="sidebar">
        <div class="sidebar-brand">
            <a href="/" class="brand-chip">
                <i class="bi bi-buildings-fill"></i>
                <div>
                    <div class="brand-text fw-black" style="font-size:1rem; line-height:1;">ENTERPRISE</div>
                    <small style="color: rgba(255,255,255,.6); font-size:.7rem;">BDS Khánh Hòa</small>
                </div>
            </a>
        </div>

        <div class="sidebar-content">
            <div class="biz-profile-card">
                <div class="d-flex align-items-center gap-3">
                    <img src="@userAvatar" alt="Avatar" class="avatar" />
                    <div class="text-start overflow-hidden">
                        <div class="name text-truncate" title="@businessName">@businessName</div>
                        <div class="meta mt-1"><i class="bi bi-patch-check-fill text-success"></i> Tài khoản pháp nhân</div>
                    </div>
                </div>
            </div>

            <span class="menu-category">CRM & Điều phối</span>
            <a href="/MemberProject/Index" class="@navClass("MemberProject", "Index")">
                <i class="bi bi-funnel-fill menu-icon"></i> Phễu khách hàng (CRM)
                @if (newLeadsCount > 0)
                {
                    <span class="menu-badge animate__animated animate__pulse animate__infinite">@newLeadsCount</span>
                }
            </a>

            <a href="/Appointments/Index" class="@navClass("Appointments", "Index")">
                <i class="bi bi-calendar2-week-fill menu-icon"></i> Lịch hẹn điều phối
                @if (upcomingAppointments > 0)
                {
                    <span class="menu-badge soft">@upcomingAppointments</span>
                }
            </a>

            <span class="menu-category">Dự án & Hồ sơ</span>
            <a href="/MemberProject/MyProjects" class="@navClass("MemberProject", "MyProjects")">
                <i class="bi bi-folder-check menu-icon"></i> Kho Dự Án Của Tôi
                @if (activeProjects > 0)
                {
                    <span class="menu-badge soft">@activeProjects</span>
                }
            </a>

            <a href="/ProjectTimeline/Index" class="@navClass("ProjectTimeline", "Index")">
                <i class="bi bi-clock-history menu-icon"></i> Nhật ký giai đoạn dự án
            </a>

            <a href="/ProjectVault/Index" class="@navClass("ProjectVault", "Index")">
                <i class="bi bi-shield-lock-fill menu-icon"></i> Kho tài liệu & pháp lý
            </a>

            <span class="menu-category">Hỗ trợ & Báo cáo</span>
            <a href="/SupportTickets/Index" class="@navClass("SupportTickets", "Index")">
                <i class="bi bi-life-preserver menu-icon"></i> Trung tâm hỗ trợ
            </a>

            <a href="/Analytics/Index" class="@navClass("Analytics", "Index")">
                <i class="bi bi-graph-up-arrow menu-icon"></i> Báo cáo hiệu suất
            </a>

            <span class="menu-category">Hệ thống & Hồ sơ</span>
            <a href="/Account/Profile" class="@navClass("Account", "Profile")">
                <i class="bi bi-person-vcard menu-icon"></i> Hồ sơ doanh nghiệp (KYC)
            </a>
        </div>

        <div class="sidebar-footer">
            <a href="/" class="mini-link text-info">
                <i class="bi bi-box-arrow-up-right"></i> Về Web Public
            </a>
            <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" class="m-0 p-0">
                @Html.AntiForgeryToken()
                <a href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit()" class="mini-link text-danger mt-1">
                    <i class="bi bi-power"></i> Đăng xuất hệ thống
                </a>
            </form>
        </div>
    </aside>

    <div class="main-panel">
        <header class="top-header">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-light border d-lg-none rounded-3" id="btnToggleSidebar" type="button">
                    <i class="bi bi-list fs-4 text-dark"></i>
                </button>
                <div>
                    <h5 class="mb-0 fw-bolder text-dark d-none d-sm-block">@ViewData["Title"]</h5>
                    <small class="text-muted d-none d-sm-inline">Cổng Quản trị Chuyên viên Dự án</small>
                </div>
            </div>

            <div class="d-flex align-items-center gap-3">
                <a href="/MemberProject/Index" class="icon-btn" title="Thông báo khách quan tâm">
                    <i class="bi bi-bell-fill fs-5 @(newLeadsCount > 0 ? "text-warning animate__animated animate__swing animate__infinite" : "")"></i>
                    @if (newLeadsCount > 0)
                    {
                        <span class="badge-dot">@newLeadsCount</span>
                    }
                </a>

                <a href="/Appointments/Index" class="icon-btn" title="Lịch hẹn">
                    <i class="bi bi-calendar-check-fill fs-5 @(activeAppointments > 0 ? "text-primary" : "")"></i>
                    @if (activeAppointments > 0)
                    {
                        <span class="badge-dot">@activeAppointments</span>
                    }
                </a>

                <div class="user-chip">
                    <img src="@userAvatar" alt="Avatar" />
                    <div class="d-none d-sm-block text-end pe-2">
                        <div class="name">@User.Identity?.Name</div>
                        <div class="role">Quản lý dự án</div>
                    </div>
                </div>
            </div>
        </header>

        <main class="content-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-4 animate__animated animate__fadeInDown">
                    <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                    <span class="fw-bold">@TempData["Success"]</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-4 animate__animated animate__shakeX">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                    <span class="fw-bold">@TempData["Error"]</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="animate__animated animate__fadeIn">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(function () {
            setTimeout(function () { $('.alert-dismissible').fadeOut('slow'); }, 5000);

            const $sidebar = $('#sidebar');
            const $overlay = $('#mobileOverlay');

            $('#btnToggleSidebar').on('click', function () {
                $sidebar.addClass('show');
                $overlay.addClass('active');
            });

            $overlay.on('click', function () {
                $sidebar.removeClass('show');
                $(this).removeClass('active');
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>