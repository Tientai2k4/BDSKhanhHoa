@model BDSKhanhHoa.Components.NavbarMenuViewModel

<li class="nav-item dropdown nav-hover-menu">
    <a class="nav-link dropdown-toggle nav-main-link d-flex align-items-center gap-2"
       href="#"
       id="buyDropdown"
       role="button"
       data-bs-toggle="dropdown"
       aria-expanded="false">
        <i class="bi bi-building-fill nav-icon text-warning"></i>
        <span class="nav-text">Bán</span>
    </a>

    <ul class="dropdown-menu border-0 shadow-lg rounded-4 p-3 nav-hover-dropdown"
        aria-labelledby="buyDropdown">
        <li class="mb-2">
            <div class="dropdown-header text-uppercase fw-bold text-primary px-2" style="font-size:.72rem; letter-spacing:.12em;">
                Danh mục mua bán
            </div>
        </li>

        @if (Model?.BuyCategories != null && Model.BuyCategories.Any())
        {
            foreach (var item in Model.BuyCategories)
            {
                <li>
                    <a class="dropdown-item dropdown-item-rich py-2 px-3 rounded-3 d-flex align-items-center gap-3"
                       href="/BatDongSan/NhaDatBan?typeId=@item.TypeID">
                        <div class="icon-box-menu bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-house-door-fill"></i>
                        </div>
                        <div class="d-flex flex-column min-w-0">
                            <span class="fw-semibold text-dark text-truncate nav-dd-title">@item.TypeName</span>
                            <small class="text-muted">Mua bán, đầu tư, an cư</small>
                        </div>
                    </a>
                </li>
            }
        }
        else
        {
            <li>
                <div class="p-3 text-center text-muted small">
                    Danh mục đang được cập nhật.
                </div>
            </li>
        }

        <li><hr class="dropdown-divider my-3 opacity-10"></li>

        <li>
            <a class="dropdown-item btn-view-all text-center fw-bold text-primary py-3 rounded-3 bg-primary bg-opacity-10 d-flex justify-content-center align-items-center gap-2"
               href="/BatDongSan/NhaDatBan">
                Xem tất cả tin bán <i class="bi bi-arrow-right-circle-fill"></i>
            </a>
        </li>
    </ul>
</li>

<li class="nav-item dropdown nav-hover-menu">
    <a class="nav-link dropdown-toggle nav-main-link d-flex align-items-center gap-2"
       href="#"
       id="rentDropdown"
       role="button"
       data-bs-toggle="dropdown"
       aria-expanded="false">
        <i class="bi bi-key-fill nav-icon text-success"></i>
        <span class="nav-text">Thuê</span>
    </a>

    <ul class="dropdown-menu border-0 shadow-lg rounded-4 p-3 nav-hover-dropdown"
        aria-labelledby="rentDropdown">
        <li class="mb-2">
            <div class="dropdown-header text-uppercase fw-bold text-success px-2" style="font-size:.72rem; letter-spacing:.12em;">
                Danh mục cho thuê
            </div>
        </li>

        @if (Model?.RentCategories != null && Model.RentCategories.Any())
        {
            foreach (var item in Model.RentCategories)
            {
                <li>
                    <a class="dropdown-item dropdown-item-rich py-2 px-3 rounded-3 d-flex align-items-center gap-3"
                       href="/BatDongSan/NhaDatChoThue?typeId=@item.TypeID">
                        <div class="icon-box-menu bg-success bg-opacity-10 text-success">
                            <i class="bi bi-door-open-fill"></i>
                        </div>
                        <div class="d-flex flex-column min-w-0">
                            <span class="fw-semibold text-dark text-truncate nav-dd-title">@item.TypeName</span>
                            <small class="text-muted">Căn hộ, nhà phố, mặt bằng</small>
                        </div>
                    </a>
                </li>
            }
        }
        else
        {
            <li>
                <div class="p-3 text-center text-muted small">
                    Danh mục đang được cập nhật.
                </div>
            </li>
        }

        <li><hr class="dropdown-divider my-3 opacity-10"></li>

        <li>
            <a class="dropdown-item btn-view-all text-center fw-bold text-success py-3 rounded-3 bg-success bg-opacity-10 d-flex justify-content-center align-items-center gap-2"
               href="/BatDongSan/NhaDatChoThue">
                Xem tất cả tin thuê <i class="bi bi-arrow-right-circle-fill"></i>
            </a>
        </li>
    </ul>
</li>