@model BDSKhanhHoa.Components.NavbarMenuViewModel

<style>
    /* =========================================================================
           NÂNG CẤP GIAO DIỆN DROPDOWN MENU CHUẨN UX/UI 2026
           ========================================================================= */
    .mega-menu-wrapper .dropdown-menu {
        border-top: 4px solid var(--primary-color, #2563eb);
        display: block;
        opacity: 0;
        visibility: hidden;
        transform: translateY(15px);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        pointer-events: none;
    }

    /* Hiệu ứng Hover thông minh - Không cần click vẫn mở mượt mà trên Desktop */
    @@media (min-width: 1200px) {
        .mega-menu-wrapper:hover .dropdown-menu {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
            pointer-events: auto;
        }
    }

    .dropdown-item-rich {
        transition: all 0.25s ease-in-out;
        border: 1px solid transparent;
    }

        .dropdown-item-rich:hover {
            background-color: #f8fafc;
            border-color: #e2e8f0;
            transform: translateX(5px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        }

    .icon-box-menu {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .dropdown-item-rich:hover .icon-box-menu {
        transform: scale(1.1);
    }

    .btn-view-all {
        transition: all 0.2s;
    }

        .btn-view-all:hover {
            filter: brightness(0.95);
            letter-spacing: 0.5px;
        }
</style>

<li class="nav-item dropdown mega-menu-wrapper">
    <a class="nav-link dropdown-toggle fw-bold d-flex align-items-center gap-2" href="#" id="buyDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-building-fill text-warning fs-5"></i>
        <span>Mua Bán</span>
    </a>

    <ul class="dropdown-menu border-0 shadow-lg rounded-4 p-3" aria-labelledby="buyDropdown" style="min-width: 320px; margin-top: 8px;">
        <li>
            <h6 class="dropdown-header text-uppercase text-primary fw-black mb-2" style="font-size: 0.75rem; letter-spacing: 1.5px;">
                <i class="bi bi-tags-fill me-1"></i> Danh mục Đầu tư
            </h6>
        </li>

        @if (Model.BuyCategories != null && Model.BuyCategories.Any())
        {
            foreach (var item in Model.BuyCategories)
            {
                <li>
                    <a class="dropdown-item dropdown-item-rich py-2 px-3 rounded-3 d-flex align-items-center gap-3" href="/BatDongSan/NhaDatBan?typeId=@item.TypeID">
                        <div class="icon-box-menu bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-house-door-fill fs-6"></i>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fw-bold text-dark lh-1 mb-1" style="font-size: 0.95rem;">@item.TypeName</span>
                            <small class="text-muted" style="font-size: 0.75rem;">Phân khúc mua bán & đầu tư</small>
                        </div>
                    </a>
                </li>
            }
        }
        else
        {
            <li>
                <div class="p-3 text-center text-muted">
                    <i class="bi bi-hourglass-split fs-4 d-block mb-1 opacity-50"></i>
                    <span class="small fst-italic">Dữ liệu đang được cập nhật...</span>
                </div>
            </li>
        }

        <li><hr class="dropdown-divider my-3 opacity-10"></li>

        <li>
            <a class="dropdown-item btn-view-all text-center fw-bold text-primary py-3 rounded-3 bg-primary bg-opacity-10 d-flex justify-content-center align-items-center gap-2" href="/BatDongSan/NhaDatBan">
                Khám phá toàn bộ rổ hàng <i class="bi bi-arrow-right-circle-fill fs-5"></i>
            </a>
        </li>
    </ul>
</li>

<li class="nav-item dropdown mega-menu-wrapper">
    <a class="nav-link dropdown-toggle fw-bold d-flex align-items-center gap-2" href="#" id="rentDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-key-fill text-success fs-5"></i>
        <span>Cho Thuê</span>
    </a>

    <ul class="dropdown-menu border-0 shadow-lg rounded-4 p-3" aria-labelledby="rentDropdown" style="min-width: 320px; margin-top: 8px;">
        <li>
            <h6 class="dropdown-header text-uppercase text-success fw-black mb-2" style="font-size: 0.75rem; letter-spacing: 1.5px;">
                <i class="bi bi-shop me-1"></i> Phân khúc Lưu trú & Kinh doanh
            </h6>
        </li>

        @if (Model.RentCategories != null && Model.RentCategories.Any())
        {
            foreach (var item in Model.RentCategories)
            {
                <li>
                    <a class="dropdown-item dropdown-item-rich py-2 px-3 rounded-3 d-flex align-items-center gap-3" href="/BatDongSan/NhaDatChoThue?typeId=@item.TypeID">
                        <div class="icon-box-menu bg-success bg-opacity-10 text-success">
                            <i class="bi bi-door-open-fill fs-6"></i>
                        </div>
                        <div class="d-flex flex-column">
                            <span class="fw-bold text-dark lh-1 mb-1" style="font-size: 0.95rem;">@item.TypeName</span>
                            <small class="text-muted" style="font-size: 0.75rem;">Giải pháp thuê tối ưu</small>
                        </div>
                    </a>
                </li>
            }
        }
        else
        {
            <li>
                <div class="p-3 text-center text-muted">
                    <i class="bi bi-inbox-fill fs-4 d-block mb-1 opacity-50"></i>
                    <span class="small fst-italic">Hạng mục đang được xây dựng...</span>
                </div>
            </li>
        }

        <li><hr class="dropdown-divider my-3 opacity-10"></li>

        <li>
            <a class="dropdown-item btn-view-all text-center fw-bold text-success py-3 rounded-3 bg-success bg-opacity-10 d-flex justify-content-center align-items-center gap-2" href="/BatDongSan/NhaDatChoThue">
                Tìm kiếm BĐS Cho thuê <i class="bi bi-arrow-right-circle-fill fs-5"></i>
            </a>
        </li>
    </ul>
</li>