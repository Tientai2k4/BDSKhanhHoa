@using System.Security.Claims

@if (User.Identity.IsAuthenticated)
{
    <div class="d-flex align-items-center">
        @if (!User.IsInRole("Admin"))
        {
            <div class="me-3 d-none d-lg-block">
                <span class="badge bg-light text-dark border p-2 shadow-sm d-flex align-items-center" style="border-radius: 8px;">
                    <i class="bi bi-wallet2 text-success me-2 fs-6"></i>
                    <div>
                        <small class="text-muted d-block" style="font-size: 10px; line-height: 1;">Số dư ví</small>
                        <span class="fw-bold text-success">@(User.FindFirst("WalletBalance")?.Value ?? "0") VNĐ</span>
                    </div>
                </span>
            </div>
        }

        <div class="dropdown">
            <button class="btn btn-white border dropdown-toggle rounded-pill shadow-sm d-flex align-items-center px-3"
                    type="button" data-bs-toggle="dropdown">
                @* Hiển thị Avatar từ Claim *@
                <img src="@(User.FindFirst("Avatar")?.Value ?? "/images/avatars/default-user.png")"
                     class="rounded-circle me-2 border" width="30" height="30" style="object-fit: cover;">
                <span class="fw-bold small text-dark">@User.Identity.Name</span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2 p-2 animate__animated animate__fadeIn"
                style="border-radius: 12px; min-width: 250px;">

                @if (User.IsInRole("Admin"))
                {
                    <li><h6 class="dropdown-header text-danger fw-bold text-uppercase py-2" style="font-size: 11px; letter-spacing: 1px;">Quản trị hệ thống</h6></li>
                    <li>
                        <a class="dropdown-item py-2 rounded-3 mb-1" href="/Admin/Dashboard">
                            <i class="bi bi-speedometer2 me-3 text-danger fs-5"></i>
                            <strong>Bảng điều khiển Admin</strong>
                        </a>
                    </li>
                    <li><hr class="dropdown-divider mx-2"></li>
                }

                @if (!User.IsInRole("Admin"))
                {
                    <li><h6 class="dropdown-header text-muted text-uppercase py-2" style="font-size: 11px; letter-spacing: 1px;">Tài khoản cá nhân</h6></li>
                    <li>
                        <a class="dropdown-item py-2 rounded-3 mb-1" href="/Account/Profile">
                            <i class="bi bi-person-circle me-3 text-primary fs-5"></i>Hồ sơ của tôi
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item py-2 rounded-3 mb-1" href="/Property/MyAds">
                            <i class="bi bi-card-checklist me-3 text-primary fs-5"></i>Quản lý tin đăng
                        </a>
                    </li>
                    <li><hr class="dropdown-divider mx-2"></li>
                    <li>
                        <a class="dropdown-item py-3 rounded-3 mb-1 bg-success bg-opacity-10" href="/Property/Create">
                            <i class="bi bi-plus-circle-fill me-3 text-success fs-5"></i>
                            <span class="fw-bold text-success">ĐĂNG TIN MỚI</span>
                        </a>
                    </li>
                }

                <li><hr class="dropdown-divider mx-2"></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item py-2 rounded-3 text-danger fw-bold">
                            <i class="bi bi-box-arrow-right me-3 fs-5"></i>Thoát tài khoản
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
}
else
{
    <div class="d-flex align-items-center gap-2">
        <a href="/Account/Login" class="btn btn-link text-decoration-none fw-bold text-dark p-0 px-3">Đăng nhập</a>
        <div class="vr my-2" style="height: 20px;"></div>
        <a href="/Account/Register" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
            Tham gia ngay
        </a>
    </div>
}