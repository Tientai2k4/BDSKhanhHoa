@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject BDSKhanhHoa.Data.ApplicationDbContext _context

@{
    int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out int currentUserId);

    // Lấy số lượng thông báo chưa đọc
    int unreadCount = _context.Notifications.Count(n => n.UserID == currentUserId && !n.IsRead);

    // Lấy 5 thông báo mới nhất để hiển thị nhanh
    var topNotifications = _context.Notifications
        .Where(n => n.UserID == currentUserId)
        .OrderByDescending(n => n.CreatedAt)
        .Take(5)
        .ToList();
}

@if (User.Identity.IsAuthenticated)
{
    <div class="d-flex align-items-center gap-3">
        @* --- CỤM THÔNG BÁO THÔNG MINH --- *@
        <div class="dropdown">
            <a href="#" class="position-relative text-secondary px-2 text-decoration-none" data-bs-toggle="dropdown" aria-expanded="false" title="Thông báo">
                <i class="bi bi-bell-fill fs-5" style="color: #475569; transition: color 0.3s;"></i>
                @if (unreadCount > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow-sm" style="font-size: 0.65rem; border: 2px solid #fff;">
                        @(unreadCount > 9 ? "9+" : unreadCount.ToString())
                        <span class="visually-hidden">thông báo chưa đọc</span>
                    </span>
                }
            </a>

            <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3 p-0 animate__animated animate__fadeIn" style="width: 350px; border-radius: 12px; overflow: hidden;">
                <div class="bg-primary text-white px-4 py-3 d-flex justify-content-between align-items-center">
                    <span class="fw-bold fs-6"><i class="bi bi-bell-fill me-2"></i>Thông báo mới</span>
                    @if (unreadCount > 0)
                    {
                        <span class="badge bg-white text-primary rounded-pill small">@unreadCount mới</span>
                    }
                </div>

                <div class="notification-list" style="max-height: 380px; overflow-y: auto;">
                    @if (topNotifications.Any())
                    {
                        @foreach (var noti in topNotifications)
                        {
                            <a href="/Notification/Details/@noti.NotificationID" class="dropdown-item p-3 border-bottom d-flex gap-3 @(noti.IsRead ? "opacity-75" : "bg-light")" style="white-space: normal;">
                                <div class="flex-shrink-0">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        <i class="bi @(noti.IsRead ? "bi-envelope-open" : "bi-envelope-fill")"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-1 small fw-bold text-dark">@noti.Title</h6>
                                    <p class="mb-1 small text-muted text-truncate-2">@noti.Content</p>
                                    <small class="text-primary fw-medium" style="font-size: 0.7rem;">
                                        <i class="bi bi-clock me-1"></i>@GetTimeAgo(noti.CreatedAt)
                                    </small>
                                </div>
                                @if (!noti.IsRead)
                                {
                                    <div class="flex-shrink-0 align-self-center">
                                        <span class="p-1 bg-primary border border-light rounded-circle d-block"></span>
                                    </div>
                                }
                            </a>
                        }
                    }
                    else
                    {
                        <div class="p-5 text-center text-muted">
                            <i class="bi bi-chat-left-dots fs-1 opacity-25"></i>
                            <p class="small mt-2">Bạn không có thông báo nào</p>
                        </div>
                    }
                </div>

                <div class="p-3 text-center bg-light border-top">
                    <a href="/Notification/Index" class="text-decoration-none fw-bold text-primary small">Xem tất cả thông báo <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>

        @* --- DROPDOWN TÀI KHOẢN (GIỮ NGUYÊN) --- *@
        <div class="dropdown">
            <button class="btn btn-white border dropdown-toggle rounded-pill shadow-sm d-flex align-items-center px-3"
                    type="button" data-bs-toggle="dropdown">
                <img src="@(User.FindFirst("Avatar")?.Value ?? "/images/avatars/default-user.png")"
                     class="rounded-circle me-2 border" width="32" height="32" style="object-fit: cover;">
                <span class="fw-bold small text-dark">@User.Identity.Name</span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3 p-2 animate__animated animate__fadeIn" style="border-radius: 12px; min-width: 260px;">
                @* ... Giữ nguyên phần logic Admin/Member của bạn ... *@
                @if (User.IsInRole("Admin"))
                {
                    <li><h6 class="dropdown-header text-danger fw-bold text-uppercase py-2" style="font-size: 11px; letter-spacing: 1px;">Quản trị hệ thống</h6></li>
                    <li><a class="dropdown-item py-2 rounded-3 mb-1" href="/Admin/Dashboard"><i class="bi bi-speedometer2 me-3 text-danger fs-5 align-middle"></i><strong>Bảng điều khiển Admin</strong></a></li>
                    <li><hr class="dropdown-divider mx-2"></li>
                }
                else
                {
                    <li><h6 class="dropdown-header text-muted text-uppercase py-2" style="font-size: 11px; letter-spacing: 1px;">Tài khoản cá nhân</h6></li>
                    <li><a class="dropdown-item py-2 rounded-3 mb-1" href="/Account/Profile"><i class="bi bi-person-circle me-3 text-primary fs-5 align-middle"></i>Hồ sơ của tôi</a></li>
                    <li><a class="dropdown-item py-2 rounded-3 mb-1" href="/Property/MyAds"><i class="bi bi-card-checklist me-3 text-primary fs-5 align-middle"></i>Quản lý tin đăng</a></li>
                    <li><a class="dropdown-item py-2 rounded-3 mb-1" href="/Favorite/Index"><i class="bi bi-heart-fill me-3 text-danger fs-5 align-middle"></i>Tin đã yêu thích</a></li>
                    <li><hr class="dropdown-divider mx-2 my-2"></li>
                    <li><a class="dropdown-item py-3 rounded-3 mb-1 bg-success bg-opacity-10 text-center" href="/Property/Create"><i class="bi bi-plus-circle-fill me-2 text-success fs-5 align-middle"></i><span class="fw-bold text-success">ĐĂNG TIN MỚI</span></a></li>
                }
                <li><hr class="dropdown-divider mx-2 my-2"></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item py-2 rounded-3 text-danger fw-bold"><i class="bi bi-box-arrow-right me-3 fs-5 align-middle"></i>Thoát tài khoản</button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
}
else
{
    @* ... Giữ nguyên nút Đăng nhập của bạn ... *@
    <div class="d-flex align-items-center gap-2">
        <div class="vr my-2" style="height: 20px;"></div>
        <a href="/Account/Login" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" style="background: linear-gradient(135deg, #0061f2, #004bb9); border: none;">
            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng Nhập
        </a>
    </div>
}

@functions {
    // Hàm phụ trợ tính thời gian "cách đây bao lâu" cho thông minh
    public string GetTimeAgo(DateTime date)
    {
        var timeSpan = DateTime.Now - date;
        if (timeSpan.TotalMinutes < 1) return "Vừa xong";
        if (timeSpan.TotalMinutes < 60) return $"{(int)timeSpan.TotalMinutes} phút trước";
        if (timeSpan.TotalHours < 24) return $"{(int)timeSpan.TotalHours} giờ trước";
        if (timeSpan.TotalDays < 7) return $"{(int)timeSpan.TotalDays} ngày trước";
        return date.ToString("dd/MM/yyyy");
    }
}