@using System.Security.Claims

@if (User.Identity.IsAuthenticated)
{
    <div class="d-flex align-items-center gap-3">

        <div class="dropdown">
            <a href="#" class="position-relative text-secondary px-2 text-decoration-none" data-bs-toggle="dropdown" aria-expanded="false" title="Thông báo">
                <i class="bi bi-bell-fill fs-5" style="color: #475569; transition: color 0.3s;" onmouseover="this.style.color='#0061f2'" onmouseout="this.style.color='#475569'"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow-sm" style="font-size: 0.65rem; border: 2px solid #fff;">
                    3
                    <span class="visually-hidden">thông báo chưa đọc</span>
                </span>
            </a>

            <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3 p-0 animate__animated animate__fadeIn" style="width: 350px; border-radius: 12px; overflow: hidden;">
                <div class="bg-primary text-white px-4 py-3 d-flex justify-content-between align-items-center">
                    <span class="fw-bold fs-6"><i class="bi bi-bell-fill me-2"></i>Thông báo mới</span>
                    <span class="badge bg-white text-primary rounded-pill">3</span>
                </div>

                <div class="list-group list-group-flush" style="max-height: 350px; overflow-y: auto;">
                    <a href="/Notification/Details/1" class="list-group-item list-group-item-action px-4 py-3 bg-light border-bottom">
                        <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                            <h6 class="mb-0 fw-bold text-success" style="font-size: 0.9rem;"><i class="bi bi-check-circle-fill me-1"></i> Duyệt tin thành công</h6>
                            <small class="text-muted" style="font-size: 0.75rem;">10 phút trước</small>
                        </div>
                        <p class="mb-0 text-muted small lh-sm mt-2">Tin đăng "Bán nhà mặt tiền đường Trần Phú" của bạn đã được hiển thị.</p>
                    </a>

                    <a href="/Notification/Details/2" class="list-group-item list-group-item-action px-4 py-3 border-bottom">
                        <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                            <h6 class="mb-0 fw-bold text-primary" style="font-size: 0.9rem;"><i class="bi bi-info-circle-fill me-1"></i> Chào mừng</h6>
                            <small class="text-muted" style="font-size: 0.75rem;">1 giờ trước</small>
                        </div>
                        <p class="mb-0 text-muted small lh-sm mt-2">Cảm ơn bạn đã tham gia hệ thống BDS Khánh Hòa. Hãy đăng tin ngay!</p>
                    </a>
                </div>
                <div class="p-3 text-center bg-light border-top">
                    <a href="/Notification/Index" class="text-decoration-none fw-bold text-primary small">Xem tất cả thông báo <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>

        <div class="dropdown">
            <button class="btn btn-white border dropdown-toggle rounded-pill shadow-sm d-flex align-items-center px-3"
                    type="button" data-bs-toggle="dropdown" style="transition: all 0.3s;">
                <img src="@(User.FindFirst("Avatar")?.Value ?? "/images/avatars/default-user.png")"
                     class="rounded-circle me-2 border" width="32" height="32" style="object-fit: cover;">
                <span class="fw-bold small text-dark">@User.Identity.Name</span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3 p-2 animate__animated animate__fadeIn"
                style="border-radius: 12px; min-width: 260px;">

                @if (User.IsInRole("Admin"))
                {
                    <li><h6 class="dropdown-header text-danger fw-bold text-uppercase py-2" style="font-size: 11px; letter-spacing: 1px;">Quản trị hệ thống</h6></li>
                    <li>
                        <a class="dropdown-item py-2 rounded-3 mb-1" href="/Admin/Dashboard">
                            <i class="bi bi-speedometer2 me-3 text-danger fs-5 align-middle"></i>
                            <strong>Bảng điều khiển Admin</strong>
                        </a>
                    </li>
                    <li><hr class="dropdown-divider mx-2"></li>
                }

                @if (!User.IsInRole("Admin"))
                {
                    <li><h6 class="dropdown-header text-muted text-uppercase py-2" style="font-size: 11px; letter-spacing: 1px;">Tài khoản cá nhân</h6></li>
                    <li>
                        <a class="dropdown-item py-2 rounded-3 mb-1" href="/Account/Profile">
                            <i class="bi bi-person-circle me-3 text-primary fs-5 align-middle"></i>Hồ sơ của tôi
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item py-2 rounded-3 mb-1" href="/Property/MyAds">
                            <i class="bi bi-card-checklist me-3 text-primary fs-5 align-middle"></i>Quản lý tin đăng
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item py-2 rounded-3 mb-1" href="/Favorite/Index">
                            <i class="bi bi-heart-fill me-3 text-danger fs-5 align-middle"></i>Tin đã yêu thích
                        </a>
                    </li>

                    <li><hr class="dropdown-divider mx-2 my-2"></li>
                    <li>
                        <a class="dropdown-item py-3 rounded-3 mb-1 bg-success bg-opacity-10 text-center" href="/Property/Create">
                            <i class="bi bi-plus-circle-fill me-2 text-success fs-5 align-middle"></i>
                            <span class="fw-bold text-success">ĐĂNG TIN MỚI</span>
                        </a>
                    </li>
                }

                <li><hr class="dropdown-divider mx-2 my-2"></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item py-2 rounded-3 text-danger fw-bold">
                            <i class="bi bi-box-arrow-right me-3 fs-5 align-middle"></i>Thoát tài khoản
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
}
else
{
    <div class="d-flex align-items-center gap-2">
        <div class="vr my-2" style="height: 20px;"></div>
        <a href="/Account/Login" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" style="background: linear-gradient(135deg, #0061f2, #004bb9); border: none;">
            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng Nhập
        </a>
    </div>
}