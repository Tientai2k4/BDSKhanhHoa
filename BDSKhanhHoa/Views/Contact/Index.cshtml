@model BDSKhanhHoa.Models.ContactMessage
@{
    ViewData["Title"] = "Liên Hệ BDSKhanhHoa";
}

<section class="bg-primary text-white py-5" style="background: linear-gradient(to right, rgba(0, 115, 230, 0.9), rgba(0, 85, 170, 0.9)), url('/images/banner-khanhhoa.jpg') center/cover;">
    <div class="container text-center py-4">
        <h1 class="fw-bold display-5 mb-2" style="text-shadow: 0 2px 4px rgba(0,0,0,0.3);">LIÊN HỆ VỚI CHÚNG TÔI</h1>
        <p class="lead mb-0 text-light" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);">Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn 24/7</p>
    </div>
</section>

<section class="container my-5 py-3">
    <div class="row g-5">
        <div class="col-lg-5 pe-lg-4">
            <h3 class="fw-bold mb-4" style="color: var(--primary-blue);">Thông Tin Trực Tiếp</h3>
            <p class="text-muted mb-5">Bạn có thắc mắc hoặc cần hỗ trợ về dịch vụ đăng tin, mua bán bất động sản? Hãy để lại thông tin, đội ngũ chuyên viên của BDSKhanhHoa sẽ hỗ trợ bạn ngay lập tức.</p>

            <div class="d-flex mb-4">
                <div class="bg-light text-primary rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 55px; height: 55px;">
                    <i class="bi bi-geo-alt-fill fs-4"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-1">Trụ sở chính</h5>
                    <p class="text-muted mb-0">Đại học Nha Trang, Số 02 Nguyễn Đình Chiểu, P. Vĩnh Thọ, TP. Nha Trang, Khánh Hòa</p>
                </div>
            </div>

            <div class="d-flex mb-4">
                <div class="bg-light text-primary rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 55px; height: 55px;">
                    <i class="bi bi-telephone-fill fs-4"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-1">Hotline hỗ trợ</h5>
                    <p class="text-muted mb-0 fw-medium">1900 1234 - 0987 654 321</p>
                </div>
            </div>

            <div class="d-flex">
                <div class="bg-light text-primary rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 55px; height: 55px;">
                    <i class="bi bi-envelope-fill fs-4"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-1">Email liên hệ</h5>
                    <p class="text-muted mb-0">contact@79land.com</p>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card border-0 shadow rounded-4 p-4 p-md-5 bg-white">
                <h3 class="fw-bold mb-4">Gửi Tin Nhắn Cho Chúng Tôi</h3>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-controller="Contact" asp-action="Index" method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium text-dark">Họ và tên <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control form-control-lg bg-light border-0" placeholder="Nhập họ tên..." />
                            <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium text-dark">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control form-control-lg bg-light border-0" placeholder="Nhập SĐT..." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium text-dark">Email liên hệ</label>
                            <input asp-for="Email" class="form-control form-control-lg bg-light border-0" placeholder="Nhập Email..." />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium text-dark">Chủ đề</label>
                            <input asp-for="Subject" class="form-control form-control-lg bg-light border-0" placeholder="Vấn đề cần hỗ trợ..." />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium text-dark">Nội dung chi tiết <span class="text-danger">*</span></label>
                            <textarea asp-for="Message" class="form-control bg-light border-0" rows="5" placeholder="Nhập nội dung cần trao đổi..."></textarea>
                            <span asp-validation-for="Message" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-12 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm" style="background-color: var(--primary-blue); transition: all 0.3s;">
                                GỬI THÔNG TIN <i class="bi bi-send ms-2"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}