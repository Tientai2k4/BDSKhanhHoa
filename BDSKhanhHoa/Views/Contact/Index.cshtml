@model BDSKhanhHoa.Models.ContactMessage
@{
    ViewData["Title"] = "Liên Hệ - BĐS Khánh Hòa";
}

<style>
    .contact-hero {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.85) 0%, rgba(59, 130, 246, 0.85) 100%), url('/images/banners/nha-trang-city.jpg') center/cover no-repeat fixed;
        padding: 80px 0;
        border-radius: 0 0 40px 40px;
        margin-top: -20px;
    }

    .contact-info-box {
        background: #ffffff;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
        height: 100%;
        border: 1px solid #f1f5f9;
    }

    .icon-wrapper {
        width: 60px;
        height: 60px;
        background: #eff6ff;
        color: #3b82f6;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
        transition: all 0.3s ease;
    }

    .contact-info-item:hover .icon-wrapper {
        background: #3b82f6;
        color: #ffffff;
        transform: scale(1.1);
    }

    .form-control-custom {
        border-radius: 12px;
        border: 2px solid #e2e8f0;
        padding: 14px 20px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #f8fafc;
    }

        .form-control-custom:focus {
            border-color: #3b82f6;
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }
</style>

<section class="contact-hero text-center text-white mb-5 animate__animated animate__fadeIn">
    <div class="container">
        <span class="badge bg-white text-primary rounded-pill px-3 py-2 mb-3 fw-bold shadow-sm">Hỗ trợ 24/7</span>
        <h1 class="display-4 fw-black mb-3">Liên Hệ Với Chúng Tôi</h1>
        <p class="lead mb-0 opacity-75 mx-auto" style="max-width: 600px;">Bất cứ khi nào bạn cần tư vấn mua bán, ký gửi bất động sản tại Khánh Hòa, chúng tôi luôn sẵn sàng lắng nghe.</p>
    </div>
</section>

<div class="container mb-5 pb-5">
    <div class="row g-5">

        <!-- Cột Thông tin & Bản đồ -->
        <div class="col-lg-5 animate__animated animate__fadeInLeft">
            <div class="contact-info-box">
                <h3 class="fw-bold text-dark mb-4">Thông tin trực tiếp</h3>
                <p class="text-muted mb-4 pb-2 border-bottom">Trụ sở điều hành chính của hệ thống Sàn Giao Dịch Bất Động Sản tỉnh Khánh Hòa.</p>

                <div class="contact-info-item d-flex mb-4">
                    <div class="icon-wrapper me-3 shadow-sm"><i class="bi bi-geo-alt-fill"></i></div>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">Trụ sở làm việc</h6>
                        <p class="text-muted small mb-0">Đại học Nha Trang, Số 02 Nguyễn Đình Chiểu, P. Vĩnh Thọ, TP. Nha Trang, Khánh Hòa.</p>
                    </div>
                </div>

                <div class="contact-info-item d-flex mb-4">
                    <div class="icon-wrapper me-3 shadow-sm"><i class="bi bi-telephone-fill"></i></div>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">Hotline hỗ trợ</h6>
                        <p class="text-muted small mb-0 fw-bold text-primary">1900 1234 - 0987 654 321</p>
                    </div>
                </div>

                <div class="contact-info-item d-flex mb-5">
                    <div class="icon-wrapper me-3 shadow-sm"><i class="bi bi-envelope-fill"></i></div>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">Email chăm sóc CSKH</h6>
                        <p class="text-muted small mb-0">support@bdskhanhhoa.vn</p>
                    </div>
                </div>

                <!-- ĐÃ SỬA LỖI: Bản đồ Google Maps thu nhỏ với link chuẩn -->
                <div class="rounded-4 overflow-hidden shadow-sm" style="height: 250px;">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3898.749007671239!2d109.20018721475516!3d12.265261491321743!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3170677811cc886f%3A0x5c4bbc0aa81edcb9!2zVHLGsOG7nW5nIMSQ4bqhaSBI4buNYyBOaGEgVHJhbmc!5e0!3m2!1svi!2s!4v1700000000000!5m2!1svi!2s" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>
        </div>

        <!-- Cột Form Liên hệ -->
        <div class="col-lg-7 animate__animated animate__fadeInRight">
            <div class="bg-white rounded-4 shadow-sm border p-4 p-md-5 h-100">
                <h3 class="fw-bold text-dark mb-2">Gửi Tin Nhắn Nhanh</h3>
                <p class="text-muted mb-4">Hãy để lại lời nhắn, chuyên viên của chúng tôi sẽ gọi lại cho bạn.</p>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0 bg-success text-white d-flex align-items-center" role="alert">
                        <i class="bi bi-check-circle-fill fs-4 me-2"></i>
                        <div>@TempData["SuccessMessage"]</div>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger rounded-3 border-0 bg-danger text-white">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                    </div>
                }

                <form asp-controller="Contact" asp-action="Index" method="post">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark">Họ và tên <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control form-control-custom" placeholder="Nhập họ tên của bạn..." />
                            <span asp-validation-for="FullName" class="text-danger small mt-1 d-block fw-semibold"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control form-control-custom" placeholder="Nhập SĐT liên hệ..." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark">Email</label>
                            <input asp-for="Email" class="form-control form-control-custom" placeholder="Nhập địa chỉ Email..." />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block fw-semibold"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark">Chủ đề</label>
                            <input asp-for="Subject" class="form-control form-control-custom" placeholder="Bạn cần hỏi về vấn đề gì?" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold text-dark">Nội dung chi tiết <span class="text-danger">*</span></label>
                            <textarea asp-for="Message" class="form-control form-control-custom" rows="5" placeholder="Hãy viết rõ nội dung bạn cần trao đổi để chúng tôi hỗ trợ tốt nhất..."></textarea>
                            <span asp-validation-for="Message" class="text-danger small mt-1 d-block fw-semibold"></span>
                        </div>
                        <div class="col-12 mt-4 pt-2">
                            <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold fs-5 shadow d-flex justify-content-center align-items-center" style="transition: all 0.3s;">
                                <i class="bi bi-send-fill me-2"></i> GỬI YÊU CẦU
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}