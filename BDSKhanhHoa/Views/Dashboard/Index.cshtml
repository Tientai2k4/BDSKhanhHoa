@using BDSKhanhHoa.Models
@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";

    // Ép kiểu dữ liệu an toàn
    var user = ViewBag.CurrentUser as User;
    int totalProps = ViewBag.TotalProperties ?? 0;
    int activeProps = ViewBag.ActiveProperties ?? 0;
    int pendingProps = ViewBag.PendingProperties ?? 0;
    int totalViews = ViewBag.TotalViews ?? 0;
    int pendingApptsCount = ViewBag.PendingAppointmentsCount ?? 0;
    int newConsults = ViewBag.NewConsultations ?? 0;
    int totalFavs = ViewBag.TotalFavorites ?? 0;

    var upcomingAppointments = ViewBag.UpcomingAppointments as List<Appointment> ?? new List<Appointment>();
    var recentTransactions = ViewBag.RecentTransactions as List<Transaction> ?? new List<Transaction>();
    var recentProperties = ViewBag.RecentProperties as List<Property> ?? new List<Property>();
    var recentNotifications = ViewBag.RecentNotifications as List<Notification> ?? new List<Notification>();
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    /* CSS UI/UX Chuẩn 2026 */
    .dashboard-header {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        border-radius: 20px;
        padding: 35px 30px;
        color: white;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.2);
    }

        .dashboard-header::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -5%;
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, rgba(59,130,246,0.3) 0%, rgba(255,255,255,0) 70%);
            border-radius: 50%;
        }

    .stat-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 25px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        height: 100%;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.06);
            border-color: #cbd5e1;
        }

    .stat-icon {
        width: 55px;
        height: 55px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
    }

    /* Các Widget bên phải */
    .widget-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        padding: 20px;
        margin-bottom: 24px;
    }

    .modern-table {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        overflow: hidden;
    }

        .modern-table thead th {
            background: #f8fafc;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            padding: 15px 20px;
        }

        .modern-table tbody td {
            padding: 15px 20px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
            font-weight: 500;
        }

    .appt-item {
        padding: 15px;
        border-radius: 12px;
        background: #f8fafc;
        border-left: 4px solid #3b82f6;
        transition: 0.2s;
    }

        .appt-item:hover {
            background: #f1f5f9;
        }

    /* Timeline thông báo */
    .timeline {
        padding-left: 20px;
        position: relative;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #e2e8f0;
        }

    .timeline-item {
        position: relative;
        margin-bottom: 15px;
    }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -25px;
            top: 5px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #3b82f6;
            border: 3px solid #e0e7ff;
        }
</style>

<div class="container-fluid p-0 animate__animated animate__fadeIn">

    <div class="dashboard-header d-flex justify-content-between align-items-center flex-wrap gap-4">
        <div class="position-relative z-1 d-flex align-items-center gap-4">
            <img src="@(user?.Avatar ?? "/images/avatars/default-user.png")" class="rounded-circle border border-3 border-light shadow" width="80" height="80" style="object-fit:cover;">
            <div>
                <h2 class="fw-bolder mb-1 text-white">Xin chào, @(user?.FullName ?? user?.Username)!</h2>
                <p class="mb-0 text-white-50 fw-medium">
                    <i class="bi bi-geo-alt-fill text-danger me-1"></i>Khu vực Khánh Hòa |
                    <i class="bi bi-clock me-1"></i>Hôm nay: @DateTime.Now.ToString("dd/MM/yyyy")
                </p>
            </div>
        </div>
        <div class="d-flex gap-2 position-relative z-1">
            <a href="/Property/Create" class="btn btn-primary fw-bold px-4 py-2 rounded-pill shadow-sm border border-primary-subtle">
                <i class="bi bi-plus-circle-fill me-2"></i>Đăng tin BĐS
            </a>
            <a href="/Package/Buy" class="btn btn-warning text-dark fw-bold px-4 py-2 rounded-pill shadow-sm">
                <i class="bi bi-lightning-charge-fill me-2"></i>Nâng cấp VIP
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted fw-bold mb-1 fs-6 text-uppercase">Tin Đăng Của Bạn</p>
                        <h2 class="fw-black mb-1 text-dark">@totalProps <small class="fs-6 text-muted fw-medium">tin</small></h2>
                        <span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle me-1"></i>@activeProps đang hiển thị</span>
                    </div>
                    <div class="stat-icon bg-primary-subtle text-primary"><i class="bi bi-houses"></i></div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted fw-bold mb-1 fs-6 text-uppercase">Tương Tác & Lượt Xem</p>
                        <h2 class="fw-black mb-1 text-dark">@totalViews <small class="fs-6 text-muted fw-medium">lượt</small></h2>
                        <span class="badge bg-danger-subtle text-danger"><i class="bi bi-heart-fill me-1"></i>@totalFavs lượt lưu tin</span>
                    </div>
                    <div class="stat-icon bg-success-subtle text-success"><i class="bi bi-eye"></i></div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted fw-bold mb-1 fs-6 text-uppercase">Yêu Cầu Tư Vấn (Leads)</p>
                        <h2 class="fw-black mb-1 text-dark">@newConsults <small class="fs-6 text-muted fw-medium">khách</small></h2>
                        @if (newConsults > 0)
                        {
                            <span class="badge bg-warning text-dark animate__animated animate__pulse animate__infinite"><i class="bi bi-fire me-1"></i>Cần liên hệ ngay!</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-secondary border">Chưa có yêu cầu mới</span>
                        }
                    </div>
                    <div class="stat-icon bg-warning-subtle text-warning-emphasis"><i class="bi bi-headset"></i></div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted fw-bold mb-1 fs-6 text-uppercase">Lịch Hẹn Xem Nhà</p>
                        <h2 class="fw-black mb-1 text-dark">@pendingApptsCount <small class="fs-6 text-muted fw-medium">lịch</small></h2>
                        <span class="badge bg-info-subtle text-info-emphasis"><i class="bi bi-calendar-event me-1"></i>Đang chờ xác nhận</span>
                    </div>
                    <div class="stat-icon bg-info-subtle text-info"><i class="bi bi-calendar-check"></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-8">
            <div class="modern-table h-100 d-flex flex-column">
                <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-graph-up-arrow text-primary me-2"></i>Lưu lượng truy cập (7 ngày qua)</h5>
                </div>
                <div class="p-4 flex-grow-1">
                    <canvas id="viewChart" style="min-height: 280px;"></canvas>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="widget-card bg-primary text-white" style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); border:none;">
                <h6 class="fw-bold opacity-75 mb-3 text-uppercase"><i class="bi bi-shield-check me-2"></i>Trạng thái tài khoản</h6>
                <div class="d-flex align-items-center gap-3 mb-3">
                    <i class="bi bi-patch-check-fill text-warning" style="font-size: 2.5rem;"></i>
                    <div>
                        <h4 class="fw-bold mb-0">Thành viên Tiêu chuẩn</h4>
                        <small class="opacity-75">Tham gia từ @user?.CreatedAt?.ToString("MM/yyyy")</small>
                    </div>
                </div>
                <a href="/Account/Profile" class="btn btn-light btn-sm fw-bold w-100 text-primary">Cập nhật hồ sơ xác thực (KYC)</a>
            </div>

            <div class="widget-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-calendar-range text-success me-2"></i>Lịch hẹn sắp tới</h6>
                    <a href="/Appointments/Index" class="small fw-bold text-decoration-none">Xem tất cả</a>
                </div>
                @if (upcomingAppointments.Any())
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var appt in upcomingAppointments)
                        {
                            <div class="appt-item">
                                <h6 class="fw-bold text-dark mb-1 fs-6">@appt.AppointmentDate.ToString("HH:mm - dd/MM/yyyy")</h6>
                                <p class="mb-1 text-muted small text-truncate">Gặp: <strong>@(appt.Buyer?.FullName ?? "Khách hàng")</strong></p>
                                <p class="mb-0 text-primary small text-truncate"><i class="bi bi-house me-1"></i>@appt.Property?.Title</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-3">
                        <i class="bi bi-calendar-x fs-1 text-muted opacity-25"></i>
                        <p class="text-muted small mt-2 m-0">Bạn chưa có lịch hẹn nào sắp tới.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8">
            <div class="modern-table pb-2 h-100">
                <div class="d-flex justify-content-between align-items-center p-4 border-bottom">
                    <h5 class="fw-bold mb-0"><i class="bi bi-card-list text-success me-2"></i>Bất động sản mới đăng</h5>
                    <a href="/Property/MyAds" class="btn btn-sm btn-outline-primary fw-bold">Quản lý kho tin</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th width="45%">Thông tin BĐS</th>
                                <th>Mức giá</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (recentProperties.Any())
                            {
                                foreach (var prop in recentProperties)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex gap-3 align-items-center">
                                                <img src="@(string.IsNullOrEmpty(prop.MainImage) ? "/images/default-house.jpg" : prop.MainImage)" class="rounded-3 object-fit-cover shadow-sm" width="65" height="65">
                                                <div>
                                                    <h6 class="fw-bold mb-1 text-dark text-truncate" style="max-width: 250px;" title="@prop.Title">@prop.Title</h6>
                                                    <small class="text-muted"><i class="bi bi-clock me-1"></i>@prop.CreatedAt.ToString("dd/MM/yyyy")</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="text-danger fw-bold">@(prop.Price.HasValue? prop.Price.Value.ToString("N0") + " VNĐ" : "Thỏa thuận")</span></td>
                                        <td>
                                            @if (prop.Status == "Approved" || prop.Status == "Active")
                                            {
                                                <span class="badge bg-success-subtle text-success px-2 py-1">Hiển thị</span>
                                            }
                                            else if (prop.Status == "Pending")
                                            {

                                                <span class="badge bg-warning-subtle text-warning-emphasis px-2 py-1">Chờ duyệt</span>
                                            }
                                            else
                                            {

                                                <span class="badge bg-danger-subtle text-danger px-2 py-1">Bị từ chối</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <a href="/Property/Edit/@prop.PropertyID" class="btn btn-sm btn-light border text-warning"><i class="bi bi-pencil-square"></i></a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted fw-medium">
                                        <i class="bi bi-folder2-open display-4 opacity-50 d-block mb-2"></i>
                                        Bạn chưa đăng bất động sản nào.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="widget-card mb-4">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-receipt text-secondary me-2"></i>Giao dịch gần đây</h6>
                    <a href="/Payment/History" class="small fw-bold text-decoration-none">Chi tiết</a>
                </div>
                @if (recentTransactions.Any())
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var trans in recentTransactions)
                        {
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1 text-dark fw-bold text-truncate" style="max-width: 150px; font-size:0.9rem;">@trans.Type</h6>
                                    <small class="text-muted">@trans.CreatedAt.ToString("dd/MM/yyyy")</small>
                                </div>
                                <div class="text-end">
                                    <span class="d-block fw-bold text-danger">-@trans.Amount.ToString("N0")đ</span>
                                    @if (trans.Status == "Success")
                                    {
                                        <small class="text-success fw-bold">Thành công</small>
                                    }
                                    else
                                    {

                                        <small class="text-warning fw-bold">Chờ xử lý</small>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-center text-muted small m-0 py-2">Chưa có giao dịch phát sinh.</p>
                }
            </div>

            <div class="widget-card">
                <h6 class="fw-bold border-bottom pb-3 mb-3"><i class="bi bi-bell text-warning me-2"></i>Thông báo hệ thống</h6>
                @if (recentNotifications.Any())
                {
                    <div class="timeline">
                        @foreach (var noti in recentNotifications)
                        {
                            <div class="timeline-item">
                                <h6 class="fw-bold text-dark mb-1 fs-6">@noti.Title</h6>
                                <p class="text-muted small mb-1 line-clamp-2">@noti.Content</p>
                                <small class="text-primary fw-medium">@noti.CreatedAt.ToString("HH:mm - dd/MM")</small>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-center text-muted small m-0 py-2">Không có thông báo mới.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Lấy dữ liệu biểu đồ từ Controller đẩy xuống
            const rawLabels = @Html.Raw(ViewBag.ChartLabels);
            const rawData = @Html.Raw(ViewBag.ChartData);

            const ctx = document.getElementById('viewChart').getContext('2d');

            // Tạo Gradient màu cực đẹp
            let gradient = ctx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, 'rgba(59, 130, 246, 0.4)'); // Blue
            gradient.addColorStop(1, 'rgba(59, 130, 246, 0.0)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: rawLabels,
                    datasets: [{
                        label: 'Lượt xem trang',
                        data: rawData,
                        borderColor: '#3b82f6',
                        backgroundColor: gradient,
                        borderWidth: 3,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: '#3b82f6',
                        pointBorderWidth: 2,
                        pointRadius: 5,
                        pointHoverRadius: 7,
                        fill: true,
                        tension: 0.4 // Đường cong mượt
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1e293b',
                            titleFont: { size: 13, family: "'Inter', sans-serif" },
                            bodyFont: { size: 14, weight: 'bold', family: "'Inter', sans-serif" },
                            padding: 12,
                            cornerRadius: 8,
                            displayColors: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { borderDash: [5, 5], color: '#f1f5f9', drawBorder: false },
                            ticks: { color: '#94a3b8', font: { family: "'Inter', sans-serif" }, stepSize: 1 }
                        },
                        x: {
                            grid: { display: false, drawBorder: false },
                            ticks: { color: '#64748b', font: { family: "'Inter', sans-serif", weight: '500' } }
                        }
                    },
                    animation: {
                        y: { duration: 1500, easing: 'easeOutElastic' }
                    }
                }
            });
        });
    </script>
}