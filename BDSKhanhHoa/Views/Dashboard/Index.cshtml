@using BDSKhanhHoa.Models
@{
    Layout = "~/Views/Shared/_UserLayout.cshtml"; // 

    // Ép kiểu dữ liệu từ ViewBag an toàn
    int totalProps = ViewBag.TotalProperties ?? 0;
    int activeProps = ViewBag.ActiveProperties ?? 0;
    int totalViews = ViewBag.TotalViews ?? 0;
    int pendingAppts = ViewBag.PendingAppointments ?? 0;
    int newConsults = ViewBag.NewConsultations ?? 0;

    var recentProperties = ViewBag.RecentProperties as List<Property> ?? new List<Property>();
    var recentNotifications = ViewBag.RecentNotifications as List<Notification> ?? new List<Notification>();
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    /* CSS UI/UX Chuẩn 2026 - Tối ưu hiển thị & Tương tác */
    .dashboard-header {
        background: linear-gradient(135deg, #0061f2 0%, #003b93 100%);
        border-radius: 20px;
        padding: 30px;
        color: white;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 97, 242, 0.2);
    }

        .dashboard-header::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            backdrop-filter: blur(10px);
        }

    /* Thẻ Thống kê (Stat Cards) với hiệu ứng Glassmorphism nhẹ */
    .stat-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 25px;
        border: 1px solid #edf2f7;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.08);
            border-color: #e2e8f0;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 4px;
            border-radius: 4px 0 0 4px;
        }

        .stat-card.primary::before {
            background: #0061f2;
        }

        .stat-card.success::before {
            background: #00ac69;
        }

        .stat-card.warning::before {
            background: #f4a100;
        }

        .stat-card.danger::before {
            background: #e81500;
        }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .bg-primary-soft {
        background: rgba(0, 97, 242, 0.1);
        color: #0061f2;
    }

    .bg-success-soft {
        background: rgba(0, 172, 105, 0.1);
        color: #00ac69;
    }

    .bg-warning-soft {
        background: rgba(244, 161, 0, 0.1);
        color: #f4a100;
    }

    .bg-danger-soft {
        background: rgba(232, 21, 0, 0.1);
        color: #e81500;
    }

    /* Custom Table Chuẩn 2026 */
    .modern-table {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        overflow: hidden;
    }

        .modern-table thead th {
            background: #f8fafc;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 15px 20px;
            border-bottom: 1px solid #edf2f7;
        }

        .modern-table tbody td {
            padding: 15px 20px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
            font-weight: 500;
        }

    /* Timeline thông báo */
    .timeline {
        position: relative;
        padding-left: 30px;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: 7px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #e2e8f0;
        }

    .timeline-item {
        position: relative;
        margin-bottom: 20px;
    }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -28px;
            top: 5px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #0061f2;
            border: 3px solid #e0e7ff;
        }
</style>

<div class="container-fluid p-0 animate__animated animate__fadeIn">

    <div class="dashboard-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div class="position-relative z-1">
            <h2 class="fw-bolder mb-1">Chào mừng trở lại, @User.Identity.Name! 👋</h2>
            <p class="mb-0 text-white-50 fw-medium">Hôm nay là @DateTime.Now.ToString("dd/MM/yyyy") - Chúc bạn một ngày giao dịch thành công.</p>
        </div>
        <div class="d-flex gap-2 position-relative z-1">
            <a href="/Property/Create" class="btn btn-light text-primary fw-bold px-4 py-2 rounded-pill shadow-sm">
                <i class="bi bi-plus-circle-fill me-2"></i>Đăng tin mới
            </a>
            <a href="/Package/Buy" class="btn btn-warning text-white fw-bold px-4 py-2 rounded-pill shadow-sm">
                <i class="bi bi-gem me-2"></i>Nạp VIP
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="stat-card primary">
                <div>
                    <p class="text-muted fw-bold mb-1 fs-6 text-uppercase">Tổng Tin Của Bạn</p>
                    <h2 class="fw-black mb-0 text-dark display-6 fw-bold">@totalProps</h2>
                    <small class="text-success fw-bold"><i class="bi bi-arrow-up-short"></i>@activeProps tin đang hiển thị</small>
                </div>
                <div class="stat-icon bg-primary-soft">
                    <i class="bi bi-houses"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card success">
                <div>
                    <p class="text-muted fw-bold mb-1 fs-6 text-uppercase">Tổng Lượt Xem</p>
                    <h2 class="fw-black mb-0 text-dark display-6 fw-bold">@totalViews</h2>
                    <small class="text-secondary fw-medium">Lượt tiếp cận khách hàng</small>
                </div>
                <div class="stat-icon bg-success-soft">
                    <i class="bi bi-eye"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card warning">
                <div>
                    <p class="text-muted fw-bold mb-1 fs-6 text-uppercase">Khách Yêu Cầu</p>
                    <h2 class="fw-black mb-0 text-dark display-6 fw-bold">@newConsults</h2>
                    <small class="text-danger fw-bold animate__animated animate__flash animate__infinite animate__slower">
                        <i class="bi bi-fire"></i> Khách đang chờ tư vấn!
                    </small>
                </div>
                <div class="stat-icon bg-warning-soft">
                    <i class="bi bi-headset"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card danger">
                <div>
                    <p class="text-muted fw-bold mb-1 fs-6 text-uppercase">Lịch Hẹn Xem Nhà</p>
                    <h2 class="fw-black mb-0 text-dark display-6 fw-bold">@pendingAppts</h2>
                    <small class="text-secondary fw-medium">Lịch hẹn đang chờ xác nhận</small>
                </div>
                <div class="stat-icon bg-danger-soft">
                    <i class="bi bi-calendar-check"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-graph-up-arrow text-primary me-2"></i>Biểu đồ tương tác (7 ngày qua)</h5>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-light border fw-bold text-muted dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            Tuần này
                        </button>
                    </div>
                </div>
                <div class="card-body p-4">
                    <canvas id="interactionChart" height="100"></canvas>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-activity text-danger me-2"></i>Hoạt động mới nhất</h5>
                </div>
                <div class="card-body p-4">
                    @if (recentNotifications.Any())
                    {
                        <div class="timeline">
                            @foreach (var noti in recentNotifications.Take(4))
                            {
                                <div class="timeline-item">
                                    <h6 class="fw-bold text-dark mb-1">@noti.Title</h6>
                                    <p class="text-muted small mb-1 line-clamp-2">@noti.Content</p>
                                    <small class="text-primary fw-medium"><i class="bi bi-clock me-1"></i>@noti.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</small>
                                </div>
                            }
                        </div>
                        <div class="text-center mt-3">
                            <a href="/Notification/Index" class="text-decoration-none fw-bold text-primary">Xem tất cả thông báo <i class="bi bi-arrow-right"></i></a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <img src="/images/empty-state.png" alt="Trống" style="width: 100px; opacity: 0.5; margin-bottom: 15px;" onerror="this.style.display='none'">
                            <p class="text-muted fw-medium">Chưa có hoạt động nào gần đây.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="modern-table pb-2">
                <div class="d-flex justify-content-between align-items-center p-4 border-bottom">
                    <h5 class="fw-bold mb-0"><i class="bi bi-card-list text-success me-2"></i>Tin đăng gần đây của bạn</h5>
                    <a href="/Property/MyAds" class="btn btn-sm btn-outline-primary fw-bold">Quản lý toàn bộ tin</a>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th width="40%">Bất động sản</th>
                                <th>Mức giá</th>
                                <th>Ngày đăng</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (recentProperties.Any())
                            {
                                foreach (var prop in recentProperties)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@(string.IsNullOrEmpty(prop.MainImage) ? "/images/default-house.jpg" : prop.MainImage)"
                                                     class="rounded-3 object-fit-cover" width="60" height="60" onerror="this.src='https://via.placeholder.com/60x60?text=No+Image'">
                                                <div>
                                                    <h6 class="fw-bold mb-1 text-truncate" style="max-width: 250px;">@prop.Title</h6>
                                                    <small class="text-muted"><i class="bi bi-geo-alt-fill text-danger"></i> Mã tin: #@prop.PropertyID</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="text-danger fw-bold fs-6">
                                                @(prop.Price.HasValue? prop.Price.Value.ToString("N0") + " VNĐ" : "Thỏa thuận")
                                            </span>
                                        </td>
                                        <td>@prop.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            @if (prop.Status == "Approved" || prop.Status == "Active")
                                            {
                                                <span class="badge bg-success-soft px-3 py-2 rounded-pill"><i class="bi bi-check-circle-fill me-1"></i>Đang hiển thị</span>
                                            }
                                            else if (prop.Status == "Pending")
                                            {
                                                <span class="badge bg-warning-soft px-3 py-2 rounded-pill"><i class="bi bi-hourglass-split me-1"></i>Chờ duyệt</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-soft px-3 py-2 rounded-pill"><i class="bi bi-x-circle-fill me-1"></i>Từ chối/Ẩn</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group">
                                                <a href="/Property/Details/@prop.PropertyID" class="btn btn-sm btn-light border text-primary" title="Xem trên Web" target="_blank"><i class="bi bi-eye"></i></a>
                                                <a href="/Property/Edit/@prop.PropertyID" class="btn btn-sm btn-light border text-warning" title="Chỉnh sửa"><i class="bi bi-pencil-square"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted fw-medium">
                                        <i class="bi bi-folder2-open display-4 d-block mb-3 text-secondary opacity-50"></i>
                                        Bạn chưa đăng bất động sản nào.<br>
                                        <a href="/Property/Create" class="btn btn-primary mt-3 fw-bold shadow-sm"><i class="bi bi-plus-circle me-2"></i>Đăng tin đầu tiên ngay</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // CẤU HÌNH BIỂU ĐỒ CHART.JS (Chuẩn 2026 - Mượt mà, Gradient đẹp)
            const ctx = document.getElementById('interactionChart').getContext('2d');

            // Tạo Gradient màu cho vùng bên dưới đường Line
            let gradient = ctx.createLinearGradient(0, 0, 0, 400);
            gradient.addColorStop(0, 'rgba(0, 97, 242, 0.4)');   // Màu xanh đậm ở trên
            gradient.addColorStop(1, 'rgba(0, 97, 242, 0.0)');   // Trong suốt ở dưới

            const interactionChart = new Chart(ctx, {
                type: 'line',
                data: {
                    // Trục X (7 Ngày qua) - Có thể fetch bằng AJAX sau này
                    labels: ['Thứ 2', 'Thứ 3', 'Thứ 4', 'Thứ 5', 'Thứ 6', 'Thứ 7', 'CN'],
                    datasets: [{
                        label: 'Lượt xem trang',
                        data: [12, 19, 15, 25, 22, 30, @(totalViews > 30 ? totalViews / 2 : 45)], // Fake data nhẹ trộn với data thật
                        borderColor: '#0061f2',
                        backgroundColor: gradient, // Đổ màu Gradient
                        borderWidth: 3,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: '#0061f2',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        fill: true, // Kích hoạt đổ màu vùng dưới
                        tension: 0.4 // Độ cong của đường (0 = thẳng, 0.4 = cong mượt)
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false // Ẩn chú thích vì chỉ có 1 đường
                        },
                        tooltip: {
                            backgroundColor: 'rgba(0, 0, 0, 0.8)',
                            titleFont: { size: 13, family: "'Inter', sans-serif" },
                            bodyFont: { size: 14, weight: 'bold', family: "'Inter', sans-serif" },
                            padding: 12,
                            cornerRadius: 8,
                            displayColors: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: '#f1f5f9',
                                drawBorder: false
                            },
                            ticks: {
                                color: '#94a3b8',
                                font: { family: "'Inter', sans-serif", size: 12 }
                            }
                        },
                        x: {
                            grid: {
                                display: false,
                                drawBorder: false
                            },
                            ticks: {
                                color: '#64748b',
                                font: { family: "'Inter', sans-serif", weight: '500' }
                            }
                        }
                    },
                    animation: {
                        y: {
                            duration: 2000,
                            easing: 'easeOutElastic'
                        }
                    }
                }
            });
        });
    </script>
}