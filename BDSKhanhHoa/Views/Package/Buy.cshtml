@model IEnumerable<BDSKhanhHoa.Models.PostServicePackage>
@{
    ViewData["Title"] = "Bảng giá dịch vụ";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    .pricing-header {
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        border-radius: 24px;
        padding: 60px 20px;
        text-align: center;
        margin-bottom: -80px;
        padding-bottom: 120px;
    }

    .pricing-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 24px;
        padding: 40px 30px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

        .pricing-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.12);
        }

    .badge-ribbon {
        position: absolute;
        top: 25px;
        right: -35px;
        color: white;
        padding: 6px 40px;
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        transform: rotate(45deg);
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

    .icon-box {
        width: 80px;
        height: 80px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin-bottom: 30px;
        transform: rotate(-5deg);
    }

    /* Các theme màu sắc */
    .theme-diamond {
        border-top: 5px solid #ef4444;
    }

        .theme-diamond .icon-box {
            background: linear-gradient(135deg, #fef2f2, #fee2e2);
            color: #ef4444;
        }

        .theme-diamond .badge-ribbon, .theme-diamond .btn-buy {
            background: linear-gradient(135deg, #ef4444, #b91c1c);
            color: white;
        }

    .theme-gold {
        border-top: 5px solid #f59e0b;
    }

        .theme-gold .icon-box {
            background: linear-gradient(135deg, #fffbeb, #fef3c7);
            color: #f59e0b;
        }

        .theme-gold .badge-ribbon, .theme-gold .btn-buy {
            background: linear-gradient(135deg, #f59e0b, #b45309);
            color: white;
        }

    .theme-silver {
        border-top: 5px solid #0ea5e9;
    }

        .theme-silver .icon-box {
            background: linear-gradient(135deg, #f0f9ff, #e0f2fe);
            color: #0ea5e9;
        }

        .theme-silver .badge-ribbon, .theme-silver .btn-buy {
            background: linear-gradient(135deg, #0ea5e9, #0369a1);
            color: white;
        }

    .theme-basic {
        border-top: 5px solid #64748b;
    }

        .theme-basic .icon-box {
            background: linear-gradient(135deg, #f8fafc, #f1f5f9);
            color: #64748b;
        }

        .theme-basic .btn-buy {
            background: #e2e8f0;
            color: #334155;
        }

            .theme-basic .btn-buy:hover {
                background: #cbd5e1;
            }

    .pricing-price {
        font-size: 2.8rem;
        font-weight: 900;
        margin-bottom: 25px;
        line-height: 1;
        color: #0f172a;
    }

        .pricing-price span {
            font-size: 1.2rem;
            color: #64748b;
            font-weight: 600;
        }

    .pricing-features {
        list-style: none;
        padding: 0;
        margin: 0 0 40px 0;
        flex-grow: 1;
    }

        .pricing-features li {
            margin-bottom: 18px;
            color: #475569;
            font-weight: 500;
            display: flex;
            align-items: flex-start;
            font-size: 1.05rem;
        }

            .pricing-features li i {
                color: #10b981;
                font-size: 1.3rem;
                margin-right: 15px;
            }

    .btn-buy {
        border: none;
        padding: 18px;
        border-radius: 16px;
        font-weight: 800;
        font-size: 1.1rem;
        transition: 0.3s;
        text-transform: uppercase;
        width: 100%;
    }

        .btn-buy:hover {
            transform: scale(1.03);
            filter: brightness(1.1);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }
</style>

<div class="container my-5">
    <div class="pricing-header shadow-sm">
        <span class="badge bg-dark text-white px-4 py-2 rounded-pill fw-bold mb-3 fs-6">DỊCH VỤ PREMIUM</span>
        <h1 class="fw-black text-dark mb-3" style="font-weight: 900; font-size: 3rem;">Tiếp Cận Hàng Triệu Khách Hàng</h1>
        <p class="text-muted fs-5 max-w-2xl mx-auto">Nâng cấp tin đăng của bạn ngay hôm nay để chốt sale nhanh chóng hơn.</p>
    </div>

    <div class="row g-4 justify-content-center position-relative z-1">
        @foreach (var pkg in Model)
        {
            string themeClass = "theme-basic";
            string iconClass = "bi-box-seam";
            if (pkg.PackageType == "Kim Cương") { themeClass = "theme-diamond"; iconClass = "bi-gem"; }
            else if (pkg.PackageType == "Vàng") { themeClass = "theme-gold"; iconClass = "bi-star-fill"; }
            else if (pkg.PackageType == "Bạc") { themeClass = "theme-silver"; iconClass = "bi-shield-check"; }

            <div class="col-lg-4 col-md-6">
                <div class="pricing-card @themeClass">
                    @if (pkg.PackageType != "Tin Thường")
                    {
                        <div class="badge-ribbon shadow-sm">@pkg.PackageType</div>
                    }

                    <div class="icon-box"><i class="bi @iconClass"></i></div>

                    <h3 class="fw-bold mb-2 text-dark">@pkg.PackageName</h3>
                    <div class="pricing-price">
                        @(pkg.Price == 0 ? "Miễn phí" : pkg.Price.ToString("N0")) <span>VNĐ</span>
                    </div>

                    <ul class="pricing-features">
                        <li><i class="bi bi-check-circle-fill"></i> Hiển thị liên tục trong <strong>@pkg.DurationDays ngày</strong></li>
                        <li><i class="bi bi-check-circle-fill"></i> Mức độ ưu tiên: <strong>Top @pkg.PriorityLevel</strong></li>
                        @if (!string.IsNullOrEmpty(pkg.Description))
                        {
                            foreach (var line in pkg.Description.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <li><i class="bi bi-check-circle-fill"></i> @line</li>
                            }
                        }
                    </ul>

                    <a href="/Payment/Checkout?packageId=@pkg.PackageID" class="btn btn-buy text-decoration-none text-center">
                        @(pkg.Price == 0 ? "Sử dụng ngay" : "CHỌN GÓI NÀY")
                    </a>
                </div>
            </div>
        }
    </div>
</div>