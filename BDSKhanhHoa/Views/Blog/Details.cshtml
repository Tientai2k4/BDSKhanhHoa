@model BDSKhanhHoa.Models.Blog
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var recentBlogs = ViewBag.RecentBlogs as IEnumerable<BDSKhanhHoa.Models.Blog>;
    var categories = ViewBag.Categories as IEnumerable<string>;
}

<style>
    body {
        background-color: #f4f6f9;
    }

    .article-header {
        margin-bottom: 30px;
    }

    .article-title {
        font-size: 2.2rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.4;
        margin-bottom: 20px;
    }

    .article-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        color: #64748b;
        font-size: 0.95rem;
        font-weight: 500;
        border-bottom: 1px solid #e2e8f0;
        padding-bottom: 20px;
    }

    .article-cover {
        width: 100%;
        height: 500px;
        object-fit: cover;
        border-radius: 16px;
        margin-bottom: 30px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .article-sapo {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.8;
        margin-bottom: 30px;
        border-left: 4px solid #0061f2;
        padding-left: 20px;
        background: #f8fafc;
        padding-top: 15px;
        padding-bottom: 15px;
        border-radius: 0 12px 12px 0;
    }

    .article-content {
        font-size: 1.1rem;
        line-height: 1.9;
        color: #334155;
    }

        .article-content img {
            max-width: 100%;
            height: auto;
            border-radius: 12px;
            margin: 25px 0;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .article-content h2, .article-content h3 {
            font-weight: 800;
            color: #0f172a;
            margin-top: 40px;
            margin-bottom: 15px;
        }

    /* SIDEBAR */
    .sidebar-widget {
        background: #fff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        border: 1px solid #edf2f7;
        margin-bottom: 30px;
    }

    .widget-title {
        font-weight: 800;
        font-size: 1.2rem;
        color: #0f172a;
        margin-bottom: 20px;
        position: relative;
        padding-bottom: 10px;
    }

        .widget-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 50px;
            height: 3px;
            background: #0061f2;
            border-radius: 5px;
        }

    .cat-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .cat-list li {
            border-bottom: 1px dashed #e2e8f0;
        }

            .cat-list li:last-child {
                border-bottom: none;
            }

        .cat-list a {
            display: block;
            padding: 12px 0;
            color: #475569;
            text-decoration: none;
            font-weight: 600;
            transition: 0.2s;
        }

            .cat-list a:hover {
                color: #0061f2;
                padding-left: 5px;
            }

    .recent-post {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
        text-decoration: none;
    }

        .recent-post:last-child {
            margin-bottom: 0;
        }

        .recent-post img {
            width: 90px;
            height: 75px;
            object-fit: cover;
            border-radius: 8px;
        }

    .recent-post-title {
        font-weight: 700;
        color: #1e293b;
        font-size: 0.95rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: 0.2s;
    }

    .recent-post:hover .recent-post-title {
        color: #0061f2;
    }
</style>

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-white p-3 rounded-4 shadow-sm border fw-medium">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-primary"><i class="bi bi-house-door-fill"></i> Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Blog/Index" class="text-decoration-none">Tin tức BĐS</a></li>
            <li class="breadcrumb-item active text-dark text-truncate" style="max-width: 300px;">@Model.Title</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-lg-8">
            <div class="bg-white p-4 p-md-5 rounded-4 border shadow-sm">
                <div class="article-header">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-3">@Model.Category</span>
                    <h1 class="article-title">@Model.Title</h1>
                    <div class="article-meta">
                        <span><i class="bi bi-person-circle text-primary me-1"></i> @(Model.User?.FullName ?? "Ban biên tập")</span>
                        <span><i class="bi bi-calendar3 text-primary me-1"></i> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        <span><i class="bi bi-eye text-primary me-1"></i> @Model.Views lượt xem</span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Summary))
                {
                    <div class="article-sapo">@Model.Summary</div>
                }

                @if (!string.IsNullOrEmpty(Model.ImageURL))
                {
                    <img src="@Model.ImageURL" class="article-cover" alt="@Model.Title" onerror="this.style.display='none'">
                }

                <div class="article-content">
                    @Html.Raw(Model.Content)
                </div>

                <div class="d-flex justify-content-between align-items-center mt-5 pt-4 border-top">
                    <div>
                        <span class="fw-bold me-3 text-dark">Chia sẻ bài viết:</span>
                        <button class="btn btn-primary rounded-circle me-1" style="width:40px; height:40px;" onclick="window.open('https://www.facebook.com/sharer/sharer.php?u=@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path')"><i class="bi bi-facebook"></i></button>
                        <button class="btn btn-info text-white rounded-circle me-1" style="width:40px; height:40px;"><i class="bi bi-twitter"></i></button>
                        <button class="btn btn-secondary rounded-circle" style="width:40px; height:40px;" onclick="navigator.clipboard.writeText(window.location.href); alert('Đã copy link bài viết!');"><i class="bi bi-link-45deg"></i></button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="sidebar-widget">
                <h4 class="widget-title">Tìm kiếm</h4>
                <form action="/Blog/Index" method="get">
                    <div class="input-group">
                        <input type="text" name="keyword" class="form-control bg-light border-0 py-2" placeholder="Nhập từ khóa...">
                        <button type="submit" class="btn btn-primary px-3"><i class="bi bi-search"></i></button>
                    </div>
                </form>
            </div>

            @if (categories != null && categories.Any())
            {
                <div class="sidebar-widget">
                    <h4 class="widget-title">Chuyên mục</h4>
                    <ul class="cat-list">
                        @foreach (var cat in categories)
                        {
                            <li><a href="/Blog/Index?category=@cat"><i class="bi bi-chevron-right small me-2 text-primary"></i> @cat</a></li>
                        }
                    </ul>
                </div>
            }

            @if (recentBlogs != null && recentBlogs.Any())
            {
                <div class="sidebar-widget sticky-top" style="top: 90px;">
                    <h4 class="widget-title">Bài viết mới nhất</h4>
                    <div class="recent-posts-wrapper">
                        @foreach (var r in recentBlogs)
                        {
                            <a href="/Blog/Details/@r.BlogID" class="recent-post">
                                <img src="@(string.IsNullOrEmpty(r.ImageURL) ? "/images/no-image.jpg" : r.ImageURL)" onerror="this.src='/images/no-image.jpg'">
                                <div>
                                    <h6 class="recent-post-title">@r.Title</h6>
                                    <small class="text-muted"><i class="bi bi-calendar3"></i> @r.CreatedAt.ToString("dd/MM/yyyy")</small>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>