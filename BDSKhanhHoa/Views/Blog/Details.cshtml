@model BDSKhanhHoa.Models.Blog
@{
    ViewData["Title"] = Model.Title;
    // Sử dụng Layout của Client (bạn chỉnh lại đường dẫn nếu layout tên khác)
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted"><i class="bi bi-house-door"></i> Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Blog" asp-action="Index" class="text-decoration-none text-muted">Tin tức</a></li>
                    <li class="breadcrumb-item active text-truncate" aria-current="page" style="max-width: 300px;">@Model.Title</li>
                </ol>
            </nav>

            <h1 class="fw-bold mb-3 text-dark">@Model.Title</h1>

            <div class="d-flex align-items-center text-muted mb-4 pb-3 border-bottom small">
                <div class="me-4">
                    <i class="bi bi-person-circle text-primary me-1"></i>
                    <span class="fw-medium">@(Model.User?.FullName ?? "Ban biên tập")</span>
                </div>
                <div class="me-4">
                    <i class="bi bi-calendar3 text-primary me-1"></i>
                    @Model.CreatedAt.ToString("dd/MM/yyyy - HH:mm")
                </div>
                <div>
                    <i class="bi bi-eye text-primary me-1"></i>
                    @Model.Views lượt xem
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Summary))
            {
                <p class="lead fw-bold text-dark mb-4" style="text-align: justify;">
                    @Model.Summary
                </p>
            }

            @if (!string.IsNullOrEmpty(Model.ImageURL))
            {
                <div class="mb-4 text-center">
                    <img src="@Model.ImageURL" class="img-fluid rounded shadow-sm w-100" style="max-height: 500px; object-fit: cover;" alt="@Model.Title" onerror="this.style.display='none'" />
                </div>
            }

            <div class="blog-content text-dark" style="font-size: 1.1rem; line-height: 1.8; text-align: justify;">
                @Html.Raw(Model.Content)
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5 pt-4 border-top">
                <div>
                    <span class="fw-bold me-2">Chia sẻ bài viết:</span>
                    <button class="btn btn-sm btn-outline-primary rounded-circle me-1"><i class="bi bi-facebook"></i></button>
                    <button class="btn btn-sm btn-outline-info rounded-circle me-1"><i class="bi bi-twitter"></i></button>
                    <button class="btn btn-sm btn-outline-danger rounded-circle"><i class="bi bi-envelope"></i></button>
                </div>

                <a asp-controller="Blog" asp-action="Index" class="btn btn-light border shadow-sm">
                    <i class="bi bi-arrow-left-circle me-2"></i> Trở về danh sách
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <style>
        .blog-content img {
            max-width: 100%;
            height: auto;
            border-radius: 8px;
            margin: 15px 0;
        }

        .blog-content h2, .blog-content h3 {
            margin-top: 30px;
            margin-bottom: 15px;
            font-weight: bold;
        }
    </style>
}