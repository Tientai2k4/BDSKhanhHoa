@model IEnumerable<BDSKhanhHoa.Models.Blog>
@{
    ViewData["Title"] = "Tin tức Bất động sản";
}

<div class="container my-5">
    <h2 class="text-center mb-4 fw-bold">TIN TỨC MỚI NHẤT</h2>
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <a asp-action="Details" asp-route-id="@item.BlogID">
                        <img src="@(string.IsNullOrEmpty(item.ImageURL) ? "/images/no-image.png" : item.ImageURL)"
                             class="card-img-top" style="height: 200px; object-fit: cover;">
                    </a>
                    <div class="card-body">
                        <small class="text-muted">@item.CreatedAt.ToString("dd/MM/yyyy") | @item.Views lượt xem</small>
                        <h5 class="card-title mt-2">
                            <a asp-action="Details" asp-route-id="@item.BlogID" class="text-decoration-none text-dark fw-bold">@item.Title</a>
                        </h5>
                        <p class="card-text text-muted">@item.Summary</p>
                    </div>
                    <div class="card-footer bg-white border-0">
                        <a asp-action="Details" asp-route-id="@item.BlogID" class="btn btn-outline-primary btn-sm">Xem thêm</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>