@model IEnumerable<BDSKhanhHoa.Models.Consultation>
@{
    ViewData["Title"] = "Lịch sử yêu cầu tư vấn";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<style>
    .req-card {
        transition: 0.3s;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        background: #fff;
        overflow: hidden;
        margin-bottom: 20px;
    }

        .req-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.06);
            border-color: #cbd5e1;
        }

    .req-header {
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f8fafc;
    }

    .req-body {
        padding: 20px;
    }

    .status-badge {
        padding: 6px 14px;
        font-weight: 800;
        font-size: 0.75rem;
        border-radius: 50px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .st-new {
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

    .st-contacted {
        background: #eff6ff;
        color: #2563eb;
        border: 1px solid #bfdbfe;
    }

    .st-closed {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
    }

    .st-cancelled {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    .source-title {
        font-size: 1.1rem;
        font-weight: 800;
        color: #0f172a;
        text-decoration: none;
        margin-bottom: 5px;
        display: block;
    }

        .source-title:hover {
            color: #2563eb;
            text-decoration: underline;
        }
</style>

<div class="container-fluid px-0">
    <div class="d-flex justify-content-between align-items-center mb-4 animate__animated animate__fadeInDown">
        <div>
            <h3 class="fw-black text-dark mb-1"><i class="bi bi-clock-history text-warning me-2"></i>Lịch sử tư vấn của bạn</h3>
            <p class="text-muted mb-0">Theo dõi trạng thái các yêu cầu bạn đã gửi cho nhà môi giới hoặc chủ nhà.</p>
        </div>
        <a href="/Property/Search" class="btn btn-primary rounded-pill fw-bold shadow-sm px-4"><i class="bi bi-search me-1"></i> Tìm BĐS mới</a>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                string stClass = "st-new", stText = "Chờ phản hồi";
                string icon = "bi-hourglass-split";
                bool canCancel = false;

                switch (item.Status)
                {
                    case "New": stClass = "st-new"; stText = "Chờ liên hệ"; icon = "bi-hourglass-split"; canCancel = true; break;
                    case "Contacted": stClass = "st-contacted"; stText = "Chuyên viên đã tiếp nhận"; icon = "bi-telephone-inbound-fill"; break;
                    case "Closed": stClass = "st-closed"; stText = "Hoàn tất"; icon = "bi-check-circle-fill"; break;
                    case "Cancelled": stClass = "st-cancelled"; stText = "Đã hủy"; icon = "bi-x-circle-fill"; break;
                    case "Spam": stClass = "st-cancelled"; stText = "Bị từ chối"; icon = "bi-shield-x"; break;
                }

                <div class="col-xl-6 col-lg-12 animate__animated animate__fadeInUp" id="card-req-@item.ConsultID">
                    <div class="req-card">
                        <div class="req-header">
                            <div class="fw-bold text-muted small"><i class="bi bi-calendar-event me-1"></i> @item.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</div>
                            <span class="status-badge @stClass" id="badge-@item.ConsultID"><i class="bi @icon"></i> @stText</span>
                        </div>
                        <div class="req-body">
                            @if (item.Property != null)
                            {
                                <span class="badge bg-primary mb-2">Nhà đất đăng bán</span>
                                <a href="/Property/Details/@item.PropertyID" class="source-title" target="_blank">@item.Property.Title</a>
                            }
                            else if (item.Project != null)
                            {
                                <span class="badge bg-info text-dark mb-2">Dự án BĐS</span>
                                <a href="/Project/Details/@item.ProjectID" class="source-title" target="_blank">@item.Project.ProjectName</a>
                            }
                            else
                            {
                                <span class="badge bg-secondary mb-2">Không xác định</span>
                                <div class="source-title text-muted fst-italic">Bất động sản đã bị gỡ khỏi hệ thống</div>
                            }

                            <div class="mt-3 bg-light p-3 rounded-3 border">
                                <div class="small text-muted fw-bold mb-1 text-uppercase">Lời nhắn của bạn:</div>
                                <div class="text-dark fw-medium fst-italic">@(string.IsNullOrWhiteSpace(item.Note) ? "Bạn chỉ để lại số điện thoại mà không ghi chú gì thêm." : item.Note)</div>
                            </div>

                            <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                                <div class="text-muted small fw-bold">Thông tin nhận: @item.Phone</div>

                                <div id="action-box-@item.ConsultID">
                                    @if (canCancel)
                                    {
                                        <form class="m-0" id="frmCancel-@item.ConsultID">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="btn btn-outline-danger btn-sm rounded-pill fw-bold px-4" onclick="cancelRequest(@item.ConsultID)">
                                                <i class="bi bi-x-circle me-1"></i> Rút lại yêu cầu
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-light btn-sm rounded-pill fw-bold px-4 text-muted border" disabled><i class="bi bi-lock-fill me-1"></i> Không thể hủy</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 mt-4 bg-white rounded-4 border shadow-sm">
                <img src="/images/empty-state.png" alt="Trống" style="width: 150px; opacity: 0.5" onerror="this.style.display='none'">
                <i class="bi bi-headset display-1 d-block mb-3 text-muted" style="opacity: 0.3;"></i>
                <h4 class="fw-black text-dark mb-2">Bạn chưa yêu cầu tư vấn nào</h4>
                <p class="text-muted fs-5">Hãy dạo quanh thị trường và tìm cho mình một bất động sản ưng ý nhé.</p>
                <a href="/Property/Search" class="btn btn-primary rounded-pill fw-bold mt-3 px-5 py-2 shadow-sm fs-5">Khám phá Bất động sản</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function cancelRequest(id) {
            Swal.fire({
                title: 'Rút lại yêu cầu tư vấn?',
                text: "Chuyên viên sẽ không gọi lại cho bạn nữa. Bạn chắc chắn chứ?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Đồng ý, Hủy ngay',
                cancelButtonText: 'Đóng'
            }).then((result) => {
                if (result.isConfirmed) {
                    const token = document.querySelector(`#frmCancel-${id} input[name="__RequestVerificationToken"]`).value;
                    const formData = new FormData();
                    formData.append('id', id);
                    formData.append('__RequestVerificationToken', token);

                    fetch('/Consultations/CancelRequest', { method: 'POST', body: formData })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                Swal.fire({toast: true, position: 'top-end', icon: 'success', title: data.message, showConfirmButton: false, timer: 2000});

                                // Đổi giao diện Card sang trạng thái Hủy
                                const badge = document.getElementById(`badge-${id}`);
                                badge.className = 'status-badge st-cancelled';
                                badge.innerHTML = '<i class="bi bi-x-circle-fill"></i> Đã tự hủy';

                                document.getElementById(`action-box-${id}`).innerHTML = '<button class="btn btn-light btn-sm rounded-pill fw-bold px-4 text-muted border" disabled><i class="bi bi-lock-fill me-1"></i> Đã đóng</button>';
                            } else {
                                Swal.fire('Lỗi', data.message, 'error');
                            }
                        })
                        .catch(() => Swal.fire('Lỗi', 'Kết nối thất bại', 'error'));
                }
            });
        }
    </script>
}