@model IEnumerable<BDSKhanhHoa.Models.Consultation>

@{
    ViewData["Title"] = "Quản lý Khách hàng (Leads CRM)";
    Layout = "~/Views/Shared/_UserLayout.cshtml";

    var totalLeads = ViewBag.TotalLeads ?? 0;
    var newLeads = ViewBag.NewLeads ?? 0;
    var contactedLeads = ViewBag.ContactedLeads ?? 0;
    var responseRate = totalLeads > 0 ? (contactedLeads * 100 / totalLeads) : 0;

    string searchString = ViewBag.SearchString as string ?? "";
    string statusFilter = ViewBag.StatusFilter as string ?? "All";
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.96);
        --p-color: #2563eb;
    }

    .stat-card-glow {
        transition: all 0.3s ease;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .stat-card-glow:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.1);
    }

    .lead-table thead th {
        background-color: #f8fafc;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        color: #64748b;
        border-top: none;
        padding: 18px 16px;
    }

    .lead-row {
        transition: all 0.2s ease;
        border-bottom: 1px solid #f1f5f9;
    }

    .lead-row td {
        padding: 18px 16px;
        vertical-align: middle;
    }

    .lead-row:hover {
        background-color: #f8fafc !important;
    }

    .status-pill {
        padding: 6px 14px;
        font-weight: 800;
        font-size: 0.75rem;
        border-radius: 50px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

    .st-new {
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

    .st-contacted {
        background: #eff6ff;
        color: #2563eb;
        border: 1px solid #bfdbfe;
    }

    .st-closed {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
    }

    .st-spam {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    .btn-action {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e2e8f0;
        background: #fff;
        color: #475569;
        transition: 0.2s;
    }

    .btn-action:hover {
        background: #f1f5f9;
        color: var(--p-color);
        border-color: #cbd5e1;
    }

    /* ====== FIX MODAL NỀN ĐEN ====== */
    #crmModal {
        z-index: 3000 !important;
    }

    .modal-backdrop {
        display: none !important;
    }

    body.modal-open {
        overflow: auto !important;
        padding-right: 0 !important;
    }

    #crmModal .modal-content {
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
    }

    #crmModal .modal-header {
        background: linear-gradient(135deg, #111827 0%, #1f2937 100%);
    }

    #crmModal .modal-body {
        background: #f8fafc;
    }

    #crmModal .form-control,
    #crmModal .form-select {
        border-color: #dbe4ee;
    }

    #crmModal .form-control:focus,
    #crmModal .form-select:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 0.15rem rgba(37, 99, 235, 0.12);
    }

    .truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .truncate-1 {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<div class="container-fluid px-0">
    <!-- Header Thống kê -->
    <div class="row g-3 mb-4 animate__animated animate__fadeIn">
        <div class="col-6 col-lg-3">
            <div class="card bg-primary text-white border-0 shadow-sm rounded-4 h-100 stat-card-glow">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 small fw-bold text-uppercase">Tổng số Lead</p>
                            <h2 class="fw-black mb-0">@totalLeads</h2>
                        </div>
                        <i class="bi bi-people fs-1 opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card bg-danger text-white border-0 shadow-sm rounded-4 h-100 stat-card-glow">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 small fw-bold text-uppercase">Khách Mới</p>
                            <h2 class="fw-black mb-0">@newLeads</h2>
                        </div>
                        <i class="bi bi-patch-exclamation fs-1 opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card bg-success text-white border-0 shadow-sm rounded-4 h-100 stat-card-glow">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 small fw-bold text-uppercase">Đã Xử Lý</p>
                            <h2 class="fw-black mb-0">@contactedLeads</h2>
                        </div>
                        <i class="bi bi-headset fs-1 opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card bg-dark text-white border-0 shadow-sm rounded-4 h-100 stat-card-glow">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 small fw-bold text-uppercase">Tỷ lệ Phản hồi</p>
                            <h2 class="fw-black mb-0">@responseRate%</h2>
                        </div>
                        <i class="bi bi-graph-up-arrow fs-1 opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bộ lọc & Tìm kiếm -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get" action="/Consultations/Index" class="row g-3">
                <div class="col-lg-5 col-md-12">
                    <div class="input-group input-group-lg border rounded-3 overflow-hidden">
                        <span class="input-group-text bg-white border-0">
                            <i class="bi bi-search text-primary"></i>
                        </span>
                        <input type="text"
                               name="searchString"
                               class="form-control border-0 bg-white fs-6"
                               placeholder="Tên khách hàng, SĐT hoặc BĐS..."
                               value="@searchString">
                    </div>
                </div>

                <div class="col-lg-3 col-6">
                    <select name="statusFilter" class="form-select form-select-lg border-secondary-subtle rounded-3 fw-bold text-muted fs-6">
                        <option value="All" selected="@(statusFilter == "All")">Tất cả trạng thái</option>
                        <option value="New" selected="@(statusFilter == "New")">Mới gửi</option>
                        <option value="Contacted" selected="@(statusFilter == "Contacted")">Đã liên hệ</option>
                        <option value="Closed" selected="@(statusFilter == "Closed")">Đã chốt (Thành công)</option>
                        <option value="Spam" selected="@(statusFilter == "Spam")">Rác / Không liên hệ được</option>
                        <option value="Cancelled" selected="@(statusFilter == "Cancelled")">Khách đã hủy</option>
                    </select>
                </div>

                <div class="col-lg-4 col-6 d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-lg rounded-3 w-100 fw-bold shadow-sm fs-6">Tra cứu</button>
                    <a href="/Consultations/Index" class="btn btn-light btn-lg rounded-3 border fw-bold text-secondary d-flex align-items-center justify-content-center">
                        <i class="bi bi-arrow-clockwise"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Danh sách -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-4 border-bottom d-flex align-items-center">
            <h5 class="mb-0 fw-black text-dark text-uppercase">
                <i class="bi bi-funnel-fill text-warning me-2"></i>
                Danh sách Khách hàng tiềm năng (Leads)
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table lead-table mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Khách hàng</th>
                            <th>Nguồn (BĐS / Dự án)</th>
                            <th>Lời nhắn & Ghi chú</th>
                            <th>Trạng thái</th>
                            <th class="text-center pe-4">Công cụ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                string stClass = "st-new";
                                string stText = "Mới";

                                switch (item.Status)
                                {
                                    case "Contacted":
                                        stClass = "st-contacted";
                                        stText = "Đã gọi";
                                        break;
                                    case "Closed":
                                        stClass = "st-closed";
                                        stText = "Hoàn tất";
                                        break;
                                    case "Spam":
                                        stClass = "st-spam";
                                        stText = "Rác/Ảo";
                                        break;
                                    case "Cancelled":
                                        stClass = "st-spam";
                                        stText = "Khách hủy";
                                        break;
                                }

                                <tr id="row-@item.ConsultID" class="lead-row">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 45px; height: 45px;">
                                                @((!string.IsNullOrEmpty(item.FullName) ? item.FullName.Substring(0, 1).ToUpper() : "K"))
                                            </div>
                                            <div>
                                                <span class="fw-bold text-dark fs-6 d-block">@(item.FullName ?? "Khách vãng lai")</span>
                                                <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                                                    <a href="tel:@item.Phone" class="text-success text-decoration-none small fw-bold">
                                                        <i class="bi bi-telephone-fill"></i> @item.Phone
                                                    </a>
                                                    <span class="text-muted small">· @item.CreatedAt.ToString("dd/MM/yy HH:mm")</span>
                                                </div>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        @if (item.Property != null)
                                        {
                                            <a href="/Property/Details/@item.PropertyID"
                                               class="text-primary text-decoration-none fw-bold small d-inline-block truncate-1"
                                               style="max-width:200px;"
                                               target="_blank">
                                                @item.Property.Title
                                            </a>
                                            <br />
                                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2 mt-1">Nhà đất</span>
                                        }
                                        else if (item.Project != null)
                                        {
                                            <a href="/Project/Details/@item.ProjectID"
                                               class="text-info text-decoration-none fw-bold small d-inline-block truncate-1"
                                               style="max-width:200px;"
                                               target="_blank">
                                                @item.Project.ProjectName
                                            </a>
                                            <br />
                                            <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-2 mt-1">Dự án</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">Nguồn đã xóa</span>
                                        }
                                    </td>

                                    <td>
                                        <div class="text-dark small d-inline-block truncate-2 fw-medium" style="max-width: 250px;">
                                            <i class="bi bi-chat-left-text text-muted me-1"></i>
                                            @(string.IsNullOrEmpty(item.Note) ? "Không có lời nhắn" : item.Note)
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.SellerNote))
                                        {
                                            <div class="text-warning-emphasis small truncate-2 mt-1" style="max-width: 250px;">
                                                <i class="bi bi-pencil-square me-1"></i> @item.SellerNote
                                            </div>
                                        }
                                    </td>

                                    <td>
                                        <span class="status-pill @stClass">@stText</span>
                                    </td>

                                    <td class="text-center pe-4">
                                        <div class="d-flex justify-content-center gap-2">
                                            <button type="button" class="btn-action text-primary" onclick="openCRMModal(@item.ConsultID)" title="Xử lý CRM">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>

                                            <form class="m-0" id="frmDel-@item.ConsultID">
                                                @Html.AntiForgeryToken()
                                                <button type="button" class="btn-action text-danger" onclick="deleteLead(@item.ConsultID)" title="Xóa rác">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <i class="bi bi-headset fs-1 d-block mb-3 text-muted opacity-25"></i>
                                    <h5 class="fw-bold text-dark">Chưa có khách hàng nào</h5>
                                    <p class="text-muted">Danh sách Leads của bạn hiện đang trống.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <div class="p-4 border-top">
                    <nav class="d-flex justify-content-center">
                        <ul class="pagination mb-0 flex-wrap">
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                    <a class="page-link shadow-sm border-0 rounded-3 mx-1 @(ViewBag.CurrentPage == i ? "bg-primary text-white" : "text-dark bg-light")"
                                       href="/Consultations/Index?page=@i&searchString=@Uri.EscapeDataString(searchString)&statusFilter=@statusFilter">
                                        @i
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>

<!-- CRM MODAL -->
<div class="modal fade" id="crmModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="false" data-bs-keyboard="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header text-white border-0 py-3 rounded-top-4">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-person-lines-fill me-2"></i>Chăm sóc khách hàng
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>

            <div class="modal-body p-4">
                <div class="bg-white p-3 rounded-4 border shadow-sm mb-4">
                    <h5 id="md-name" class="fw-bold text-primary mb-1">Khách Hàng</h5>
                    <div class="d-flex gap-3 mb-2 flex-wrap">
                        <a href="#" id="md-phone" class="fw-bold text-success text-decoration-none">
                            <i class="bi bi-telephone-fill"></i> <span></span>
                        </a>
                        <span id="md-email" class="text-muted fw-medium">
                            <i class="bi bi-envelope"></i> <span></span>
                        </span>
                    </div>
                    <div class="p-3 bg-warning bg-opacity-10 border border-warning border-opacity-25 rounded-3">
                        <span class="d-block fw-bold text-warning-emphasis mb-1" style="font-size:0.8rem;">LỜI NHẮN TỪ KHÁCH:</span>
                        <div id="md-note" class="text-dark fw-medium fst-italic"></div>
                    </div>
                </div>

                <form id="frmUpdateLead" method="post" action="/Consultations/SellerUpdateStatus">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="md-id" />

                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Trạng thái chăm sóc <span class="text-danger">*</span></label>
                        <select name="newStatus" id="md-status-select" class="form-select form-select-lg border rounded-3 fw-bold bg-white shadow-sm" required>
                            <option value="New">🚩 Mới (Chưa gọi)</option>
                            <option value="Contacted">📞 Đã gọi / Đang theo dõi</option>
                            <option value="Closed">✅ Chốt thành công</option>
                            <option value="Spam">✖️ Khách ảo / Spam</option>
                            <option value="Cancelled">🚫 Khách đã hủy</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Ghi chú của bạn (Lịch sử làm việc)</label>
                        <textarea name="sellerNote" id="md-sellerNote" class="form-control border rounded-3 shadow-sm bg-white" rows="4" placeholder="Ví dụ: Khách bảo cuối tuần qua xem nhà, nhớ gọi lại..."></textarea>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm">
                            Cập nhật & Lưu hệ thống
                        </button>
                        <button type="button" class="btn btn-light border rounded-pill fw-bold" data-bs-dismiss="modal">
                            Đóng cửa sổ
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let crmModalInstance = null;

        function getCrmModal() {
            const el = document.getElementById('crmModal');
            if (!crmModalInstance) {
                crmModalInstance = new bootstrap.Modal(el, {
                    backdrop: false,
                    keyboard: true,
                    focus: true
                });
            }
            return crmModalInstance;
        }

        function setModalLoadingState(isLoading) {
            const btn = document.querySelector('#frmUpdateLead button[type="submit"]');
            if (!btn) return;

            if (isLoading) {
                btn.dataset.originalHtml = btn.innerHTML;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang lưu...';
                btn.disabled = true;
            } else {
                btn.innerHTML = btn.dataset.originalHtml || 'Cập nhật & Lưu hệ thống';
                btn.disabled = false;
            }
        }

        function openCRMModal(id) {
            Swal.fire({
                title: 'Đang tải...',
                allowOutsideClick: false,
                allowEscapeKey: false,
                didOpen: () => Swal.showLoading()
            });

            fetch(`/Consultations/GetDetails/${id}`, {
                method: 'GET',
                headers: { 'Accept': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                Swal.close();

                if (!data.success) {
                    Swal.fire('Lỗi', data.message || 'Không tải được dữ liệu', 'error');
                    return;
                }

                const d = data.data;

                document.getElementById('md-id').value = d.id || '';
                document.getElementById('md-name').innerText = d.fullName || 'Khách Hàng';

                const phoneLink = document.getElementById('md-phone');
                phoneLink.href = d.phone ? ('tel:' + d.phone) : '#';
                phoneLink.querySelector('span').innerText = d.phone || '';

                document.getElementById('md-email').querySelector('span').innerText = d.email || '';
                document.getElementById('md-note').innerText = d.note || 'Không có lời nhắn';
                document.getElementById('md-sellerNote').value = d.sellerNote || '';

                const sel = document.getElementById('md-status-select');
                sel.disabled = false;

                if (d.status === "Cancelled") {
                    sel.value = "Cancelled";
                    sel.disabled = true;
                } else {
                    sel.value = d.status || "New";
                }

                getCrmModal().show();
            })
            .catch(() => {
                Swal.close();
                Swal.fire('Lỗi', 'Không thể tải dữ liệu từ máy chủ', 'error');
            });
        }

        document.getElementById('frmUpdateLead').addEventListener('submit', function (e) {
            e.preventDefault();

            const formData = new FormData(this);
            const btn = this.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;

            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang lưu...';
            btn.disabled = true;

            fetch(this.action, {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công',
                        text: data.message || 'Đã cập nhật',
                        confirmButtonText: 'OK'
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Lỗi', data.message || 'Cập nhật thất bại', 'error');
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            })
            .catch(() => {
                Swal.fire('Lỗi', 'Lỗi mạng, vui lòng thử lại', 'error');
                btn.innerHTML = originalText;
                btn.disabled = false;
            });
        });

        function deleteLead(id) {
            Swal.fire({
                title: 'Xóa yêu cầu tư vấn?',
                text: 'Hành động này không thể hoàn tác!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Đóng'
            }).then((result) => {
                if (!result.isConfirmed) return;

                const tokenEl = document.querySelector(`#frmDel-${id} input[name="__RequestVerificationToken"]`);
                const token = tokenEl ? tokenEl.value : '';

                const formData = new FormData();
                formData.append('id', id);
                formData.append('__RequestVerificationToken', token);

                fetch('/Consultations/Delete', {
                    method: 'POST',
                    body: formData
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            toast: true,
                            position: 'top-end',
                            icon: 'success',
                            title: 'Đã xóa!',
                            showConfirmButton: false,
                            timer: 1500
                        });

                        const row = document.getElementById(`row-${id}`);
                        if (row) row.remove();
                    } else {
                        Swal.fire('Lỗi', data.message || 'Xóa thất bại', 'error');
                    }
                })
                .catch(() => {
                    Swal.fire('Lỗi', 'Lỗi mạng, vui lòng thử lại', 'error');
                });
            });
        }
    </script>
}