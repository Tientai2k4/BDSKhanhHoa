@* ═══════════════════════════ SCRIPTS ══════════════════════════ *@
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // ── Toast helper ────────────────────────────────────────────────
        function showToast(msg, icon = 'success') {
            Swal.fire({ toast: true, position: 'top-end', icon, title: msg, showConfirmButton: false, timer: 3000, timerProgressBar: true });
        }

        // ── Expand description ──────────────────────────────────────────
        (function(){
            const body = document.getElementById('descBody');
            const btn  = document.getElementById('readMoreBtn');
            if (body && body.scrollHeight > 210) btn.style.display = 'inline-flex';
        })();
        function expandDesc() {
            const body = document.getElementById('descBody');
            const btn  = document.getElementById('readMoreBtn');
            body.classList.remove('desc-collapsed');
            btn.style.display = 'none';
        }

        // ── Gallery thumb switch ────────────────────────────────────────
        function switchImg(el) {
            document.getElementById('heroImg').src = el.src;
            document.getElementById('galleryDisplayImg').src = el.src;
            document.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }
        function switchGallery(el) {
            document.getElementById('galleryDisplayImg').src = el.src;
            document.getElementById('heroImg').src = el.src;
        }

        // ── Phone reveal ────────────────────────────────────────────────
        const btnReveal = document.getElementById('btnReveal');
        const btnCopyPh = document.getElementById('btnCopyPh');
        const fullPhone = '@(Model.User?.Phone ?? "")';
        if (btnReveal) {
            btnReveal.addEventListener('click', function() {
                if (!fullPhone) { showToast('Người dùng chưa cập nhật số điện thoại', 'info'); return; }
                document.getElementById('phoneText').innerText = fullPhone;
                btnCopyPh.style.display = 'block';
                this.style.cursor = 'default';
            });
            btnCopyPh.addEventListener('click', function() {
                navigator.clipboard.writeText(fullPhone).then(() => {
                    this.innerHTML = '<i class="bi bi-check2-all"></i>';
                    setTimeout(() => { this.innerHTML = '<i class="bi bi-copy"></i>'; }, 2000);
                });
            });
        }

        // ── Generic AJAX POST helper ────────────────────────────────────
        async function ajaxPost(url, fd, btn, loadingLabel, originalHtml, modalId) {
            btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>${loadingLabel}`;
            btn.disabled = true;
            try {
                const res  = await fetch(url, { method: 'POST', body: fd });
                const data = await res.json();
                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Thành công!', text: data.message, confirmButtonColor: 'var(--p1)' });
                    if (modalId) bootstrap.Modal.getInstance(document.getElementById(modalId))?.hide();
                    return true;
                } else {
                    if (data.message?.includes('đăng nhập')) {
                        if (modalId) bootstrap.Modal.getInstance(document.getElementById(modalId))?.hide();
                        Swal.fire({ icon: 'warning', title: 'Yêu cầu đăng nhập', text: data.message, confirmButtonColor: 'var(--p1)' })
                            .then(() => window.location.href = '/Account/Login');
                    } else {
                        Swal.fire({ icon: 'info', title: 'Thông báo', text: data.message, confirmButtonColor: 'var(--p1)' });
                    }
                    return false;
                }
            } catch (e) {
                Swal.fire({ icon: 'error', title: 'Lỗi mạng', text: 'Mất kết nối tới máy chủ. Vui lòng thử lại.', confirmButtonColor: 'var(--p1)' });
                return false;
            } finally {
                btn.innerHTML = originalHtml;
                btn.disabled  = false;
            }
        }

        // ── Favorite ────────────────────────────────────────────────────
        document.getElementById('btnFav')?.addEventListener('click', async function() {
            try {
                const res  = await fetch('/Favorite/ToggleFavorite', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(@Model.PropertyID)
                });
                const data = await res.json();
                if (data.success) {
                    const icon = document.getElementById('iconFav');
                    const text = document.getElementById('textFav');
                    showToast(data.message);
                    if (data.isSaved) {
                        this.classList.add('saved');
                        icon.className = 'bi bi-heart-fill'; icon.style.color = 'var(--acc)';
                        text.innerText = 'Đã lưu';
                    } else {
                        this.classList.remove('saved');
                        icon.className = 'bi bi-heart'; icon.style.color = 'var(--mu)';
                        text.innerText = 'Lưu tin';
                    }
                } else {
                    Swal.fire({ icon: 'warning', title: 'Yêu cầu đăng nhập', text: data.message, confirmButtonColor: 'var(--p1)' })
                        .then(() => window.location.href = '/Account/Login');
                }
            } catch(e) { console.error(e); }
        });

        // ── Report ──────────────────────────────────────────────────────
        document.getElementById('btnReport')?.addEventListener('click', async function() {
            const fd = new FormData();
            fd.append('propertyId', '@Model.PropertyID');
            fd.append('reason', document.querySelector('input[name="repReason"]:checked')?.value ?? '');
            fd.append('description', document.getElementById('repDesc').value);
            if (await ajaxPost('/Property/SubmitReport', fd, this, 'Đang gửi...', '<i class="bi bi-send-fill me-1"></i>Gửi báo cáo', 'reportModal')) {
                document.getElementById('repDesc').value = '';
            }
        });

        // ── Appointment ─────────────────────────────────────────────────
        document.getElementById('btnAppt')?.addEventListener('click', async function() {
            const d = document.getElementById('apptDate').value;
            if (!d) { Swal.fire('Lỗi', 'Vui lòng chọn ngày & giờ hẹn!', 'warning'); return; }
            const fd = new FormData();
            fd.append('propertyId', '@Model.PropertyID');
            fd.append('appointmentDate', d);
            fd.append('note', document.getElementById('apptNote').value);
            if (await ajaxPost('/Property/BookAppointment', fd, this, 'Đang đặt lịch...', '<i class="bi bi-send-check me-1"></i>Xác nhận đặt lịch', 'appointmentModal')) {
                document.getElementById('apptDate').value = '';
                document.getElementById('apptNote').value = '';
            }
        });

        // ── Consultation ────────────────────────────────────────────────
        document.getElementById('btnConsult')?.addEventListener('click', async function() {
            const name  = document.getElementById('csName').value.trim();
            const phone = document.getElementById('csPhone').value.trim();
            if (!name || !phone) { Swal.fire('Thiếu thông tin', 'Họ tên và số điện thoại là bắt buộc!', 'warning'); return; }
            const fd = new FormData();
            fd.append('propertyId', '@Model.PropertyID');
            fd.append('fullName', name);
            fd.append('phone', phone);
            fd.append('email', document.getElementById('csEmail').value);
            fd.append('note',  document.getElementById('csNote').value);
            if (await ajaxPost('/Property/SubmitConsultation', fd, this, 'Đang gửi...', '<i class="bi bi-send-fill me-1"></i>Gửi yêu cầu', 'consultationModal')) {
                ['csName','csPhone','csEmail','csNote'].forEach(id => document.getElementById(id).value = '');
            }
        });

        // ── Internal Chat ───────────────────────────────────────────────
        document.getElementById('btnSendChat')?.addEventListener('click', async function() {
            const content = document.getElementById('chatContent').value.trim();
            if (!content) { Swal.fire('Lỗi', 'Vui lòng nhập nội dung tin nhắn!', 'warning'); return; }
            const fd = new FormData();
            fd.append('receiverId',      '@Model.UserID');
            fd.append('propertyId',      '@Model.PropertyID');
            fd.append('messageContent',  content);
            if (await ajaxPost('/Property/SendMessage', fd, this, 'Đang gửi...', '<i class="bi bi-send-fill me-1"></i>Gửi tin nhắn', 'internalChatModal')) {
                document.getElementById('chatContent').value = '';
            }
        });

        // ── Comment ─────────────────────────────────────────────────────
        document.getElementById('btnComment')?.addEventListener('click', async function() {
            const content = document.getElementById('commentContent').value.trim();
            if (!content) { Swal.fire('Lỗi', 'Vui lòng nhập nội dung bình luận!', 'warning'); return; }
            const fd = new FormData();
            fd.append('propertyId', '@Model.PropertyID');
            fd.append('content', content);
            if (await ajaxPost('/Property/SubmitComment', fd, this, 'Đang đăng...', '<i class="bi bi-send-fill me-1"></i>Gửi', null)) {
                document.getElementById('commentContent').value = '';
                showToast('Bình luận đã gửi, chờ Admin duyệt!');
            }
        });
    </script>
}
