@model BDSKhanhHoa.Models.Property
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var similarProps = ViewBag.SimilarProperties as IEnumerable<BDSKhanhHoa.Models.Property> ?? new List<BDSKhanhHoa.Models.Property>();
    var userProps = ViewBag.UserProperties as IEnumerable<BDSKhanhHoa.Models.Property> ?? new List<BDSKhanhHoa.Models.Property>();
    var comments = ViewBag.Comments as IEnumerable<BDSKhanhHoa.Models.Comment> ?? new List<BDSKhanhHoa.Models.Comment>();
    var features = ViewBag.Features as List<BDSKhanhHoa.Models.PropertyFeature>;
    var propertyImages = ViewBag.PropertyImages as IEnumerable<BDSKhanhHoa.Models.PropertyImage> ?? new List<BDSKhanhHoa.Models.PropertyImage>();

    var bed = features?.FirstOrDefault(f => f.FeatureName == "Phòng ngủ")?.FeatureValue;
    var bath = features?.FirstOrDefault(f => f.FeatureName == "Phòng vệ sinh")?.FeatureValue;
    var direction = features?.FirstOrDefault(f => f.FeatureName == "Hướng nhà")?.FeatureValue;
    var legal = features?.FirstOrDefault(f => f.FeatureName == "Pháp lý")?.FeatureValue;
    var amenities = features?.FirstOrDefault(f => f.FeatureName == "Tiện ích")?.FeatureValue;

    var isRent = Model.PropertyType?.ParentID == 2 || Model.TypeID == 2;
    var isAuthenticated = User.Identity.IsAuthenticated;

    int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out int currentUserId);
    bool isOwner = (currentUserId > 0 && currentUserId == Model.UserID);
    bool isAdminOrStaff = User.IsInRole("Admin") || User.IsInRole("Staff");

    var totalImages = propertyImages.Count() + (string.IsNullOrEmpty(Model.MainImage) ? 0 : 1);

    string zaloLink = !string.IsNullOrEmpty(Model.User?.Zalo)
        ? (Model.User.Zalo.StartsWith("0") || Model.User.Zalo.StartsWith("+84") ? "https://zalo.me/" + Model.User.Zalo : Model.User.Zalo) : "";
    string fbLink = !string.IsNullOrEmpty(Model.User?.Facebook)
        ? (Model.User.Facebook.StartsWith("http") ? Model.User.Facebook : "https://facebook.com/" + Model.User.Facebook) : "";

    string fullAddress = $"{(Model.AddressDetail != null ? Model.AddressDetail + ", " : "")}{Model.Ward?.WardName}, {Model.Ward?.Area?.AreaName}, Khánh Hòa";
    string mapQuery = Uri.EscapeDataString(fullAddress ?? "");

    // Format price helper inline
    string priceDisplay = Model.Price.HasValue
        ? (Model.Price.Value >= 1_000_000_000
            ? (Model.Price.Value / 1_000_000_000M).ToString("0.##") + " Tỷ"
            : (Model.Price.Value / 1_000_000M).ToString("0.##") + " Triệu")
        : "Thỏa thuận";

    string pricePerM2 = (Model.Price.HasValue && Model.AreaSize.HasValue && Model.AreaSize.Value > 0)
        ? ((Model.Price.Value / (decimal)Model.AreaSize.Value / 1_000_000M).ToString("0.##") + " Tr/m²")
        : "";
}

@* ─────────────────────────────────────────────────────────── *@
@* CSS                                                          *@
@* ─────────────────────────────────────────────────────────── *@
<style>
    /* ── Variables ───────────────────────────────────────────────── */
    :root {
        --p1: #1a56db;
        --p2: #1242a8;
        --pl: #ebf2ff;
        --acc: #e81c2e;
        --grn: #16a34a;
        --bg: #f0f4fa;
        --sur: #ffffff;
        --bor: #e4e8f0;
        --tx: #0f172a;
        --mu: #64748b;
        --r8: 8px;
        --r12: 12px;
        --r16: 16px;
        --r20: 20px;
        --sh1: 0 2px 12px rgba(15,23,42,.07);
        --sh2: 0 8px 32px rgba(15,23,42,.10);
        --sh3: 0 20px 60px rgba(15,23,42,.13);
        --tr: all .2s cubic-bezier(.4,0,.2,1);
    }

    /* ── Base ────────────────────────────────────────────────────── */
    body {
        background: var(--bg);
    }

    /* ── Breadcrumb ──────────────────────────────────────────────── */
    .bc-wrap {
        background: var(--sur);
        border-bottom: 1px solid var(--bor);
        padding: 12px 0;
    }

    .bc-inner {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
        font-size: .84rem;
        color: var(--mu);
    }

        .bc-inner a {
            color: var(--mu);
            text-decoration: none;
            transition: var(--tr);
        }

            .bc-inner a:hover {
                color: var(--p1);
            }

        .bc-inner .sep {
            opacity: .4;
        }

        .bc-inner .cur {
            color: var(--tx);
            font-weight: 600;
        }

    /* ── Status Badge ────────────────────────────────────────────── */
    .status-bar {
        background: linear-gradient(90deg,#fffbeb,#fff7d6);
        border-left: 4px solid #f59e0b;
        padding: 10px 18px;
        border-radius: 0 var(--r8) var(--r8) 0;
        font-size: .88rem;
        color: #92400e;
        margin-bottom: 18px;
    }

    /* ── Gallery ─────────────────────────────────────────────────── */
    .gallery-wrap {
        position: relative;
        border-radius: var(--r20);
        overflow: hidden;
        background: #000;
        box-shadow: var(--sh2);
    }

    .hero-img {
        width: 100%;
        height: 500px;
        object-fit: cover;
        cursor: zoom-in;
        transition: transform .4s ease;
        display: block;
    }

        .hero-img:hover {
            transform: scale(1.015);
        }

    .gallery-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,.55) 0%, transparent 50%);
        pointer-events: none;
    }

    .gallery-top-badges {
        position: absolute;
        top: 16px;
        left: 16px;
        display: flex;
        gap: 8px;
        z-index: 3;
    }

    .badge-vip {
        background: linear-gradient(135deg,#f59e0b,#ef4444);
        color: #fff;
        font-weight: 800;
        font-size: .78rem;
        padding: 5px 14px;
        border-radius: 20px;
        letter-spacing: .04em;
        box-shadow: 0 2px 8px rgba(0,0,0,.25);
        text-transform: uppercase;
    }

    .badge-type {
        background: rgba(26,86,219,.92);
        color: #fff;
        font-weight: 700;
        font-size: .78rem;
        padding: 5px 14px;
        border-radius: 20px;
        backdrop-filter: blur(6px);
    }

    .gallery-photo-btn {
        position: absolute;
        bottom: 18px;
        right: 18px;
        background: rgba(255,255,255,.15);
        backdrop-filter: blur(10px);
        border: 1.5px solid rgba(255,255,255,.4);
        color: #fff;
        padding: 9px 20px;
        border-radius: var(--r12);
        font-weight: 700;
        font-size: .88rem;
        cursor: pointer;
        z-index: 3;
        transition: var(--tr);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .gallery-photo-btn:hover {
            background: rgba(255,255,255,.28);
        }

    .thumb-row {
        display: flex;
        gap: 8px;
        margin-top: 10px;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-width: thin;
        scrollbar-color: var(--bor) transparent;
    }

    .thumb-item {
        flex-shrink: 0;
        width: 82px;
        height: 64px;
        border-radius: var(--r8);
        object-fit: cover;
        cursor: pointer;
        border: 2.5px solid transparent;
        transition: var(--tr);
        opacity: .75;
    }

        .thumb-item:hover, .thumb-item.active {
            border-color: var(--p1);
            opacity: 1;
            box-shadow: 0 0 0 3px rgba(26,86,219,.18);
        }

    /* ── Main Info Card ──────────────────────────────────────────── */
    .info-card {
        background: var(--sur);
        border-radius: var(--r20);
        padding: 28px 32px;
        box-shadow: var(--sh1);
        border: 1px solid var(--bor);
        margin-bottom: 20px;
    }

    .prop-title {
        font-size: 1.55rem;
        font-weight: 800;
        color: var(--tx);
        line-height: 1.35;
        margin-bottom: 8px;
    }

    .prop-address {
        display: flex;
        align-items: flex-start;
        gap: 6px;
        color: var(--mu);
        font-size: .93rem;
        margin-bottom: 20px;
    }

        .prop-address i {
            color: var(--acc);
            margin-top: 2px;
            flex-shrink: 0;
        }

    .price-area-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1px;
        background: var(--bor);
        border-radius: var(--r12);
        overflow: hidden;
        border: 1px solid var(--bor);
    }

    .pa-cell {
        background: var(--sur);
        padding: 18px 22px;
        text-align: center;
    }

    .pa-label {
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--mu);
        margin-bottom: 6px;
    }

    .pa-val-price {
        font-size: 1.9rem;
        font-weight: 900;
        color: var(--acc);
        line-height: 1;
    }

    .pa-val {
        font-size: 1.45rem;
        font-weight: 800;
        color: var(--tx);
        line-height: 1;
    }

    .pa-unit {
        font-size: .82rem;
        color: var(--mu);
        margin-top: 4px;
    }

    /* ── Quick Stat Pills ────────────────────────────────────────── */
    .quick-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 20px;
    }

    .qs-pill {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--bg);
        border: 1px solid var(--bor);
        border-radius: 30px;
        padding: 8px 16px;
        font-size: .87rem;
        font-weight: 600;
        color: var(--tx);
    }

        .qs-pill i {
            color: var(--p1);
            font-size: 1rem;
        }

    /* ── Section Card ────────────────────────────────────────────── */
    .sec-card {
        background: var(--sur);
        border-radius: var(--r20);
        padding: 28px 32px;
        box-shadow: var(--sh1);
        border: 1px solid var(--bor);
        margin-bottom: 20px;
    }

    .sec-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--tx);
        margin-bottom: 22px;
        padding-bottom: 14px;
        border-bottom: 2px solid var(--bg);
    }

        .sec-title i {
            width: 36px;
            height: 36px;
            background: var(--pl);
            border-radius: var(--r8);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--p1);
            font-size: 1.1rem;
            flex-shrink: 0;
        }

    /* ── Detail Grid ─────────────────────────────────────────────── */
    .detail-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0;
    }

    .dg-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 13px 16px;
        border-bottom: 1px solid var(--bg);
        transition: var(--tr);
    }

        .dg-row:hover {
            background: #fafbff;
        }

        .dg-row:nth-child(odd) {
            border-right: 1px solid var(--bg);
        }

    .dg-key {
        font-size: .87rem;
        color: var(--mu);
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .dg-key i {
            color: var(--p1);
            font-size: .95rem;
        }

    .dg-val {
        font-size: .9rem;
        font-weight: 700;
        color: var(--tx);
        text-align: right;
        max-width: 55%;
    }

        .dg-val.highlight {
            color: var(--p1);
        }

        .dg-val.green {
            color: var(--grn);
        }

    /* ── Description ─────────────────────────────────────────────── */
    .desc-body {
        line-height: 1.85;
        font-size: 1rem;
        color: #334155;
        white-space: pre-wrap;
    }

    .read-more-btn {
        display: none;
        margin-top: 14px;
        font-size: .88rem;
        font-weight: 700;
        color: var(--p1);
        background: var(--pl);
        border: none;
        border-radius: 20px;
        padding: 7px 20px;
        cursor: pointer;
        transition: var(--tr);
    }

        .read-more-btn:hover {
            background: #d6e4ff;
        }

    .desc-collapsed {
        max-height: 200px;
        overflow: hidden;
        position: relative;
    }

        .desc-collapsed::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 60px;
            background: linear-gradient(transparent, var(--sur));
        }

    /* ── Amenity Pills ───────────────────────────────────────────── */
    .amenity-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .am-pill {
        display: flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg,#f0fdf4,#dcfce7);
        border: 1px solid #bbf7d0;
        color: #166534;
        padding: 9px 18px;
        border-radius: 30px;
        font-size: .88rem;
        font-weight: 600;
        transition: var(--tr);
    }

        .am-pill:hover {
            background: linear-gradient(135deg,#dcfce7,#bbf7d0);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(22,163,74,.15);
        }

        .am-pill i {
            font-size: 1rem;
        }

    /* ── Warning Box ─────────────────────────────────────────────── */
    .warn-box {
        display: flex;
        gap: 14px;
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-left: 5px solid #f59e0b;
        border-radius: var(--r12);
        padding: 18px 22px;
        margin-bottom: 20px;
    }

        .warn-box i {
            color: #f59e0b;
            font-size: 1.4rem;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .warn-box ul {
            margin: 0;
            padding-left: 18px;
            font-size: .88rem;
            color: #78350f;
            line-height: 1.75;
        }

        .warn-box h6 {
            font-weight: 800;
            color: #92400e;
            margin-bottom: 8px;
            font-size: .95rem;
        }

    /* ── Map ─────────────────────────────────────────────────────── */
    .map-wrap {
        border-radius: var(--r12);
        overflow: hidden;
        border: 1px solid var(--bor);
    }

    /* ── Comments ────────────────────────────────────────────────── */
    .comment-item {
        display: flex;
        gap: 14px;
        padding: 18px 0;
        border-bottom: 1px solid var(--bg);
    }

        .comment-item:last-child {
            border-bottom: none;
        }

    .c-avatar {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
        border: 2px solid var(--bor);
    }

    .c-bubble {
        flex: 1;
        background: var(--bg);
        border-radius: 4px var(--r12) var(--r12) var(--r12);
        padding: 14px 18px;
        border: 1px solid var(--bor);
    }

    .c-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }

    .c-name {
        font-weight: 700;
        color: var(--tx);
        font-size: .9rem;
    }

    .c-time {
        font-size: .78rem;
        color: var(--mu);
    }

    .c-text {
        color: #475569;
        font-size: .9rem;
        line-height: 1.65;
        white-space: pre-wrap;
        margin: 0;
    }

    /* ── Right Sidebar ───────────────────────────────────────────── */
    .contact-sticky {
        position: sticky;
        top: 90px;
    }

    .contact-card {
        background: var(--sur);
        border-radius: var(--r20);
        box-shadow: var(--sh2);
        border: 1px solid var(--bor);
        overflow: hidden;
        margin-bottom: 20px;
    }

    .contact-header {
        background: linear-gradient(135deg, var(--p1) 0%, #1e40af 100%);
        padding: 22px 24px 18px;
        text-align: center;
        position: relative;
    }

        .contact-header::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 20px;
            background: var(--sur);
            border-radius: 20px 20px 0 0;
        }

    .c-avatar-wrap {
        position: relative;
        display: inline-block;
        margin-bottom: 10px;
    }

    .c-avatar-lg {
        width: 82px;
        height: 82px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid rgba(255,255,255,.4);
    }

    .c-online-dot {
        position: absolute;
        bottom: 4px;
        right: 4px;
        width: 14px;
        height: 14px;
        background: #22c55e;
        border: 2.5px solid #fff;
        border-radius: 50%;
    }

    .c-seller-name {
        font-size: 1.05rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 2px;
    }

    .c-seller-role {
        font-size: .78rem;
        color: rgba(255,255,255,.75);
        background: rgba(255,255,255,.15);
        padding: 3px 12px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 4px;
    }

    .contact-body {
        padding: 20px 22px 22px;
    }

    .phone-reveal-box {
        background: linear-gradient(135deg, #15803d, #16a34a);
        border-radius: var(--r12);
        overflow: hidden;
        display: flex;
        margin-bottom: 14px;
        box-shadow: 0 4px 16px rgba(22,163,74,.25);
        transition: var(--tr);
    }

        .phone-reveal-box:hover {
            box-shadow: 0 6px 22px rgba(22,163,74,.35);
        }

    .btn-reveal {
        flex: 1;
        background: transparent;
        border: none;
        color: #fff;
        font-weight: 800;
        font-size: 1rem;
        padding: 13px 16px;
        text-align: left;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-copy-ph {
        background: rgba(255,255,255,.18);
        border: none;
        color: #fff;
        padding: 13px 18px;
        cursor: pointer;
        transition: var(--tr);
        display: none;
    }

        .btn-copy-ph:hover {
            background: rgba(255,255,255,.32);
        }

    .btn-zalo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: #0068FF;
        color: #fff;
        font-weight: 700;
        font-size: .9rem;
        padding: 11px 0;
        border-radius: var(--r12);
        text-decoration: none;
        transition: var(--tr);
        border: none;
        width: 100%;
    }

        .btn-zalo:hover {
            background: #0054cc;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(0,104,255,.3);
        }

    .btn-fb {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: #1877F2;
        color: #fff;
        font-weight: 700;
        font-size: .9rem;
        padding: 11px 0;
        border-radius: var(--r12);
        text-decoration: none;
        transition: var(--tr);
        border: none;
        width: 100%;
    }

        .btn-fb:hover {
            background: #145dbf;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(24,119,242,.3);
        }

    .action-btns {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .action-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        font-weight: 700;
        font-size: .9rem;
        padding: 12px 0;
        border-radius: var(--r12);
        border: none;
        cursor: pointer;
        transition: var(--tr);
        text-decoration: none;
        text-align: center;
    }

        .action-btn:hover {
            transform: translateY(-2px);
        }

    .ab-consult {
        background: linear-gradient(135deg,#0ea5e9,#0284c7);
        color: #fff;
        box-shadow: 0 4px 14px rgba(14,165,233,.25);
    }

        .ab-consult:hover {
            box-shadow: 0 6px 20px rgba(14,165,233,.38);
            color: #fff;
        }

    .ab-chat {
        background: var(--p1);
        color: #fff;
        box-shadow: 0 4px 14px rgba(26,86,219,.25);
    }

        .ab-chat:hover {
            background: var(--p2);
            box-shadow: 0 6px 20px rgba(26,86,219,.38);
            color: #fff;
        }

    .ab-appt {
        background: linear-gradient(135deg,#16a34a,#15803d);
        color: #fff;
        box-shadow: 0 4px 14px rgba(22,163,74,.25);
    }

        .ab-appt:hover {
            box-shadow: 0 6px 20px rgba(22,163,74,.38);
            color: #fff;
        }

    /* ── Utility buttons row ─────────────────────────────────────── */
    .util-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 8px;
        margin-top: 16px;
    }

    .util-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
        padding: 10px 6px;
        border-radius: var(--r8);
        border: 1.5px solid var(--bor);
        background: var(--sur);
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        transition: var(--tr);
    }

        .util-btn i {
            font-size: 1.15rem;
        }

        .util-btn:hover {
            background: var(--bg);
            border-color: var(--p1);
        }

        .util-btn.saved {
            background: #fef2f2;
            border-color: #fca5a5;
            color: var(--acc);
        }

            .util-btn.saved i {
                color: var(--acc);
            }

    /* ── Locked overlay ──────────────────────────────────────────── */
    .locked-wrap {
        position: relative;
        border-radius: var(--r12);
        overflow: hidden;
        margin-bottom: 14px;
    }

    .locked-blur {
        filter: blur(6px);
        opacity: .45;
        pointer-events: none;
        user-select: none;
    }

    .locked-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: rgba(255,255,255,.55);
        backdrop-filter: blur(2px);
    }

        .locked-overlay i {
            font-size: 1.6rem;
            color: var(--tx);
        }

        .locked-overlay p {
            font-size: .82rem;
            font-weight: 700;
            color: var(--tx);
            margin: 0;
        }

    /* ── Mini property card ──────────────────────────────────────── */
    .mini-prop {
        display: flex;
        gap: 12px;
        padding: 12px;
        border-radius: var(--r12);
        border: 1px solid var(--bor);
        background: var(--sur);
        text-decoration: none;
        transition: var(--tr);
        align-items: flex-start;
    }

        .mini-prop:hover {
            box-shadow: var(--sh1);
            border-color: var(--p1);
            transform: translateX(3px);
        }

    .mini-prop-img {
        width: 80px;
        height: 64px;
        border-radius: var(--r8);
        object-fit: cover;
        flex-shrink: 0;
    }

    .mini-prop-info {
        flex: 1;
        min-width: 0;
    }

    .mini-prop-title {
        font-size: .85rem;
        font-weight: 700;
        color: var(--tx);
        margin-bottom: 4px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .mini-prop-price {
        color: var(--acc);
        font-weight: 800;
        font-size: .9rem;
    }

    .mini-prop-meta {
        font-size: .75rem;
        color: var(--mu);
        margin-top: 3px;
    }

    /* ── Seller's other listings card ────────────────────────────── */
    .seller-listing-card {
        display: block;
        border-radius: var(--r12);
        overflow: hidden;
        border: 1px solid var(--bor);
        text-decoration: none;
        transition: var(--tr);
        background: var(--sur);
    }

        .seller-listing-card:hover {
            box-shadow: var(--sh2);
            transform: translateY(-3px);
            border-color: var(--p1);
        }

        .seller-listing-card img {
            width: 100%;
            height: 120px;
            object-fit: cover;
            display: block;
        }

    .slc-body {
        padding: 10px 12px 12px;
    }

    .slc-title {
        font-size: .83rem;
        font-weight: 700;
        color: var(--tx);
        margin-bottom: 4px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .slc-price {
        color: var(--acc);
        font-weight: 800;
        font-size: .88rem;
    }

    /* ── Empty State ─────────────────────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 36px 20px;
        color: var(--mu);
        background: var(--bg);
        border-radius: var(--r12);
        border: 1px dashed var(--bor);
    }

        .empty-state i {
            font-size: 2.5rem;
            opacity: .35;
            display: block;
            margin-bottom: 10px;
        }

        .empty-state p {
            margin: 0;
            font-size: .9rem;
        }

    /* ── Progress Bar for stats ──────────────────────────────────── */
    .stat-bar-row {
        margin-bottom: 12px;
    }

    .stat-bar-label {
        display: flex;
        justify-content: space-between;
        font-size: .83rem;
        font-weight: 600;
        color: var(--mu);
        margin-bottom: 5px;
    }

    .stat-bar-track {
        background: var(--bg);
        height: 7px;
        border-radius: 99px;
        overflow: hidden;
    }

    .stat-bar-fill {
        height: 100%;
        border-radius: 99px;
        background: linear-gradient(90deg, var(--p1), #60a5fa);
        transition: width .8s ease;
    }

    /* ── Modal improvements ──────────────────────────────────────── */
    .modal-content {
        border: none;
        border-radius: var(--r20);
        box-shadow: var(--sh3);
        overflow: hidden;
    }

    .modal-header {
        border-bottom: none;
        padding: 22px 26px 14px;
    }

    .modal-body {
        padding: 6px 26px 10px;
    }

    .modal-footer {
        border-top: 1px solid var(--bg);
        padding: 14px 26px 22px;
    }

    .form-control, .form-select {
        border: 1.5px solid var(--bor);
        border-radius: var(--r8);
        padding: 10px 14px;
        font-size: .9rem;
        transition: var(--tr);
        background: var(--bg);
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--p1);
            box-shadow: 0 0 0 4px rgba(26,86,219,.1);
            background: var(--sur);
        }

    .form-label {
        font-weight: 700;
        font-size: .87rem;
        color: var(--tx);
        margin-bottom: 6px;
    }

    /* ── Fullscreen image modal ──────────────────────────────────── */
    #galleryModal .modal-dialog {
        max-width: 95vw;
    }

    #galleryModal .modal-content {
        background: #000;
        border-radius: var(--r12);
    }

    #galleryModal .modal-body {
        padding: 6px;
    }

    #galleryDisplayImg {
        max-height: 88vh;
        max-width: 100%;
        object-fit: contain;
        border-radius: var(--r8);
        display: block;
        margin: auto;
    }

    /* ── Loading spinner inside btn ──────────────────────────────── */
    .btn-loading {
        pointer-events: none;
        opacity: .7;
    }

    /* ── Responsive tweaks ───────────────────────────────────────── */
    @@media (max-width: 768px) {
        .hero-img

    {
        height: 280px;
    }

    .prop-title {
        font-size: 1.25rem;
    }

    .price-area-row {
        grid-template-columns: 1fr 1fr;
    }

    .pa-cell:last-child {
        grid-column: 1/-1;
    }

    .detail-grid {
        grid-template-columns: 1fr;
    }

    .dg-row:nth-child(odd) {
        border-right: none;
    }

    .sec-card, .info-card {
        padding: 20px 16px;
    }

    }

    /* ── Smooth fade-in animation for page elements ──────────────── */
    @@keyframes fadeUp {
        from

    {
        opacity: 0;
        transform: translateY(18px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .fade-up {
        animation: fadeUp .5s ease forwards;
    }

    .fade-up-1 {
        animation-delay: .05s;
        opacity: 0;
    }

    .fade-up-2 {
        animation-delay: .12s;
        opacity: 0;
    }

    .fade-up-3 {
        animation-delay: .20s;
        opacity: 0;
    }

    .fade-up-4 {
        animation-delay: .28s;
        opacity: 0;
    }
</style>

@* ─────────────────────────────────────────────────────────── *@
@* BREADCRUMB                                                    *@
@* ─────────────────────────────────────────────────────────── *@
<div class="bc-wrap">
    <div class="container">
        <div class="bc-inner">
            <a href="/"><i class="bi bi-house-door-fill"></i> Trang chủ</a>
            <span class="sep">›</span>
            <a href="/BatDongSan/@(isRent ? "NhaDatChoThue" : "NhaDatBan")">@(isRent ? "Cho thuê" : "Nhà đất bán")</a>
            <span class="sep">›</span>
            <a href="#">@Model.PropertyType?.TypeName</a>
            <span class="sep">›</span>
            <a href="#">@Model.Ward?.Area?.AreaName</a>
            <span class="sep">›</span>
            <span class="cur">@Model.Ward?.WardName</span>
        </div>
    </div>
</div>

<div class="container my-4">

    @* Status warning for non-approved *@
    @if (Model.Status == "Pending" && (isAdminOrStaff || isOwner))
    {
        <div class="status-bar fade-up fade-up-1">
            <i class="bi bi-hourglass-split me-2"></i>
            <strong>Tin đăng đang chờ kiểm duyệt.</strong> Bài đăng chỉ hiển thị với bạn và Admin cho đến khi được phê duyệt.
        </div>
    }

    <div class="row g-4">
        @* ═══════════════════════════════ LEFT COLUMN ═══════════════════════════════ *@
        <div class="col-lg-8">

            @* ── GALLERY ── *@
            <div class="gallery-wrap fade-up fade-up-1 mb-3">
                <div class="gallery-top-badges">
                    @if (Model.PackageID != null && Model.PostServicePackage?.PriorityLevel > 1)
                    {
                        <span class="badge-vip"><i class="bi bi-star-fill me-1"></i>VIP @Model.PostServicePackage.PackageName</span>
                    }
                    <span class="badge-type">@(isRent ? "Cho thuê" : "Bán")</span>
                </div>

                <img id="heroImg"
                     src="@(string.IsNullOrEmpty(Model.MainImage) ? "/images/no-image.jpg" : Model.MainImage)"
                     class="hero-img"
                     alt="@Model.Title"
                     onerror="this.src='/images/no-image.jpg'"
                     data-bs-toggle="modal" data-bs-target="#galleryModal" />

                <div class="gallery-overlay"></div>

                <button class="gallery-photo-btn" data-bs-toggle="modal" data-bs-target="#galleryModal">
                    <i class="bi bi-images"></i> @totalImages ảnh
                </button>
            </div>

            @if (propertyImages.Any())
            {
                <div class="thumb-row mb-3">
                    <img src="@(string.IsNullOrEmpty(Model.MainImage) ? "/images/no-image.jpg" : Model.MainImage)"
                         class="thumb-item active"
                         onclick="switchImg(this)"
                         onerror="this.src='/images/no-image.jpg'" />
                    @foreach (var img in propertyImages)
                    {
                        <img src="@img.ImageURL" class="thumb-item" onclick="switchImg(this)" onerror="this.src='/images/no-image.jpg'" />
                    }
                </div>
            }

            @* ── TITLE + PRICE CARD ── *@
            <div class="info-card fade-up fade-up-2">
                <div class="d-flex justify-content-between align-items-start mb-1 gap-3 flex-wrap">
                    <h1 class="prop-title flex-1">@Model.Title</h1>
                    <div class="d-flex gap-2 flex-shrink-0 align-items-start">
                        @if (isOwner)
                        {
                            <a href="/Property/Edit/@Model.PropertyID" class="btn btn-sm btn-outline-secondary rounded-pill fw-bold">
                                <i class="bi bi-pencil me-1"></i>Sửa tin
                            </a>
                        }
                    </div>
                </div>
                <div class="prop-address">
                    <i class="bi bi-geo-alt-fill"></i>
                    <span>@fullAddress</span>
                </div>

                <div class="price-area-row">
                    <div class="pa-cell">
                        <div class="pa-label">Mức giá</div>
                        <div class="pa-val-price">@priceDisplay</div>
                        @if (isRent)
                        {
                            <div class="pa-unit">/ tháng</div>
                        }
                    </div>
                    <div class="pa-cell">
                        <div class="pa-label">Diện tích</div>
                        <div class="pa-val">@Model.AreaSize m²</div>
                    </div>
                    <div class="pa-cell">
                        <div class="pa-label">Đơn giá</div>
                        <div class="pa-val" style="font-size:1.1rem;">@(string.IsNullOrEmpty(pricePerM2) ? "—" : pricePerM2)</div>
                    </div>
                </div>

                @* Quick stats pills *@
                <div class="quick-stats">
                    @if (!string.IsNullOrEmpty(bed))
                    {
                        <span class="qs-pill"><i class="bi bi-door-closed"></i> @bed phòng ngủ</span>
                    }
                    @if (!string.IsNullOrEmpty(bath))
                    {
                        <span class="qs-pill"><i class="bi bi-droplet"></i> @bath phòng tắm</span>
                    }
                    @if (!string.IsNullOrEmpty(direction))
                    {
                        <span class="qs-pill"><i class="bi bi-compass"></i> Hướng @direction</span>
                    }
                    @if (!string.IsNullOrEmpty(legal))
                    {
                        <span class="qs-pill"><i class="bi bi-patch-check"></i> @legal</span>
                    }
                    <span class="qs-pill"><i class="bi bi-eye"></i> @Model.Views lượt xem</span>
                    <span class="qs-pill"><i class="bi bi-calendar3"></i> Đăng @Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                </div>
            </div>

            @* ── DETAIL TABLE ── *@
            <div class="sec-card fade-up fade-up-3">
                <div class="sec-title"><i class="bi bi-list-ul"></i> Thông tin chi tiết</div>
                <div class="detail-grid">
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-hash"></i>Mã tin</span>
                        <span class="dg-val highlight">#@Model.PropertyID</span>
                    </div>
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-geo-alt"></i>Khu vực</span>
                        <span class="dg-val">@Model.Ward?.Area?.AreaName</span>
                    </div>
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-pin-map"></i>Phường/Xã</span>
                        <span class="dg-val">@Model.Ward?.WardName</span>
                    </div>
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-buildings"></i>Dự án</span>
                        <span class="dg-val">@(Model.Project?.ProjectName ?? "Không có")</span>
                    </div>
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-tag"></i>Loại hình</span>
                        <span class="dg-val">@Model.PropertyType?.TypeName</span>
                    </div>
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-arrow-left-right"></i>Giao dịch</span>
                        <span class="dg-val">@(isRent ? "Cho thuê" : "Mua bán")</span>
                    </div>
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-door-closed"></i>Phòng ngủ</span>
                        <span class="dg-val">@(bed ?? "N/A")</span>
                    </div>
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-droplet"></i>Phòng tắm</span>
                        <span class="dg-val">@(bath ?? "N/A")</span>
                    </div>
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-compass"></i>Hướng nhà</span>
                        <span class="dg-val">@(direction ?? "N/A")</span>
                    </div>
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-patch-check"></i>Pháp lý</span>
                        <span class="dg-val green">@(legal ?? "Đang cập nhật")</span>
                    </div>
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-calendar-plus"></i>Ngày đăng</span>
                        <span class="dg-val">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-arrow-clockwise"></i>Cập nhật</span>
                        <span class="dg-val green">
                            @(Model.UpdatedAt.HasValue? Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm") : Model.CreatedAt.ToString("dd/MM/yyyy"))
                        </span>
                    </div>
                    @if (Model.VipExpiryDate.HasValue)
                    {
                        <div class="dg-row">
                            <span class="dg-key"><i class="bi bi-clock-history"></i>Hết hạn VIP</span>
                            <span class="dg-val">@Model.VipExpiryDate.Value.ToString("dd/MM/yyyy")</span>
                        </div>
                    }
                    <div class="dg-row">
                        <span class="dg-key"><i class="bi bi-eye"></i>Lượt xem</span>
                        <span class="dg-val">@Model.Views lượt</span>
                    </div>
                </div>
            </div>

            @* ── DESCRIPTION ── *@
            <div class="sec-card fade-up fade-up-3">
                <div class="sec-title"><i class="bi bi-file-text"></i> Mô tả bất động sản</div>
                <div id="descBody" class="desc-body desc-collapsed">@Model.Description</div>
                <button id="readMoreBtn" class="read-more-btn" onclick="expandDesc()">
                    <i class="bi bi-chevron-down me-1"></i> Xem thêm nội dung
                </button>
            </div>

            @* ── AMENITIES ── *@
            @if (!string.IsNullOrEmpty(amenities))
            {
                <div class="sec-card fade-up fade-up-3">
                    <div class="sec-title"><i class="bi bi-stars"></i> Tiện ích nổi bật</div>
                    <div class="amenity-grid">
                        @foreach (var am in amenities.Split(','))
                        {
                            <span class="am-pill">
                                <i class="bi bi-check-circle-fill"></i>@am.Trim()
                            </span>
                        }
                    </div>
                </div>
            }

            @* ── SAFETY WARNING ── *@
            <div class="warn-box fade-up fade-up-3">
                <i class="bi bi-shield-exclamation"></i>
                <div>
                    <h6><i class="bi bi-exclamation-triangle-fill me-1"></i> Lưu ý an toàn giao dịch</h6>
                    <ul>
                        <li>Không chuyển khoản khi chưa gặp mặt trực tiếp và xác minh giấy tờ pháp lý bản gốc.</li>
                        <li>Luôn yêu cầu xem sổ đỏ/sổ hồng gốc và công chứng hợp đồng tại văn phòng công chứng.</li>
                        <li>Cẩn thận với các trường hợp yêu cầu đặt cọc trước khi ký hợp đồng chính thức.</li>
                        <li>Hệ thống không chịu trách nhiệm với các nội dung do người dùng tự đăng tải.</li>
                        <li>Phát hiện tin giả / lừa đảo? <a href="#" data-bs-toggle="modal" data-bs-target="#reportModal" class="fw-bold text-danger">Báo cáo ngay tại đây</a>.</li>
                    </ul>
                </div>
            </div>

            @* ── MAP ── *@
            <div class="sec-card fade-up fade-up-4">
                <div class="sec-title"><i class="bi bi-map"></i> Vị trí trên bản đồ</div>
                <div class="map-wrap">
                    <iframe width="100%" height="360" style="border:0;" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade"
                            src="https://maps.google.com/maps?q=@mapQuery&t=&z=15&ie=UTF8&iwloc=&output=embed"></iframe>
                </div>
            </div>

            @* ── SELLER'S OTHER LISTINGS ── *@
            @if (userProps.Any())
            {
                <div class="sec-card fade-up fade-up-4">
                    <div class="sec-title"><i class="bi bi-person-lines-fill"></i> Tin khác của người đăng</div>
                    <div class="row g-3">
                        @foreach (var p in userProps)
                        {
                            string pPrice = p.Price.HasValue
                            ? (p.Price >= 1_000_000_000 ? (p.Price / 1_000_000_000M)?.ToString("0.##") + " Tỷ" : (p.Price / 1_000_000M)?.ToString("0.##") + " Tr")
                            : "Thỏa thuận";
                            <div class="col-6 col-md-3">
                                <a href="/Property/Details/@p.PropertyID" class="seller-listing-card">
                                    <img src="@(string.IsNullOrEmpty(p.MainImage) ? "/images/no-image.jpg" : p.MainImage)" onerror="this.src='/images/no-image.jpg'" />
                                    <div class="slc-body">
                                        <div class="slc-title">@p.Title</div>
                                        <div class="slc-price">@pPrice</div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }

            @* ── COMMENTS ── *@
            <div class="sec-card fade-up fade-up-4">
                <div class="sec-title">
                    <i class="bi bi-chat-text"></i>
                    Bình luận & Đánh giá
                    <span class="badge bg-primary rounded-pill ms-1" style="font-size:.75rem;">@comments.Count()</span>
                </div>

                @if (isAuthenticated)
                {
                    <div class="d-flex gap-3 mb-4">
                        <img src="@(User.FindFirst("Avatar")?.Value ?? "/images/avatars/default-user.png")"
                             class="c-avatar" style="width:46px;height:46px;" />
                        <div class="flex-grow-1">
                            <textarea id="commentContent" class="form-control" rows="3"
                                  placeholder="Chia sẻ nhận xét của bạn về bất động sản này..."></textarea>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Bình luận sẽ hiển thị sau khi Admin duyệt.</small>
                                <button id="btnComment" type="button" class="btn btn-primary rounded-pill px-4 fw-bold" style="font-size:.88rem;">
                                    <i class="bi bi-send-fill me-1"></i>Gửi
                                </button>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="empty-state mb-4">
                        <i class="bi bi-lock"></i>
                        <p>Vui lòng <a href="/Account/Login" class="fw-bold text-primary">đăng nhập</a> để tham gia bình luận.</p>
                    </div>
                }

                @if (comments.Any())
                {
                    @foreach (var c in comments)
                    {
                        <div class="comment-item">
                            <img src="@(c.User?.Avatar ?? "/images/avatars/default-user.png")" class="c-avatar" />
                            <div class="c-bubble">
                                <div class="c-header">
                                    <span class="c-name">@c.User?.FullName</span>
                                    <span class="c-time"><i class="bi bi-clock me-1"></i>@c.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                                <p class="c-text">@c.Content</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-chat-square-dots"></i>
                        <p>Chưa có bình luận nào. Hãy là người đầu tiên!</p>
                    </div>
                }
            </div>

        </div>@* /col-lg-8 *@

        @* ═══════════════════════════════ RIGHT SIDEBAR ═══════════════════════════ *@
        <div class="col-lg-4">
            <div class="contact-sticky">

                @* ── CONTACT CARD ── *@
                <div class="contact-card fade-up fade-up-2">
                    <div class="contact-header">
                        <a href="/Nguoi-Dang-Tin/@Model.UserID" title="Xem hồ sơ người đăng">
                            <div class="c-avatar-wrap">
                                <img src="@(Model.User?.Avatar ?? "/images/avatars/default-user.png")"
                                     class="c-avatar-lg" alt="Avatar" />
                                <span class="c-online-dot"></span>
                            </div>
                        </a>
                        <div class="mt-2">
                            <a href="/Nguoi-Dang-Tin/@Model.UserID" class="c-seller-name text-decoration-none" title="Xem hồ sơ người đăng">
                                @(Model.User?.FullName ?? "Người dùng ẩn danh")
                            </a>
                        </div>                        <span class="c-seller-role">Người đăng tin</span>
                    </div>

                    <div class="contact-body">

                        @if (isAuthenticated)
                        {
                            @* Phone reveal *@
                            <div class="phone-reveal-box" id="phoneBox">
                                <button class="btn-reveal" id="btnReveal">
                                    <i class="bi bi-telephone-fill"></i>
                                    <span id="phoneText">
                                        @(!string.IsNullOrEmpty(Model.User?.Phone)
                                                                            ? Model.User.Phone.Substring(0, Math.Min(4, Model.User.Phone.Length)) + " *** *** – Bấm để hiện"
                                                                            : "Chưa cập nhật SĐT")
                                </span>
                            </button>
                            <button class="btn-copy-ph" id="btnCopyPh" title="Sao chép">
                                <i class="bi bi-copy"></i>
                            </button>
                        </div>

                            @* Social *@
                            <div class="row g-2 mb-3">
                            @if (!string.IsNullOrEmpty(zaloLink))
                                {
                                    <div class="@(!string.IsNullOrEmpty(fbLink) ? "col-6" : "col-12")">
                                        <a href="@zaloLink" target="_blank" class="btn-zalo">
                                            <i class="bi bi-chat-dots-fill"></i> Zalo
                                        </a>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(fbLink))
                                {
                                    <div class="@(!string.IsNullOrEmpty(zaloLink) ? "col-6" : "col-12")">
                                        <a href="@fbLink" target="_blank" class="btn-fb">
                                            <i class="bi bi-facebook"></i> Facebook
                                        </a>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            @* Locked blur *@
                            <div class="locked-wrap mb-3">
                                <div class="locked-blur">
                                    <div class="phone-reveal-box" style="margin-bottom:10px;">
                                        <button class="btn-reveal w-100">
                                            <i class="bi bi-telephone-fill"></i> 0987 *** ***
                                        </button>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button class="btn-zalo w-50">Zalo</button>
                                        <button class="btn-fb w-50">Facebook</button>
                                    </div>
                                </div>
                                <div class="locked-overlay">
                                    <i class="bi bi-lock-fill"></i>
                                    <p>Đăng nhập để xem liên hệ</p>
                                    <a href="/Account/Login" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold shadow-sm">Đăng nhập ngay</a>
                                </div>
                            </div>
                        }

                        @* Action buttons *@
                        <div class="action-btns">
                            <button type="button" class="action-btn ab-consult"
                                    data-bs-toggle="modal" data-bs-target="#consultationModal">
                                <i class="bi bi-headset fs-5"></i> Yêu cầu tư vấn miễn phí
                            </button>

                            @if (!isOwner)
                            {
                                <button type="button" class="action-btn ab-chat"
                                        data-bs-toggle="modal" data-bs-target="#internalChatModal">
                                    <i class="bi bi-chat-dots-fill fs-5"></i> Chat trực tiếp ngay
                                </button>

                                <button type="button" class="action-btn ab-appt"
                                        data-bs-toggle="modal" data-bs-target="#appointmentModal">
                                    <i class="bi bi-calendar-check-fill fs-5"></i> Đặt lịch xem nhà
                                </button>
                            }
                        </div>

                        @* Utility buttons *@
                        <div class="util-row">
                            <button class="util-btn @(ViewBag.IsFavorited ? "saved" : "")"
                                    id="btnFav" data-id="@Model.PropertyID">
                                <i class="bi @(ViewBag.IsFavorited ? "bi-heart-fill" : "bi-heart")"
                                   id="iconFav"
                                   style="color:@(ViewBag.IsFavorited ? "var(--acc)" : "var(--mu)")"></i>
                                <span id="textFav">@(ViewBag.IsFavorited ? "Đã lưu" : "Lưu tin")</span>
                            </button>
                            <button class="util-btn"
                                    onclick="navigator.clipboard.writeText(window.location.href).then(()=>showToast('Đã copy link!','success'))">
                                <i class="bi bi-share" style="color:var(--p1);"></i>
                                <span>Chia sẻ</span>
                            </button>
                            <button class="util-btn" data-bs-toggle="modal" data-bs-target="#reportModal">
                                <i class="bi bi-flag" style="color:var(--mu);"></i>
                                <span>Báo cáo</span>
                            </button>
                        </div>

                    </div>
                </div>

                @* ── SIMILAR PROPERTIES ── *@
                @if (similarProps.Any())
                {
                    <div class="sec-card fade-up fade-up-3" style="padding:22px 20px;">
                        <div class="sec-title" style="font-size:1rem; margin-bottom:14px;"><i class="bi bi-grid-3x3-gap"></i>Bất động sản tương tự</div>
                        <div class="d-flex flex-column gap-2">
                            @foreach (var p in similarProps)
                            {
                                string simPrice = p.Price.HasValue
                                ? (p.Price >= 1_000_000_000 ? (p.Price / 1_000_000_000M)?.ToString("0.##") + " Tỷ" : (p.Price / 1_000_000M)?.ToString("0.##") + " Tr")
                                : "Thỏa thuận";
                                <a href="/Property/Details/@p.PropertyID" class="mini-prop">
                                    <img src="@(string.IsNullOrEmpty(p.MainImage) ? "/images/no-image.jpg" : p.MainImage)"
                                         class="mini-prop-img" onerror="this.src='/images/no-image.jpg'" />
                                    <div class="mini-prop-info">
                                        <div class="mini-prop-title">@p.Title</div>
                                        <div class="mini-prop-price">@simPrice</div>
                                        <div class="mini-prop-meta">
                                            <i class="bi bi-geo-alt me-1"></i>@p.Ward?.WardName
                                            &nbsp;·&nbsp;
                                            <i class="bi bi-calendar3 me-1"></i>@p.CreatedAt.ToString("dd/MM/yy")
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>@* /col-lg-4 *@
    </div>@* /row *@
</div>@* /container *@


@* ═══════════════════════════ MODALS ════════════════════════════ *@

@* ── Gallery Fullscreen Modal ── *@
<div class="modal fade" id="galleryModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-dark border-0 py-2 px-3">
                <span class="text-white fw-bold small">@Model.Title</span>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-2" style="background:#111;">
                <img id="galleryDisplayImg"
                     src="@(string.IsNullOrEmpty(Model.MainImage) ? "/images/no-image.jpg" : Model.MainImage)"
                     id="galleryDisplayImg" style="max-height:85vh;max-width:100%;object-fit:contain;border-radius:8px;" />

                @if (propertyImages.Any())
                {
                    <div style="display:flex;gap:8px;overflow-x:auto;padding:10px 4px 4px;justify-content:center;flex-wrap:wrap;margin-top:8px;">
                        <img src="@(string.IsNullOrEmpty(Model.MainImage) ? "/images/no-image.jpg" : Model.MainImage)"
                             style="height:56px;width:72px;object-fit:cover;border-radius:6px;cursor:pointer;opacity:.7;border:2px solid transparent;"
                             onclick="switchGallery(this)" />
                        @foreach (var gi in propertyImages)
                        {
                            <img src="@gi.ImageURL"
                                 style="height:56px;width:72px;object-fit:cover;border-radius:6px;cursor:pointer;opacity:.7;border:2px solid transparent;"
                                 onclick="switchGallery(this)" />
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ── Internal Chat Modal ── *@
<div class="modal fade" id="internalChatModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background:var(--p1);color:#fff;">
                <h5 class="modal-title fw-bold"><i class="bi bi-chat-dots-fill me-2"></i>Nhắn tin trực tiếp</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            @* ── Tìm đến đoạn Internal Chat Modal và thay bằng đoạn này ── *@
            <div class="modal-body pt-4">
                @* Chỉ cần 1 thẻ <a> duy nhất bọc toàn bộ thông tin người đăng *@
                <a href="/Nguoi-Dang-Tin/@Model.UserID" class="text-decoration-none d-flex align-items-center gap-3 p-3 mb-4 rounded-3"
                   style="background:var(--bg); border:1px solid var(--bor); transition: var(--tr);"
                   onmouseover="this.style.borderColor='var(--p1)'" onmouseout="this.style.borderColor='var(--bor)'">

                    <img src="@(Model.User?.Avatar ?? "/images/avatars/default-user.png")"
                         width="55" height="55" class="rounded-circle border shadow-sm" style="object-fit:cover;">

                    <div>
                        <div class="fw-bold text-dark" style="font-size:1rem;">@(Model.User?.FullName ?? "Ẩn danh")</div>
                        <div style="font-size:.8rem; color:var(--mu);">
                            Xem hồ sơ uy tín <i class="bi bi-arrow-right-short"></i>
                        </div>
                    </div>
                </a>

                <div class="mb-3">
                    <label class="form-label fw-bold">Nội dung tin nhắn <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="chatContent" rows="4"
                              style="background:#fff;"
                              placeholder="Ví dụ: Bất động sản này còn không ạ? Tôi muốn hỏi thêm về giá chốt..." required></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light rounded-pill fw-bold px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="button" id="btnSendChat" class="btn btn-primary rounded-pill fw-bold px-4 shadow-sm">
                    <i class="bi bi-send-fill me-1"></i>Gửi tin nhắn
                </button>
            </div>
        </div>
    </div>
</div>

@* ── Report Modal ── *@
<div class="modal fade" id="reportModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background:#fef2f2;">
                <h5 class="modal-title fw-bold text-danger"><i class="bi bi-flag-fill me-2"></i>Báo cáo vi phạm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-4">
                <p class="text-muted small mb-4">Chọn lý do báo cáo. Chúng tôi sẽ xem xét và xử lý trong vòng 24 giờ.</p>
                <div class="mb-3">
                    <label class="form-label">Lý do vi phạm <span class="text-danger">*</span></label>
                    @foreach (var reason in new[] { "Tin giả, lừa đảo tiền cọc", "Đã bán/cho thuê rồi", "Giá hoặc diện tích sai thực tế", "Hình ảnh giả / không đúng bất động sản", "Lý do khác" })
                    {
                        <div class="form-check mb-2">
