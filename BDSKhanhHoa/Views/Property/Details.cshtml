            <div class="modal-footer border-top-0 px-4 pb-4">
                <button type="button" class="btn btn-light fw-bold rounded-pill px-4" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" class="btn btn-danger fw-bold rounded-pill px-4 shadow-sm" id="btnSubmitReport"><i class="bi bi-send-fill me-1"></i> Gửi báo cáo</button>
            </div>
        </div>
    </div>
</div>

