                    <i class="bi bi-send-fill me-1"></i> Gửi Yêu Cầu
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // 1. XỬ LÝ ĐỔI ẢNH LỚN TRONG GALLERY
        function changeMainImg(element) {
            document.getElementById('main-hero-img').src = element.src;
            document.getElementById('galleryDisplayImg').src = element.src;
            const thumbs = document.querySelectorAll('.sub-img-thumb');
            thumbs.forEach(el => el.classList.remove('active'));
            element.classList.add('active');
        }

        // 2. XỬ LÝ NÚT SỐ ĐIỆN THOẠI
        const btnPhone = document.getElementById('btnRevealPhone');
        const btnCopy = document.getElementById('btnCopyPhone');
        if (btnPhone) {
            btnPhone.addEventListener('click', function(e) {
                e.preventDefault();
                const fullPhone = '@Model.User?.Phone';
                if(fullPhone) {
                    document.getElementById('phoneText').innerText = fullPhone;
                    btnCopy.style.display = 'block';
                    this.style.pointerEvents = 'none';
                } else {
                    Swal.fire({ icon: 'info', title: 'Thông báo', text: 'Người dùng này chưa cập nhật số điện thoại.' });
                }
            });

            btnCopy.addEventListener('click', function(e) {
                e.preventDefault();
                navigator.clipboard.writeText('@Model.User?.Phone').then(() => {
                    this.innerHTML = '<i class="bi bi-check2-all text-light"></i>';
                    setTimeout(() => { this.innerHTML = '<i class="bi bi-copy"></i>'; }, 2000);
                });
            });
        }

        // 3. HÀM DÙNG CHUNG GỌI AJAX RẤT CHUYÊN NGHIỆP
        async function submitFormAjax(url, formData, btnElement, loadingText, originalText, modalIdToClose) {
            btnElement.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> ${loadingText}...`;
            btnElement.disabled = true;
            try {
                const response = await fetch(url, { method: 'POST', body: formData });
                const data = await response.json();

                if(data.success) {
                    Swal.fire({ icon: 'success', title: 'Thành công', text: data.message });
                    if(modalIdToClose) {
                        var myModalEl = document.getElementById(modalIdToClose);
                        var modal = bootstrap.Modal.getInstance(myModalEl);
                        modal.hide();
                    }
                    return true;
                } else {
                    if(data.message.includes('đăng nhập')) {
                        if(modalIdToClose) bootstrap.Modal.getInstance(document.getElementById(modalIdToClose)).hide();
                        Swal.fire({ icon: 'warning', title: 'Yêu cầu đăng nhập', text: data.message }).then(() => { window.location.href = '/Account/Login'; });
                    } else {
                        Swal.fire({ icon: 'info', title: 'Thông báo', text: data.message });
                    }
                    return false;
                }
            } catch(e) {
                Swal.fire({ icon: 'error', title: 'Lỗi mạng', text: 'Mất kết nối tới máy chủ. Vui lòng thử lại.' });
                return false;
            } finally {
                btnElement.innerHTML = originalText;
                btnElement.disabled = false;
            }
        }

        // 4. LƯU TIN YÊU THÍCH (FAVORITE)
        const btnSaveFav = document.getElementById('btnSaveFavorite');
        if (btnSaveFav) {
            btnSaveFav.addEventListener('click', async function() {
                try {
                    const response = await fetch('/Favorite/ToggleFavorite', {
                        method: 'POST', headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(@Model.PropertyID)
                    });
                    const data = await response.json();

                    if(data.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: data.message, showConfirmButton: false, timer: 3000 });
                        const iconFav = document.getElementById('iconFavorite');
                        const textFav = document.getElementById('textFavorite');
                        if(data.isSaved) {
                            this.classList.replace('btn-light', 'btn-danger'); this.classList.replace('text-danger', 'text-white');
                            iconFav.classList.replace('bi-heart', 'bi-heart-fill'); textFav.innerText = "Đã lưu";
                        } else {
                            this.classList.replace('btn-danger', 'btn-light'); this.classList.replace('text-white', 'text-danger');
                            iconFav.classList.replace('bi-heart-fill', 'bi-heart'); textFav.innerText = "Lưu tin";
                        }
                    } else {
                        Swal.fire({ icon: 'warning', title: 'Yêu cầu', text: data.message }).then(() => window.location.href = '/Account/Login');
                    }
                } catch(e) { console.log(e); }
            });
        }

        // 5. GỬI BÁO CÁO VI PHẠM
        const btnSubmitReport = document.getElementById('btnSubmitReport');
        if (btnSubmitReport) {
            btnSubmitReport.addEventListener('click', async function() {
                var fd = new FormData();
                fd.append('propertyId', '@Model.PropertyID');
                fd.append('reason', document.querySelector('input[name="reportReason"]:checked').value);
                fd.append('description', document.getElementById('reportDescription').value);

                if(await submitFormAjax('/Property/SubmitReport', fd, this, 'Đang gửi', '<i class="bi bi-send-fill me-1"></i> Gửi báo cáo', 'reportModal')){
                    document.getElementById('frmReport').reset();
                }
            });
        }

        // 6. ĐẶT LỊCH XEM NHÀ
        const btnSubmitAppt = document.getElementById('btnSubmitAppointment');
        if (btnSubmitAppt) {
            btnSubmitAppt.addEventListener('click', async function() {
                var dateVal = document.getElementById('apptDate').value;
                if(!dateVal) { Swal.fire('Lỗi', 'Vui lòng chọn ngày giờ hẹn!', 'warning'); return; }

                var fd = new FormData();
                fd.append('propertyId', '@Model.PropertyID');
                fd.append('appointmentDate', dateVal);
                fd.append('note', document.getElementById('apptNote').value);

                if(await submitFormAjax('/Property/BookAppointment', fd, this, 'Đang đặt lịch', '<i class="bi bi-send-check me-1"></i> Xác nhận đặt lịch', 'appointmentModal')){
                    document.getElementById('frmAppointment').reset();
                }
            });
        }

        // 7. YÊU CẦU NHẬN BÁN HỘ (CO-BROKER)
        const btnSubmitCoBroker = document.getElementById('btnSubmitCoBroker');
        if (btnSubmitCoBroker) {
            btnSubmitCoBroker.addEventListener('click', async function() {
                var msg = document.getElementById('coBrokerMessage').value;
                if(!msg) { Swal.fire('Lỗi', 'Vui lòng nhập lời nhắn!', 'warning'); return; }

                var fd = new FormData();
                fd.append('propertyId', '@Model.PropertyID');
                fd.append('message', msg);

                if(await submitFormAjax('/Property/SubmitCoBroker', fd, this, 'Đang gửi', '<i class="bi bi-send-fill me-1"></i> Gửi Yêu Cầu Hợp Tác', 'coBrokerModal')){
                    // Do nothing, alert is handled
                }
            });
        }

        // 8. YÊU CẦU TƯ VẤN (GUEST & MEMBER) - ĐÃ CHUYỂN SANG MODAL
        const btnSubmitConsultation = document.getElementById('btnSubmitConsultation');
        if (btnSubmitConsultation) {
            btnSubmitConsultation.addEventListener('click', async function() {
                var name = document.getElementById('consultName').value;
                var phone = document.getElementById('consultPhone').value;
                if(!name || !phone) { Swal.fire('Lỗi', 'Họ tên và Số điện thoại là bắt buộc!', 'warning'); return; }

                var fd = new FormData();
                fd.append('propertyId', '@Model.PropertyID');
                fd.append('fullName', name);
                fd.append('phone', phone);
                fd.append('email', document.getElementById('consultEmail').value);
                fd.append('note', document.getElementById('consultNote').value);

                if(await submitFormAjax('/Property/SubmitConsultation', fd, this, 'Đang gửi', '<i class="bi bi-send-fill me-1"></i> Gửi Yêu Cầu', 'consultationModal')){
                    document.getElementById('frmConsultation').reset();
                }
            });
        }

        // 9. GỬI BÌNH LUẬN
        const btnSubmitComment = document.getElementById('btnSubmitComment');
        if (btnSubmitComment) {
            btnSubmitComment.addEventListener('click', async function() {
                var content = document.getElementById('commentContent').value;
                if(!content.trim()) { Swal.fire('Lỗi', 'Vui lòng nhập nội dung bình luận!', 'warning'); return; }

                var fd = new FormData();
                fd.append('propertyId', '@Model.PropertyID');
                fd.append('content', content);

                if(await submitFormAjax('/Property/SubmitComment', fd, this, 'Đang đăng', 'Gửi bình luận', null)){
                    document.getElementById('commentContent').value = '';
                    // Comment đã được đưa vào trạng thái chờ duyệt (IsHidden = true) nên trang sẽ reload mà không hiện comment đó ngay
                }
            });
        }
    </script>
}