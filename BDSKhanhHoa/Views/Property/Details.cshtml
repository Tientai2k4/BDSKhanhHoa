@model BDSKhanhHoa.Models.Property
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Ép kiểu rõ ràng các List từ ViewBag để chống lỗi RuntimeBinderException (HasValue)
    var similarProps = ViewBag.SimilarProperties as IEnumerable<BDSKhanhHoa.Models.Property> ?? new List<BDSKhanhHoa.Models.Property>();
    var userProps = ViewBag.UserProperties as IEnumerable<BDSKhanhHoa.Models.Property> ?? new List<BDSKhanhHoa.Models.Property>();

    var features = ViewBag.Features as List<BDSKhanhHoa.Models.PropertyFeature>;
    var bed = features?.FirstOrDefault(f => f.FeatureName == "Phòng ngủ")?.FeatureValue;
    var bath = features?.FirstOrDefault(f => f.FeatureName == "Phòng vệ sinh")?.FeatureValue;
    var direction = features?.FirstOrDefault(f => f.FeatureName == "Hướng nhà")?.FeatureValue;
    var legal = features?.FirstOrDefault(f => f.FeatureName == "Pháp lý")?.FeatureValue;
    var amenities = features?.FirstOrDefault(f => f.FeatureName == "Tiện ích")?.FeatureValue;

    var isRent = Model.PropertyType?.ParentID == 2 || Model.TypeID == 2;
}

<style>
    body {
        background-color: #f4f6f9;
    }

    .prop-hero-img {
        width: 100%;
        height: 450px;
        object-fit: cover;
        border-radius: 16px;
    }

    .prop-price {
        font-size: 2.2rem;
        font-weight: 800;
        color: #e81c2e;
    }

    .section-card {
        background: #fff;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        margin-bottom: 25px;
        border: 1px solid #edf2f7;
    }

    .section-title {
        font-weight: 800;
        margin-bottom: 20px;
        font-size: 1.3rem;
        color: #0f172a;
        display: flex;
        align-items: center;
    }

        .section-title i {
            color: #0061f2;
            margin-right: 10px;
            font-size: 1.5rem;
        }

    .overview-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
    }

    .overview-item {
        display: flex;
        justify-content: space-between;
        padding-bottom: 10px;
        border-bottom: 1px dashed #e2e8f0;
    }

        .overview-item span:first-child {
            color: #64748b;
            font-weight: 500;
        }

        .overview-item span:last-child {
            color: #1e293b;
            font-weight: 700;
            text-align: right;
        }

    .amenity-pill {
        display: inline-block;
        background: #f1f5f9;
        color: #334155;
        padding: 8px 20px;
        border-radius: 50px;
        margin: 0 10px 10px 0;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .contact-card {
        background: #fff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        border: 1px solid #edf2f7;
        position: sticky;
        top: 90px;
    }

    .contact-avatar {
        width: 85px;
        height: 85px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #e0e7ff;
    }

    .btn-call {
        background: #16a34a;
        color: white;
        font-weight: 800;
        border-radius: 50px;
        font-size: 1.15rem;
        letter-spacing: 0.5px;
    }

    .warning-box {
        background-color: #fffbeb;
        border-left: 5px solid #f59e0b;
        padding: 15px 20px;
        border-radius: 0 12px 12px 0;
    }

    .trend-box {
        background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        border: 1px solid #bbf7d0;
        border-radius: 12px;
        padding: 20px;
    }

    .mini-card {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        text-decoration: none;
        transition: 0.3s;
        display: block;
    }

        .mini-card:hover {
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            transform: translateY(-3px);
            border-color: #cbd5e1;
        }

        .mini-card img {
            width: 100%;
            height: 140px;
            object-fit: cover;
        }
</style>

<div class="container my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-white p-3 rounded-4 shadow-sm border mb-4 fw-medium">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-primary"><i class="bi bi-house-door-fill"></i> Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/BatDongSan/@(isRent ? "NhaDatChoThue" : "NhaDatBan")" class="text-decoration-none">@(isRent ? "Cho thuê" : "Mua bán")</a></li>
            <li class="breadcrumb-item active text-dark">@Model.Ward?.Area?.AreaName</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="section-card p-2">
                <img src="@(string.IsNullOrEmpty(Model.MainImage) ? "/images/no-image.jpg" : Model.MainImage)" class="prop-hero-img" alt="@Model.Title" onerror="this.src='/images/no-image.jpg'">
            </div>

            <div class="section-card">
                <h1 class="fw-bold mb-3 lh-base" style="font-size: 1.6rem; color: #0f172a;">@Model.Title</h1>
                <p class="text-secondary fs-6 mb-4"><i class="bi bi-geo-alt-fill text-danger me-2"></i>@(Model.AddressDetail != null ? Model.AddressDetail + ", " : "")@Model.Ward?.WardName, @Model.Ward?.Area?.AreaName, Tỉnh Khánh Hòa</p>

                <div class="d-flex align-items-center justify-content-between border-top pt-4">
                    <div>
                        <span class="d-block text-muted mb-1 fw-bold text-uppercase" style="font-size: 0.8rem;">Mức giá</span>
                        <span class="prop-price">
                            @(Model.Price.HasValue ? (Model.Price.Value >= 1000000000 ? (Model.Price.Value / 1000000000).ToString("0.##") + " Tỷ" : (Model.Price.Value / 1000000).ToString("0.##") + " Triệu") : "Thỏa thuận")
                            @if (isRent)
                            {
                                <span class="fs-5 text-muted fw-normal">/tháng</span>
                            }
                        </span>
                    </div>
                    <div class="text-end">
                        <span class="d-block text-muted mb-1 fw-bold text-uppercase" style="font-size: 0.8rem;">Diện tích</span>
                        <span class="fs-3 fw-bold text-dark">@Model.AreaSize m²</span>
                    </div>
                </div>
            </div>

            <div class="section-card">
                <h4 class="section-title"><i class="bi bi-ui-checks-grid"></i> Thông tin tổng quan</h4>
                <div class="overview-grid">
                    <div class="overview-item"><span>Mã tin</span><span>#@Model.PropertyID</span></div>
                    <div class="overview-item"><span>Khu vực</span><span>@Model.Ward?.Area?.AreaName</span></div>
                    <div class="overview-item"><span>Loại hình</span><span>@Model.PropertyType?.TypeName</span></div>
                    <div class="overview-item"><span>Giao dịch</span><span>@(isRent ? "Cho thuê" : "Bán")</span></div>
                    <div class="overview-item"><span>Phòng ngủ</span><span>@(bed ?? "N/A")</span></div>
                    <div class="overview-item"><span>Phòng tắm</span><span>@(bath ?? "N/A")</span></div>
                    <div class="overview-item"><span>Hướng nhà</span><span>@(direction ?? "N/A")</span></div>
                    <div class="overview-item"><span>Pháp lý</span><span>@(legal ?? "N/A")</span></div>
                    <div class="overview-item"><span>Ngày đăng</span><span>@Model.CreatedAt.ToString("dd/MM/yyyy")</span></div>
                    <div class="overview-item"><span>Hết hạn VIP</span><span>@(Model.VipExpiryDate.HasValue? Model.VipExpiryDate.Value.ToString("dd/MM/yyyy") : "Không có")</span></div>
                    <div class="overview-item"><span>Loại tin</span><span>@Model.PostServicePackage?.PackageName</span></div>
                    <div class="overview-item"><span>Lượt xem</span><span>@Model.Views lượt</span></div>
                </div>
            </div>

            <div class="section-card">
                <h4 class="section-title"><i class="bi bi-file-text"></i> Mô tả chi tiết</h4>
                <div class="text-dark" style="line-height: 1.8; font-size: 1.05rem; white-space: pre-wrap;">@Model.Description</div>
            </div>

            <div class="warning-box mb-4">
                <h6 class="fw-bold text-danger mb-2"><i class="bi bi-exclamation-triangle-fill me-2"></i>Cảnh báo an toàn:</h6>
                <ul class="mb-0 text-dark small" style="line-height: 1.6;">
                    <li>Không chuyển tiền cọc online khi chưa gặp mặt và xác minh rõ ràng.</li>
                    <li>Luôn gặp trực tiếp để xem nhà/đất và xác thực giấy tờ pháp lý trước khi giao dịch.</li>
                    <li>Website chỉ là nền tảng đăng tin, không chịu trách nhiệm với các nội dung do người dùng đăng.</li>
                    <li>Nếu phát hiện tin giả, lừa đảo, vui lòng <a href="#" class="text-danger fw-bold text-decoration-none">báo cáo ngay tại đây</a>.</li>
                </ul>
            </div>


            @if (!string.IsNullOrEmpty(amenities))
            {
                <div class="section-card mt-4">
                    <h4 class="section-title"><i class="bi bi-stars"></i> Tiện ích đi kèm</h4>
                    <div>
                        @foreach (var am in amenities.Split(','))
                        {
                            <span class="amenity-pill"><i class="bi bi-check-circle-fill text-success me-2"></i>@am.Trim()</span>
                        }
                    </div>
                </div>
            }

            <div class="section-card p-0 overflow-hidden mt-4">
                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 350px;">
                    <div class="text-center text-muted">
                        <i class="bi bi-geo-alt display-1 text-primary opacity-50 mb-3 d-block"></i>
                        <h5 class="fw-bold">Vị trí trên bản đồ</h5>
                        <p class="small">Bản đồ đang được hệ thống cập nhật cho khu vực này.</p>
                    </div>
                </div>
            </div>

            <div class="section-card mt-4">
                <h4 class="section-title"><i class="bi bi-chat-text"></i> Bình luận (0)</h4>
                <div class="d-flex gap-3 mb-4">
                    <img src="/images/avatars/default-user.png" class="rounded-circle" width="50" height="50">
                    <div class="flex-grow-1">
                        <textarea class="form-control bg-light rounded-4" rows="3" placeholder="Viết bình luận của bạn về bất động sản này..."></textarea>
                        <div class="text-end mt-2"><button class="btn btn-primary rounded-pill px-4 fw-bold">Gửi bình luận</button></div>
                    </div>
                </div>
                <div class="text-center py-4 text-muted bg-light rounded-4 border">
                    <i class="bi bi-chat-square-dots fs-1 mb-2 d-block opacity-50"></i>
                    <p class="mb-0">Chưa có bình luận nào. Hãy là người đầu tiên bình luận!</p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="contact-card mb-4">
                <div class="text-center border-bottom pb-4 mb-4">
                    <p class="text-muted small fw-bold text-uppercase mb-3">Được đăng bởi</p>
                    <img src="@(Model.User?.Avatar ?? "/images/avatars/default-user.png")" alt="Avatar" class="contact-avatar mb-3">
                    <h4 class="fw-bold text-dark mb-1">@Model.User?.FullName</h4>
                    <div class="text-warning small mb-3">
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i> <span class="text-muted ms-1">(Chưa có đánh giá)</span>
                    </div>

                    <button class="btn btn-call w-100 py-3 shadow-sm" id="btnRevealPhone">
                        <i class="bi bi-telephone-outbound-fill me-2"></i>
                        <span id="phoneText">@(!string.IsNullOrEmpty(Model.User?.Phone) ? Model.User.Phone.Substring(0, 4) + " *** *** (Hiện số)" : "Chưa có SĐT")</span>
                    </button>
                </div>

                <div class="d-grid gap-2">
                    <a href="mailto:@Model.User?.Email" class="btn btn-outline-primary py-2 fw-bold"><i class="bi bi-envelope-at me-2"></i> Gửi Email</a>
                    <button class="btn btn-outline-success py-2 fw-bold"><i class="bi bi-headset me-2"></i> Gửi yêu cầu tư vấn</button>
                </div>

                <div class="row g-2 mt-3 pt-3 border-top text-center">
                    <div class="col-4"><button class="btn btn-sm btn-light w-100 text-danger fw-bold" onclick="alert('Đã lưu tin!')"><i class="bi bi-heart d-block fs-5 mb-1"></i> Yêu thích</button></div>
                    <div class="col-4"><button class="btn btn-sm btn-light w-100 text-primary fw-bold"><i class="bi bi-share d-block fs-5 mb-1"></i> Chia sẻ</button></div>
                    <div class="col-4"><button class="btn btn-sm btn-light w-100 text-secondary fw-bold"><i class="bi bi-flag d-block fs-5 mb-1"></i> Báo cáo</button></div>
                </div>
            </div>

            @if (similarProps.Any())
            {
                <div class="section-card p-4 mb-4 bg-white">
                    <h5 class="fw-bold mb-3" style="font-size: 1.1rem;">Tin đăng cùng loại</h5>
                    <div class="d-grid gap-3">
                        @foreach (var p in similarProps)
                        {
                            <a href="/Property/Details/@p.PropertyID" class="mini-card text-dark">
                                <img src="@(string.IsNullOrEmpty(p.MainImage) ? "/images/no-image.jpg" : p.MainImage)" onerror="this.src='/images/no-image.jpg'">
                                <div class="p-3">
                                    <h6 class="fw-bold text-truncate mb-1" style="font-size: 0.95rem;">@p.Title</h6>
                                    <div class="text-danger fw-bold mb-1">@(p.Price.HasValue ? (p.Price >= 1000000000 ? (p.Price / 1000000000)?.ToString("0.##") + " Tỷ" : (p.Price / 1000000)?.ToString("0.##") + " Triệu") : "Thỏa thuận")</div>
                                    <small class="text-muted fw-bold"><i class="bi bi-geo-alt"></i> @p.Ward?.Area?.AreaName</small>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (userProps.Any())
            {
                <div class="section-card p-4 bg-white">
                    <h5 class="fw-bold mb-3" style="font-size: 1.1rem;">Tin đăng khác của @Model.User?.FullName</h5>
                    <div class="d-grid gap-3">
                        @foreach (var p in userProps)
                        {
                            <a href="/Property/Details/@p.PropertyID" class="mini-card text-dark">
                                <img src="@(string.IsNullOrEmpty(p.MainImage) ? "/images/no-image.jpg" : p.MainImage)" onerror="this.src='/images/no-image.jpg'">
                                <div class="p-3">
                                    <h6 class="fw-bold text-truncate mb-1" style="font-size: 0.95rem;">@p.Title</h6>
                                    <div class="text-danger fw-bold mb-1">@(p.Price.HasValue ? (p.Price >= 1000000000 ? (p.Price / 1000000000)?.ToString("0.##") + " Tỷ" : (p.Price / 1000000)?.ToString("0.##") + " Triệu") : "Thỏa thuận")</div>
                                    <small class="text-muted fw-bold"><i class="bi bi-geo-alt"></i> @p.Ward?.Area?.AreaName</small>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnRevealPhone').addEventListener('click', function() {
            var fullPhone = '@Model.User?.Phone';
            if(fullPhone && fullPhone !== '') {
                document.getElementById('phoneText').innerText = fullPhone;
                this.classList.replace('btn-call', 'btn-success');
                window.location.href = "tel:" + fullPhone;
            }
        });
    </script>
}