                <form id="frmReport">
                    <div class="mb-3">
                        <label class="form-label text-dark fw-bold">Chọn vấn đề: <span class="text-danger">*</span></label>
                        <div class="form-check mb-2"><input class="form-check-input" type="radio" name="reportReason" value="Tin giả, lừa đảo" checked><label class="form-check-label">Tin giả, có dấu hiệu lừa đảo tiền cọc</label></div>
                        <div class="form-check mb-2"><input class="form-check-input" type="radio" name="reportReason" value="Đã bán/cho thuê"><label class="form-check-label">Bất động sản đã bán hoặc cho thuê rồi</label></div>
                        <div class="form-check mb-2"><input class="form-check-input" type="radio" name="reportReason" value="Thông tin sai"><label class="form-check-label">Giá bán, diện tích hoặc vị trí không đúng thực tế</label></div>
                        <div class="form-check mb-2"><input class="form-check-input" type="radio" name="reportReason" value="Lý do khác"><label class="form-check-label">Lý do khác</label></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-dark fw-bold">Chi tiết thêm (Không bắt buộc)</label>
                        <textarea class="form-control bg-light" id="reportDescription" rows="3" placeholder="Mô tả rõ hơn vấn đề..."></textarea>
                    </div>
