@model BDSKhanhHoa.Models.Property
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var similarProps = ViewBag.SimilarProperties as IEnumerable<BDSKhanhHoa.Models.Property> ?? new List<BDSKhanhHoa.Models.Property>();
    var userProps = ViewBag.UserProperties as IEnumerable<BDSKhanhHoa.Models.Property> ?? new List<BDSKhanhHoa.Models.Property>();
    var comments = ViewBag.Comments as IEnumerable<BDSKhanhHoa.Models.Comment> ?? new List<BDSKhanhHoa.Models.Comment>();

    var features = ViewBag.Features as List<BDSKhanhHoa.Models.PropertyFeature>;
    var bed = features?.FirstOrDefault(f => f.FeatureName == "Phòng ngủ")?.FeatureValue;
    var bath = features?.FirstOrDefault(f => f.FeatureName == "Phòng vệ sinh")?.FeatureValue;
    var direction = features?.FirstOrDefault(f => f.FeatureName == "Hướng nhà")?.FeatureValue;
    var legal = features?.FirstOrDefault(f => f.FeatureName == "Pháp lý")?.FeatureValue;
    var amenities = features?.FirstOrDefault(f => f.FeatureName == "Tiện ích")?.FeatureValue;

    var isRent = Model.PropertyType?.ParentID == 2 || Model.TypeID == 2;
    var isAuthenticated = User.Identity.IsAuthenticated;

    int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out int currentUserId);
    bool isOwner = (currentUserId > 0 && currentUserId == Model.UserID);

    var propertyImages = ViewBag.PropertyImages as IEnumerable<BDSKhanhHoa.Models.PropertyImage> ?? new List<BDSKhanhHoa.Models.PropertyImage>();
    var totalImages = propertyImages.Count() + (string.IsNullOrEmpty(Model.MainImage) ? 0 : 1);

    string zaloLink = !string.IsNullOrEmpty(Model.User?.Zalo) ? (Model.User.Zalo.StartsWith("http") ? Model.User.Zalo : "https://zalo.me/" + Model.User.Zalo) : "";
    string fbLink = !string.IsNullOrEmpty(Model.User?.Facebook) ? (Model.User.Facebook.StartsWith("http") ? Model.User.Facebook : "https://facebook.com/" + Model.User.Facebook) : "";

    string fullAddress = $"{(Model.AddressDetail != null ? Model.AddressDetail + ", " : "")}{Model.Ward?.WardName}, {Model.Ward?.Area?.AreaName}, Khánh Hòa";
    string mapQuery = Uri.EscapeDataString(fullAddress ?? "");
}

<style>
    body {
        background-color: #f4f6f9;
    }

    .prop-hero-img {
        width: 100%;
        height: 480px;
        object-fit: cover;
        border-radius: 16px;
        position: relative;
        cursor: zoom-in;
    }

    .img-overlay-btn {
        position: absolute;
        bottom: 20px;
        right: 20px;
        background: rgba(0,0,0,0.7);
        color: white;
        border: 1px solid rgba(255,255,255,0.3);
        padding: 8px 20px;
        border-radius: 8px;
        backdrop-filter: blur(5px);
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
        z-index: 2;
    }

        .img-overlay-btn:hover {
            background: rgba(0,0,0,0.9);
        }

    .thumb-gallery-scroll {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        padding-bottom: 5px;
        margin-top: 15px;
        scrollbar-width: thin;
    }

    .sub-img-thumb {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 8px;
        border: 2px solid transparent;
        cursor: pointer;
        transition: 0.2s ease;
        flex-shrink: 0;
    }

        .sub-img-thumb:hover, .sub-img-thumb.active {
            border-color: #0061f2;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    .prop-price {
        font-size: 2.2rem;
        font-weight: 800;
        color: #e81c2e;
    }

    .section-card {
        background: #fff;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        margin-bottom: 25px;
        border: 1px solid #edf2f7;
    }

    .section-title {
        font-weight: 800;
        margin-bottom: 20px;
        font-size: 1.3rem;
        color: #0f172a;
        display: flex;
        align-items: center;
    }

        .section-title i {
            color: #0061f2;
            margin-right: 10px;
            font-size: 1.5rem;
        }

    .overview-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
    }

    .overview-item {
        display: flex;
        justify-content: space-between;
        padding-bottom: 10px;
        border-bottom: 1px dashed #e2e8f0;
    }

        .overview-item span:first-child {
            color: #64748b;
            font-weight: 500;
        }

        .overview-item span:last-child {
            color: #1e293b;
            font-weight: 700;
            text-align: right;
        }

    .amenity-pill {
        display: inline-flex;
        align-items: center;
        background: #f8fafc;
        color: #334155;
        padding: 10px 20px;
        border-radius: 10px;
        margin: 0 10px 10px 0;
        font-weight: 600;
        font-size: 0.95rem;
        border: 1px solid #e2e8f0;
        transition: 0.2s;
    }

        .amenity-pill:hover {
            background: #e0e7ff;
            color: #0061f2;
            border-color: #0061f2;
        }

    .contact-card {
        background: #fff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        border: 1px solid #edf2f7;
        position: sticky;
        top: 90px;
    }

    .contact-avatar {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #e0e7ff;
        padding: 3px;
    }

    .phone-box {
        display: flex;
        align-items: center;
        background: #16a34a;
        border-radius: 12px;
        overflow: hidden;
        transition: 0.3s;
        margin-bottom: 15px;
    }

        .phone-box:hover {
            background: #15803d;
            box-shadow: 0 5px 15px rgba(22, 163, 74, 0.3);
        }

    .btn-call {
        flex-grow: 1;
        background: transparent;
        color: white;
        font-weight: 800;
        border: none;
        padding: 12px 15px;
        font-size: 1.1rem;
        letter-spacing: 0.5px;
        text-align: left;
    }

    .btn-copy {
        background: rgba(255, 255, 255, 0.2);
        color: white;
        border: none;
        padding: 12px 20px;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-copy:hover {
            background: rgba(255, 255, 255, 0.4);
        }

    .btn-zalo {
        background: #0068FF;
        color: white;
        font-weight: 700;
        border-radius: 12px;
        transition: 0.3s;
    }

        .btn-zalo:hover {
            background: #0054cc;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 104, 255, 0.3);
        }

    .btn-fb {
        background: #1877F2;
        color: white;
        font-weight: 700;
        border-radius: 12px;
        transition: 0.3s;
    }

        .btn-fb:hover {
            background: #145dbf;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(24, 119, 242, 0.3);
        }

    .locked-contact {
        position: relative;
        overflow: hidden;
        border-radius: 12px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 20px;
        text-align: center;
    }

    .locked-content {
        filter: blur(5px);
        opacity: 0.5;
        pointer-events: none;
        user-select: none;
    }

    .locked-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 10;
        background: rgba(255,255,255,0.6);
    }

    .warning-box {
        background-color: #fffbeb;
        border-left: 5px solid #f59e0b;
        padding: 15px 20px;
        border-radius: 0 12px 12px 0;
    }

    .mini-card {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        text-decoration: none;
        transition: 0.3s;
        display: block;
    }

        .mini-card:hover {
            box-shadow: 0 10px 20px rgba(0,0,0,0.08);
            transform: translateY(-3px);
            border-color: #0061f2;
        }

        .mini-card img {
            width: 100%;
            height: 140px;
            object-fit: cover;
        }

    .comment-item {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 20px;
    }

    .comment-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
    }

    .comment-box {
        background: #f8fafc;
        padding: 15px;
        border-radius: 0 16px 16px 16px;
        border: 1px solid #e2e8f0;
        flex-grow: 1;
    }
</style>

<div class="container my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-white p-3 rounded-4 shadow-sm border mb-4 fw-medium">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-primary"><i class="bi bi-house-door-fill"></i> Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/BatDongSan/@(isRent ? "NhaDatChoThue" : "NhaDatBan")" class="text-decoration-none">@(isRent ? "Cho thuê" : "Mua bán")</a></li>
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">@Model.PropertyType?.TypeName</a></li>
            <li class="breadcrumb-item active text-dark">@Model.Ward?.Area?.AreaName</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="section-card p-2 position-relative mb-4">
                <img id="main-hero-img" src="@(string.IsNullOrEmpty(Model.MainImage) ? "/images/no-image.jpg" : Model.MainImage)" class="prop-hero-img" alt="@Model.Title" onerror="this.src='/images/no-image.jpg'" data-bs-toggle="modal" data-bs-target="#imageGalleryModal">
                <div class="img-overlay-btn" data-bs-toggle="modal" data-bs-target="#imageGalleryModal">
                    <i class="bi bi-images me-2"></i> Xem tất cả ảnh (@totalImages)
                </div>

                @if (propertyImages.Any())
                {
                    <div class="thumb-gallery-scroll">
                        <img src="@(string.IsNullOrEmpty(Model.MainImage) ? "/images/no-image.jpg" : Model.MainImage)" class="sub-img-thumb active" onclick="changeMainImg(this)" onerror="this.src='/images/no-image.jpg'" />
                        @foreach (var img in propertyImages)
                        {
                            <img src="@img.ImageURL" class="sub-img-thumb" onclick="changeMainImg(this)" onerror="this.src='/images/no-image.jpg'" />
                        }
                    </div>
                }
            </div>

            <div class="section-card">
                <h1 class="fw-bold mb-3 lh-base" style="font-size: 1.6rem; color: #0f172a;">@Model.Title</h1>
                <p class="text-secondary fs-6 mb-4"><i class="bi bi-geo-alt-fill text-danger me-2"></i>@fullAddress</p>

                <div class="d-flex align-items-center justify-content-between border-top pt-4">
                    <div>
                        <span class="d-block text-muted mb-1 fw-bold text-uppercase" style="font-size: 0.8rem;">Mức giá</span>
                        <span class="prop-price">
                            @(Model.Price.HasValue ? (Model.Price.Value >= 1000000000 ? (Model.Price.Value / 1000000000).ToString("0.##") + " Tỷ" : (Model.Price.Value / 1000000).ToString("0.##") + " Triệu") : "Thỏa thuận")
                            @if (isRent)
                            {
                                <span class="fs-5 text-muted fw-normal">/tháng</span>
                            }
                        </span>
                    </div>
                    <div class="text-end">
                        <span class="d-block text-muted mb-1 fw-bold text-uppercase" style="font-size: 0.8rem;">Diện tích</span>
                        <span class="fs-3 fw-bold text-dark">@Model.AreaSize m²</span>
                    </div>
                </div>
            </div>

            <div class="section-card">
                <h4 class="section-title"><i class="bi bi-ui-checks-grid"></i> Thông tin chi tiết</h4>
                <div class="overview-grid">
                    <div class="overview-item"><span>Mã tin</span><span class="text-primary">#@Model.PropertyID</span></div>
                    <div class="overview-item"><span>Khu vực</span><span>@Model.Ward?.Area?.AreaName</span></div>
                    <div class="overview-item"><span>Loại hình</span><span>@Model.PropertyType?.TypeName</span></div>
                    <div class="overview-item"><span>Giao dịch</span><span>@(isRent ? "Cho thuê" : "Bán")</span></div>
                    <div class="overview-item"><span>Phòng ngủ</span><span>@(bed ?? "N/A")</span></div>
                    <div class="overview-item"><span>Phòng tắm</span><span>@(bath ?? "N/A")</span></div>
                    <div class="overview-item"><span>Hướng nhà</span><span>@(direction ?? "N/A")</span></div>
                    <div class="overview-item"><span>Pháp lý</span><span>@(legal ?? "Đang cập nhật")</span></div>
                    <div class="overview-item"><span>Ngày đăng</span><span>@Model.CreatedAt.ToString("dd/MM/yyyy")</span></div>
                    <div class="overview-item"><span>Lượt xem</span><span>@Model.Views lượt</span></div>
                </div>
            </div>

            <div class="section-card">
                <h4 class="section-title"><i class="bi bi-file-text"></i> Mô tả bất động sản</h4>
                <div class="text-dark" style="line-height: 1.8; font-size: 1.05rem; white-space: pre-wrap;">@Model.Description</div>
            </div>

            <div class="warning-box mb-4 shadow-sm">
                <h6 class="fw-bold text-danger mb-2"><i class="bi bi-shield-exclamation me-2"></i>Cảnh báo an toàn giao dịch:</h6>
                <ul class="mb-0 text-dark small" style="line-height: 1.6;">
                    <li>Không chuyển khoản ngân hàng khi chưa gặp mặt và xác minh rõ ràng.</li>
                    <li>Luôn yêu cầu xem giấy tờ pháp lý bản gốc trước khi tiến hành giao dịch.</li>
                    <li>Hệ thống không chịu trách nhiệm với các nội dung do người dùng tự đăng tải.</li>
                    <li>Phát hiện tin giả, lừa đảo? <a href="#" class="text-danger fw-bold" data-bs-toggle="modal" data-bs-target="#reportModal">Báo cáo ngay</a>.</li>
                </ul>
            </div>

            @if (!string.IsNullOrEmpty(amenities))
            {
                <div class="section-card mt-4">
                    <h4 class="section-title"><i class="bi bi-stars"></i> Tiện ích nổi bật</h4>
                    <div class="d-flex flex-wrap">
                        @foreach (var am in amenities.Split(','))
                        {
                            <span class="amenity-pill"><i class="bi bi-check-circle-fill text-success me-2 fs-5"></i>@am.Trim()</span>
                        }
                    </div>
                </div>
            }

            <div class="section-card p-4 overflow-hidden mt-4">
                <h4 class="section-title"><i class="bi bi-map"></i> Vị trí trên bản đồ</h4>
                <div class="rounded-4 overflow-hidden border">
                    <iframe width="100%" height="350" style="border:0;" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade" src="https://maps.google.com/maps?q=@mapQuery&t=&z=15&ie=UTF8&iwloc=&output=embed"></iframe>
                </div>
            </div>

            <div class="section-card mt-4">
                <h4 class="section-title"><i class="bi bi-chat-text"></i> Bình luận & Đánh giá (@comments.Count())</h4>

                @if (isAuthenticated)
                {
                    <div class="d-flex gap-3 mb-5">
                        <img src="@(User.FindFirst("Avatar")?.Value ?? "/images/avatars/default-user.png")" class="comment-avatar border">
                        <div class="flex-grow-1">
                            <textarea id="commentContent" class="form-control bg-light rounded-4" rows="3" placeholder="Chia sẻ trải nghiệm hoặc nhận xét của bạn về bất động sản này..."></textarea>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Bình luận sẽ được hiển thị sau khi Ban quản trị duyệt.</small>
                                <button type="button" id="btnSubmitComment" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">Gửi bình luận</button>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary border-0 rounded-4 text-center mb-5">
                        Vui lòng <a href="/Account/Login" class="fw-bold text-primary">đăng nhập</a> để tham gia bình luận.
                    </div>
                }

                <div class="comments-list">
                    @if (comments.Any())
                    {
                        foreach (var c in comments)
                        {
                            <div class="comment-item">
                                <img src="@(c.User?.Avatar ?? "/images/avatars/default-user.png")" class="comment-avatar border shadow-sm">
                                <div class="comment-box">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <strong class="text-dark">@c.User?.FullName</strong>
                                        <small class="text-muted">@c.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                    <p class="mb-0 text-secondary" style="white-space:pre-wrap;">@c.Content</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted bg-light rounded-4 border">
                            <i class="bi bi-chat-square-dots fs-1 mb-2 d-block opacity-50"></i>
                            <p class="mb-0">Chưa có bình luận nào. Hãy là người đầu tiên bình luận!</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="contact-card mb-4">
                <div class="text-center border-bottom pb-4 mb-4">
                    <p class="text-muted small fw-bold text-uppercase mb-3">Thông tin liên hệ</p>
                    <img src="@(Model.User?.Avatar ?? "/images/avatars/default-user.png")" alt="Avatar" class="contact-avatar mb-3 shadow-sm">
                    <h4 class="fw-bold text-dark mb-1">@(Model.User?.FullName ?? "Người dùng ẩn danh")</h4>
                    <div class="text-warning small mb-3">
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                        <span class="text-muted ms-1">(Chưa có đánh giá)</span>
                    </div>

                    @if (isAuthenticated)
                    {
                        <div class="phone-box">
                            <button class="btn-call" id="btnRevealPhone">
                                <i class="bi bi-telephone-fill me-2"></i>
                                <span id="phoneText">@(!string.IsNullOrEmpty(Model.User?.Phone) ? Model.User.Phone.Substring(0, 4) + " *** *** (Bấm hiện số)" : "Chưa có SĐT")</span>
                            </button>
                            <button class="btn-copy" id="btnCopyPhone" title="Sao chép số" style="display: none;">
                                <i class="bi bi-copy"></i>
                            </button>
                        </div>

                        <div class="row g-2 mb-3">
                            @if (!string.IsNullOrEmpty(zaloLink))
                            {
                                <div class="col-6"><a href="@zaloLink" target="_blank" class="btn btn-zalo w-100 py-2"><i class="bi bi-chat-dots-fill me-1"></i> Zalo</a></div>
                            }
                            @if (!string.IsNullOrEmpty(fbLink))
                            {
                                <div class="col-6"><a href="@fbLink" target="_blank" class="btn btn-fb w-100 py-2"><i class="bi bi-facebook me-1"></i> Facebook</a></div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="locked-contact mb-3">
                            <div class="locked-content">
                                <div class="phone-box mb-2"><button class="btn-call w-100 py-3"><i class="bi bi-telephone-fill"></i> 0987 *** ***</button></div>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-zalo w-50 py-2"><i class="bi bi-chat-dots-fill"></i> Zalo</button>
                                    <button class="btn btn-fb w-50 py-2"><i class="bi bi-facebook"></i> FB</button>
                                </div>
                            </div>
                            <div class="locked-overlay">
                                <i class="bi bi-lock-fill text-dark fs-2 mb-2"></i>
                                <p class="small fw-bold text-dark mb-2">Thông tin bị ẩn để bảo mật</p>
                                <a href="/Account/Login" class="btn btn-primary btn-sm px-4 rounded-pill fw-bold shadow-sm">Đăng nhập để xem</a>
                            </div>
                        </div>
                    }

                    <button class="btn btn-info text-white w-100 mb-2 py-2 fw-bold shadow-sm rounded-3" data-bs-toggle="modal" data-bs-target="#consultationModal">
                        <i class="bi bi-headset me-2"></i> YÊU CẦU TƯ VẤN MIỄN PHÍ
                    </button>

                    @if (!isOwner)
                    {
                        <button class="btn btn-success w-100 mb-2 py-2 fw-bold shadow-sm rounded-3" data-bs-toggle="modal" data-bs-target="#appointmentModal">
                            <i class="bi bi-calendar-check-fill me-2"></i> ĐẶT LỊCH XEM NHÀ
                        </button>

                        @if (isAuthenticated)
                        {
                            <button class="btn btn-outline-primary w-100 py-2 fw-bold border-2 rounded-3" data-bs-toggle="modal" data-bs-target="#coBrokerModal">
                                <i class="bi bi-person-vcard-fill me-2"></i> XIN NHẬN BÁN HỘ (MÔI GIỚI)
                            </button>
                        }
                    }
                </div>

                <div class="row g-2 mt-3 text-center">
                    <div class="col-4">
                        <button class="btn btn-sm border w-100 fw-bold py-2 @(ViewBag.IsFavorited ? "btn-danger text-white shadow-sm" : "btn-light text-danger")" id="btnSaveFavorite" data-id="@Model.PropertyID">
                            <i class="bi @(ViewBag.IsFavorited ? "bi-heart-fill" : "bi-heart") d-block fs-5 mb-1" id="iconFavorite"></i>
                            <span id="textFavorite">@(ViewBag.IsFavorited ? "Đã lưu" : "Lưu tin")</span>
                        </button>
                    </div>
                    <div class="col-4">
                        <button class="btn btn-sm btn-light border w-100 text-primary fw-bold py-2" onclick="navigator.clipboard.writeText(window.location.href); alert('Đã copy link!');">
                            <i class="bi bi-share d-block fs-5 mb-1"></i> Chia sẻ
                        </button>
                    </div>
                    <div class="col-4">
                        <button class="btn btn-sm btn-light border w-100 text-secondary fw-bold py-2" data-bs-toggle="modal" data-bs-target="#reportModal">
                            <i class="bi bi-flag d-block fs-5 mb-1"></i> Báo cáo
                        </button>
                    </div>
                </div>
            </div>

            @if (similarProps.Any())
            {
                <div class="section-card p-4 mb-4 bg-white">
                    <h5 class="fw-bold mb-3 border-bottom pb-2" style="font-size: 1.1rem;">Bất động sản tương tự</h5>
                    <div class="d-grid gap-3">
                        @foreach (var p in similarProps)
                        {
                            <a href="/Property/Details/@p.PropertyID" class="mini-card text-dark">
                                <img src="@(string.IsNullOrEmpty(p.MainImage) ? "/images/no-image.jpg" : p.MainImage)" onerror="this.src='/images/no-image.jpg'">
                                <div class="p-3">
                                    <h6 class="fw-bold text-truncate mb-1" style="font-size: 0.95rem;">@p.Title</h6>
                                    <div class="text-danger fw-bold mb-1">@(p.Price.HasValue ? (p.Price >= 1000000000 ? (p.Price / 1000000000)?.ToString("0.##") + " Tỷ" : (p.Price / 1000000)?.ToString("0.##") + " Tr") : "Thỏa thuận")</div>
                                    <small class="text-muted fw-medium"><i class="bi bi-geo-alt"></i> @p.Ward?.Area?.AreaName</small>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

