@model IEnumerable<BDSKhanhHoa.Models.Property>
@using System.Linq

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var filters = ViewBag.CurrentFilters;
    string transactionType = filters?.transactionType ?? "buy";
    bool isBuy = transactionType == "buy";

    var currentAmenities = (filters?.amenities as string[]) ?? Array.Empty<string>();

    int totalItems = ViewBag.TotalItems != null ? (int)ViewBag.TotalItems : 0;
    int totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    int currentPage = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;

    string subTypesJson = ViewBag.SubTypesJson ?? "[]";

    decimal priceMinLimit = 0m;
    decimal priceMaxLimit = ViewBag.PriceMaxLimit != null ? Convert.ToDecimal(ViewBag.PriceMaxLimit) : 50000m;
    decimal areaMinLimit = 0m;
    decimal areaMaxLimit = ViewBag.AreaMaxLimit != null ? Convert.ToDecimal(ViewBag.AreaMaxLimit) : 1000m;

    decimal currentMinPrice = filters?.minPrice != null ? Convert.ToDecimal(filters.minPrice) : priceMinLimit;
    decimal currentMaxPrice = filters?.maxPrice != null ? Convert.ToDecimal(filters.maxPrice) : priceMaxLimit;

    decimal currentMinArea = filters?.minSize != null ? Convert.ToDecimal(filters.minSize) : areaMinLimit;
    decimal currentMaxArea = filters?.maxSize != null ? Convert.ToDecimal(filters.maxSize) : areaMaxLimit;

    ViewData["Title"] = transactionType == "rent" ? "Cho thuê Bất động sản Khánh Hòa" : "Mua bán Bất động sản Khánh Hòa";
}

@functions {
    public string FormatRangeLabel(decimal value) => value >= 1000m ? $"{(value / 1000m):0.##} Tỷ" : $"{value:0.##} Triệu";
    public string FormatAreaLabel(decimal value) => $"{value:0.##} m²";
}

<style>
    :root {
        --page-bg: #f6f8fc;
        --surface: #ffffff;
        --border: #e5e7eb;
        --text: #0f172a;
        --muted: #64748b;
        --primary: #2563eb;
        --primary-2: #1d4ed8;
        --danger: #dc2626;
        --shadow-sm: 0 2px 10px rgba(15, 23, 42, 0.05);
        --shadow-md: 0 10px 30px rgba(15, 23, 42, 0.08);
        --shadow-lg: 0 20px 50px rgba(15, 23, 42, 0.12);
        --transition: all .25s cubic-bezier(.4, 0, .2, 1);
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: radial-gradient(circle at top left, rgba(37, 99, 235, 0.06), transparent 28%), radial-gradient(circle at top right, rgba(249, 115, 22, 0.05), transparent 24%), var(--page-bg);
        color: var(--text);
        overflow-x: hidden;
    }

    .page-shell {
        padding: 18px 0 34px;
    }

    .page-layout {
        margin-top: 0;
    }

    /* ---- STICKY SIDEBAR ---- */
    @@media (min-width: 992px) {
        .filter-wrapper {
            position: sticky;
            top: 92px; /* Phụ thuộc vào chiều cao của Navbar trên trang web của bạn */
            z-index: 10;
            height: calc(100vh - 110px);
            overflow-y: auto;
            border-radius: 24px;
        }

            .filter-wrapper::-webkit-scrollbar {
                width: 6px;
            }

            .filter-wrapper::-webkit-scrollbar-thumb {
                background-color: #cbd5e1;
                border-radius: 10px;
            }

        .col-lg-3 {
            align-self: start;
        }
        /* Quan trọng để Sticky hoạt động trong flexbox */
    }

    .filter-card {
        background: rgba(255,255,255,.94);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(229,231,235,.9);
        border-radius: 24px;
        box-shadow: var(--shadow-md);
        overflow: hidden;
    }

    .filter-head {
        padding: 18px 18px 14px;
        border-bottom: 1px solid rgba(229,231,235,.75);
        background: linear-gradient(180deg, rgba(255,255,255,1), rgba(248,250,252,.96));
    }

    .filter-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 900;
        letter-spacing: -.03em;
        color: var(--text);
    }

    .filter-body {
        padding: 18px;
    }

    /* Auto Suggest Dropdown */
    .suggest-box {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 0 0 14px 14px;
        box-shadow: var(--shadow-lg);
        z-index: 50;
        display: none;
        max-height: 250px;
        overflow-y: auto;
    }

    .suggest-item {
        padding: 10px 14px;
        font-size: 0.9rem;
        cursor: pointer;
        border-bottom: 1px solid #f1f5f9;
        transition: background 0.2s;
        color: var(--text);
        font-weight: 600;
    }

        .suggest-item:hover {
            background: #eef2ff;
            color: var(--primary);
        }

        .suggest-item:last-child {
            border-bottom: none;
        }

    /* UI Các bộ lọc khác */
    .segmented-control {
        display: flex;
        gap: 10px;
        background: #eef2ff;
        padding: 6px;
        border-radius: 18px;
        margin-bottom: 18px;
    }

    .segmented-item {
        flex: 1;
        border: 0;
        border-radius: 14px;
        padding: 11px 10px;
        background: transparent;
        color: #475569;
        font-weight: 800;
        transition: var(--transition);
    }

        .segmented-item.active {
            background: linear-gradient(135deg, var(--primary), var(--primary-2));
            color: #fff;
            box-shadow: 0 8px 20px rgba(37, 99, 235, .22);
        }

    .field {
        margin-bottom: 16px;
        position: relative;
    }

        .field label {
            display: block;
            font-size: .92rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 8px;
        }

    .soft-input, .soft-select {
        border-radius: 14px !important;
        border: 1px solid var(--border) !important;
        background: #fbfdff !important;
        padding: 12px 14px !important;
        box-shadow: none !important;
        transition: var(--transition);
    }

        .soft-input:focus, .soft-select:focus {
            border-color: rgba(37, 99, 235, .38) !important;
            box-shadow: 0 0 0 .25rem rgba(37, 99, 235, .10) !important;
            background: #fff !important;
        }

    .range-box {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 14px;
        box-shadow: var(--shadow-sm);
    }

    .range-values {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
        font-size: .86rem;
        color: var(--muted);
        font-weight: 700;
        flex-wrap: wrap;
    }

        .range-values strong {
            color: var(--text);
            font-weight: 900;
        }

    .range-slider {
        position: relative;
        height: 42px;
        margin-top: 4px;
    }

        .range-slider input[type="range"] {
            position: absolute;
            left: 0;
            top: 10px;
            width: 100%;
            height: 22px;
            pointer-events: none;
            appearance: none;
            background: transparent;
            margin: 0;
            padding: 0;
            outline: none;
        }

            .range-slider input[type="range"]::-webkit-slider-runnable-track {
                height: 8px;
                border-radius: 999px;
                background: transparent;
            }

            .range-slider input[type="range"]::-webkit-slider-thumb {
                pointer-events: auto;
                appearance: none;
                width: 22px;
                height: 22px;
                border-radius: 50%;
                background: #fff;
                border: 4px solid var(--primary);
                box-shadow: 0 6px 16px rgba(37, 99, 235, .22);
                cursor: pointer;
                margin-top: -7px;
                position: relative;
                z-index: 2;
            }

    .range-track {
        position: absolute;
        left: 0;
        right: 0;
        top: 17px;
        height: 8px;
        border-radius: 999px;
        background: linear-gradient(90deg, #e2e8f0 0%, #e2e8f0 100%);
        pointer-events: none;
    }

    .pill-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

        .pill-grid .btn-check:checked + .pill-btn {
            background: linear-gradient(135deg, var(--primary), var(--primary-2));
            color: #fff;
            border-color: transparent;
            box-shadow: 0 8px 16px rgba(37, 99, 235, .18);
        }

    .pill-btn {
        border-radius: 999px !important;
        border: 1px solid var(--border);
        background: #fff;
        color: #334155;
        font-weight: 700;
        font-size: .9rem;
        padding: 9px 13px;
        cursor: pointer;
        transition: var(--transition);
    }

        .pill-btn:hover {
            transform: translateY(-1px);
            border-color: rgba(37, 99, 235, .20);
            box-shadow: var(--shadow-sm);
        }

    .amenity-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .amenity-item {
        border: 1px solid var(--border);
        border-radius: 14px;
        background: #fff;
        padding: 10px 12px;
        transition: var(--transition);
        box-shadow: var(--shadow-sm);
    }

        .amenity-item:hover {
            transform: translateY(-1px);
            border-color: rgba(37, 99, 235, .18);
            box-shadow: var(--shadow-md);
        }

    .amenity-label {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0;
        cursor: pointer;
        font-size: .9rem;
        font-weight: 700;
        color: #334155;
        user-select: none;
    }

        .amenity-label input {
            width: 16px;
            height: 16px;
            margin: 0;
            accent-color: var(--primary);
            flex: 0 0 auto;
        }

    .amenity-item.is-checked {
        border-color: rgba(37, 99, 235, .3);
        background: linear-gradient(180deg, rgba(37,99,235,.08), rgba(37,99,235,.03));
        color: var(--primary-2);
    }

    .action-group {
        display: grid;
        gap: 10px;
        margin-top: 18px;
    }

    .action-secondary {
        border-radius: 16px;
        padding: 12px 16px;
        font-weight: 800;
        border: 1px solid var(--border);
        background: #fff;
        color: #475569;
        transition: var(--transition);
    }

        .action-secondary:hover {
            transform: translateY(-1px);
            border-color: rgba(249, 115, 22, .25);
            box-shadow: var(--shadow-sm);
        }

    /* Results UI */
    .results-shell {
        background: transparent;
        position: relative;
        min-height: 500px;
    }

    .results-card {
        background: rgba(255,255,255,.92);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(229,231,235,.9);
        border-radius: 24px;
        box-shadow: var(--shadow-sm);
        padding: 16px;
    }

    .results-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

    .results-title {
        margin: 0;
        font-weight: 900;
        letter-spacing: -.03em;
        color: var(--text);
        font-size: 1.25rem;
    }

    .results-meta {
        color: var(--muted);
        font-size: .95rem;
        margin: 4px 0 0;
    }

    .sort-wrap {
        min-width: 220px;
    }

        .sort-wrap .form-select {
            border-radius: 14px;
            border: 1px solid var(--border);
            padding: 11px 14px;
            font-weight: 700;
            background-color: #fff;
            box-shadow: var(--shadow-sm);
            cursor: pointer;
        }

    /* Loader Overlay */
    #loadingOverlay {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.7);
        z-index: 10;
        display: none;
        align-items: center;
        justify-content: center;
        border-radius: 24px;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 4px solid var(--border);
        border-top-color: var(--primary);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* Property Card UI */
    .property-grid {
        margin-top: 18px;
    }

    .property-card {
        height: 100%;
        border: 1px solid rgba(229,231,235,.9);
        border-radius: 22px;
        overflow: hidden;
        background: #fff;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
        position: relative;
    }

        .property-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg);
            border-color: rgba(37,99,235,.18);
        }

    .property-media {
        position: relative;
        aspect-ratio: 16/10;
        overflow: hidden;
        background: #e2e8f0;
    }

        .property-media img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scale(1.001);
            transition: transform .45s ease;
        }

    .property-card:hover .property-media img {
        transform: scale(1.04);
    }

    .property-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 20%, rgba(15,23,42,.18) 100%);
        pointer-events: none;
    }

    .property-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        z-index: 2;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 100px;
        font-size: .75rem;
        font-weight: 800;
        letter-spacing: .02em;
        text-transform: uppercase;
        box-shadow: var(--shadow-sm);
    }

    .badge-diamond {
        background: linear-gradient(135deg, #00c6ff, #0072ff);
        color: #fff;
        box-shadow: 0 4px 12px rgba(0,114,255,0.3);
    }

    .badge-gold {
        background: linear-gradient(135deg, #f59e0b, #ea580c);
        color: #fff;
        box-shadow: 0 4px 12px rgba(245,158,11,0.3);
    }

    .badge-silver {
        background: linear-gradient(135deg, #cbd5e1, #64748b);
        color: #fff;
    }

    .badge-bronze {
        background: linear-gradient(135deg, #fcd34d, #d97706);
        color: #fff;
    }

    .badge-normal {
        background: rgba(255,255,255,0.95);
        color: #64748b;
        border: 1px solid #e2e8f0;
    }

    .prop-fav {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 34px;
        height: 34px;
        background: rgba(255,255,255,0.95);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        z-index: 5;
        transition: var(--transition);
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

        .prop-fav:hover {
            background: #fff;
            transform: scale(1.1);
        }

        .prop-fav i {
            font-size: 0.9rem;
            color: var(--muted);
        }

        .prop-fav.active i, .prop-fav:hover i {
            color: #dc2626;
        }
    /* Active (Đã lưu) sẽ có tim đỏ */

    .prop-trans-tag {
        position: absolute;
        bottom: 12px;
        right: 12px;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 5px 12px;
        border-radius: 6px;
        z-index: 5;
        color: #fff;
        box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    }

    .tag-buy {
        background: #ea4335;
    }

    .tag-rent {
        background: #3b82f6;
    }

    .property-body {
        padding: 16px;
    }

    .property-price {
        font-size: 1.15rem;
        font-weight: 900;
        color: var(--danger);
        line-height: 1.2;
        margin-bottom: 8px;
    }

    .property-title {
        font-size: 1rem;
        font-weight: 800;
        line-height: 1.4;
        color: var(--text);
        min-height: 44px;
        margin-bottom: 12px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .property-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        padding-top: 12px;
        border-top: 1px solid rgba(229,231,235,.85);
        color: var(--muted);
        font-size: .85rem;
        font-weight: 700;
    }

        .property-meta span {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            min-width: 0;
        }

        .property-meta .text-truncate {
            max-width: 50%;
        }

    .pagination-wrap {
        margin-top: 32px;
    }

    .pagination {
        gap: 8px;
        flex-wrap: wrap;
    }

    .page-item .page-link {
        border: 1px solid var(--border);
        border-radius: 14px !important;
        color: #334155;
        font-weight: 700;
        min-width: 42px;
        text-align: center;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
    }

    .page-item.active .page-link {
        background: linear-gradient(135deg, var(--primary), var(--primary-2));
        color: #fff;
        border-color: transparent;
    }

    .page-item .page-link:hover {
        transform: translateY(-1px);
        border-color: rgba(37,99,235,.22);
        box-shadow: var(--shadow-md);
    }

    .empty-state {
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(229,231,235,.9);
        border-radius: 26px;
        padding: 52px 20px;
        box-shadow: var(--shadow-sm);
    }

        .empty-state img {
            width: 160px;
            max-width: 100%;
            opacity: .7;
            margin-bottom: 16px;
        }

    /* Dự án nổi bật */
    .project-card {
        border-radius: var(--r-lg);
        overflow: hidden;
        background: var(--surface);
        box-shadow: var(--shadow-md);
        transition: var(--transition);
        text-decoration: none;
        display: block;
        border: 1px solid var(--border);
    }

        .project-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

    .project-img-wrap {
        position: relative;
        height: 180px;
        overflow: hidden;
    }

        .project-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

    .project-card:hover .project-img-wrap img {
        transform: scale(1.05);
    }

    .project-body {
        padding: 16px;
    }

    .project-investor {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .project-name {
        font-family: 'Playfair Display',serif;
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 8px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .project-loc {
        font-size: 0.85rem;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
    }

    @@media (max-width: 991.98px) {
        .page-shell {
            padding-top: 12px;
        }

        .results-card {
            padding: 14px;
        }

        .property-meta .text-truncate {
            max-width: 55%;
        }

        .amenity-list {
            grid-template-columns: 1fr;
        }

        .sort-wrap {
            width: 100%;
        }
    }
</style>

<div class="container page-shell">
    <div class="row g-4 page-layout">

        <!-- Khối Offcanvas bộ lọc -->
        <div class="col-lg-3">
            <div class="filter-wrapper">
                <div class="offcanvas-lg offcanvas-start" tabindex="-1" id="filterPanel" aria-labelledby="filterPanelLabel">
                    <div class="offcanvas-header d-lg-none border-bottom">
                        <h5 class="offcanvas-title fw-bold" id="filterPanelLabel"><i class="bi bi-sliders2 text-primary me-2"></i>Bộ lọc tìm kiếm</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#filterPanel" aria-label="Close"></button>
                    </div>

                    <div class="offcanvas-body p-0">
                        <div class="filter-card">
                            <div class="filter-head d-none d-lg-block">
                                <h3 class="filter-title"><i class="bi bi-sliders2 text-primary me-2"></i>Bộ lọc nâng cao</h3>
                                <div class="text-muted small mt-1">Lọc tự động không cần load lại trang</div>
                            </div>

                            <div class="filter-body">
                                <form id="filterForm" action="/Property/Search" method="get" onsubmit="event.preventDefault(); triggerFilter();">
                                    <input type="hidden" name="transactionType" id="transTypeInput" value="@transactionType" />
                                    <input type="hidden" name="page" id="pageInput" value="@currentPage" />
                                    <input type="hidden" name="sortOrder" id="sortInput" value="@(filters?.sortOrder ?? "")" />

                                    <div class="segmented-control">
                                        <button type="button" class="segmented-item @(isBuy ? "active" : "")" data-trans="buy">
                                            <i class="bi bi-house me-1"></i>Mua bán
                                        </button>
                                        <button type="button" class="segmented-item @(!isBuy ? "active" : "")" data-trans="rent">
                                            <i class="bi bi-key me-1"></i>Cho thuê
                                        </button>
                                    </div>

                                    <div class="field">
                                        <label for="keywordInput">Từ khóa</label>
                                        <input type="text" id="keywordInput" name="keyword" class="form-control soft-input" placeholder="Tiêu đề, địa chỉ, dự án..." value="@(filters?.keyword ?? "")" autocomplete="off" />
                                        <div id="suggestBox" class="suggest-box"></div>
                                    </div>

                                    <div class="field">
                                        <label for="subTypeSelect">Loại bất động sản</label>
                                        <select name="typeId" id="subTypeSelect" class="form-select soft-select">
                                            <option value="">Tất cả loại hình</option>
                                        </select>
                                    </div>

                                    <div class="field">
                                        <label for="areaSelect">Khu vực</label>
                                        <select name="areaId" id="areaSelect" class="form-select soft-select">
                                            <option value="">Toàn tỉnh Khánh Hòa</option>
                                            @foreach (var a in ViewBag.Areas)
                                            {
                                                <option value="@a.AreaID" selected="@(filters?.areaId != null && Convert.ToString(filters.areaId) == Convert.ToString(a.AreaID) ? "selected" : null)">@a.AreaName</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="field">
                                        <label for="wardSelect">Phường / Xã</label>
                                        <select name="wardId" id="wardSelect" class="form-select soft-select">
                                            <option value="">Tất cả Phường / Xã</option>
                                            @if (filters?.wardId != null)
                                            {
                                                <option value="@filters.wardId" selected>Đang chọn</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="field">
                                        <label>Mức giá</label>
                                        <div class="range-box">
                                            <div class="range-values">
                                                <span>Từ: <strong id="priceMinLabel">@FormatRangeLabel(currentMinPrice)</strong></span>
                                                <span>Đến: <strong id="priceMaxLabel">@FormatRangeLabel(currentMaxPrice)</strong></span>
                                            </div>
                                            <div class="range-slider">
                                                <input type="range" id="priceMinRange" name="minPrice" min="@priceMinLimit" max="@priceMaxLimit" step="10" value="@currentMinPrice" />
                                                <input type="range" id="priceMaxRange" name="maxPrice" min="@priceMinLimit" max="@priceMaxLimit" step="10" value="@currentMaxPrice" />
                                                <div class="range-track" id="priceTrack"></div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="field">
                                        <label>Diện tích (m²)</label>
                                        <div class="range-box">
                                            <div class="range-values">
                                                <span>Từ: <strong id="areaMinLabel">@FormatAreaLabel(currentMinArea)</strong></span>
                                                <span>Đến: <strong id="areaMaxLabel">@FormatAreaLabel(currentMaxArea)</strong></span>
                                            </div>
                                            <div class="range-slider">
                                                <input type="range" id="areaMinRange" name="minSize" min="@areaMinLimit" max="@areaMaxLimit" step="1" value="@currentMinArea" />
                                                <input type="range" id="areaMaxRange" name="maxSize" min="@areaMinLimit" max="@areaMaxLimit" step="1" value="@currentMaxArea" />
                                                <div class="range-track" id="areaTrack"></div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="field">
                                        <label>Phòng ngủ</label>
                                        <div class="pill-grid">
                                            @foreach (var n in new[] { "1", "2", "3", "4", "5" })
                                            {
                                                var checkedBedroom = filters?.bedrooms != null && Convert.ToString(filters.bedrooms) == n;
                                                <div>
                                                    <input class="btn-check" type="radio" name="bedrooms" id="bed_@n" value="@n" @(checkedBedroom ? "checked" : "") />
                                                    <label class="pill-btn" for="bed_@n">@(n == "5" ? "5+" : n)</label>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <div class="field">
                                        <label>Phòng tắm</label>
                                        <div class="pill-grid">
                                            @foreach (var n in new[] { "1", "2", "3", "4" })
                                            {
                                                var checkedBathroom = filters?.bathrooms != null && Convert.ToString(filters.bathrooms) == n;
                                                <div>
                                                    <input class="btn-check" type="radio" name="bathrooms" id="bath_@n" value="@n" @(checkedBathroom ? "checked" : "") />
                                                    <label class="pill-btn" for="bath_@n">@(n == "4" ? "4+" : n)</label>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <div class="field">
                                        <label for="directionSelect">Hướng nhà</label>
                                        <select name="direction" id="directionSelect" class="form-select soft-select">
                                            <option value="">Tất cả hướng</option>
                                            @foreach (var direction in new[] { "Đông", "Đông Nam", "Nam", "Tây Nam", "Tây", "Tây Bắc", "Bắc", "Đông Bắc" })
                                            {
                                                <option value="@direction" selected="@(filters?.direction != null && Convert.ToString(filters.direction) == direction ? "selected" : null)">@direction</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="field">
                                        <label for="legalStatusSelect">Pháp lý</label>
                                        <select name="legalStatus" id="legalStatusSelect" class="form-select soft-select">
                                            <option value="">Tất cả</option>
                                            @foreach (var legal in new[] { "Sổ hồng", "Sổ đỏ", "Giấy tờ hợp lệ", "Hợp đồng mua bán" })
                                            {
                                                <option value="@legal" selected="@(filters?.legalStatus != null && Convert.ToString(filters.legalStatus) == legal ? "selected" : null)">@legal</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="field">
                                        <label>Tiện ích (Bắt buộc thỏa mãn tất cả ô được chọn)</label>
                                        <ul class="amenity-list">
                                            @foreach (var am in new[] { "Gần chợ", "Gần trường học", "Gần bệnh viện", "Có thang máy", "Hồ bơi", "Gym", "An ninh 24/7", "Ban công", "Bãi đỗ xe", "Sân vườn", "Công viên", "Siêu thị" })
                                            {
                                                var checkedAmenity = currentAmenities.Contains(am);
                                                <li class="amenity-item @(checkedAmenity ? "is-checked" : "")">
                                                    <label class="amenity-label">
                                                        <input type="checkbox" name="amenities" value="@am" @(checkedAmenity ? "checked" : "") />
                                                        <span>@am</span>
                                                    </label>
                                                </li>
                                            }
                                        </ul>
                                    </div>

                                    <div class="action-group">
                                        <button type="button" onclick="resetFilters()" class="action-secondary text-center text-decoration-none"><i class="bi bi-arrow-counterclockwise me-2"></i>Xóa bộ lọc</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Khối kết quả -->
        <div class="col-lg-9 results-shell">

            <!-- NÚT MỞ BỘ LỌC DÀNH CHO MOBILE RẤT TO VÀ HIỆN ĐẠI -->
            <div class="d-lg-none mb-3">
                <button class="btn w-100 fw-bold py-3 d-flex align-items-center justify-content-center gap-2"
                        style="background: linear-gradient(135deg, var(--primary), var(--primary-2)); color: #fff; border-radius: 16px; box-shadow: 0 8px 20px rgba(37, 99, 235, 0.2);"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#filterPanel"
                        aria-controls="filterPanel">
                    <i class="bi bi-sliders2 fs-5"></i>
                    <span style="font-size: 1.05rem;">Mở Bộ Lọc Nâng Cao</span>
                </button>
            </div>

        

            <div class="results-card">
                <div id="loadingOverlay">
                    <div class="spinner"></div>
                </div>

                <div class="results-top">
                    <div>
                        <h2 class="results-title">@ViewData["Title"]</h2>
                        <p class="results-meta mb-0">
                            Đang hiển thị <strong class="text-primary" id="totalItemsCountUI">@totalItems</strong> kết quả phù hợp.
                        </p>
                    </div>

                    <div class="d-flex align-items-center gap-2 flex-wrap w-100-mobile">
                        <div class="sort-wrap">
                            <label class="form-label fw-bold text-secondary mb-2 d-none d-md-block" style="font-size:0.85rem">Sắp xếp theo</label>
                            <select id="sortSelect" class="form-select text-dark">
                                <option value="" selected="@(string.IsNullOrEmpty(filters?.sortOrder) ? "selected" : null)">Tin Mới nhất (VIP ưu tiên)</option>
                                <option value="price_asc" selected="@(Convert.ToString(filters?.sortOrder) == "price_asc" ? "selected" : null)">Giá Tăng dần (VIP ưu tiên)</option>
                                <option value="price_desc" selected="@(Convert.ToString(filters?.sortOrder) == "price_desc" ? "selected" : null)">Giá Giảm dần (VIP ưu tiên)</option>
                                <option value="area_desc" selected="@(Convert.ToString(filters?.sortOrder) == "area_desc" ? "selected" : null)">Diện tích lớn nhất (VIP ưu tiên)</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Khu vực Partial View sẽ được Render thay thế bằng AJAX -->
                <div id="partialRenderArea">
                    <partial name="_PropertyGridPartial" model="Model" />
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const subTypesData = @Html.Raw(string.IsNullOrWhiteSpace(subTypesJson) ? "[]" : subTypesJson);
        const initialTransaction = '@transactionType';
        const initialTypeId = '@(filters?.typeId ?? "")';
        const initialAreaId = '@(filters?.areaId ?? "")';
        const initialWardId = '@(filters?.wardId ?? "")';

        const filterForm = document.getElementById('filterForm');
        const transTypeInput = document.getElementById('transTypeInput');
        const pageInput = document.getElementById('pageInput');
        const sortInput = document.getElementById('sortInput');

        const subTypeSelect = document.getElementById('subTypeSelect');
        const areaSelect = document.getElementById('areaSelect');
        const wardSelect = document.getElementById('wardSelect');
        const sortSelect = document.getElementById('sortSelect');

        // =====================================
        // LOGIC LƯU TIN (TRÁI TIM) - BẰNG AJAX
        // =====================================
        async function toggleFav(propertyId, btnElement) {
            try {
                const response = await fetch('/Home/ToggleFavorite', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `propertyId=${propertyId}`
                });

                const result = await response.json();

                if (result.success) {
                    const icon = btnElement.querySelector('i');
                    if (result.isSaved) {
                        btnElement.classList.add('active');
                        Swal.fire({ icon: 'success', title: 'Đã lưu', text: 'Bất động sản đã được lưu vào danh sách yêu thích!', timer: 1500, showConfirmButton: false, toast: true, position: 'top-end' });
                    } else {
                        btnElement.classList.remove('active');
                        Swal.fire({ icon: 'info', title: 'Đã bỏ lưu', text: 'Đã xóa khỏi danh sách yêu thích.', timer: 1500, showConfirmButton: false, toast: true, position: 'top-end' });
                    }
                } else {
                    Swal.fire({ icon: 'warning', title: 'Chưa đăng nhập', text: result.message, showConfirmButton: true, confirmButtonText: 'Đăng nhập ngay' }).then((res) => {
                        if(res.isConfirmed) { window.location.href = '/Account/Login'; }
                    });
                }
            } catch (error) {
                console.error("Lỗi khi lưu tin:", error);
            }
        }

        // =====================================
        // LOGIC LỌC TỰ ĐỘNG KHÔNG CẦN NÚT (AJAX)
        // =====================================
        let filterTimeout;
        function triggerFilter() {
            clearTimeout(filterTimeout);
            filterTimeout = setTimeout(async () => {
                const overlay = document.getElementById('loadingOverlay');
                if(overlay) overlay.style.display = 'flex'; // Hiện spinner

                const formData = new FormData(filterForm);
                const params = new URLSearchParams(formData);
                // Bắt buộc đẩy giá trị Sort đang chọn vào request
                params.set('sortOrder', sortSelect.value);

                const url = '/Property/Search?' + params.toString();
                history.pushState(null, '', url); // Cập nhật URL trên thanh địa chỉ

                try {
                    const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    const html = await response.text();

                    // Đổ HTML Partial lấy được vào vùng chứa
                    document.getElementById('partialRenderArea').innerHTML = html;

                    // Cập nhật con số đếm kết quả ở phía trên
                    const newTotalElement = document.getElementById('hiddenTotalCount');
                    if(newTotalElement) {
                        document.getElementById('totalItemsCountUI').innerText = newTotalElement.innerText;
                    }
                } catch (e) {
                    console.error("Lỗi filter: ", e);
                } finally {
                    if(overlay) overlay.style.display = 'none'; // Tắt spinner
                }
            }, 600); // Đợi 600ms user ngừng thao tác mới gửi Request (Chống giật lag)
        }

        // Gắn sự kiện Change/Input cho toàn bộ Form
        filterForm.querySelectorAll('input, select').forEach(el => {
            if(el.type === 'text' || el.type === 'range') {
                el.addEventListener('input', triggerFilter); // Kéo slider / Gõ text
            } else {
                el.addEventListener('change', triggerFilter); // Checkbox / Dropdown
            }
        });

        if (sortSelect) {
            sortSelect.addEventListener('change', () => {
                pageInput.value = 1; // Sắp xếp lại thì quay về trang 1
                triggerFilter();
            });
        }

        // Checkbox đổi màu UI
        document.querySelectorAll('.amenity-item input[type="checkbox"]').forEach(cb => {
            cb.addEventListener('change', function() {
                this.closest('.amenity-item').classList.toggle('is-checked', this.checked);
            });
        });

        function submitPage(pageNum) {
            pageInput.value = pageNum;
            triggerFilter();
            window.scrollTo({ top: 200, behavior: 'smooth' }); // Tự cuộn lên đầu danh sách
        }

        function resetFilters() {
            window.location.href = '/Property/Search?transactionType=' + transTypeInput.value;
        }

        // =====================================
        // AUTO SUGGESTION BOX (TÌM KIẾM ĐỀ XUẤT)
        // =====================================
        const keywordInput = document.getElementById('keywordInput');
        const suggestBox = document.getElementById('suggestBox');

        keywordInput.addEventListener('input', async function() {
            const kw = this.value.trim();
            if(kw.length < 2) { suggestBox.style.display = 'none'; return; }

            try {
                const res = await fetch(`/Property/Suggest?keyword=${encodeURIComponent(kw)}`);
                const data = await res.json();

                if(data && data.length > 0) {
                    suggestBox.innerHTML = data.map(d => `<div class="suggest-item" onclick="selectSuggest(this)">${d}</div>`).join('');
                    suggestBox.style.display = 'block';
                } else {
                    suggestBox.style.display = 'none';
                }
            } catch(e) {}
        });

        // Ẩn Suggest Box khi click ra ngoài
        document.addEventListener('click', function(e) {
            if (e.target !== keywordInput && e.target !== suggestBox) {
                suggestBox.style.display = 'none';
            }
        });

        function selectSuggest(el) {
            keywordInput.value = el.innerText;
            suggestBox.style.display = 'none';
            triggerFilter();
        }

        // =====================================
        // LOGIC RANGE SLIDER & UI CƠ BẢN
        // =====================================
        function syncSliderUI(minRange, maxRange, minLabel, maxLabel, trackEl, limitMin, limitMax, formatter) {
            let minVal = parseFloat(minRange.value);
            let maxVal = parseFloat(maxRange.value);

            if (minVal > maxVal) {
                let temp = minVal;
                minVal = maxVal;
                maxVal = temp;
                minRange.value = minVal;
                maxRange.value = maxVal;
            }

            minLabel.innerText = formatter(minVal);
            maxLabel.innerText = formatter(maxVal);

            let percent1 = ((minVal - limitMin) / (limitMax - limitMin)) * 100;
            let percent2 = ((maxVal - limitMin) / (limitMax - limitMin)) * 100;
            trackEl.style.background = `linear-gradient(to right, #e2e8f0 ${percent1}% , var(--primary) ${percent1}% , var(--primary) ${percent2}%, #e2e8f0 ${percent2}%)`;
        }

        function initDualSlider(prefix, limitMin, limitMax, formatter) {
            const minRange = document.getElementById(`${prefix}MinRange`);
            const maxRange = document.getElementById(`${prefix}MaxRange`);
            const minLabel = document.getElementById(`${prefix}MinLabel`);
            const maxLabel = document.getElementById(`${prefix}MaxLabel`);
            const trackEl = document.getElementById(`${prefix}Track`);

            if(!minRange) return;

            const update = () => syncSliderUI(minRange, maxRange, minLabel, maxLabel, trackEl, limitMin, limitMax, formatter);
            minRange.addEventListener("input", update);
            maxRange.addEventListener("input", update);
            update();
        }

        function formatMoneyLabel(val) { return val >= 1000 ? `${(val / 1000).toFixed(2).replace(/\.?0+$/, '')} Tỷ` : `${val} Triệu`; }
        function formatAreaLabel(val) { return `${val} m²`; }

        function renderSubTypes(transactionType, selectedTypeId) {
            const parentId = transactionType === 'buy' ? 1 : 2;
            const list = subTypesData.filter(x => String(x.ParentID) === String(parentId));

            subTypeSelect.innerHTML = '<option value="">Tất cả loại hình</option>';
            list.forEach(x => {
                const opt = document.createElement('option');
                opt.value = x.TypeID;
                opt.textContent = x.TypeName;
                if (String(x.TypeID) === String(selectedTypeId)) opt.selected = true;
                subTypeSelect.appendChild(opt);
            });
        }

        async function loadWards(areaId, selectedWardId) {
            wardSelect.innerHTML = '<option value="">Đang tải...</option>';
            if (!areaId) {
                wardSelect.innerHTML = '<option value="">Tất cả Phường / Xã</option>';
                return;
            }
            try {
                const response = await fetch(`/Home/GetWardsByArea?areaId=${encodeURIComponent(areaId)}`);
                const data = await response.json();
                wardSelect.innerHTML = '<option value="">Tất cả Phường / Xã</option>';
                data.forEach(w => {
                    const opt = document.createElement('option');
                    opt.value = w.wardId;
                    opt.textContent = w.wardName;
                    if (String(w.wardId) === String(selectedWardId)) opt.selected = true;
                    wardSelect.appendChild(opt);
                });
            } catch (error) { wardSelect.innerHTML = '<option value="">Lỗi tải phường/xã</option>'; }
        }

        function setTransaction(type) {
            transTypeInput.value = type;
            pageInput.value = 1;
            document.querySelectorAll('[data-trans]').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.trans === type);
            });
            renderSubTypes(type, subTypeSelect.value || initialTypeId);
            triggerFilter();
        }

        document.querySelectorAll('[data-trans]').forEach(btn => {
            btn.addEventListener('click', function () { setTransaction(this.dataset.trans); });
        });

        areaSelect.addEventListener('change', async function () {
            pageInput.value = 1;
            await loadWards(this.value, '');
        });

        document.addEventListener('DOMContentLoaded', async function () {
            renderSubTypes(initialTransaction, initialTypeId);
            await loadWards(initialAreaId, initialWardId);

            initDualSlider('price', @priceMinLimit, @priceMaxLimit, formatMoneyLabel);
            initDualSlider('area', @areaMinLimit, @areaMaxLimit, formatAreaLabel);
        });
    </script>
}