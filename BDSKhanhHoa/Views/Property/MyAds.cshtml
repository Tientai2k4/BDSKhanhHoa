@model IEnumerable<BDSKhanhHoa.Models.Property>
@{
    ViewData["Title"] = "Quản lý tin đăng của tôi";
    Layout = "~/Views/Shared/_UserLayout.cshtml"; // Sử dụng Layout chuyên dụng cho Member
}

<div class="card-custom p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold mb-0">Danh sách bất động sản (@Model.Count())</h5>
        <a href="/Property/Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Đăng tin mới
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light text-secondary">
                <tr>
                    <th scope="col">Hình ảnh</th>
                    <th scope="col" width="30%">Tiêu đề</th>
                    <th scope="col">Giá</th>
                    <th scope="col">Trạng thái</th>
                    <th scope="col">Ngày đăng</th>
                    <th scope="col" class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-clipboard-x fs-1 d-block mb-3"></i>
                            Bạn chưa có tin đăng nào. <a href="/Property/Create">Đăng tin ngay!</a>
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@item.MainImage" class="rounded" style="width: 80px; height: 60px; object-fit: cover;" />
                        </td>
                        <td>
                            <p class="mb-1 fw-bold text-dark text-truncate" style="max-width: 250px;" title="@item.Title">@item.Title</p>
                            <small class="text-muted"><i class="bi bi-tag-fill me-1"></i>@item.PropertyType?.TypeName</small>
                        </td>
                        <td class="text-danger fw-bold">@(item.Price.HasValue? item.Price.Value.ToString("N0") + " VNĐ" : "Thỏa thuận")</td>
                        <td>
                            @if (item.Status == "Approved")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">Đang hiển thị</span>
                            }
                            else if (item.Status == "Pending")
                            {

                                <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill">Chờ duyệt</span>
                            }
                            else if (item.Status == "Rejected")
                            {

                                <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill">Bị từ chối</span>
                            }
                            else
                            {

                                <span class="badge bg-secondary px-3 py-2 rounded-pill">@item.Status</span>
                            }
                        </td>
                        <td class="text-muted small">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <a href="/Property/Edit/@item.PropertyID" class="btn btn-sm btn-light border text-primary" title="Sửa">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a href="#" class="btn btn-sm btn-light border text-danger" title="Xóa">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>