@model IEnumerable<BDSKhanhHoa.Models.Property>
@{
    ViewData["Title"] = "Quản lý tin đăng của tôi";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    /* Bảng màu Gradient cho các gói VIP */
    .badge-diamond {
        background: linear-gradient(135deg, #00c6ff 0%, #0072ff 100%);
        color: white;
        border: none;
    }

    .badge-gold {
        background: linear-gradient(135deg, #F6D365 0%, #FDA085 100%);
        color: white;
        border: none;
    }

    .badge-silver {
        background: linear-gradient(135deg, #e2e2e2 0%, #9ca3af 100%);
        color: #1f2937;
        border: none;
    }

    .badge-normal {
        background: #f8fafc;
        color: #64748b;
        border: 1px solid #cbd5e1;
    }

    /* CSS Tối ưu hiển thị Mobile (Biến Table thành Card trên màn hình nhỏ) */
    @@media (max-width: 767.98px) {
        .mobile-card-table thead {
            display: none;
        }

        .mobile-card-table tbody tr {
            display: block;
            margin-bottom: 1.2rem;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 1.2rem;
            background: #fff;
            box-shadow: 0 8px 20px rgba(0,0,0,0.04);
        }

        .mobile-card-table tbody td {
            display: block;
            border: none;
            padding: 0.5rem 0;
            text-align: left !important;
        }

            .mobile-card-table tbody td:not(:last-child) {
                border-bottom: 1px dashed #f1f5f9;
            }

        .mobile-action-bar {
            margin-top: 0.5rem;
            padding-top: 0.8rem;
            border-top: 1px solid #f1f5f9 !important;
            justify-content: flex-start !important;
        }

        .property-img-mobile {
            width: 80px !important;
            height: 80px !important;
            border-radius: 12px !important;
        }
    }

    /* Hiệu ứng nút bấm & Ảnh */
    .btn-action-icon {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: all 0.2s ease-in-out;
    }

        .btn-action-icon:hover {
            transform: translateY(-2px);
        }

    .property-thumb {
        width: 120px;
        height: 90px;
        object-fit: cover;
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
</style>

<div class="card-custom p-4 shadow-sm border-0 rounded-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3 flex-wrap gap-3">
        <div>
            <h4 class="fw-bold mb-1 text-primary"><i class="bi bi-list-task me-2"></i>TIN ĐĂNG CỦA BẠN</h4>
            <p class="text-muted small mb-0">Quản lý kho lưu trữ, gói tin và trạng thái giao dịch bất động sản.</p>
        </div>
        <a href="/Property/Create" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-bold">
            <i class="bi bi-plus-lg me-1"></i> Đăng tin mới
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mobile-card-table">
            <thead class="table-light text-secondary">
                <tr>
                    <th scope="col" style="width: 40%;">Thông tin Bất động sản</th>
                    <th scope="col" style="width: 22%;">Gói hiển thị & Mức giá</th>
                    <th scope="col" class="text-center" style="width: 15%;">Trạng thái</th>
                    <th scope="col" class="text-center" style="width: 23%;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted bg-light rounded-3">
                            <i class="bi bi-clipboard-x display-4 d-block mb-3 opacity-50"></i>
                            <h6 class="fw-bold">Bạn chưa có tin đăng nào trên hệ thống.</h6>
                            <a href="/Property/Create" class="btn btn-outline-primary mt-2 rounded-pill px-4">Đăng tin ngay!</a>
                        </td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    // Logic nhận diện Bán hay Cho Thuê
                    bool isSale = item.PropertyType != null && (item.PropertyType.ParentID == 1 || item.PropertyType.TypeName.Contains("Bán", StringComparison.OrdinalIgnoreCase));
                    bool isRent = item.PropertyType != null && (item.PropertyType.ParentID == 2 || item.PropertyType.TypeName.Contains("Thuê", StringComparison.OrdinalIgnoreCase));

                    <tr>
                        <!-- Cột 1: Thông tin cơ bản -->
                        <td>
                            <div class="d-flex align-items-start gap-3">
                                <img src="@(string.IsNullOrEmpty(item.MainImage) ? "/images/no-image.jpg" : item.MainImage)" class="property-thumb property-img-mobile flex-shrink-0" onerror="this.src='/images/no-image.jpg'">
                                <div>
                                    <span class="text-muted small fw-bold d-block mb-1">Mã tin: #@item.PropertyID</span>
                                    <a href="/Property/Details/@item.PropertyID" target="_blank" class="fw-bold text-dark text-decoration-none d-block" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-size: 1.05rem;" title="@item.Title">
                                        @item.Title
                                    </a>
                                    <div class="small text-muted mt-2"><i class="bi bi-clock me-1"></i> Đăng lúc: @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>

                                    @if (item.Status == "Rejected" && !string.IsNullOrEmpty(item.RejectionReason))
                                    {
                                        <div class="mt-2 p-2 bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded-3 text-danger small fw-medium">
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i> <strong>Lý do từ chối:</strong> @item.RejectionReason
                                        </div>
                                    }
                                </div>
                            </div>
                        </td>

                        <!-- Cột 2: Phân loại, VIP và Giá -->
                        <td>
                            <div class="mb-2">
                                @{
                                    string pkgName = item.PostServicePackage?.PackageName ?? "Tin Thường";
                                    string badgeClass = "badge-normal";
                                    string iconClass = "bi-tag";

                                    if (pkgName.Contains("Kim Cương", StringComparison.OrdinalIgnoreCase))
                                    {
                                        badgeClass = "badge-diamond shadow-sm";
                                        iconClass = "bi-gem";
                                    }
                                    else if (pkgName.Contains("Vàng", StringComparison.OrdinalIgnoreCase) || pkgName.Contains("Gold", StringComparison.OrdinalIgnoreCase))
                                    {
                                        badgeClass = "badge-gold shadow-sm";
                                        iconClass = "bi-star-fill";
                                    }
                                    else if (pkgName.Contains("Bạc", StringComparison.OrdinalIgnoreCase) || pkgName.Contains("Silver", StringComparison.OrdinalIgnoreCase))
                                    {
                                        badgeClass = "badge-silver shadow-sm";
                                        iconClass = "bi-award-fill";
                                    }
                                }
                                <span class="badge @badgeClass px-2 py-1 fs-7"><i class="bi @iconClass me-1"></i>@pkgName</span>
                            </div>
                            <span class="badge bg-light text-secondary border border-secondary-subtle mb-2">@(item.PropertyType?.TypeName ?? "Chưa phân loại")</span>
                            <div class="text-danger fw-bold fs-5">
                                @(item.Price.HasValue ? (item.Price.Value >= 1000000000 ? (item.Price.Value / 1000000000).ToString("0.##") + " Tỷ" : (item.Price.Value / 1000000).ToString("0.##") + " Tr") : "Thỏa thuận")
                            </div>
                        </td>

                        <!-- Cột 3: Trạng thái -->
                        <td class="text-md-center">
                            @if (item.Status == "Approved")
                            {
                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-bold"><i class="bi bi-eye-fill me-1"></i> Đang hiển thị</span>
                            }
                            else if (item.Status == "Pending")
                            {
                                <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill fw-bold"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt</span>
                            }
                            else if (item.Status == "Rejected")
                            {
                                <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill fw-bold"><i class="bi bi-x-circle-fill me-1"></i> Bị từ chối</span>
                            }
                            else if (item.Status == "Sold")
                            {
                                <span class="badge bg-primary text-white px-3 py-2 rounded-pill fw-bold"><i class="bi bi-bag-check-fill me-1"></i> Đã bán</span>
                                <div class="small text-muted mt-1 text-md-center">@item.SoldAt?.ToString("dd/MM/yyyy")</div>
                            }
                            else if (item.Status == "Rented")
                            {
                                <span class="badge bg-info text-white px-3 py-2 rounded-pill fw-bold"><i class="bi bi-key-fill me-1"></i> Đã cho thuê</span>
                                <div class="small text-muted mt-1 text-md-center">@item.SoldAt?.ToString("dd/MM/yyyy")</div>
                            }
                        </td>

                        <!-- Cột 4: Thao tác -->
                        <td class="text-md-center border-0 mobile-action-bar">
                            <div class="d-flex flex-wrap align-items-center gap-2 justify-content-md-center justify-content-start">

                                <a href="/Property/Details/@item.PropertyID" target="_blank" class="btn btn-outline-info btn-action-icon shadow-sm" title="Xem trang đích">
                                    <i class="bi bi-eye-fill"></i>
                                </a>

                                <a href="/Property/Edit/@item.PropertyID" class="btn btn-outline-primary btn-action-icon shadow-sm" title="Chỉnh sửa / Nâng cấp tin">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                @if (item.Status == "Approved")
                                {
                                    @if (isSale || (!isSale && !isRent))
                                    {
                                        <form action="/Property/MarkAsTransacted" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.PropertyID" />
                                            <input type="hidden" name="transactionStatus" value="Sold" />
                                            <button type="submit" class="btn btn-success fw-bold shadow-sm" style="border-radius: 10px; height: 36px; display: inline-flex; align-items: center;" onclick="return confirm('Xác nhận: Bất động sản này ĐÃ BÁN thành công? Việc này không thể hoàn tác.');">
                                                <i class="bi bi-bag-check-fill"></i>
                                            </button>
                                        </form>
                                    }

                                    @if (isRent || (!isSale && !isRent))
                                    {
                                        <form action="/Property/MarkAsTransacted" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.PropertyID" />
                                            <input type="hidden" name="transactionStatus" value="Rented" />
                                            <button type="submit" class="btn btn-info text-white fw-bold shadow-sm" style="border-radius: 10px; height: 36px; display: inline-flex; align-items: center;" onclick="return confirm('Xác nhận: Bất động sản này ĐÃ CHO THUÊ thành công? Việc này không thể hoàn tác.');">
                                                <i class="bi bi-key-fill"></i>
                                            </button>
                                        </form>
                                    }
                                }

                                <button type="button" class="btn btn-outline-danger btn-action-icon shadow-sm" onclick="confirmDelete(@item.PropertyID)" title="Xóa vĩnh viễn tin đăng">
                                    <i class="bi bi-trash3-fill"></i>
                                </button>
                                <form id="deleteForm-@item.PropertyID" action="/Property/DeleteMyAd" method="post" class="d-none">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.PropertyID" />
                                </form>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Kích hoạt Bootstrap tooltips cho các icon (Đảm bảo người dùng biết icon đó là gì khi rê chuột)
        document.addEventListener("DOMContentLoaded", function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[title]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })
        });

        function confirmDelete(id) {
            Swal.fire({
                title: 'Bạn chắc chắn muốn xóa?',
                text: "Tin đăng này sẽ bị gỡ khỏi hệ thống và không thể khôi phục!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Đồng ý xóa!',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteForm-' + id).submit();
                }
            });
        }

        @if (TempData["Success"] != null)
        {
                <text>
                Swal.fire({ icon: 'success', title: 'Thành công', text: '@Html.Raw(TempData["Success"])', timer: 3500, showConfirmButton: false, toast: true, position: 'top-end' });
                </text>
        }
        @if (TempData["Error"] != null)
        {
                <text>
                Swal.fire({ icon: 'error', title: 'Lỗi', text: '@Html.Raw(TempData["Error"])', timer: 4500, showConfirmButton: false, toast: true, position: 'top-end' });
                </text>
        }
    </script>
}