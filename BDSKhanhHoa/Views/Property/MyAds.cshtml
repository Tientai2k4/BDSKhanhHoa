@model IEnumerable<BDSKhanhHoa.Models.Property>
@{
    ViewData["Title"] = "Quản lý tin đăng của tôi";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="card-custom p-4 shadow-sm border-0 rounded-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h4 class="fw-bold mb-1 text-primary"><i class="bi bi-list-task me-2"></i>TIN ĐĂNG CỦA BẠN</h4>
            <p class="text-muted small mb-0">Quản lý kho lưu trữ bất động sản bạn đã đăng tải.</p>
        </div>
        <a href="/Property/Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
            <i class="bi bi-plus-lg me-1"></i> Đăng tin mới
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light text-secondary">
                <tr>
                    <th scope="col" style="width: 45%;">Bất động sản</th>
                    <th scope="col">Loại hình & Giá</th>
                    <th scope="col" class="text-center">Trạng thái</th>
                    <th scope="col" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted bg-light rounded-3">
                            <i class="bi bi-clipboard-x display-4 d-block mb-3 opacity-50"></i>
                            <h6 class="fw-bold">Bạn chưa có tin đăng nào.</h6>
                            <a href="/Property/Create" class="btn btn-outline-primary mt-2 rounded-pill px-4">Đăng tin ngay!</a>
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-start gap-3">
                                <img src="@(string.IsNullOrEmpty(item.MainImage) ? "/images/no-image.jpg" : item.MainImage)" class="rounded-3 shadow-sm" style="width: 100px; height: 75px; object-fit: cover;" onerror="this.src='/images/no-image.jpg'">
                                <div>
                                    <a href="/Property/Details/@item.PropertyID" target="_blank" class="fw-bold text-dark text-decoration-none d-block text-truncate" style="max-width: 300px; font-size: 1.05rem;" title="@item.Title">@item.Title</a>
                                    <div class="small text-muted mt-1"><i class="bi bi-clock me-1"></i> Đăng lúc: @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>

                                    @if (item.Status == "Rejected" && !string.IsNullOrEmpty(item.RejectionReason))
                                    {
                                        <div class="mt-2 p-2 bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded-3 text-danger small fw-medium">
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i> <strong>Lý do từ chối:</strong> @item.RejectionReason
                                        </div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-light text-primary border border-primary-subtle mb-1">@(item.PropertyType?.TypeName ?? "Chưa phân loại")</span>
                            <div class="text-danger fw-bold fs-6">@(item.Price.HasValue ? (item.Price.Value >= 1000000000 ? (item.Price.Value / 1000000000).ToString("0.##") + " Tỷ" : (item.Price.Value / 1000000).ToString("0.##") + " Tr") : "Thỏa thuận")</div>
                        </td>
                        <td class="text-center">
                            @if (item.Status == "Approved")
                            {
                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Đang hiển thị</span>
                            }
                            else if (item.Status == "Pending")
                            {

                                <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill fw-bold"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt</span>
                            }
                            else if (item.Status == "Rejected")
                            {

                                <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill fw-bold"><i class="bi bi-x-circle-fill me-1"></i> Bị từ chối</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group shadow-sm rounded-3">
                                <a href="/Property/Details/@item.PropertyID" target="_blank" class="btn btn-sm btn-light border text-info" title="Xem bài">
                                    <i class="bi bi-eye-fill"></i>
                                </a>
                                <a href="/Property/Edit/@item.PropertyID" class="btn btn-sm btn-light border text-primary" title="Sửa bài">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-light border text-danger" title="Xóa tin" onclick="confirmDelete(@item.PropertyID)">
                                    <i class="bi bi-trash3-fill"></i>
                                </button>
                            </div>
                            <form id="deleteForm-@item.PropertyID" action="/Property/DeleteMyAd" method="post" style="display:none;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.PropertyID" />
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: 'Xóa tin đăng này?',
                text: "Sau khi xóa, tin sẽ được đưa vào thùng rác!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Đồng ý xóa!',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteForm-' + id).submit();
                }
            });
        }
    </script>
}