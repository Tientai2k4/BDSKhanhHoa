@model BDSKhanhHoa.Models.Property
@{
    ViewData["Title"] = "Đăng tin bất động sản mới";
    Layout = "~/Views/Shared/_UserLayout.cshtml";

    // LẤY DỮ LIỆU GỐC TỪ ADMIN ĐỂ HIỂN THỊ
    var masterFeatures = ViewBag.MasterFeatures as List<BDSKhanhHoa.Models.PropertyFeature> ?? new List<BDSKhanhHoa.Models.PropertyFeature>();
    var huongNhaList = masterFeatures.Where(f => f.FeatureGroup == "Hướng nhà").ToList();
    var phapLyList = masterFeatures.Where(f => f.FeatureGroup == "Pháp lý").ToList();
    var tienIchList = masterFeatures.Where(f => f.FeatureGroup == "Tiện ích").ToList();
    var khacList = masterFeatures.Where(f => f.FeatureGroup == "Khác").ToList(); // LẤY DANH SÁCH LỚP CON CỦA NHÓM "KHÁC"
}

<style>
    .radio-toolbar input[type="radio"] {
        display: none;
    }

    .radio-toolbar label {
        display: inline-block;
        background-color: #f8fafc;
        border: 2px solid #e2e8f0;
        padding: 10px 25px;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s;
        color: #64748b;
        margin-right: 8px;
        margin-bottom: 8px;
    }

    .radio-toolbar input[type="radio"]:checked + label {
        background-color: #e0e7ff;
        border-color: #0061f2;
        color: #0061f2;
        box-shadow: 0 4px 10px rgba(0, 97, 242, 0.15);
    }

    .amenity-checkbox input[type="checkbox"] {
        display: none;
    }

    .amenity-checkbox label {
        display: inline-block;
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        padding: 8px 18px;
        font-size: 0.9rem;
        font-weight: 500;
        border-radius: 50px;
        cursor: pointer;
        transition: all 0.2s;
        color: #475569;
        margin: 0 8px 10px 0;
    }

    .amenity-checkbox input[type="checkbox"]:checked + label {
        background-color: #dcfce7;
        border-color: #16a34a;
        color: #16a34a;
        box-shadow: 0 4px 10px rgba(22, 163, 74, 0.15);
    }

    .img-upload-zone {
        border: 2px dashed #cbd5e1;
        border-radius: 12px;
        height: 220px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        cursor: pointer;
        overflow: hidden;
        position: relative;
        transition: 0.3s;
    }

        .img-upload-zone:hover {
            border-color: #0061f2;
            background: #f1f5f9;
        }

    #imgPreview {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
        position: absolute;
        top: 0;
        left: 0;
        z-index: 1;
    }

    .img-upload-zone .overlay-text {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(0,0,0,0.6);
        color: white;
        text-align: center;
        padding: 8px 0;
        font-size: 0.85rem;
        font-weight: bold;
        z-index: 2;
        display: none;
    }

    .img-upload-zone:hover .overlay-text {
        display: block;
    }

    .sub-img-thumb {
        width: 75px;
        height: 75px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        transition: 0.3s;
    }

        .sub-img-thumb:hover {
            transform: scale(1.05);
            border-color: #0061f2;
        }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-dark mb-0"><i class="bi bi-pencil-square text-primary me-2"></i> Đăng Tin Bất Động Sản Mới</h4>
    <a href="/Property/MyAds" class="btn btn-light border shadow-sm fw-bold rounded-pill px-4"><i class="bi bi-arrow-left me-1"></i> Trở về</a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data" id="frmCreateProp">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card-custom p-4 mb-4 bg-white">
                <h5 class="fw-bold mb-4 border-bottom pb-3"><i class="bi bi-info-circle text-primary me-2"></i>1. Thông tin cơ bản</h5>

                <div class="mb-4">
                    <label class="form-label fw-bold d-block">Hình thức giao dịch <span class="text-danger">*</span></label>
                    <div class="radio-toolbar" id="parentTypeContainer">
                        @foreach (var parent in ViewBag.ParentTypes)
                        {
                            <input type="radio" id="parent_@parent.TypeID" name="ParentTypeSelector" value="@parent.TypeID" onchange="filterSubTypes(this.value)">
                            <label for="parent_@parent.TypeID"><i class="bi bi-check-circle me-1"></i> @parent.TypeName</label>
                        }
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Loại bất động sản <span class="text-danger">*</span></label>
                        <select asp-for="TypeID" id="subTypeSelect" class="form-select form-select-lg bg-light fw-medium" required>
                            <option value="">-- Vui lòng chọn Hình thức trước --</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tiêu đề tin đăng <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control form-control-lg bg-light" placeholder=".............." required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả chi tiết <span class="text-danger">*</span></label>
                    <textarea asp-for="Description" class="form-control bg-light" rows="7" placeholder="Mô tả chi tiết về vị trí, tiện ích xung quanh, tình trạng nội thất, kiến trúc, khu dân cư..." required></textarea>
                </div>
            </div>

            <div class="card-custom p-4 mb-4 bg-white">
                <h5 class="fw-bold mb-4 border-bottom pb-3"><i class="bi bi-geo-alt text-primary me-2"></i>2. Địa điểm & Kích thước</h5>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Khu vực  <span class="text-danger">*</span></label>
                        <select id="areaSelect" class="form-select bg-light fw-medium" asp-items="ViewBag.Areas" onchange="loadWards(this.value)" required>
                            <option value="">-- Chọn khu vực  --</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Phường / Xã <span class="text-danger">*</span></label>
                        <select asp-for="WardID" id="wardSelect" class="form-select bg-light fw-medium" required>
                            <option value="">-- Vui lòng chọn Khu vực trước --</option>
                        </select>
                    </div>
                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">Địa chỉ chi tiết</label>
                        <input asp-for="AddressDetail" class="form-control bg-light" placeholder="Ví dụ: Số 02 Nguyễn Đình Chiểu" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Mức giá (VNĐ)</label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <input asp-for="Price" type="number" class="form-control bg-light border-0" placeholder="Để trống nếu muốn Thỏa thuận" />
                            <span class="input-group-text bg-white fw-bold border-0 border-start">VNĐ</span>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Diện tích đất (m²)</label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <input asp-for="AreaSize" type="number" step="0.01" class="form-control bg-light border-0" placeholder="Ví dụ: 100" />
                            <span class="input-group-text bg-white fw-bold border-0 border-start">m²</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-custom p-4 mb-4 bg-white">
                <h5 class="fw-bold mb-4 border-bottom pb-3"><i class="bi bi-list-check text-primary me-2"></i>3. Thông tin chi tiết & Tiện ích</h5>
                <div class="row mb-4">
                    <div class="col-md-3 col-6 mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">Phòng ngủ</label>
                        <input type="number" name="Bedrooms" class="form-control bg-light fw-bold text-center" placeholder="0" min="1" max="20" />
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">Phòng tắm</label>
                        <input type="number" name="Bathrooms" class="form-control bg-light fw-bold text-center" placeholder="0" min="1" max="20" />
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">Hướng nhà</label>
                        <select name="Direction" class="form-select bg-light fw-medium">
                            <option value="">-- Không rõ --</option>
                            @foreach (var item in huongNhaList)
                            {
                                <option value="@item.FeatureName">@item.FeatureName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">Giấy tờ pháp lý</label>
                        <select name="LegalStatus" class="form-select bg-light fw-medium">
                            <option value="">-- Trạng thái --</option>
                            @foreach (var item in phapLyList)
                            {
                                <option value="@item.FeatureName">@item.FeatureName</option>
                            }
                        </select>
                    </div>
                </div>

                <label class="form-label fw-bold mb-3 d-block">Tiện ích nổi bật (Chọn nhiều)</label>
                <div class="amenity-checkbox">
                    @if (!tienIchList.Any())
                    {
                        <p class="text-muted small"><i>Hệ thống chưa cấu hình tiện ích mẫu.</i></p>
                    }
                    else
                    {
                        int count = 1;
                        foreach (var item in tienIchList)
                        {
                            <input type="checkbox" id="am_@count" name="Amenities" value="@item.FeatureName">
                            <label for="am_@count"><i class="bi bi-check2-square me-1"></i> @item.FeatureName</label>
                            count++;
                        }
                    }
                </div>

                <label class="form-label fw-bold mb-3 d-block mt-4">Đặc điểm khác (Chọn nhiều)</label>
                <div class="amenity-checkbox">
                    @if (!khacList.Any())
                    {
                        <p class="text-muted small"><i>Hệ thống chưa cấu hình đặc điểm khác.</i></p>
                    }
                    else
                    {
                        int countKhac = 1;
                        foreach (var item in khacList)
                        {
                            <input type="checkbox" id="khac_@countKhac" name="Amenities" value="@item.FeatureName">
                            <label for="khac_@countKhac"><i class="bi bi-check2-square me-1"></i> @item.FeatureName</label>
                            countKhac++;
                        }
                    }
                </div>

            </div>
        </div>

        <div class="col-lg-4">
            <div class="card-custom p-4 sticky-top bg-white" style="top: 20px;">
                <h5 class="fw-bold mb-4 border-bottom pb-3"><i class="bi bi-camera text-primary me-2"></i>4. Media & Gói tin</h5>

                <div class="mb-4">
                    <label class="form-label fw-bold">Ảnh đại diện (Bắt buộc) <span class="text-danger">*</span></label>
                    <label for="MainImageFile" class="img-upload-zone w-100 d-block">
                        <div id="uploadPlaceholder" class="text-center text-muted mt-5 pt-3">
                            <i class="bi bi-cloud-arrow-up display-4 text-primary opacity-75"></i>
                            <p class="mt-2 fw-bold mb-0 text-dark">Tải ảnh chính lên</p>
                            <small class="opacity-75">Khuyên dùng tỷ lệ 16:9</small>
                        </div>
                        <img id="imgPreview" src="" />
                        <div class="overlay-text"><i class="bi bi-pencil-square"></i> Đổi ảnh khác</div>
                    </label>
                    <input type="file" id="MainImageFile" name="MainImageFile" class="d-none" accept="image/*" onchange="previewImage(event)" required />
                </div>

                <div class="mb-4 pt-3 border-top">
                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <label class="form-label fw-bold mb-0">Ảnh phụ (Tùy chọn)</label>
                        <span class="badge bg-secondary">Tối đa 10 ảnh</span>
                    </div>

                    <label for="AdditionalImagesFile" class="btn btn-light border border-2 border-dashed w-100 fw-bold text-secondary mb-3 py-2">
                        <i class="bi bi-images me-2 text-primary fs-5 align-middle"></i> Chọn danh sách ảnh phụ
                    </label>
                    <input type="file" id="AdditionalImagesFile" name="AdditionalImages" class="d-none" accept="image/*" multiple onchange="previewGallery(event)" />

                    <div class="d-flex flex-wrap gap-2" id="galleryPreviewContainer"></div>
                </div>

                <div class="mb-4 pt-3 border-top">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <label class="form-label fw-bold mb-0 text-dark">Áp dụng Lượt đăng (Ví) <span class="text-danger">*</span></label>
                        <button type="button" class="btn btn-sm btn-outline-primary rounded-pill fw-bold" onclick="loadMyPackages()" title="Cập nhật lại ví gói tin">
                            <i class="bi bi-arrow-clockwise"></i> Làm mới ví
                        </button>
                    </div>

                    <div id="freeGiftAlert" class="alert alert-success bg-opacity-10 border-success border-opacity-25 small mb-3 p-3 rounded-3" style="display: none;">
                        <i class="bi bi-gift-fill text-success fs-5 me-1 align-middle"></i>
                        Bạn đang có <strong class="text-danger" id="freeCountSpan"></strong> lượt đăng <strong>Miễn phí</strong>. Hãy chọn ở danh sách bên dưới!
                    </div>

                    <select asp-for="PackageID" id="packageSelect" class="form-select form-select-lg border-primary shadow-sm mb-3 fw-bold text-primary" required>
                        <option value="">Đang tải dữ liệu ví...</option>
                    </select>

                    <div class="text-center bg-light p-3 rounded-3 border">
                        <span class="d-block small text-muted mb-2">Hết lượt đăng hoặc muốn hiển thị nổi bật hơn?</span>
                        <a href="/Package/Buy" target="_blank" class="btn btn-warning fw-bold text-dark rounded-pill w-100 shadow-sm">
                            <i class="bi bi-cart-plus-fill me-1"></i> Mua thêm gói VIP ngay
                        </a>
                    </div>
                </div>

                <hr />
                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm rounded-pill" onclick="clearDraftStorage()">
                        <i class="bi bi-check2-circle me-2"></i> HOÀN TẤT ĐĂNG TIN
                    </button>
                    <a href="/Property/MyAds" class="btn btn-light border mt-2 text-secondary fw-bold rounded-pill">Hủy bỏ</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const subTypesData = @Html.Raw(ViewBag.SubTypesJson);
        const subTypeSelect = document.getElementById('subTypeSelect');

        function filterSubTypes(parentId) {
            subTypeSelect.innerHTML = '<option value="">-- Chọn loại bất động sản --</option>';
            const filteredTypes = subTypesData.filter(t => t.ParentID == parentId);
            filteredTypes.forEach(t => {
                let opt = new Option(t.TypeName, t.TypeID);
                subTypeSelect.add(opt);
            });
        }

        async function loadWards(areaId) {
            const wardSelect = document.getElementById('wardSelect');
            wardSelect.innerHTML = '<option value="">Đang tải...</option>';
            if (!areaId) {
                wardSelect.innerHTML = '<option value="">-- Vui lòng chọn Khu vực trước --</option>';
                return;
            }
            try {
                const response = await fetch(`/Home/GetWardsByArea?areaId=${areaId}`);
                const data = await response.json();
                wardSelect.innerHTML = '<option value="">-- Chọn Phường / Xã --</option>';
                data.forEach(w => wardSelect.add(new Option(w.wardName, w.wardId)));
            } catch (error) {
                wardSelect.innerHTML = '<option value="">Lỗi kết nối</option>';
            }
        }

        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function() {
                var output = document.getElementById('imgPreview');
                var placeholder = document.getElementById('uploadPlaceholder');
                output.src = reader.result;
                output.style.display = 'block';
                placeholder.style.display = 'none';
            };
            if(event.target.files[0]){
                reader.readAsDataURL(event.target.files[0]);
            }
        }

        function previewGallery(event) {
            const container = document.getElementById('galleryPreviewContainer');
            container.innerHTML = '';

            const files = event.target.files;
            if(files.length > 10) {
                alert('Chỉ được chọn tối đa 10 ảnh phụ!');
                event.target.value = '';
                return;
            }

            for(let i = 0; i < files.length; i++) {
                const file = files[i];
                if(!file.type.startsWith('image/')) continue;

                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'sub-img-thumb shadow-sm border border-2 border-white';
                    container.appendChild(img);
                }
                reader.readAsDataURL(file);
            }
        }

        async function loadMyPackages() {
            const selectEl = document.getElementById('packageSelect');
            const alertGift = document.getElementById('freeGiftAlert');
            const spanCount = document.getElementById('freeCountSpan');

            selectEl.innerHTML = '<option value="">Đang tải dữ liệu ví...</option>';
            try {
                const response = await fetch('/Property/GetAvailablePackages');
                const result = await response.json();

                if (result.success && result.data.length > 0) {
                    selectEl.innerHTML = '<option value="">-- Click để chọn gói đăng --</option>';
                    let totalFreeCount = 0;

                    result.data.forEach(pkg => {
                        let isFree = (pkg.price == 0);
                        let typeLabel = isFree ? "Miễn phí" : "VIP " + pkg.type;
                        let textStr = `[${typeLabel}] ${pkg.name} - (Còn: ${pkg.availableCount} Lượt)`;

                        let option = new Option(textStr, pkg.id);

                        if(isFree) {
                            option.style.color = "#16a34a";
                            option.style.fontWeight = "bold";
                            totalFreeCount += parseInt(pkg.availableCount);
                        } else {
                            option.style.color = "#e81c2e";
                            option.style.fontWeight = "bold";
                        }

                        selectEl.add(option);
                    });

                    if(totalFreeCount > 0) {
                        spanCount.innerText = totalFreeCount;
                        alertGift.style.display = 'block';
                    } else {
                        alertGift.style.display = 'none';
                    }

                } else {
                    selectEl.innerHTML = '<option value="">Ví của bạn đã hết lượt đăng. Vui lòng mua thêm!</option>';
                    alertGift.style.display = 'none';
                }
            } catch (error) {
                selectEl.innerHTML = '<option value="">Lỗi tải dữ liệu gói</option>';
                alertGift.style.display = 'none';
            }
        }

        const FORM_STORAGE_KEY = "bds_draft_form";

        function saveFormDraft() {
            const form = document.getElementById('frmCreateProp');
            const formData = new FormData(form);
            let obj = {};

            for (let [key, value] of formData.entries()) {
                if(key !== "MainImageFile" && key !== "AdditionalImages" && !key.includes("RequestVerificationToken")) {
                    if(obj[key] !== undefined) {
                        if(!Array.isArray(obj[key])) obj[key] = [obj[key]];
                        obj[key].push(value);
                    } else {
                        obj[key] = value;
                    }
                }
            }
            localStorage.setItem(FORM_STORAGE_KEY, JSON.stringify(obj));
        }

        function restoreFormDraft() {
            const draft = localStorage.getItem(FORM_STORAGE_KEY);
            if (!draft) return;
            const obj = JSON.parse(draft);

            for (let key in obj) {
                const inputList = document.querySelectorAll(`[name="${key}"]`);
                if (!inputList || inputList.length === 0) continue;

                const input = inputList[0];
                if (input.type === 'radio' || input.type === 'checkbox') {
                    let values = Array.isArray(obj[key]) ? obj[key] : [obj[key]];
                    inputList.forEach(el => { el.checked = values.includes(el.value); });
                } else {
                    input.value = obj[key];
                }
            }

            const selectedRadio = document.querySelector('input[name="ParentTypeSelector"]:checked');
            if (selectedRadio) {
                filterSubTypes(selectedRadio.value);
                if (obj["TypeID"]) document.getElementById('subTypeSelect').value = obj["TypeID"];
            }

            const areaSelect = document.getElementById('areaSelect');
            if(areaSelect && areaSelect.value) {
                loadWards(areaSelect.value).then(() => {
                    if (obj["WardID"]) document.getElementById('wardSelect').value = obj["WardID"];
                });
            }
        }

        function clearDraftStorage() {
            localStorage.removeItem(FORM_STORAGE_KEY);
        }

        document.addEventListener("DOMContentLoaded", () => {
            loadMyPackages();
            restoreFormDraft();

            const formElement = document.getElementById('frmCreateProp');
            formElement.addEventListener('input', saveFormDraft);
            formElement.addEventListener('change', saveFormDraft);

            const firstRadio = document.querySelector('input[name="ParentTypeSelector"]');
            const checkedRadio = document.querySelector('input[name="ParentTypeSelector"]:checked');
            if(firstRadio && !checkedRadio) firstRadio.click();
        });
    </script>
}