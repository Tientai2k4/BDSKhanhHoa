@model IEnumerable<BDSKhanhHoa.Models.Transaction>
@{
    ViewData["Title"] = "Lịch sử giao dịch";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="container my-5">
    <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
        <div class="d-flex flex-wrap justify-content-between align-items-center border-bottom pb-4 mb-4">
            <h3 class="fw-black text-dark mb-0"><i class="bi bi-receipt-cutoff text-primary me-2"></i> Lịch sử thanh toán</h3>
            <a href="/Package/Buy" class="btn btn-dark rounded-pill fw-bold px-4 mt-3 mt-md-0 shadow-sm">Mua thêm gói VIP</a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="py-3 text-secondary text-uppercase small fw-bold rounded-start">Mã GD</th>
                        <th class="py-3 text-secondary text-uppercase small fw-bold">Dịch vụ</th>
                        <th class="py-3 text-secondary text-uppercase small fw-bold text-center">SL</th>
                        <th class="py-3 text-secondary text-uppercase small fw-bold text-end">Tổng Tiền</th>
                        <th class="py-3 text-secondary text-uppercase small fw-bold text-center">Trạng Thái</th>
                        <th class="py-3 text-secondary text-uppercase small fw-bold text-end rounded-end pe-4">Thời Gian</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-folder-x display-3 d-block mb-3 text-black-50"></i>
                                <h5 class="fw-bold">Chưa có giao dịch nào phát sinh.</h5>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark py-4"><span class="bg-light px-2 py-1 rounded text-secondary font-monospace small">@item.TransactionCode</span></td>
                            <td class="py-4">
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2 rounded-pill fs-6">
                                    <i class="bi bi-box-seam me-1"></i> @item.Package?.PackageName
                                </span>
                            </td>
                            <td class="text-center py-4 fw-bold fs-5 text-dark">x@(item.Quantity > 0 ? item.Quantity : 1)</td>
                            <td class="text-end fw-bold text-danger fs-5 py-4">@item.Amount.ToString("N0") đ</td>
                            <td class="text-center py-4">
                                @if (item.Status == "Success")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2"><i class="bi bi-check2-circle me-1"></i>Thành công</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 text-dark rounded-pill px-3 py-2"><i class="bi bi-hourglass-split me-1"></i>Đang chờ</span>
                                }
                            </td>
                            <td class="text-end pe-4 text-muted small fw-medium py-4">@item.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>