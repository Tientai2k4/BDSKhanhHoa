@model BDSKhanhHoa.Models.Project
@{
    ViewData["Title"] = "Đăng ký mở Dự án mới";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xl-10">
        <div class="alert alert-info border-0 shadow-sm rounded-4 mb-4 p-4 d-flex align-items-center">
            <i class="bi bi-shield-lock-fill display-4 text-info me-4"></i>
            <div>
                <h5 class="fw-bold text-dark mb-1">Chính sách kiểm duyệt Dự án</h5>
                <p class="mb-0 text-secondary">Để bảo vệ người mua, hệ thống yêu cầu mọi dự án đăng tải phải có đầy đủ <strong>Giấy phép kinh doanh</strong> và <strong>Quyết định 1/500</strong>. Ban quản trị sẽ đối chiếu tính pháp lý trước khi phê duyệt hiển thị.</p>
            </div>
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data" class="bg-white p-5 rounded-4 shadow-sm border">
            <h4 class="fw-bold mb-4 pb-2 border-bottom text-dark"><i class="bi bi-building-add text-primary me-2"></i>Khai báo thông tin Dự án</h4>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Tên thương mại dự án <span class="text-danger">*</span></label>
                    <input asp-for="ProjectName" class="form-control bg-light" placeholder="VD: Vinhomes Ocean Park Nha Trang" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Tên Chủ đầu tư <span class="text-danger">*</span></label>
                    <input asp-for="Investor" class="form-control bg-light" placeholder="VD: Tập đoàn Vingroup" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Khu vực (Tỉnh/Thành) <span class="text-danger">*</span></label>
                    <select asp-for="AreaID" id="areaSelect" class="form-select bg-light" asp-items="ViewBag.Areas" onchange="loadWards(this.value)" required>
                        <option value="">-- Chọn Khu vực --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Phường / Xã <span class="text-danger">*</span></label>
                    <select asp-for="WardID" id="wardSelect" class="form-select bg-light" required>
                        <option value="">-- Vui lòng chọn Khu vực trước --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Tiến độ dự án</label>
                    <select asp-for="ProjectStatus" class="form-select bg-light">
                        <option value="Sắp mở bán">Sắp mở bán</option>
                        <option value="Đang mở bán">Đang mở bán</option>
                        <option value="Đang bàn giao">Đang bàn giao</option>
                        <option value="Đã bàn giao">Đã bàn giao hoàn thiện</option>
                    </select>
                </div>
                <div class="col-md-12">
                    <label class="form-label fw-bold">Quy mô tổng quan</label>
                    <input asp-for="Scale" class="form-control bg-light" placeholder="VD: Tổng diện tích 50ha, gồm 4 tòa tháp và 500 biệt thự..." />
                </div>
                <div class="col-md-12">
                    <label class="form-label fw-bold">Mô tả chi tiết dự án</label>
                    <textarea asp-for="Description" class="form-control bg-light" rows="6" placeholder="Giới thiệu vị trí vàng, tiện ích nội khu, thiết kế kiến trúc..."></textarea>
                </div>
            </div>

            <div class="row g-4 p-4 bg-light rounded-4 border">
                <div class="col-md-6">
                    <label class="form-label fw-bold text-dark">Hình ảnh phối cảnh dự án <span class="text-danger">*</span></label>
                    <input type="file" name="MainImageFile" class="form-control" accept="image/*" required />
                    <small class="text-muted mt-1 d-block">Ảnh hiển thị chính trên banner. Tỷ lệ chuẩn 16:9.</small>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold text-danger">Hồ sơ pháp lý (Bản Scan) <span class="text-danger">*</span></label>
                    <input type="file" name="LegalDocsFile" class="form-control border-danger" accept=".pdf,image/*" required />
                    <small class="text-muted mt-1 d-block">Đóng gói GPKD, Sổ đỏ, QĐ 1/500 thành 1 file PDF hoặc nén.</small>
                    <span asp-validation-for="LegalDocs" class="text-danger small"></span>
                </div>
            </div>

            <div class="text-end mt-4">
                <a href="/Project/MyProjects" class="btn btn-light border px-4 fw-bold text-secondary me-2">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm"><i class="bi bi-send-check me-2"></i> NỘP HỒ SƠ KIỂM DUYỆT</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        async function loadWards(areaId) {
            const wardSelect = document.getElementById('wardSelect');
            wardSelect.innerHTML = '<option value="">Đang tải...</option>';
            if (!areaId) { wardSelect.innerHTML = '<option value="">-- Phường/Xã --</option>'; return; }
            try {
                const response = await fetch(`/Home/GetWardsByArea?areaId=${areaId}`);
                const data = await response.json();
                wardSelect.innerHTML = '<option value="">-- Chọn Phường / Xã --</option>';
                data.forEach(w => wardSelect.add(new Option(w.wardName, w.wardId)));
            } catch (e) { wardSelect.innerHTML = '<option value="">Lỗi kết nối</option>'; }
        }
    </script>
}