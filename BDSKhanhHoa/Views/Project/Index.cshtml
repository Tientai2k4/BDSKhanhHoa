@model IEnumerable<BDSKhanhHoa.Models.Project>
@{
    ViewData["Title"] = "Dự án Bất động sản Khánh Hòa 2026";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var areas = ViewBag.Areas as IEnumerable<BDSKhanhHoa.Models.Area>;
}

<style>
    /* Tổng thể */
    :root {
        --glass: rgba(255, 255, 255, 0.9);
        --grad-primary: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        --grad-gold: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    }

    /* Hero Section */
    .project-hero {
        background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1449156001437-3a16d1dfbe69?auto=format&fit=crop&w=1920&q=80') center/cover no-repeat;
        padding: 120px 0 100px;
        color: #fff;
        border-radius: 0 0 50px 50px;
        text-align: center;
        margin-bottom: -60px;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 900;
        letter-spacing: -1px;
    }

    /* Bộ lọc nổi */
    .filter-box-floating {
        background: var(--glass);
        backdrop-filter: blur(15px);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        border: 1px solid #fff;
        position: relative;
        z-index: 100;
    }

    /* Project Card */
    .pj-modern-card {
        border: none;
        border-radius: 24px;
        overflow: hidden;
        background: #fff;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .pj-modern-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 30px 60px rgba(15, 23, 42, 0.15);
        }

    .pj-img-container {
        position: relative;
        height: 250px;
        overflow: hidden;
    }

        .pj-img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s ease;
        }

    .pj-modern-card:hover .pj-img-container img {
        transform: scale(1.1);
    }

    .pj-badge {
        position: absolute;
        top: 20px;
        left: 20px;
        padding: 8px 18px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.7rem;
        text-transform: uppercase;
        color: #fff;
        z-index: 10;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    .pj-price-overlay {
        position: absolute;
        bottom: 20px;
        right: 20px;
        background: var(--grad-gold);
        color: #000;
        padding: 6px 16px;
        border-radius: 12px;
        font-weight: 900;
        font-size: 1.1rem;
    }

    .pj-content {
        padding: 25px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .pj-title {
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 8px;
        font-size: 1.3rem;
        line-height: 1.3;
    }

    .pj-loc {
        font-size: 0.85rem;
        color: #64748b;
        margin-bottom: 15px;
    }

    .pj-desc {
        font-size: 0.9rem;
        color: #475569;
        margin-bottom: 20px;
        line-height: 1.6;
        height: 3.2rem;
        overflow: hidden;
    }

    .pj-footer {
        border-top: 1px solid #f1f5f9;
        padding-top: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .investor-tag {
        font-weight: 700;
        color: #2563eb;
        font-size: 0.85rem;
    }

    /* Stats Section */
    .stat-strip {
        background: #fff;
        border-radius: 20px;
        padding: 40px;
        margin-top: 50px;
        border: 1px solid #e2e8f0;
    }

    .stat-num {
        font-size: 2.5rem;
        font-weight: 900;
        color: #0f172a;
        display: block;
    }

    .stat-label {
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
    }

</style>

<div class="project-hero animate__animated animate__fadeIn">
    <div class="container">
        <h1 class="hero-title">ĐỊNH VỊ THỊNH VƯỢNG</h1>
        <p class="fs-4 opacity-75">Hệ thống phân tích & đăng tải dự án BĐS hàng đầu Tỉnh Khánh Hòa</p>
    </div>
</div>

<div class="container">
    <div class="filter-box-floating animate__animated animate__fadeInUp">
        <form action="/Project/Search" method="get">
            <div class="row g-4 align-items-end">
                <div class="col-lg-4">
                    <label class="form-label fw-bold small text-muted text-uppercase">Bạn đang tìm dự án nào?</label>
                    <div class="input-group bg-light rounded-3 overflow-hidden">
                        <span class="input-group-text bg-transparent border-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="keyword" class="form-control border-0 bg-transparent py-3" placeholder="Tên dự án, địa danh, tập đoàn...">
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-bold small text-muted text-uppercase">Vị trí quy hoạch</label>
                    <select name="areaId" class="form-select bg-light border-0 py-3 rounded-3">
                        <option value="">Tất cả khu vực</option>
                        @if (areas != null)
                        {
                            foreach (var a in areas)
                            {
                                <option value="@a.AreaID">@a.AreaName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-bold small text-muted text-uppercase">Tiến độ thi công</label>
                    <select name="status" class="form-select bg-light border-0 py-3 rounded-3">
                        <option value="">Mọi trạng thái</option>
                        <option value="Sắp mở bán">Sắp mở bán (Booking)</option>
                        <option value="Đang mở bán">Đang mở bán</option>
                        <option value="Đã bàn giao">Đã bàn giao hoàn thiện</option>
                    </select>
                </div>
                <div class="col-lg-2">
                    <button type="submit" class="btn btn-dark w-100 py-3 fw-bold rounded-3 shadow-lg">
                        TÌM KIẾM NGAY
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="my-5 pt-5">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h2 class="fw-black text-dark mb-1">DỰ ÁN TIÊU BIỂU</h2>
                <p class="text-muted mb-0">Cập nhật lúc @DateTime.Now.ToString("HH:mm") hôm nay</p>
            </div>
            <a href="/Project/Search" class="btn btn-outline-primary fw-bold rounded-pill px-4">
                Xem tất cả dự án <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    string statusColor = item.ProjectStatus == "Đang mở bán" ? "#10b981" : "#f59e0b";
                    <div class="col-xl-4 col-lg-6">
                        <a href="/Project/Details/@item.ProjectID" class="text-decoration-none">
                            <div class="pj-modern-card">
                                <div class="pj-img-container">
                                    <span class="pj-badge" style="background: @statusColor">@item.ProjectStatus</span>
                                    <img src="@(string.IsNullOrEmpty(item.MainImage) ? "/images/no-image.jpg" : item.MainImage)" alt="@item.ProjectName">
                                    <div class="pj-price-overlay">
                                        ~ @item.PriceMin @item.PriceUnit
                                    </div>
                                </div>
                                <div class="pj-content">
                                    <h3 class="pj-title">@item.ProjectName</h3>
                                    <div class="pj-loc">
                                        <i class="bi bi-geo-alt-fill text-danger me-1"></i> @item.Ward?.WardName, @item.Area?.AreaName
                                    </div>
                                    <div class="pj-desc">@item.Description</div>

                                    <div class="d-flex gap-2 mb-3">
                                        <span class="badge bg-light text-dark border">@item.ProjectType</span>
                                        <span class="badge bg-light text-dark border">@item.AreaMin - @item.AreaMax m²</span>
                                    </div>

                                    <div class="pj-footer">
                                        <span class="investor-tag"><i class="bi bi-patch-check-fill me-1"></i>@item.Investor</span>
                                        <span class="text-muted small">@item.PublishedAt?.ToString("dd/MM/yyyy")</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <img src="/images/empty-box.png" style="width: 200px; opacity: 0.5;">
                    <h4 class="text-muted mt-4">Hiện tại chưa có dự án nào được đăng tải.</h4>
                </div>
            }
        </div>
    </div>

    <div class="stat-strip mb-5 shadow-sm">
        <div class="row text-center g-4">
            <div class="col-md-3 border-end">
                <span class="stat-num">@(Model?.Count() ?? 0)</span>
                <span class="stat-label">Dự án đang bán</span>
            </div>
            <div class="col-md-3 border-end">
                <span class="stat-num">500+</span>
                <span class="stat-label">Căn hộ & Đất nền</span>
            </div>
            <div class="col-md-3 border-end">
                <span class="stat-num">24h</span>
                <span class="stat-label">Hỗ trợ tư vấn</span>
            </div>
            <div class="col-md-3">
                <span class="stat-num">100%</span>
                <span class="stat-label">Pháp lý minh bạch</span>
            </div>
        </div>
    </div>

    <div class="bg-primary rounded-5 p-5 mb-5 text-white position-relative overflow-hidden shadow-lg">
        <div style="position:relative; z-index:2;">
            <h2 class="fw-black mb-3">Bạn là Chủ Đầu Tư?</h2>
            <p class="fs-5 opacity-75 mb-4" style="max-width: 600px;">Hợp tác cùng sàn giao dịch BĐS lớn nhất Khánh Hòa để tiếp cận 100.000+ khách hàng tiềm năng mỗi tháng.</p>
            <a href="/Contact" class="btn btn-warning btn-lg fw-black px-5 rounded-pill shadow">LIÊN HỆ HỢP TÁC NGAY</a>
        </div>
        <i class="bi bi-buildings position-absolute" style="font-size: 15rem; bottom: -50px; right: -20px; opacity: 0.1; transform: rotate(-15deg);"></i>
    </div>
</div>

@section Scripts {
    <script>
        // Hiệu ứng FadeIn tuần tự cho các thẻ dự án
        $(document).ready(function() {
            $(".pj-modern-card").each(function(i) {
                $(this).css("animation-delay", (i * 0.1) + "s");
            });
        });
    </script>
}